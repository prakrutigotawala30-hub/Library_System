@model IEnumerable<Tuple<LibraryManagementSystem.ClassLibrary.Models.Book, int>>

@{
    ViewData["Title"] = "Most Wishlisted";
}

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
    .table thead th { font-family:'Poppins',sans-serif; font-size:15px; font-weight:700; }
    .table tbody td { font-family:'Segoe UI',sans-serif; font-size:14px; font-weight:500; }
</style>

<div class="container mt-4">
    <h2 class="mb-3">❤️ Most Wishlisted Books</h2>
    <p class="text-muted small">Top 20 by total wishlist adds — use for purchasing decisions.</p>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-dark">
                    <tr>
                        <th style="width:60px;">Rank</th>
                        <th>Title</th>
                        <th>Author</th>
                        <th>Wishlist Count</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr><td colspan="4" class="text-center text-muted p-4">No wishlists yet.</td></tr>
                    }
                    @{ var i = 0; }
                    @foreach (var t in Model)
                    {
                        i++;
                        <tr>
                            <td>#@i</td>
                            <td>@t.Item1.Title</td>
                            <td>@(t.Item1.Author?.Name ?? "—")</td>
                            <td><strong>@t.Item2</strong></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
