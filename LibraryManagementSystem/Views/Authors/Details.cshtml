@model LibraryManagementSystem.Models.Author

@{
    ViewData["Title"] = "Author Details";
}

<div class="container mt-4">

    <!-- Author Info -->
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-dark text-white">
            <h4 class="mb-0">👤 Author Details</h4>
        </div>

        <div class="card-body">
            <h5><strong>Name:</strong> @Model.Name</h5>

            <p>
                <strong>Bio:</strong>
                @(string.IsNullOrEmpty(Model.Bio) ? "No bio available" : Model.Bio)
            </p>

            <p>
                <strong>Total Books:</strong> @Model.Books.Count
            </p>
        </div>
    </div>

    <!-- Books List -->
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">📚 Books by this Author</h5>
        </div>

        <div class="card-body p-0">

            @if (!Model.Books.Any())
            {
                <div class="p-3 text-center text-muted">
                    No books found for this author.
                </div>
            }
            else
            {
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Title</th>
                            <th>ISBN</th>
                            <th>Category</th>
                            <th>Total</th>
                            <th>Available</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var book in Model.Books)
                        {
                            <tr>
                                <td>@book.Title</td>
                                <td>@book.ISBN</td>
                                <td>@book.Category?.Name</td>
                                <td>@book.TotalCopies</td>
                                <td>@book.AvailableCopies</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }

        </div>
    </div>

    <!-- Back Button -->
    <div class="mt-3">
        <a asp-action="Index" class="btn btn-secondary">⬅ Back to Authors</a>
    </div>

</div>
