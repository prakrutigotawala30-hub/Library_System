@model IEnumerable<LibraryManagementSystem.Models.BorrowRecord>

<div class="container mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>📚 Borrow History - @ViewBag.MemberName</h3>

        <a asp-controller="Members" asp-action="Index" class="btn btn-secondary">
            ⬅ Back to Members
        </a>
    </div>

    <div class="card p-3 shadow-sm">

        @if (Model.Any())
        {
            <table class="table table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Book</th>
                        <th>Issued On</th>
                        <th>Due Date</th>
                        <th>Returned On</th>
                        <th>Status</th>
                        <th>Fine</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        var isOverdue = item.ReturnedOn == null && item.DueDate < DateTime.Now;

                        <tr>
                            <td>@item.Book?.Title</td>
                            <td>@item.IssuedOn.ToShortDateString()</td>
                            <td>@item.DueDate.ToShortDateString()</td>

                            <td>
                                @(item.ReturnedOn != null
                                                        ? item.ReturnedOn.Value.ToShortDateString()
                                                        : "-")
                            </td>

                            <td>
                                @if (item.Status == "Issued")
                                {
                                    if (isOverdue)
                                    {
                                        <span class="badge bg-danger">Overdue</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">Issued</span>
                                    }
                                }
                                else
                                {
                                    <span class="badge bg-success">Returned</span>
                                }
                            </td>

                            <td>
                                @if (item.FineAmount > 0)
                                {
                                    <span class="text-danger fw-bold">₹ @item.FineAmount</span>
                                }
                                else
                                {
                                    <span>₹ 0</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="alert alert-info text-center">
                No borrow history found for this member.
            </div>
        }

    </div>
</div>