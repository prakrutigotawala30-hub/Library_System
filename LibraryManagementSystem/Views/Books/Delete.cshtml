@model LibraryManagementSystem.ClassLibrary.Models.Book

@{
    ViewData["Title"] = "Delete Book";
}

<div class="container mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2 class="text-danger fw-bold">
            🗑 Delete Book
        </h2>

        <a asp-action="Index"
           class="btn btn-outline-secondary">
            ← Back
        </a>

    </div>

    <!-- CARD -->
    <div class="card shadow border-danger rounded-4 overflow-hidden">

        <div class="card-header bg-danger text-white py-3">
            <h4 class="mb-0">
                Confirm Book Deletion
            </h4>
        </div>

        <div class="card-body">

            <div class="alert alert-warning">
                ⚠ Are you sure you want to permanently delete this book?
            </div>

            <div class="row">

                <!-- IMAGE -->
                <div class="col-md-4 text-center mb-3">

                    @if (!string.IsNullOrEmpty(Model.CoverImageUrl))
                    {
                        <img src="@Model.CoverImageUrl"
                             class="img-fluid rounded shadow"
                             style="max-height:400px; object-fit:cover;" />
                    }
                    else
                    {
                        <img src="https://via.placeholder.com/300x400?text=No+Cover"
                             class="img-fluid rounded shadow" />
                    }

                </div>

                <!-- DETAILS -->
                <div class="col-md-8">

                    <div class="mb-3">

                        <h3 class="fw-bold text-primary">
                            @Model.Title
                        </h3>

                        @if (Model.IsFeatured)
                        {
                            <span class="badge bg-warning text-dark px-3 py-2">
                                ⭐ Featured
                            </span>
                        }

                    </div>

                    <hr />

                    <div class="row">

                        <div class="col-md-6">

                            <p>
                                <strong>ISBN:</strong>
                                @Model.ISBN
                            </p>

                            <p>
                                <strong>Author:</strong>
                                @Model.Author?.Name
                            </p>

                            <p>
                                <strong>Category:</strong>
                                @Model.Category?.Name
                            </p>

                            <p>
                                <strong>Department:</strong>
                                @Model.Department?.Name
                            </p>

                        </div>

                        <div class="col-md-6">

                            <p>
                                <strong>Total Copies:</strong>
                                @Model.TotalCopies
                            </p>

                            <p>
                                <strong>Available Copies:</strong>
                                @Model.AvailableCopies
                            </p>

                            <p>
                                <strong>Total Pages:</strong>
                                @Model.TotalPages
                            </p>

                            <p>
                                <strong>Borrow Count:</strong>
                                @Model.BorrowCount
                            </p>

                        </div>

                    </div>

                    <!-- DESCRIPTION -->
                    <div class="mt-4">

                        <h5 class="fw-bold text-primary">
                            📘 Book Description
                        </h5>

                        <p class="text-muted">
                            @(string.IsNullOrWhiteSpace(Model.Description)
                                                        ? "No description available."
                                                        : Model.Description)
                        </p>

                    </div>

                    <!-- AUTHOR BIO -->
                    <div class="mt-4">

                        <h5 class="fw-bold text-primary">
                            ✍ Author Biography
                        </h5>

                        <p class="text-muted">
                            @(string.IsNullOrWhiteSpace(Model.Author?.Bio)
                                                        ? "No biography available."
                                                        : Model.Author?.Bio)
                        </p>

                    </div>

                    <!-- DEPARTMENT DESCRIPTION -->
                    <div class="mt-4">

                        <h5 class="fw-bold text-primary">
                            🏢 Department Description
                        </h5>

                        <p class="text-muted">
                            @(string.IsNullOrWhiteSpace(Model.Department?.Description)
                                                        ? "No department description available."
                                                        : Model.Department?.Description)
                        </p>

                    </div>

                </div>

            </div>

            <!-- BUTTONS -->
            <form asp-action="Delete"
                  method="post"
                  class="mt-4">

                <input type="hidden"
                       asp-for="Id" />

                <div class="d-flex justify-content-between">

                    <a asp-action="Index"
                       class="btn btn-secondary">
                        ⬅ Cancel
                    </a>

                    <button type="submit"
                            class="btn btn-danger px-4">
                        🗑 Yes, Delete Book
                    </button>

                </div>

            </form>

        </div>

    </div>

</div>