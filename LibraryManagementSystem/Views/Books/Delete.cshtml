@model LibraryManagementSystem.Models.Book

@{
    ViewData["Title"] = "Delete Book";
}

<div class="container mt-4">

    <div class="card shadow-sm border-danger">

        <div class="card-header bg-danger text-white">
            <h4 class="mb-0">🗑 Delete Book</h4>
        </div>

        <div class="card-body">

            <h5 class="text-danger mb-3">
                Are you sure you want to delete this book?
            </h5>

            <div class="border p-3 rounded bg-light">

                <p><strong>Title:</strong> @Model.Title</p>
                <p><strong>ISBN:</strong> @Model.ISBN</p>
                <p><strong>Author:</strong> @Model.Author?.Name</p>
                <p><strong>Category:</strong> @Model.Category?.Name</p>
                <p><strong>Department:</strong> @Model.Department?.Name</p>
                <p><strong>Total Copies:</strong> @Model.TotalCopies</p>
                <p><strong>Available Copies:</strong> @Model.AvailableCopies</p>

            </div>

            <form asp-action="Delete" method="post" class="mt-4">
                <input type="hidden" name="id" value="@Model.Id" />

                <div class="d-flex justify-content-between">

                    <a asp-action="Index" class="btn btn-secondary">
                        ⬅ Cancel
                    </a>

                    <button type="submit" class="btn btn-danger">
                        🗑 Yes, Delete
                    </button>

                </div>
            </form>

        </div>
    </div>

</div>