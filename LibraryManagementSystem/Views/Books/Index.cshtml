@model IEnumerable<LibraryManagementSystem.ClassLibrary.Models.Book>
@{
    ViewData["Title"] = "Books";
}
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
 <!-- Datatable plugin CSS file -->

 <link rel="stylesheet" href="https://cdn.datatables.net/1.10.22/css/jquery.dataTables.min.css" />


 
<style>
    /* =========================
       MOBILE TABLE RESPONSIVE
    ========================= */

    .table-responsive {
        width: 100%;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        border-radius: 16px;
    }

    .table {
        min-width: 700px;
    }
        /* TABLE HEADING FONT */
        .table thead th {
            font-family: 'Poppins', sans-serif;
            font-size: 15px;
            font-weight: 700;
            letter-spacing: 0.5px;
        }

        /* TABLE BODY FONT */
        .table tbody td {
            font-family: 'Segoe UI', sans-serif;
            font-size: 14px;
            font-weight: 500;
        }

    @@media (max-width: 768px) {

        .table-responsive {
            overflow-x: auto;
        }

        .table th,
        .table td {
            white-space: nowrap;
            font-size: 14px;
            padding: 12px;
        }

        .table {
            min-width: 650px;
        }
    }
</style>
<div class="container mt-4">

    <!-- Header -->
    <div class="row align-items-center mb-3">

        <!-- Left Title -->
        <div class="col-md-6">
            <h2 class="m-0">📚 Books List</h2>
        </div>

        <!-- Right Buttons -->
        <div class="col-md-6 text-end">

            <a class="btn btn-success" asp-controller="Books" asp-action="ExportExcel">
                Export Excel
            </a>

            <a asp-action="Import"
               class="btn btn-dark me-2">
                ⬆️ Bulk Import
            </a>

            <a class="btn btn-primary"
               asp-action="Create">
                + Add Book
            </a>

        </div>

    </div>


    <!-- ✅ SUCCESS MESSAGE HERE -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    <!-- Filters -->
    <div class="row mb-3">

        <!-- Search Box -->
        <div class="col-md-6 mb-2">
            <input type="text" id="searchBox" class="form-control" placeholder="Search by title or ISBN..." />
        </div>

        <!-- Category Filter -->
        <div class="col-md-6 mb-2">
            <select id="categoryFilter" class="form-select">
                <option value="">All Categories</option>
                @foreach (var item in Model.Where(x => x.Category != null)
                                              .Select(x => x.Category!.Name)
                                              .Distinct())
                {
                    <option value="@item">@item</option>
                }
            </select>
        </div>

    </div>

    <!-- Table -->
    <div class="table-responsive">

                <div class="card-body">

            <form asp-action="BulkDelete" method="post"
                  onsubmit="return confirm('Delete all selected books?');">
            <table class="table table-bordered table-striped table-hover align-middle" id="booksTable">
                        <thead class="table-dark">
                            <tr>
                                <th style="width:42px;">
                                    <input type="checkbox" id="selectAllBooks"
                                           onclick="document.querySelectorAll('.book-check').forEach(c=>c.checked=this.checked);" />
                                </th>
                                <th>Title</th>
                                <th>ISBN</th>
                                <th>Author</th>
                                <th>Category</th>
                                <th>Department</th>
                                <th>PDF</th>
                                <th>Pages</th>
                                <th>Featured</th>
                                <th>Total</th>
                                <th>Available</th>
                                <th>Actions</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <input type="checkbox" class="book-check"
                                               name="ids" value="@item.Id" />
                                    </td>
                                    <td>@item.Title</td>
                                    <td>@item.ISBN</td>
                                    <td>@item.Author?.Name</td>
                                <td class="category">@item.Category?.Name</td>
                                    <td>@item.Department?.Name</td>
                                <td>

                                    @if (!string.IsNullOrWhiteSpace(item.PdfUrl))
                                    {
                                        <a href="@item.PdfUrl"
                                           target="_blank"
                                           class="btn btn-sm btn-danger">

                                            PDF

                                        </a>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">
                                            No PDF
                                        </span>
                                    }

                                </td>
                                    <td>@item.TotalPages</td>

                                    <td>
                                        @if (item.IsFeatured)
                                        {
                                            <span class="badge bg-success">Yes</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">No</span>
                                        }
                                    </td>

                                    <td>@item.TotalCopies</td>
                                    <td>@item.AvailableCopies</td>

                                    <!-- FIX: Actions must be inside TD -->
                                    <td class="text-nowrap">

                                        <!-- VIEW -->
                                        <a asp-action="Details"
                                           asp-route-id="@item.Id"
                                           class="btn btn-sm btn-primary me-1"
                                           title="View">

                                            <i class="bi bi-eye-fill"></i>

                                        </a>

                                        <!-- EDIT -->
                                        <a asp-action="Edit"
                                           asp-route-id="@item.Id"
                                           class="btn btn-sm btn-warning me-1"
                                           title="Edit">

                                            <i class="bi bi-pencil-square"></i>

                                        </a>

                                        <!-- DELETE -->
                                        <a asp-action="Delete"
                                           asp-route-id="@item.Id"
                                           class="btn btn-sm btn-danger"
                                           title="Delete">

                                            <i class="bi bi-trash-fill"></i>

                                        </a>

                                    </td>

                                </tr>
                            }
                        </tbody>

                    </table>

                    <div class="p-3 border-top">
                        <button type="submit" class="btn btn-danger">
                            🗑 Delete Selected
                        </button>
                        <small class="text-muted ms-2">
                            Books with borrow history will fail FK and be reported.
                        </small>
                    </div>

                    </form>

                </div>
            </div>

    
</div>

@section Scripts {

    <script src="https://code.jquery.com/jquery-3.5.1.js"></script>

    <!-- Datatable plugin JS -->
    <script src="https://cdn.datatables.net/1.10.22/js/jquery.dataTables.min.js"></script>

    <script>
        $(document).ready(function () {

            // DATATABLE
            var table = $('#booksTable').DataTable({
                searching: false, // remove default datatable search
                paging: true,
                info: true,
                ordering: true,
                responsive: true
            });

            // CUSTOM SEARCH BAR
            $("#searchBox").on("keyup", function () {

                let value = $(this).val().toLowerCase();

                $("#booksTable tbody tr").filter(function () {

                    $(this).toggle(
                        $(this).text().toLowerCase().indexOf(value) > -1
                    );

                });

            });

            // CATEGORY FILTER
            $("#categoryFilter").on("change", function () {

                let value = $(this).val().toLowerCase();

                $("#booksTable tbody tr").each(function () {

                    if (!value) {

                        $(this).show();

                    } else {

                        let category = $(this)
                            .find(".category")
                            .text()
                            .toLowerCase();

                        $(this).toggle(category.includes(value));

                    }

                });

            });

        });
    </script>
}
