@model LibraryManagementSystem.ViewModels.BookDetailsViewModel

@{
    ViewData["Title"] = "Book Details";
}

<div class="container mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary">📖 Book Details</h2>

        <a asp-action="Index"
           class="btn btn-outline-secondary">
            ← Back
        </a>
    </div>

    <!-- MAIN CARD -->
    <div class="card shadow border-0 rounded-4 overflow-hidden">

        <div class="row g-0">

            <!-- BOOK IMAGE -->
            <div class="col-md-4 bg-light text-center p-4">

                @if (!string.IsNullOrEmpty(Model.Book.CoverImageUrl))
                {
                    <img src="@Model.Book.CoverImageUrl"
                         class="img-fluid rounded shadow-sm"
                         style="max-height:400px; object-fit:cover;" />
                }
                else
                {
                    <img src="https://via.placeholder.com/300x400?text=No+Cover"
                         class="img-fluid rounded shadow-sm" />
                }

            </div>

            <!-- BOOK INFO -->
            <div class="col-md-8">

                <div class="card-body p-4">

                    <!-- TITLE -->
                    <div class="d-flex align-items-center mb-3">

                        <h2 class="fw-bold text-dark mb-0">
                            @Model.Book.Title
                        </h2>

                        @if (Model.Book.IsFeatured)
                        {
                            <span class="badge bg-warning text-dark ms-3 px-3 py-2">
                                ⭐ Featured
                            </span>
                        }

                    </div>

                    <!-- BASIC INFO -->
                    <div class="row mb-4">

                        <div class="col-md-6">

                            <p>
                                <strong>ISBN:</strong>
                                @Model.Book.ISBN
                            </p>

                            <p>
                                <strong>Category:</strong>
                                @Model.Book.Category?.Name
                            </p>

                            <p>
                                <strong>Department:</strong>
                                @Model.Book.Department?.Name
                            </p>

                            <p>
                                <strong>Total Pages:</strong>
                                @Model.Book.TotalPages
                            </p>

                        </div>

                        <div class="col-md-6">

                            <p>
                                <strong>Total Copies:</strong>
                                @Model.Book.TotalCopies
                            </p>

                            <p>
                                <strong>Available Copies:</strong>
                                @Model.Book.AvailableCopies
                            </p>

                            <p>
                                <strong>Borrow Count:</strong>
                                @Model.Book.BorrowCount
                            </p>

                            <p>
                                <strong>Added On:</strong>
                                @Model.Book.CreatedAt.ToString("dd MMM yyyy")
                            </p>

                        </div>

                    </div>

                    <!-- DESCRIPTION -->
                    <div class="mb-4">

                        <h5 class="fw-bold text-primary">
                            📘 Book Description
                        </h5>

                        <p class="text-muted">
                            @(string.IsNullOrWhiteSpace(Model.Book.Description)
                                                        ? "No description available."
                                                        : Model.Book.Description)
                        </p>

                    </div>

                    <!-- PDF SECTION -->
                    @if (!string.IsNullOrWhiteSpace(Model.Book.PdfUrl))
                    {
                        <div class="mb-4">

                            <h5 class="fw-bold text-primary">
                                📄 Digital Book
                            </h5>

                            <div class="d-flex gap-2 flex-wrap">

                                <!-- VIEW PDF -->

                                <a href="@Model.Book.PdfUrl"
                                   target="_blank"
                                   class="btn btn-danger">

                                    📖 Read PDF

                                </a>

                                <!-- DOWNLOAD PDF -->

                                <a href="@Model.Book.PdfUrl"
                                   download
                                   class="btn btn-outline-dark">

                                    ⬇ Download PDF

                                </a>

                            </div>

                        </div>
                    }

                    <!-- AUTHOR -->
                    <div class="mb-4">

                        <h5 class="fw-bold text-primary">
                            ✍ Author Information
                        </h5>

                        <p>
                            <strong>Name:</strong>
                            @Model.Book.Author?.Name
                        </p>

                        <p class="text-muted">
                            @(string.IsNullOrWhiteSpace(Model.Book.Author?.Bio)
                                                        ? "No biography available."
                                                        : Model.Book.Author?.Bio)
                        </p>

                    </div>

                    <!-- DEPARTMENT -->
                    <div class="mb-2">

                        <h5 class="fw-bold text-primary">
                            🏢 Department Information
                        </h5>

                        <p class="text-muted">
                            @(string.IsNullOrWhiteSpace(Model.Book.Department?.Description)
                                                        ? "No department description available."
                                                        : Model.Book.Department?.Description)
                        </p>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <!-- BORROW HISTORY -->
    <div class="card shadow border-0 rounded-4 mt-4">

        <div class="card-header bg-dark text-white py-3">
            <h5 class="mb-0">📊 Borrow History</h5>
        </div>

        <div class="card-body p-0">

            @if (Model.BorrowHistory != null && Model.BorrowHistory.Any())
            {
                <div class="table-responsive">

                    <table class="table table-hover table-bordered align-middle mb-0">

                        <thead class="table-light">
                            <tr>
                                <th>Student</th>
                                <th>Issued On</th>
                                <th>Returned On</th>
                                <th>Status</th>
                                <th>Fine</th>
                            </tr>
                        </thead>

                        <tbody>

                            @foreach (var item in Model.BorrowHistory)
                            {
                                <tr>

                                    <td>@item.Member?.Name</td>

                                    <td>
                                        @item.IssuedOn.ToString("dd MMM yyyy")
                                    </td>

                                    <td>
                                        @(item.ReturnedOn.HasValue
                                                                        ? item.ReturnedOn.Value.ToString("dd MMM yyyy")
                                                                        : "-")
                                    </td>

                                    <td>

                                        @if (item.Status == "Issued")
                                        {
                                            <span class="badge bg-warning text-dark px-3 py-2">
                                                Issued
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success px-3 py-2">
                                                Returned
                                            </span>
                                        }

                                    </td>

                                    <td>
                                        ₹@item.FineAmount
                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>

                </div>
            }
            else
            {
                <div class="text-center p-5 text-muted">
                    📭 No borrow history available
                </div>
            }

        </div>

    </div>

</div>
