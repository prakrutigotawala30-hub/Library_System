@model LibraryManagementSystem.ClassLibrary.Models.ContactMessage

@{
    ViewData["Title"] = "Message Details";
}

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="m-0">📨 Message #@Model.Id</h2>
        <a asp-action="Index" class="btn btn-secondary">← Back</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">

            <dl class="row">
                <dt class="col-sm-3">From</dt>
                <dd class="col-sm-9">@Model.Name</dd>

                <dt class="col-sm-3">Email</dt>
                <dd class="col-sm-9">
                    <a href="mailto:@Model.Email">@Model.Email</a>
                </dd>

                <dt class="col-sm-3">Received</dt>
                <dd class="col-sm-9">
                    @Model.ReceivedOn.ToString("dd MMM yyyy HH:mm")
                </dd>

                <dt class="col-sm-3">Subject</dt>
                <dd class="col-sm-9"><strong>@Model.Subject</strong></dd>

                <dt class="col-sm-3">Message</dt>
                <dd class="col-sm-9" style="white-space:pre-wrap;">@Model.Message</dd>
            </dl>

            <hr />

            <a class="btn btn-primary"
               href="mailto:@Model.Email?subject=Re:%20@Uri.EscapeDataString(Model.Subject)">
                Reply by Email
            </a>

            <form asp-action="Delete"
                  asp-route-id="@Model.Id"
                  method="post"
                  onsubmit="return confirm('Delete this message?');"
                  style="display:inline;">
                <button class="btn btn-danger">
                    <i class="bi bi-trash"></i> Delete
                </button>
            </form>
        </div>
    </div>
</div>
