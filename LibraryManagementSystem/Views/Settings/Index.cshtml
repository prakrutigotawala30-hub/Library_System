@model LibraryManagementSystem.ClassLibrary.Models.LibrarySettings

@{
    ViewData["Title"] = "Settings";
}

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">

<div class="container mt-4" style="max-width:780px;">
    <h2 class="mb-3">⚙️ Library Settings</h2>

    <form asp-action="Index" method="post">
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="card shadow-sm mb-3">
            <div class="card-body">
                <h5 class="card-title">General</h5>
                <div class="mb-3">
                    <label asp-for="LibraryName" class="form-label">Library Name</label>
                    <input asp-for="LibraryName" class="form-control" />
                </div>
            </div>
        </div>

        <div class="card shadow-sm mb-3">
            <div class="card-body">
                <h5 class="card-title">Borrowing</h5>
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="DefaultLoanDays" class="form-label">Default Loan Days</label>
                        <input asp-for="DefaultLoanDays" type="number" min="1" class="form-control" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="MaxRenewals" class="form-label">Max Renewals</label>
                        <input asp-for="MaxRenewals" type="number" min="0" class="form-control" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="FinePerDay" class="form-label">Fine ₹/day</label>
                        <input asp-for="FinePerDay" type="number" step="0.01" min="0" class="form-control" />
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm mb-3">
            <div class="card-body">
                <h5 class="card-title">Membership Fees (₹)</h5>
                <table class="table">
                    <thead>
                        <tr><th>Plan</th><th>Monthly</th><th>Annual</th></tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Student</td>
                            <td><input asp-for="StudentMonthly" type="number" step="0.01" class="form-control" /></td>
                            <td><input asp-for="StudentAnnual" type="number" step="0.01" class="form-control" /></td>
                        </tr>
                        <tr>
                            <td>Regular</td>
                            <td><input asp-for="RegularMonthly" type="number" step="0.01" class="form-control" /></td>
                            <td><input asp-for="RegularAnnual" type="number" step="0.01" class="form-control" /></td>
                        </tr>
                        <tr>
                            <td>Premium</td>
                            <td><input asp-for="PremiumMonthly" type="number" step="0.01" class="form-control" /></td>
                            <td><input asp-for="PremiumAnnual" type="number" step="0.01" class="form-control" /></td>
                        </tr>
                    </tbody>
                </table>
                <small class="text-muted">
                    These values are read by user-app MembershipController.Buy and BorrowController.Issue.
                </small>
            </div>
        </div>

        <button class="btn btn-primary">Save Settings</button>
    </form>
</div>
