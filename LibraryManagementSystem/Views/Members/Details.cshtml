@model LibraryManagementSystem.Models.Member

<div class="container mt-4">

    <!-- MEMBER PROFILE -->
    <div class="card p-4 mb-4 shadow-sm">
        <h3 class="mb-3">👤 Member Profile</h3>

        <div class="row">
            <div class="col-md-6">
                <p><strong>Name:</strong> @Model.Name</p>
                <p><strong>Email:</strong> @Model.Email</p>
                <p><strong>Phone:</strong> @Model.Phone</p>
            </div>

            <div class="col-md-6">
                <p><strong>Joined:</strong> @Model.JoinedOn.ToShortDateString()</p>
                <p><strong>Total Borrowed:</strong> @Model.BorrowRecords.Count()</p>
                <p>
                    <strong>Currently Borrowed:</strong>
                    @Model.BorrowRecords.Count(b => b.ReturnedOn == null)
                </p>
            </div>
        </div>

        <div class="mt-3">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                Edit Member
            </a>

            <a asp-action="Index" class="btn btn-secondary">
                Back to List
            </a>

            <a asp-controller="Borrow"
               asp-action="History"
               asp-route-memberId="@Model.Id"
               class="btn btn-info">
                📚 View Borrow History
            </a>
        </div>
    </div>


    <!-- BORROW HISTORY -->
    <div class="card p-4 shadow-sm">
        <h4 class="mb-3">📚 Borrow History</h4>

        @if (Model.BorrowRecords.Any())
        {
            <table class="table table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Book</th>
                        <th>Issued On</th>
                        <th>Due Date</th>
                        <th>Returned On</th>
                        <th>Status</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var record in Model.BorrowRecords.OrderByDescending(b => b.IssuedOn))
                    {
                        <tr>
                            <td>@record.Book?.Title</td>
                            <td>@record.IssuedOn.ToShortDateString()</td>
                            <td>@record.DueDate.ToShortDateString()</td>
                            <td>
                                @(record.ReturnedOn != null
                                                        ? record.ReturnedOn.Value.ToShortDateString()
                                                        : "-")
                            </td>

                            <td>
                                @if (record.ReturnedOn == null)
                                {
                                    if (record.DueDate < DateTime.Now)
                                    {
                                        <span class="badge bg-danger">Overdue</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">Borrowed</span>
                                    }
                                }
                                else
                                {
                                    <span class="badge bg-success">Returned</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="alert alert-info text-center">
                No borrow history found.
            </div>
        }
    </div>

</div>