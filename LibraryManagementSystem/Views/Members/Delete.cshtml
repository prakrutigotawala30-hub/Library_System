@model LibraryManagementSystem.Models.Member

<div class="container d-flex justify-content-center align-items-center vh-100">

    <div class="card shadow-lg p-4 text-center" style="width: 420px; border-radius: 15px;">

        <h3 class="text-danger mb-3">⚠️ Delete Member</h3>

        <p class="text-muted">
            Are you sure you want to delete this member?
        </p>

        <!-- Member Info -->
        <div class="mb-3 text-start">
            <p><strong>Name:</strong> @Model.Name</p>
            <p><strong>Email:</strong> @Model.Email</p>
            <p><strong>Phone:</strong> @Model.Phone</p>
        </div>

        @if (Model.BorrowRecords != null && Model.BorrowRecords.Any())
        {
            <div class="alert alert-warning">
                ⚠ This member has borrow history. Deleting will remove all related records.
            </div>
        }

        <!-- FORM -->
        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="Id" />

            <button type="submit" class="btn btn-danger w-100 mb-2">
                🗑 Confirm Delete
            </button>

            <a asp-action="Index" class="btn btn-secondary w-100">
                Cancel
            </a>
        </form>

    </div>

</div>