@{
    Layout = null;
}

@model LibraryManagementSystem.ViewModels.RegisterViewModel

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Admin Register</title>

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">

    <style>

        body {
            margin: 0;
            height: 100vh;
            font-family: 'Segoe UI', sans-serif;
            overflow: hidden;
            background: #f1f5f9;
        }

        /* WRAPPER */
        .auth-wrapper {
            display: flex;
            height: 100vh;
        }

        /* LEFT PANEL */
        .left-panel {
            flex: 1;
            background: linear-gradient(135deg, #0f172a, #1e3a8a, #2563eb);
            color: white;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 70px;
        }

            .left-panel h1 {
                font-size: 46px;
                font-weight: 800;
                margin-bottom: 15px;
            }

            .left-panel p {
                opacity: 0.85;
                font-size: 16px;
                line-height: 1.7;
            }

        .features {
            margin-top: 35px;
        }

            .features div {
                margin-bottom: 14px;
                font-size: 15px;
                opacity: 0.95;
            }

        /* RIGHT PANEL */
        .right-panel {
            flex: 1;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 30px;
        }

        /* CARD */
        .register-card {
            width: 430px;
            background: white;
            border-radius: 24px;
            padding: 35px;
            box-shadow: 0 25px 60px rgba(0,0,0,0.12);
        }

            .register-card h3 {
                font-weight: 700;
                margin-bottom: 8px;
                color: #0f172a;
            }

        .sub-text {
            color: #64748b;
            margin-bottom: 25px;
            font-size: 14px;
        }

        .form-control {
            border-radius: 12px;
            padding: 12px;
            border: 1px solid #dbeafe;
        }

            .form-control:focus {
                border-color: #2563eb;
                box-shadow: 0 0 0 0.2rem rgba(37,99,235,0.15);
            }

        .btn-register {
            width: 100%;
            background: linear-gradient(135deg, #16a34a, #22c55e);
            border: none;
            padding: 12px;
            border-radius: 12px;
            color: white;
            font-weight: 700;
            transition: 0.3s;
        }

            .btn-register:hover {
                transform: translateY(-2px);
                box-shadow: 0 10px 25px rgba(34,197,94,0.35);
            }

        .login-link {
            text-align: center;
            margin-top: 18px;
        }

            .login-link a {
                text-decoration: none;
                color: #2563eb;
                font-weight: 600;
            }

        .text-danger {
            font-size: 13px;
        }

        /* MOBILE */
        @@media (max-width: 992px) {

            .left-panel {
                display: none;
            }

            .right-panel {
                flex: 1 1 100%;
            }
        }

    </style>
</head>

<body>

    <div class="auth-wrapper">

        <!-- LEFT -->
        <div class="left-panel">

            <h1>📚 Library System</h1>

            <p>
                Secure admin portal for managing books,
                members, reports, borrowing records,
                and complete digital library operations.
            </p>

            <div class="features">

                <div>✔ Smart Book Management</div>

                <div>✔ Borrow & Return Tracking</div>

                <div>✔ PDF Receipt Generation</div>

                <div>✔ Fine & Due Calculation</div>

                <div>✔ Reports & Analytics</div>

            </div>

        </div>

        <!-- RIGHT -->
        <div class="right-panel">

            <div class="register-card">

                <h3>Create Admin Account</h3>

                <div class="sub-text">
                    Register securely to access the library dashboard.
                </div>

                <!-- ALERTS -->
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger">
                        @TempData["Error"]
                    </div>
                }

                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success">
                        @TempData["Success"]
                    </div>
                }

                <form asp-action="Register" method="post">

                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly"
                         class="text-danger mb-2">
                    </div>

                    <!-- FULL NAME -->
                    <div class="mb-3">

                        <input asp-for="FullName"
                               class="form-control"
                               placeholder="Full Name" />

                        <span asp-validation-for="FullName"
                              class="text-danger"></span>

                    </div>

                    <!-- EMAIL -->
                    <div class="mb-3">

                        <input asp-for="Email"
                               type="email"
                               class="form-control"
                               placeholder="Email Address" />

                        <span asp-validation-for="Email"
                              class="text-danger"></span>

                    </div>

                    <!-- PASSWORD -->
                    <div class="mb-3">

                        <input asp-for="Password"
                               type="password"
                               class="form-control"
                               placeholder="Password" />

                        <span asp-validation-for="Password"
                              class="text-danger"></span>

                    </div>

                    <!-- CONFIRM PASSWORD -->
                    <div class="mb-3">

                        <input asp-for="ConfirmPassword"
                               type="password"
                               class="form-control"
                               placeholder="Confirm Password" />

                        <span asp-validation-for="ConfirmPassword"
                              class="text-danger"></span>

                    </div>

                    <!-- ADMIN KEY -->
                    <div class="mb-3">

                        <input asp-for="PrivateKey"
                               type="password"
                               class="form-control"
                               placeholder="Admin Security Key" />

                        <span asp-validation-for="PrivateKey"
                              class="text-danger"></span>

                    </div>

                    <!-- BUTTON -->
                    <button type="submit"
                            class="btn-register">

                        Create Admin Account

                    </button>

                    <!-- LOGIN -->
                    <div class="login-link">

                        <a asp-action="Login">
                            Already have an account?
                        </a>

                    </div>

                </form>

            </div>

        </div>

    </div>

    <!-- JQUERY -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>

    <!-- VALIDATION -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>

    <script>
        setTimeout(function () {

            let alerts = document.querySelectorAll(".alert");

            alerts.forEach(a => {
                a.style.display = "none";
            });

        }, 3000);
    </script>
</body>
</html>