@{
    Layout = null;
}

@model LibraryManagementSystem.ViewModels.LoginViewModel

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Login</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>

        /* FULL PAGE */
        body {
            margin: 0;
            height: 100vh;
            font-family: 'Segoe UI', sans-serif;
            overflow: hidden;
        }

        /* SPLIT LAYOUT */
        .auth-wrapper {
            display: flex;
            height: 100vh;
        }

        /* LEFT PANEL */
        .left-panel {
            flex: 1;
            background: linear-gradient(135deg, #0f172a, #1e3a8a, #2563eb);
            color: white;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 60px;
            position: relative;
        }

            .left-panel h1 {
                font-size: 42px;
                font-weight: bold;
            }

            .left-panel p {
                opacity: 0.8;
                margin-top: 10px;
                font-size: 16px;
            }

        .badge-box {
            margin-top: 30px;
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

            .badge-box span {
                background: rgba(255,255,255,0.15);
                padding: 8px 12px;
                border-radius: 20px;
                font-size: 12px;
            }

        /* RIGHT PANEL */
        .right-panel {
            flex: 1;
            display: flex;
            justify-content: center;
            align-items: center;
            background: #f8fafc;
        }

        /* LOGIN CARD */
        .login-card {
            width: 380px;
            background: white;
            border-radius: 18px;
            padding: 30px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.15);
        }

            .login-card h3 {
                font-weight: 700;
                margin-bottom: 20px;
                color: #0f172a;
            }

        .form-control {
            border-radius: 10px;
            padding: 10px;
        }

        .btn-login {
            width: 100%;
            background: linear-gradient(135deg, #2563eb, #06b6d4);
            border: none;
            padding: 10px;
            border-radius: 10px;
            color: white;
            font-weight: 600;
            transition: 0.3s;
        }

            .btn-login:hover {
                transform: translateY(-2px);
                box-shadow: 0 10px 25px rgba(37,99,235,0.3);
            }

        .link {
            text-align: center;
            margin-top: 15px;
        }

            .link a {
                text-decoration: none;
                color: #2563eb;
            }

    </style>
</head>

<body>

    <div class="auth-wrapper">

        <!-- LEFT -->
        <div class="left-panel">

            <h1>📚 Library System</h1>
            <p>Manage books, members, and borrowing with a modern digital system.</p>

            <div class="badge-box">
                <span>Smart Borrowing</span>
                <span>Fine Management</span>
                <span>Membership System</span>
                <span>Dashboard Analytics</span>
            </div>

        </div>

        <!-- RIGHT -->
        <div class="right-panel">

            <div class="login-card">

                <h3>Login</h3>

                @if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

                <form asp-action="Login" method="post">

                    @Html.AntiForgeryToken()

                    <!-- GLOBAL ERROR -->
                    <div asp-validation-summary="ModelOnly"
                         class="text-danger mb-3">
                    </div>

                    <!-- EMAIL -->
                    <div class="mb-3">

                        <label>Email</label>

                        <input asp-for="Email"
                               class="form-control"
                               placeholder="Enter email" />

                        <span asp-validation-for="Email"
                              class="text-danger"></span>

                    </div>

                    <!-- PASSWORD -->
                    <div class="mb-3">

                        <label>Password</label>

                        <input asp-for="Password"
                               type="password"
                               class="form-control"
                               placeholder="Enter password" />

                        <span asp-validation-for="Password"
                              class="text-danger"></span>

                    </div>

                    <!-- REMEMBER ME -->
                    <div class="form-check mb-3">

                        <input asp-for="RememberMe"
                               class="form-check-input" />

                        <label asp-for="RememberMe"
                               class="form-check-label">
                            Remember Me
                        </label>

                    </div>

                    <button type="submit"
                            class="btn-login">

                        Login

                    </button>

                    <div class="link">

                        <a asp-action="Register">
                            Create new account
                        </a>

                    </div>

                </form>

            </div>

        </div>

    </div>
    <!-- JQUERY -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>

    <!-- VALIDATION -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>

    <script>
        setTimeout(function () {

            let alerts = document.querySelectorAll(".alert");

            alerts.forEach(a => {
                a.style.display = "none";
            });

        }, 3000);
    </script>
</body>
</html>