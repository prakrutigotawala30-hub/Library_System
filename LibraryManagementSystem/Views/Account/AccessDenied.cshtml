@{
    ViewData["Title"] = "Access Denied";
    Layout = "_Layout";
}

<style>

    /* BLUR BACKGROUND */
    .blur-bg {
        position: fixed;
        inset: 0;
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
        background: rgba(15, 23, 42, 0.35);
        z-index: 999;
    }

    .navbar {
        position: relative;
        z-index: 1100;
    }

    /* CARD */
    .access-card {
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 430px;
        max-width: 92%;
        background: rgba(255,255,255,0.12);
        backdrop-filter: blur(24px);
        border: 1px solid rgba(255,255,255,0.15);
        border-radius: 24px;
        padding: 35px;
        text-align: center;
        box-shadow: 0 20px 60px rgba(0,0,0,0.35);
        z-index: 1000;
        color: white;
    }

    /* ICON */
    .access-icon {
        width: 90px;
        height: 90px;
        margin: auto auto 20px;
        border-radius: 50%;
        background: linear-gradient(135deg,#dc2626,#ef4444);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 42px;
        box-shadow: 0 15px 30px rgba(239,68,68,0.4);
    }

    .access-title {
        font-size: 30px;
        font-weight: 800;
        margin-bottom: 10px;
    }

    .access-subtitle {
        color: #cbd5e1;
        font-size: 15px;
        line-height: 1.7;
        margin-bottom: 22px;
    }

    /* ERROR BOX */
    .error-box {
        background: rgba(239,68,68,0.12);
        border: 1px solid rgba(239,68,68,0.3);
        color: #fecaca;
        padding: 14px;
        border-radius: 14px;
        font-size: 14px;
        margin-bottom: 25px;
        text-align: left;
    }

    /* BUTTONS */
    .action-buttons {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

    .btn-custom {
        flex: 1;
        border: none;
        padding: 12px;
        border-radius: 12px;
        text-decoration: none;
        font-weight: 600;
        transition: 0.3s ease;
    }

    .btn-login {
        background: linear-gradient(135deg,#2563eb,#06b6d4);
        color: white;
    }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(37,99,235,0.35);
            color: white;
        }

    .btn-home {
        background: rgba(255,255,255,0.08);
        border: 1px solid rgba(255,255,255,0.12);
        color: white;
    }

        .btn-home:hover {
            background: rgba(255,255,255,0.16);
            color: white;
        }

    /* MOBILE */
    @@media(max-width:576px) {

        .access-card {
            padding: 28px 20px;
        }

        .action-buttons {
            flex-direction: column;
        }
    }

</style>

<!-- BLUR -->
<div class="blur-bg"></div>

<!-- CARD -->
<div class="access-card">

    <!-- ICON -->
    <div class="access-icon">
        🚫
    </div>

    <!-- TITLE -->
    <div class="access-title">
        Access Denied
    </div>

    <!-- SUBTITLE -->
    <div class="access-subtitle">

        You tried to open a protected page
        that requires special permission
        or administrator access.

    </div>

    <!-- ERROR -->
    <div class="error-box">

        <strong>Reason:</strong>
        <br />

        @ViewBag.ErrorMessage

    </div>

    <!-- BUTTONS -->
    <div class="action-buttons">

        <a asp-controller="Account"
           asp-action="Login"
           class="btn-custom btn-login">

            Login Again

        </a>

        <a asp-controller="Home"
           asp-action="Index"
           class="btn-custom btn-home">

            Go Home

        </a>

    </div>

</div>