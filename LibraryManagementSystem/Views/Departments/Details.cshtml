@model LibraryManagementSystem.Models.Department

@{
    ViewData["Title"] = "Department Details";
}

<h2>Department Details</h2>

<hr />

<div class="card shadow p-4">

    <div class="mb-3">
        <h4>Name</h4>
        <p>@Model.Name</p>
    </div>

    <div class="mb-3">
        <h4>Description</h4>
        <p>@Model.Description</p>
    </div>

</div>

<br />

<a asp-action="Edit"
   asp-route-id="@Model.Id"
   class="btn btn-warning">
    Edit
</a>

<a asp-action="Index"
   class="btn btn-secondary">
    Back
</a>