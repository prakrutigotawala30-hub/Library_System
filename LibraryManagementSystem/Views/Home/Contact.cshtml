@{
    ViewData["Title"] = "Contact Us";
}

<div class="container-fluid mt-4">

    <div class="row">

        <!-- LEFT: CONTACT FORM -->
        <div class="col-md-7">

            <h3 class="mb-4">📞 Contact Library Admin</h3>

            <div class="card shadow-sm p-4 border-0">

                <form>

                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <input type="text" class="form-control" placeholder="Enter your name" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-control" placeholder="Enter your email" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Message</label>
                        <textarea class="form-control" rows="5" placeholder="Write your message"></textarea>
                    </div>

                    <button class="btn btn-primary w-100">
                        Send Message
                    </button>

                </form>

            </div>
        </div>

        <!-- RIGHT: INFO PANEL -->
        <div class="col-md-5">

            <div class="card shadow-sm border-0 p-4 bg-light">

                <h5>📍 Library Info</h5>

                <hr />

                <p><strong>Email:</strong> librarysupport@example.com</p>
                <p><strong>Phone:</strong> +91 98765 43210</p>
                <p><strong>Address:</strong> Surat, Gujarat</p>

                <hr />

                <p class="text-muted">
                    We are available Monday to Saturday for support, borrowing, and account issues.
                </p>

            </div>

        </div>

    </div>

</div>