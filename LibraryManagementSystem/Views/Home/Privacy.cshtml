@{
    ViewData["Title"] = "Privacy";
}

<div class="container">

    <!-- Header -->
    <div class="text-center mb-4">
        <h2 class="fw-bold">Library Management System</h2>
        <p class="text-muted">Privacy Policy & System Information</p>
    </div>

    <div class="row g-4">

        <!-- About -->
        <div class="col-md-6">
            <div class="card p-4 h-100">
                <h4 class="text-primary">About System</h4>
                <hr />
                <p>
                    This system is designed to manage books, members, and borrowing activities efficiently using
                    ASP.NET Core MVC and Entity Framework Core.
                </p>

                <ul>
                    <li>Book Management</li>
                    <li>Member Management</li>
                    <li>Borrow & Return System</li>
                    <li>Dashboard Reports</li>
                    <li>Authentication & Authorization</li>
                </ul>
            </div>
        </div>

        <!-- Privacy -->
        <div class="col-md-6">
            <div class="card p-4 h-100">
                <h4 class="text-success">Privacy Policy</h4>
                <hr />

                <p>We respect user privacy and ensure secure handling of all system data.</p>

                <ul>
                    <li>User data is securely stored</li>
                    <li>No data shared with third parties</li>
                    <li>Access restricted to authorized users</li>
                    <li>Identity-based authentication used</li>
                </ul>
            </div>
        </div>

    </div>
</div>