@{
    ViewData["Title"] = "Server Error";
}

<div class="error-page">

    <div class="error-card">

        <div class="error-icon">
            ⚠
        </div>

        <h1 class="error-code text-danger">
            500
        </h1>

        <h3 class="mb-3">
            Internal Server Error
        </h3>

        <p class="text-muted mb-4">
            Something went wrong inside the
            Library Management System.
        </p>

        <a asp-controller="Home"
           asp-action="Index"
           class="btn btn-dark px-4">

            Return Dashboard

        </a>

    </div>

</div>

<style>

    .error-page {
        min-height: 80vh;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .error-card {
        background: white;
        padding: 60px;
        border-radius: 24px;
        text-align: center;
        max-width: 500px;
        box-shadow: 0 15px 40px rgba(0,0,0,0.08);
    }

    .error-icon {
        font-size: 70px;
        margin-bottom: 15px;
    }

    .error-code {
        font-size: 90px;
        font-weight: 800;
    }

</style>