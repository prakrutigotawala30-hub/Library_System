@model LibraryManagementSystem.ClassLibrary.Models.Event

@{
    ViewData["Title"] = "Event Details";
}

<div class="container mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2 class="fw-bold text-primary">
            🎉 Event Details
        </h2>

        <a asp-action="Index"
           class="btn btn-outline-secondary">
            ← Back
        </a>

    </div>

    <!-- MAIN CARD -->
    <div class="card shadow border-0 rounded-4 overflow-hidden">

        <div class="row g-0">

            <!-- EVENT IMAGE -->
            <div class="col-md-4 bg-light text-center p-4">

                @if (!string.IsNullOrEmpty(Model.ImagePath))
                {
                    <img src="@Model.ImagePath"
                         class="img-fluid rounded shadow-sm"
                         style="max-height:420px; object-fit:cover;" />
                }
                else
                {
                    <img src="https://via.placeholder.com/400x500?text=No+Event+Image"
                         class="img-fluid rounded shadow-sm" />
                }

            </div>

            <!-- EVENT INFO -->
            <div class="col-md-8">

                <div class="card-body p-4">

                    <!-- TITLE -->
                    <div class="mb-4">

                        <h2 class="fw-bold text-dark mb-2">
                            @Model.Title
                        </h2>

                        <span class="badge bg-primary px-3 py-2">
                            Upcoming Event
                        </span>

                    </div>

                    <!-- EVENT DETAILS -->
                    <div class="row mb-4">

                        <div class="col-md-6">

                            <div class="mb-3">
                                <h6 class="fw-bold text-primary">
                                    📅 Event Date
                                </h6>

                                <p class="text-muted mb-0">
                                    @Model.Date.ToString("dd MMM yyyy")
                                </p>
                            </div>

                            <div class="mb-3">
                                <h6 class="fw-bold text-primary">
                                    ⏰ Event Time
                                </h6>

                                <p class="text-muted mb-0">
                                    @Model.Date.ToString("hh:mm tt")
                                </p>
                            </div>

                        </div>

                        <div class="col-md-6">

                            <div class="mb-3">
                                <h6 class="fw-bold text-primary">
                                    📍 Location
                                </h6>

                                <p class="text-muted mb-0">
                                    @Model.Location
                                </p>
                            </div>

                            <div class="mb-3">
                                <h6 class="fw-bold text-primary">
                                    🗓 Created
                                </h6>

                                <p class="text-muted mb-0">
                                    @DateTime.Now.ToString("dd MMM yyyy")
                                </p>
                            </div>

                        </div>

                    </div>

                    <!-- DESCRIPTION -->
                    <div class="mb-4">

                        <h5 class="fw-bold text-primary">
                            📖 Event Description
                        </h5>

                        <p class="text-muted" style="line-height:1.8;">

                            @(string.IsNullOrWhiteSpace(Model.Description)
                                                        ? "No description available for this event."
                                                        : Model.Description)

                        </p>

                    </div>

                    <!-- ACTION BUTTONS -->
                    <div class="d-flex gap-2 flex-wrap">

                        <a asp-action="Edit"
                           asp-route-id="@Model.Id"
                           class="btn btn-warning px-4">

                            ✏ Edit Event

                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@Model.Id"
                           class="btn btn-danger px-4">

                            🗑 Delete Event

                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>