@model LibraryManagementSystem.ClassLibrary.Models.Event

@{
    ViewData["Title"] = "Create Event";
}

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>

    body {
        background: #f4f7fb;
        font-family: 'Poppins', sans-serif;
    }

    .event-card {
        border: none;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 15px 40px rgba(15,23,42,0.08);
    }

    .event-header {
        background: linear-gradient(135deg,#7c3aed,#9333ea);
        padding: 24px 30px;
        color: white;
    }

        .event-header h3 {
            margin: 0;
            font-weight: 700;
        }

    .event-body {
        padding: 35px;
        background: white;
    }

    .form-label {
        font-weight: 600;
        color: #0f172a;
        margin-bottom: 8px;
    }

    .form-control {
        border-radius: 14px;
        padding: 12px 16px;
        border: 1px solid #dbe2ea;
        min-height: 52px;
    }

        .form-control:focus {
            border-color: #7c3aed;
            box-shadow: 0 0 0 0.15rem rgba(124,58,237,.15);
        }

    textarea.form-control {
        min-height: 140px;
    }

    .btn-custom {
        border-radius: 14px;
        padding: 12px 22px;
        font-weight: 600;
    }

    .preview-image {
        width: 100%;
        max-height: 260px;
        object-fit: cover;
        border-radius: 18px;
        border: 1px solid #e5e7eb;
        margin-top: 15px;
    }

</style>

<div class="container py-4">

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="card event-card">

                <!-- HEADER -->
                <div class="event-header">

                    <h3>
                        🎉 Create New Event
                    </h3>

                </div>

                <!-- BODY -->
                <div class="event-body">

                    <form asp-action="Create" method="post">

                        <!-- VALIDATION -->
                        <div asp-validation-summary="All"
                             class="alert alert-danger">
                        </div>

                        <!-- TITLE -->
                        <div class="mb-4">

                            <label asp-for="Title"
                                   class="form-label">
                            </label>

                            <input asp-for="Title"
                                   class="form-control"
                                   placeholder="Enter event title" />

                            <span asp-validation-for="Title"
                                  class="text-danger">
                            </span>

                        </div>

                        <!-- DESCRIPTION -->
                        <div class="mb-4">

                            <label asp-for="Description"
                                   class="form-label">
                            </label>

                            <textarea asp-for="Description"
                                      class="form-control"
                                      placeholder="Write event details..."></textarea>

                            <span asp-validation-for="Description"
                                  class="text-danger">
                            </span>

                        </div>

                        <!-- DATE -->
                        <div class="mb-4">

                            <label asp-for="Date"
                                   class="form-label">
                            </label>

                            <input asp-for="Date"
                                   type="datetime-local"
                                   class="form-control" />

                            <span asp-validation-for="Date"
                                  class="text-danger">
                            </span>

                        </div>

                        <!-- LOCATION -->
                        <div class="mb-4">

                            <label asp-for="Location"
                                   class="form-label">
                            </label>

                            <input asp-for="Location"
                                   class="form-control"
                                   placeholder="Enter location" />

                            <span asp-validation-for="Location"
                                  class="text-danger">
                            </span>

                        </div>

                        <!-- IMAGE -->
                        <div class="mb-4">

                            <label asp-for="ImagePath"
                                   class="form-label">
                            </label>

                            <input asp-for="ImagePath"
                                   id="imageInput"
                                   class="form-control"
                                   placeholder="Paste image URL" />

                            <span asp-validation-for="ImagePath"
                                  class="text-danger">
                            </span>

                            <img id="previewImage"
                                 src="/images/no-event.svg"
                                 class="preview-image" />

                        </div>

                        <!-- BUTTONS -->
                        <div class="d-flex justify-content-between mt-4">

                            <a asp-action="Index"
                               class="btn btn-secondary btn-custom">

                                ← Back

                            </a>

                            <button type="submit"
                                    class="btn btn-primary btn-custom">

                                💾 Save Event

                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>

        const imageInput = document.getElementById("imageInput");
        const previewImage = document.getElementById("previewImage");

        imageInput.addEventListener("input", function () {

            if (this.value.trim() !== "") {

                previewImage.src = this.value;

            } else {

                previewImage.src = "/images/no-event.svg";

            }

        });

    </script>

}