@model LibraryManagementSystem.ClassLibrary.Models.Membership

@{
    ViewData["Title"] = "Membership Details";
    var payments = ViewBag.Payments as IEnumerable<LibraryManagementSystem.ClassLibrary.Models.MembershipPayment>
                   ?? Enumerable.Empty<LibraryManagementSystem.ClassLibrary.Models.MembershipPayment>();
}

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="m-0">🎫 Membership #@Model.Id</h2>
        <div>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning me-1">
                <i class="bi bi-pencil-square"></i> Edit
            </a>
            <a asp-action="Index" class="btn btn-secondary">← Back</a>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Member</dt>
                <dd class="col-sm-9">@(Model.Member?.Name ?? "—")</dd>

                <dt class="col-sm-3">Type</dt>
                <dd class="col-sm-9">@Model.MembershipType</dd>

                <dt class="col-sm-3">Duration</dt>
                <dd class="col-sm-9">@Model.DurationMonths months</dd>

                <dt class="col-sm-3">Start</dt>
                <dd class="col-sm-9">@Model.StartDate.ToString("dd MMM yyyy")</dd>

                <dt class="col-sm-3">End</dt>
                <dd class="col-sm-9">@Model.EndDate.ToString("dd MMM yyyy")</dd>

                <dt class="col-sm-3">Fee</dt>
                <dd class="col-sm-9">₹@Model.Fee.ToString("0.00")</dd>

                <dt class="col-sm-3">Active</dt>
                <dd class="col-sm-9">
                    @if (Model.IsActive)
                    {
                        <span class="badge bg-success">Active</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Inactive</span>
                    }
                </dd>
            </dl>
        </div>
    </div>

    <h4>Payment History</h4>
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table mb-0 align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Date</th>
                        <th>Amount</th>
                        <th>Method</th>
                        <th>Status</th>
                        <th>Transaction</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!payments.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted p-3">
                                No payments recorded.
                            </td>
                        </tr>
                    }
                    @foreach (var p in payments)
                    {
                        <tr>
                            <td>@p.PaymentDate.ToString("dd MMM yyyy HH:mm")</td>
                            <td>₹@p.Amount.ToString("0.00")</td>
                            <td>@p.PaymentMethod</td>
                            <td>@p.PaymentStatus</td>
                            <td class="small text-muted">@p.TransactionId</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
