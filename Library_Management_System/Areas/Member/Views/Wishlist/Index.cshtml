@model IEnumerable<LibraryManagementSystem.ClassLibrary.Models.Wishlist>

@{
    Layout = "~/Areas/Member/Views/Shared/_MemberLayout.cshtml";
    ViewData["Title"] = "My Wishlist";
    var hasItems = Model != null && Model.Any();
}
<style>
    body {
        background: radial-gradient(circle at top right, rgba(168,85,247,.15), transparent 30%), radial-gradient(circle at bottom left, rgba(236,72,153,.10), transparent 30%), linear-gradient(135deg,#070b1a,#0f172a);
        font-family: 'Inter', sans-serif;
        color: white;
    }

    /* PAGE */
    .wishlist-page {
        min-height: 100vh;
        padding: 30px;
    }

    /* EMPTY */
    .empty-box {
        text-align: center;
        padding: 80px 20px;
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.08);
        border-radius: 28px;
        backdrop-filter: blur(16px);
    }

        .empty-box h3 {
            font-size: 28px;
            margin-bottom: 10px;
        }

        .empty-box p {
            color: #9ca3af;
        }

    /* GRID */
    .wishlist-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 22px;
    }

    /* CARD */
    .wishlist-card {
        position: relative;
        border-radius: 28px;
        overflow: hidden;
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.08);
        backdrop-filter: blur(16px);
        box-shadow: 0 10px 35px rgba(0,0,0,.25);
        transition: .4s ease;
    }

        .wishlist-card:hover {
            transform: translateY(-10px);
            border-color: rgba(168,85,247,.30);
            box-shadow: 0 25px 55px rgba(139,92,246,.18);
        }

        /* IMAGE */
        .wishlist-card img {
            width: 100%;
            height: 280px;
            object-fit: cover;
            transition: .6s ease;
        }

        .wishlist-card:hover img {
            transform: scale(1.08);
        }

        /* DARK OVERLAY */
        .wishlist-card::after {
            content: "";
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 60%;
            background: linear-gradient(to top, rgba(0,0,0,.92), transparent);
        }

    /* TEXT */
    .wishlist-info {
        position: absolute;
        bottom: 14px;
        left: 16px;
        right: 16px;
        z-index: 2;
    }

    .wishlist-title {
        font-size: 18px;
        font-weight: 800;
    }

    .wishlist-author {
        font-size: 14px;
        color: #ddd6fe;
    }

    /* BUTTON */
    .wishlist-btn {
        position: absolute;
        top: 14px;
        right: 14px;
        width: 48px;
        height: 48px;
        border-radius: 50%;
        border: 1px solid rgba(255,255,255,.08);
        background: rgba(15,23,42,.85);
        color: #fb7185;
        font-size: 20px;
        cursor: pointer;
        z-index: 5;
        backdrop-filter: blur(12px);
        transition: .3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .wishlist-btn:hover {
            transform: scale(1.15);
            background: linear-gradient(135deg,#e11d48,#fb7185);
            color: white;
        }
</style>
<link rel="stylesheet" href="~/css/wishlist.css" />

<section class="wishlist-page container">

    <!-- EMPTY STATE -->
    @if (!hasItems)
    {
        <div class="empty-box">
            <h3>💔 Wishlist Empty</h3>
            <p>Add books you love to see them here</p>
        </div>
    }

    else
    {
        <div class="wishlist-grid">

            @foreach (var item in Model)
            {
                <div class="wishlist-card" id="card-@item.Book.Id">

                    <!-- REMOVE BUTTON -->
                    <button class="wishlist-btn"
                            onclick="toggleWishlist(@item.Book.Id)">
                        ❤️
                    </button>

                    <!-- IMAGE -->
                    <a asp-controller="Catalog"
                       asp-action="Details"
                       asp-route-id="@item.Book.Id">

                        <img src="@(string.IsNullOrEmpty(item.Book.CoverImageUrl)
                                                                 ? "/images/no-book.png"
                                                                 : item.Book.CoverImageUrl)" />
                    </a>

                    <!-- TEXT OVERLAY -->
                    <div class="wishlist-info">
                        <div class="wishlist-title">
                            @item.Book.Title
                        </div>

                        <div class="wishlist-author">
                            @item.Book.Author?.Name
                        </div>
                    </div>

                </div>
            }

        </div>
    }

</section>

<!-- AJAX SCRIPT -->
<form>
    <script>
        function toggleWishlist(bookId) {

            fetch('/Member/Wishlist/Toggle?bookId=' + bookId, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                }
            })
            .then(r => {
                if (r.ok) {
                    document.getElementById('card-' + bookId)?.remove();
                }
            });
        }
    </script>
</form>
