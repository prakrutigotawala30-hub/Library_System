@model IEnumerable<LibraryManagementSystem.ClassLibrary.Models.Wishlist>

@{
    Layout = "~/Areas/Member/Views/Shared/_MemberLayout.cshtml";
    ViewData["Title"] = "My Wishlist";
}

<style>
    body {
        background: #070b1a;
        color: #fff;
        font-family: 'Inter', sans-serif;
    }

    .wishlist-page {
        padding: 40px 0 80px;
        min-height: 100vh;
    }

    .wishlist-title {
        font-size: 2.3rem;
        font-weight: 800;
        margin-bottom: 10px;
    }

    .wishlist-subtitle {
        color: #9ca3af;
        margin-bottom: 40px;
    }

    .wishlist-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
        gap: 28px;
    }

    .book-card {
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 24px;
        overflow: hidden;
        transition: 0.3s;
    }

        .book-card:hover {
            transform: translateY(-6px);
            border-color: #7c3aed;
        }

    .book-image {
        height: 320px;
        background: #111827;
    }

        .book-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .book-content {
        padding: 18px;
    }

    .book-title {
        font-size: 1.1rem;
        font-weight: 700;
    }

    .book-author {
        color: #9ca3af;
        margin-bottom: 15px;
    }

    .book-actions {
        display: flex;
        gap: 10px;
    }

    .details-btn {
        flex: 1;
        text-align: center;
        background: linear-gradient(135deg,#7c3aed,#2563eb);
        padding: 10px;
        border-radius: 10px;
        text-decoration: none;
        color: white;
        font-weight: 600;
    }

    .remove-btn {
        border: none;
        background: rgba(239,68,68,0.2);
        color: #ef4444;
        padding: 10px 12px;
        border-radius: 10px;
        font-weight: 600;
    }

        .remove-btn:hover {
            background: #ef4444;
            color: white;
        }

    .empty-box {
        text-align: center;
        padding: 100px 20px;
        border: 1px dashed rgba(255,255,255,0.2);
        border-radius: 20px;
    }

    .browse-btn {
        display: inline-block;
        margin-top: 20px;
        padding: 12px 20px;
        background: linear-gradient(135deg,#7c3aed,#2563eb);
        color: white;
        border-radius: 12px;
        text-decoration: none;
    }
</style>

<section class="wishlist-page">
    <div class="container">

        <h1 class="wishlist-title">My Wishlist</h1>
        <p class="wishlist-subtitle">Your saved books collection</p>

        @if (Model != null && Model.Any())
        {
            <div class="wishlist-grid">

                @foreach (var item in Model)
                {
                    <div class="book-card">

                        <div class="book-image">
                            <img src="@(item.Book?.CoverImageUrl ?? "/images/no-book.png")"
                                 alt="@item.Book?.Title" />
                        </div>

                        <div class="book-content">

                            <h3 class="book-title">
                                @item.Book?.Title
                            </h3>

                            <div class="book-author">
                                by @item.Book?.Author
                            </div>

                            <div class="book-actions">

                                <a asp-controller="Catalog"
                                   asp-action="Details"
                                   asp-route-id="@item.BookId"
                                   class="details-btn">
                                    View Details
                                </a>

                                <form asp-controller="Wishlist"
                                      asp-action="Remove"
                                      method="post">

                                    <input type="hidden" name="bookId" value="@item.BookId" />

                                    <button type="submit" class="remove-btn">
                                        Remove
                                    </button>

                                </form>

                            </div>

                        </div>

                    </div>
                }

            </div>
        }
        else
        {
            <div class="empty-box">

                <h2>No Books Saved</h2>
                <p>Your wishlist is empty right now.</p>

                <a asp-area=""
                  asp-controller="Catalog"
                   asp-action="Index"
                   class="browse-btn">
                    Browse Books
                </a>

            </div>
        }

    </div>

</section>


