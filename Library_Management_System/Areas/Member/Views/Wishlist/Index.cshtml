@model IEnumerable<Library_Management_System.ViewModels.WishlistViewModel>
<style>
    .wishlist-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill,minmax(220px,1fr));
        gap: 25px;
    }

    .wishlist-card {
        background: white;
        border-radius: 18px;
        padding: 15px;
        box-shadow: 0 6px 20px rgba(0,0,0,0.08);
        transition: 0.3s;
    }

        .wishlist-card:hover {
            transform: translateY(-6px);
        }

        .wishlist-card img {
            width: 100%;
            height: 260px;
            object-fit: cover;
            border-radius: 12px;
        }

    .view-btn {
        display: inline-block;
        margin-top: 12px;
        padding: 10px 18px;
        background: #5e35b1;
        color: white;
        border-radius: 10px;
        text-decoration: none;
    }
</style>
<div class="wishlist-page">

    <h2>My Wishlist</h2>

    <div class="wishlist-grid">

        @foreach (var item in Model)
        {
            <div class="wishlist-card">

                <img src="@item.ImageUrl" />

                <h4>@item.Title</h4>

                <p>@item.Author</p>

                <a asp-controller="Book"
                   asp-action="Details"
                   asp-route-id="@item.BookId"
                   class="view-btn">

                    View Details

                </a>

            </div>
        }

    </div>

</div>
