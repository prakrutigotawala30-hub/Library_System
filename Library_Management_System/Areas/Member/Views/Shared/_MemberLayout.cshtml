@using Microsoft.AspNetCore.Identity
@inject UserManager<LibraryManagementSystem.ClassLibrary.Models.ApplicationUser> UserManager

@{
    var currentUser = await UserManager.GetUserAsync(User);

    string profileImage = "/images/default-user.svg";

    if (currentUser != null &&
        !string.IsNullOrEmpty(currentUser.ProfileImagePath))
    {

        profileImage = currentUser.ProfileImagePath;
    }

    string userName = "Member";

    if (currentUser != null &&
        !string.IsNullOrEmpty(currentUser.FullName))
    {
        userName = currentUser.FullName;
    }
}

<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Library System</title>

    <!-- Bootstrap -->

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

    <!-- Bootstrap Icons -->

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <!-- Font Awesome -->

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

    <!-- Google Font -->

    <link rel="preconnect"
          href="https://fonts.googleapis.com">

    <link rel="preconnect"
          href="https://fonts.gstatic.com"
          crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
          rel="stylesheet">

    <style>

        body {
            background: #050816;
            color: white;
            overflow-x: hidden;
            font-family: 'Inter', sans-serif;
        }

        a {
            text-decoration: none;
        }

        /* =========================================
                           LAYOUT
                        ========================================= */

        .layout-wrapper {
            display: flex;
            min-height: 100vh;
        }
        /* =========================================
               SIDEBAR
            ========================================= */

        .sidebar {
            width: 245px;
            position: fixed;
            top: 0;
            left: 0;
            height: 100vh;
            background: var(--sidebar-bg);
            padding: 24px 18px;
            z-index: 9999;
            border-right: 1px solid var(--border);
            overflow-y: auto;
            transition: .35s;
            scrollbar-width: none;
            -ms-overflow-style: none;
        }

            .sidebar::-webkit-scrollbar {
                display: none;
            }


            .sidebar hr {
                border-color: rgba(255,255,255,.08);
                margin: 22px 0;
            }

        ::-webkit-scrollbar-thumb {
            background: #7c3aed;
            border-radius: 20px;
        }

        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }

        /* =========================================
               SCROLLBAR
            ========================================= */

        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }

        ::-webkit-scrollbar-thumb {
            background: #7c3aed;
            border-radius: 20px;
        }

        /* =========================================
                           LOGO
                        ========================================= */

        .brand-logo {
            display: flex;
            align-items: center;
            gap: 14px;
            margin-bottom: 30px;
            padding: 10px 6px;
        }

        .brand-icon {
            width: 52px;
            height: 52px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #d946ef;
            font-size: 54px;
            font-weight: 900;
            box-shadow: none;
            background: none;
        }

        .brand-text h2 {
            margin: 0;
            color: var(--text);
            font-size: 28px;
            font-weight: 900;
            letter-spacing: 1px;
        }

        .brand-text span {
            color: #d946ef;
        }

        .brand-text p {
            margin: 0;
            color: var(--text-muted);
            font-size: 8px;
            letter-spacing: 2px;
            margin-top: 2px;
        }

        /* =========================================
               MENU HEADING
            ========================================= */

        .menu-heading {
            color: var(--text-muted);
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 2px;
            margin: 28px 14px 14px;
        }

        /* =========================================
               MENU LIST
            ========================================= */

        .menu-list {
            margin-bottom: 10px;
        }

        /* =========================================
               MENU ITEM
            ========================================= */

        .menu-item {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 15px 18px;
            margin-bottom: 10px;
            border-radius: 18px;
            color: var(--text-light);
            transition: .3s;
            position: relative;
            overflow: hidden;
        }

            .menu-item i {
                font-size: 18px;
                min-width: 22px;
            }

            .menu-item span {
                font-size: 15px;
                font-weight: 600;
            }

            /* HOVER */

            .menu-item:hover {
                background: var(--hover);
                color: var(--text);
                transform: translateX(4px);
            }

            /* ACTIVE */

            .menu-item.active {
                background: linear-gradient(135deg,#7c3aed,#9333ea);
                color: white;
                box-shadow: 0 10px 30px rgba(124,58,237,.35);
            }

        /* =========================================
               HORIZONTAL LINE
            ========================================= */

        .sidebar hr {
            border-color: var(--border);
            margin: 22px 0;
        }

        /* =========================================
                           LOGOUT
                        ========================================= */

        .logout-link {
            display: flex;
            align-items: center;
            gap: 12px;
            background: rgba(239,68,68,.12);
            color: #f87171;
            padding: 15px 16px;
            border-radius: 18px;
            transition: .3s;
            font-weight: 600;
        }

            .logout-link:hover {
                background: rgba(239,68,68,.2);
                color: white;
            }

        /* =========================================
                           MAIN CONTENT
                        ========================================= */

        .main-content {
            margin-left: 270px;
            width: calc(100% - 270px);
            min-height: 100vh;
            padding: 0 24px 24px 24px;
        }
        /* =========================
                           NAVBAR
                        ==========================*/

        .modern-navbar {
            position: sticky;
            top: 0;
            z-index: 99999;
            background: rgba(5,8,22,.96);
            backdrop-filter: blur(18px);
            border-bottom: 1px solid rgba(255,255,255,.08);
            padding: 12px 0;
        }
        /* =========================
                           SEARCH
                        ==========================*/

        .search-box {
            position: relative;
            width: 430px;
        }

        .search-input {
            width: 100%;
            height: 58px;
            border-radius: 18px;
            border: 1px solid rgba(255,255,255,.08);
            background: rgba(255,255,255,.05);
            color: white;
            padding: 0 55px 0 22px;
            outline: none;
            transition: .3s;
            font-size: 15px;
        }

            .search-input:focus {
                border-color: #9333ea;
                background: rgba(255,255,255,.08);
            }

            .search-input::placeholder {
                color: #9ca3af;
            }

        .search-icon {
            position: absolute;
            top: 50%;
            right: 18px;
            transform: translateY(-50%);
            color: #9ca3af;
            font-size: 18px;
            pointer-events: none;
        }

        /* =========================
                           PROFILE
                        ==========================*/

        .dropdown {
            position: relative;
        }

        .profile-trigger {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 8px 16px;
            border-radius: 50px;
            background: rgba(255,255,255,.05);
            border: 1px solid rgba(255,255,255,.08);
            transition: .3s;
            color: white;
        }

            .profile-trigger:hover {
                background: rgba(255,255,255,.08);
                color: white;
            }

        .profile-avatar {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid rgba(255,255,255,.15);
        }

        .profile-user {
            color: white;
            font-size: 14px;
            font-weight: 700;
        }

        .default-avatar {
            background: white;
            color: black;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
        }

        /* =========================
                           DROPDOWN
                        ==========================*/

        .dropdown-menu {
            background: rgba(10,14,28,.98);
            border: 1px solid rgba(255,255,255,.08);
            border-radius: 20px;
            padding: 12px;
            min-width: 240px;
            margin-top: 18px;
        }

        .dropdown-item {
            color: white;
            padding: 13px 16px;
            border-radius: 14px;
            font-weight: 600;
            transition: .3s;
        }

            .dropdown-item:hover {
                background: rgba(255,255,255,.08);
                color: white;
            }

        .dropdown-divider {
            border-color: rgba(255,255,255,.08);
        }

        /* =========================
                           TOGGLER
                        ==========================*/

        .navbar-toggler {
            border: 1px solid rgba(255,255,255,.12);
            border-radius: 14px;
            padding: 10px 14px;
        }

            .navbar-toggler:focus {
                box-shadow: none;
            }


        /* =========================================
                           TABLET
                        ========================================= */
        @@media(max-width:992px) {

            .navbar-collapse {
                margin-top: 20px;
                padding: 20px;
                border-radius: 24px;
                background: rgba(10,14,28,.98);
                border: 1px solid rgba(255,255,255,.08);
            }

            .search-box {
                width: 100%;
            }

            .profile-trigger {
                width: 100%;
                justify-content: center;
            }

            .navbar-right {
                flex-direction: column;
                width: 100%;
            }
            
            .main-content {
                margin-left: 0;
                width: 100%;
                padding: 85px 18px 25px;
            }

            .sidebar {
                width: 85px;
                padding: 20px 12px;
            }

            .page-content {
                margin-left: 85px;
                width: calc(100% - 85px);
            }

            .brand-text,
            .menu-heading,
            .menu-item span {
                display: none;
            }

            .brand-logo {
                justify-content: center;
            }

            .menu-item {
                justify-content: center;
                padding: 16px;
            }
        }


        /* =========================================
                           MOBILE
                        ========================================= */

        @@media(max-width:576px) {

            .main-content {
                padding: 82px 12px 20px;
            }

            .sidebar {
                position: fixed;
                left: -100%;
                transition: .4s;
            }

                .sidebar.active {
                    left: 0;
                }
        }
        @@media(max - width:768px) {

            .sidebar {
                position: fixed;
                left: -100%;
                transition: .4s;
            }

                .sidebar.active {
                    left: 0;
                }
        }
    </style>

</head>

<body>

    <!-- MOBILE BUTTON -->

    @* <button class="mobile-toggle"
            id="mobileToggle">

        <i class="fa-solid fa-bars"></i>

    </button> *@

    <!-- OVERLAY -->

    <div class="sidebar-overlay"
         id="sidebarOverlay"></div>

    <div class="layout-wrapper">

        <!-- SIDEBAR -->

        <aside class="sidebar"
               id="sidebar">

            <!-- LOGO -->

            <a class="brand-logo"
               asp-controller="Home"
               asp-action="Index">

                <div class="brand-icon">
                    ∞
                </div>

                <div class="brand-text">

                    <h2>
                        BOOK<span>VERSE</span>
                    </h2>

                    <p>
                        LIBRARY MANAGEMENT SYSTEM
                    </p>

                </div>

            </a>

            <!-- MENU -->
            <a class="menu-item"
               asp-area=""
               asp-controller="Home"
               asp-action="Index">

                <i class="bi bi-house-fill"></i>
                <span>Home</span>

            </a>

            <div class="menu-heading">
                MEMBER PANEL
            </div>

            <a class="menu-item active"
               asp-area="Member"
               asp-controller="Dashboard"
               asp-action="Index">

                <i class="bi bi-grid-fill"></i>
                <span>My Dashboard</span>

            </a>

            <a class="menu-item"
               asp-area="Member"
               asp-controller="BorrowHistory"
               asp-action="Index"
               asp-route-status="active">

                <i class="bi bi-book"></i>
                <span>My Books</span>

            </a>

            <a class="menu-item"
               asp-area="Member"
               asp-controller="BorrowHistory"
               asp-action="Index">

                <i class="bi bi-clock-history"></i>
                <span>Borrow History</span>

            </a>

            <a class="menu-item"
               asp-area="Member"
               asp-controller="Wishlist"
               asp-action="Index">

                <i class="bi bi-heart-fill"></i>
                <span>Wishlist</span>

            </a>

            <a class="menu-item"
               asp-area="Member"
               asp-controller="Reservation"
               asp-action="Index">

                <i class="bi bi-calendar-event"></i>
                <span>Reservations</span>

            </a>

            <a class="menu-item"
               asp-area="Member"
               asp-controller="Profile"
               asp-action="Index">

                <i class="bi bi-person-circle"></i>
                <span>Profile</span>

            </a>

            <a class="menu-item"
               asp-area="Member"
               asp-controller="Profile"
               asp-action="ChangePassword">

                <i class="bi bi-shield-lock"></i>
                <span>Change Password</span>

            </a>

            <hr />

            <!-- LOGOUT -->

            <a asp-area=""
               asp-controller="Account"
               asp-action="Logout"
               class="logout-link">

                <i class="bi bi-box-arrow-right"></i>

                Logout

            </a>

        </aside>

        <!-- MAIN CONTENT -->

        <main class="main-content">

            <!-- NAVBAR -->

            <nav class="navbar navbar-expand-lg navbar-dark modern-navbar">

                <div class="container-fluid px-4">



                    <!-- NAVBAR -->

                    <div class="collapse navbar-collapse"
                         id="mainNavbar">

                        <!-- SEARCH LEFT -->

                        <div class="search-box">

                            <input type="text"
                                   class="search-input"
                                   placeholder="Search books, authors..." />

                            <span class="search-icon">
                                🔍
                            </span>

                        </div>

                        <!-- RIGHT SIDE -->

                        <div class="ms-auto d-flex align-items-center gap-4 navbar-right">

                            <!-- USER -->
                            @if (User.Identity != null &&
                                                        User.Identity.IsAuthenticated)
                            {
                                <div class="dropdown">

                                    <a href="javascript:void(0)"
                                       class="profile-trigger dropdown-toggle"
                                       data-bs-toggle="dropdown">

                                        @if (!string.IsNullOrEmpty(currentUser?.ProfileImagePath))
                                        {
                                            <img src="@currentUser.ProfileImagePath"
                                                 class="profile-avatar" />
                                        }
                                        else
                                        {
                                            <div class="profile-avatar default-avatar">

                                                @(string.IsNullOrEmpty(currentUser?.FullName)
                                                                                        ? "U"
                                                                                        : currentUser.FullName.Substring(0, 1).ToUpper())

                                            </div>
                                        }

                                        <span class="profile-user">

                                            @currentUser?.FullName

                                        </span>

                                    </a>

                                    <ul class="dropdown-menu dropdown-menu-end">

                                        <li>

                                            <a class="dropdown-item"
                                               asp-area="Member"
                                               asp-controller="Dashboard"
                                               asp-action="Index">

                                                📊 Dashboard

                                            </a>

                                        </li>

                                        <li>

                                            <a class="dropdown-item"
                                               asp-area="Member"
                                               asp-controller="Profile"
                                               asp-action="Index">

                                                👤 My Profile

                                            </a>

                                        </li>

                                        <li>

                                            <a class="dropdown-item"
                                            asp-area=""
                                               asp-controller="Account"
                                               asp-action="Logout">

                                                🚪 Logout

                                            </a>

                                        </li>

                                    </ul>

                                </div>
                            }

                        </div>

                    </div>

                </div>

            </nav>

            <!-- PAGE CONTENT -->
            @{
                var flashKey = (TempData["Success"] ?? TempData["success"]) != null ? "success"
                              : (TempData["Error"] ?? TempData["error"]) != null ? "danger"
                              : null;
                var flashText = TempData["Success"] ?? TempData["success"]
                              ?? TempData["Error"] ?? TempData["error"];
            }
            @if (flashKey != null)
            {
                <div class="alert alert-@flashKey alert-dismissible fade show m-3" role="alert">
                    @flashText
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @RenderBody()

        </main>

    </div>

    <!-- BOOTSTRAP -->

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- SIDEBAR SCRIPT -->

    <script>

        const toggleBtn =
            document.getElementById("mobileToggle");

        const sidebar =
            document.getElementById("sidebar");

        const overlay =
            document.getElementById("sidebarOverlay");

        toggleBtn.addEventListener("click", () => {

            sidebar.classList.toggle("show");
            overlay.classList.toggle("show");

        });

        overlay.addEventListener("click", () => {

            sidebar.classList.remove("show");
            overlay.classList.remove("show");

        });

    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>
