<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Library System</title>

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

    <style>

        body {
            margin: 0;
            background: #070b1a;
            color: white;
            font-family: 'Segoe UI', sans-serif;
        }

        .layout-wrapper {
            display: flex;
            min-height: 100vh;
        }

        /* SIDEBAR */

        .sidebar {
            width: 260px;
            background: #0b1120;
            border-right: 1px solid rgba(255,255,255,0.05);
            padding: 20px;
            position: fixed;
            height: 100vh;
        }

        .logo {
            font-size: 24px;
            font-weight: bold;
            margin-bottom: 35px;
            color: #8b5cf6;
        }

        .menu-title {
            color: #6b7280;
            font-size: 12px;
            margin-top: 20px;
            margin-bottom: 10px;
            text-transform: uppercase;
        }

        .nav-link-custom {
            display: flex;
            align-items: center;
            gap: 12px;
            color: #d1d5db;
            text-decoration: none;
            padding: 12px 15px;
            border-radius: 12px;
            margin-bottom: 10px;
            transition: 0.3s;
        }

            .nav-link-custom:hover,
            .nav-link-custom.active {
                background: linear-gradient(90deg,#7c3aed,#9333ea);
                color: white;
            }

        /* MAIN CONTENT */

        .main-content {
            margin-left: 260px;
            width: calc(100% - 260px);
            padding: 25px;
        }

        /* TOPBAR */

        .topbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }

        .search-box {
            width: 400px;
            background: #111827;
            border: none;
            color: white;
            padding: 12px 18px;
            border-radius: 12px;
        }

        .profile-box {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .profile-avatar {
            width: 45px;
            height: 45px;
            border-radius: 50%;
            background: #7c3aed;
            display: flex;
            justify-content: center;
            align-items: center;
            font-weight: bold;
        }

    </style>

</head>

<body>

    <div class="layout-wrapper">

        <!-- SIDEBAR -->

        <div class="sidebar">

            <div class="logo">
                📚 BookVerse
            </div>

            <div class="menu-title">Menu</div>

            <a asp-area="Member"
               asp-controller="Dashboard"
               asp-action="Index"
               class="nav-link-custom active">

                <i class="fa fa-home"></i>
                Dashboard

            </a>

            <a href="#" class="nav-link-custom">
                <i class="fa fa-book"></i>
                My Borrowed Books
            </a>

            <a href="#" class="nav-link-custom">
                <i class="fa fa-clock-rotate-left"></i>
                Borrow History
            </a>

            <a href="#" class="nav-link-custom">
                <i class="fa fa-heart"></i>
                Wishlist
            </a>

            <a href="#" class="nav-link-custom">
                <i class="fa fa-bookmark"></i>
                Reservations
            </a>

            <a href="#" class="nav-link-custom">
                <i class="fa fa-user"></i>
                Profile
            </a>

            <a href="#" class="nav-link-custom">
                <i class="fa fa-lock"></i>
                Change Password
            </a>

            <a href="#" class="nav-link-custom">
                <i class="fa fa-right-from-bracket"></i>
                Logout
            </a>

        </div>

        <!-- MAIN -->

        <div class="main-content">

            <!-- TOPBAR -->

            <div class="topbar">

                <input type="text"
                       placeholder="Search books, authors..."
                       class="search-box" />

                <div class="profile-box">

                    <div class="profile-avatar">
                        @User.Identity?.Name?.Substring(0, 1)
                    </div>

                    <div>
                        @User.Identity?.Name
                    </div>

                </div>

            </div>

            @RenderBody()

        </div>

    </div>

</body>

</html>