@using Microsoft.AspNetCore.Identity
@inject UserManager<LibraryManagementSystem.ClassLibrary.Models.ApplicationUser> UserManager

@{
    var currentUser = await UserManager.GetUserAsync(User);

    string profileImage = "/images/default-user.png";

    if (currentUser != null &&
        !string.IsNullOrEmpty(currentUser.ProfileImagePath))
    {
        profileImage = currentUser.ProfileImagePath;
    }

    string userName = "Member";

    if (currentUser != null &&
        !string.IsNullOrEmpty(currentUser.FullName))
    {
        userName = currentUser.FullName;
    }
}

<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Library System</title>

    <!-- Bootstrap -->

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

    <!-- Bootstrap Icons -->

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <!-- Font Awesome -->

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

    <!-- Google Font -->

    <link rel="preconnect"
          href="https://fonts.googleapis.com">

    <link rel="preconnect"
          href="https://fonts.gstatic.com"
          crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
          rel="stylesheet">

    <style>

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            background: #050816;
            color: white;
            overflow-x: hidden;
            font-family: 'Inter', sans-serif;
        }

        a {
            text-decoration: none;
        }

        /* =========================================
                   LAYOUT
                ========================================= */

        .layout-wrapper {
            display: flex;
            min-height: 100vh;
        }

        /* =========================================
                   SIDEBAR
                ========================================= */

        .sidebar {
            width: 270px;
            position: fixed;
            top: 0;
            left: 0;
            height: 100vh;
            background: linear-gradient(180deg,#0f172a 0%, #111827 100%);
            border-right: 1px solid rgba(255,255,255,.06);
            padding: 24px 18px;
            overflow-y: auto;
            z-index: 2000;
            transition: .35s ease;
            scrollbar-width: none;
        }

            .sidebar::-webkit-scrollbar {
                display: none;
            }

        /* =========================================
                   LOGO
                ========================================= */

        .brand-logo {
            display: flex;
            align-items: center;
            gap: 14px;
            margin-bottom: 32px;
        }

        .brand-icon {
            width: 58px;
            height: 58px;
            border-radius: 18px;
            background: linear-gradient(135deg,#7c3aed,#d946ef);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
            color: white;
            font-weight: 800;
            box-shadow: 0 10px 30px rgba(124,58,237,.35);
        }

        .brand-text h2 {
            font-size: 25px;
            font-weight: 900;
            margin: 0;
            color: white;
            letter-spacing: 1px;
        }

        .brand-text span {
            color: #d946ef;
        }

        .brand-text p {
            margin: 0;
            font-size: 10px;
            letter-spacing: 2px;
            color: #9ca3af;
        }

        /* =========================================
                   MENU
                ========================================= */

        .menu-heading {
            color: #6b7280;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 2px;
            margin-bottom: 14px;
        }

        .menu-item {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 15px 16px;
            margin-bottom: 10px;
            border-radius: 18px;
            color: #d1d5db;
            transition: .3s ease;
            font-weight: 500;
        }

            .menu-item:hover {
                background: rgba(124,58,237,.16);
                color: white;
                transform: translateX(3px);
            }

            .menu-item.active {
                background: linear-gradient(135deg,#7c3aed,#9333ea);
                color: white;
                box-shadow: 0 10px 25px rgba(124,58,237,.25);
            }

            .menu-item i {
                font-size: 18px;
                width: 20px;
                text-align: center;
            }

        .sidebar hr {
            border-color: rgba(255,255,255,.08);
            margin: 22px 0;
        }

        /* =========================================
                   LOGOUT
                ========================================= */

        .logout-link {
            display: flex;
            align-items: center;
            gap: 12px;
            background: rgba(239,68,68,.12);
            color: #f87171;
            padding: 15px 16px;
            border-radius: 18px;
            transition: .3s;
            font-weight: 600;
        }

            .logout-link:hover {
                background: rgba(239,68,68,.2);
                color: white;
            }

        /* =========================================
                   MAIN CONTENT
                ========================================= */

        .main-content {
            margin-left: 270px;
            width: calc(100% - 270px);
            min-height: 100vh;
            padding: 24px;
            transition: .35s ease;
        }

        /* =========================================
                   PERFECT NAVBAR
                ========================================= */

        .modern-navbar {
            position: sticky;
            top: 0;
            z-index: 999;
            margin-bottom: 28px;
            padding: 16px 22px;
            border-radius: 28px;
            background: rgba(15,23,42,.82);
            backdrop-filter: blur(18px);
            border: 1px solid rgba(255,255,255,.06);
            box-shadow: 0 10px 40px rgba(0,0,0,.25);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 20px;
        }

        /* =========================================
                   SEARCH BAR
                ========================================= */

        .search-box {
            position: relative;
            width: 450px;
            max-width: 100%;
        }

        .search-input {
            width: 100%;
            height: 60px;
            border: 1px solid rgba(255,255,255,.08);
            background: rgba(255,255,255,.05);
            border-radius: 20px;
            outline: none;
            padding: 0 58px 0 22px;
            color: white;
            font-size: 15px;
            transition: .3s;
        }

            .search-input:focus {
                border-color: #9333ea;
                background: rgba(255,255,255,.08);
                box-shadow: 0 0 0 4px rgba(147,51,234,.15);
            }

            .search-input::placeholder {
                color: #9ca3af;
            }

        .search-icon {
            position: absolute;
            right: 20px;
            top: 50%;
            transform: translateY(-50%);
            color: #9ca3af;
            font-size: 18px;
        }

        /* =========================================
                   PROFILE
                ========================================= */

        .profile-dropdown .dropdown-toggle::after {
            display: none;
        }

        .profile-trigger {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 8px 12px;
            border-radius: 60px;
            background: rgba(255,255,255,.05);
            border: 1px solid rgba(255,255,255,.07);
            transition: .3s;
            min-width: 240px;
        }

            .profile-trigger:hover {
                background: rgba(255,255,255,.08);
            }

        .profile-avatar {
            width: 52px;
            height: 52px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid rgba(255,255,255,.12);
        }

        .default-avatar {
            background: linear-gradient(135deg,#7c3aed,#d946ef);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 800;
            font-size: 20px;
        }

        .profile-info {
            display: flex;
            flex-direction: column;
            line-height: 1.2;
        }

        .profile-name {
            color: white;
            font-size: 15px;
            font-weight: 700;
        }

        .profile-role {
            color: #9ca3af;
            font-size: 12px;
            margin-top: 2px;
        }

        .profile-arrow {
            margin-left: auto;
            color: #9ca3af;
            font-size: 14px;
        }

        /* =========================================
                   DROPDOWN
                ========================================= */

        .dropdown-menu {
            background: rgba(10,14,28,.98);
            border: 1px solid rgba(255,255,255,.08);
            border-radius: 22px;
            padding: 12px;
            min-width: 250px;
            margin-top: 16px;
        }

        .dropdown-item {
            color: white;
            padding: 14px 16px;
            border-radius: 14px;
            transition: .3s;
            font-weight: 600;
        }

            .dropdown-item:hover {
                background: rgba(255,255,255,.08);
                color: white;
            }

        .dropdown-divider {
            border-color: rgba(255,255,255,.08);
        }

        /* =========================================
                   MOBILE BUTTON
                ========================================= */

        .mobile-toggle {
            position: fixed;
            top: 16px;
            left: 16px;
            width: 48px;
            height: 48px;
            border: none;
            border-radius: 14px;
            background: linear-gradient(135deg,#7c3aed,#9333ea);
            color: white;
            font-size: 18px;
            z-index: 3000;
            display: none;
            align-items: center;
            justify-content: center;
            box-shadow: 0 10px 25px rgba(124,58,237,.35);
        }

        /* =========================================
                   OVERLAY
                ========================================= */

        .sidebar-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,.6);
            z-index: 1500;
            opacity: 0;
            visibility: hidden;
            transition: .3s;
        }

            .sidebar-overlay.show {
                opacity: 1;
                visibility: visible;
            }

        /* =========================================
                   TABLET
                ========================================= */

        @@media(max-width:991px) {

            .mobile-toggle {
                display: flex;
            }

            .sidebar {
                left: -270px;
            }

                .sidebar.show {
                    left: 0;
                }

            .main-content {
                margin-left: 0;
                width: 100%;
                padding: 85px 18px 25px;
            }

            .modern-navbar {
                flex-direction: column;
                align-items: stretch;
                padding: 18px;
            }

            .search-box {
                width: 100%;
            }

            .profile-trigger {
                width: 100%;
            }
        }

        /* =========================================
                   MOBILE
                ========================================= */

        @@media(max-width:576px) {

            .sidebar {
                width: 245px;
            }

            .main-content {
                padding: 82px 12px 20px;
            }

            .modern-navbar {
                border-radius: 22px;
            }

            .profile-name {
                font-size: 14px;
            }

            .profile-role {
                font-size: 11px;
            }
        }
    </style>

</head>

<body>

    <!-- MOBILE BUTTON -->

    <button class="mobile-toggle"
            id="mobileToggle">

        <i class="fa-solid fa-bars"></i>

    </button>

    <!-- OVERLAY -->

    <div class="sidebar-overlay"
         id="sidebarOverlay"></div>

    <div class="layout-wrapper">

        <!-- SIDEBAR -->

        <aside class="sidebar"
               id="sidebar">

            <!-- LOGO -->

            <a class="brand-logo"
               asp-area=""
               asp-controller="Home"
               asp-action="Index">

                <div class="brand-icon">
                    <i class="bi bi-book-half"></i>
                </div>

                <div class="brand-text">

                    <h2>
                        BOOK<span>VERSE</span>
                    </h2>

                    <p>
                        LIBRARY MANAGEMENT
                    </p>

                </div>

            </a>

            <!-- MENU -->
            <a class="menu-item"
               asp-area=""
               asp-controller="Home"
               asp-action="Index">

                <i class="bi bi-house-fill"></i>
                <span>Home</span>

            </a>

            <div class="menu-heading">
                MEMBER PANEL
            </div>

            <a class="menu-item active"
               asp-area="Member"
               asp-controller="Dashboard"
               asp-action="Index">

                <i class="bi bi-grid-fill"></i>
                <span>My Dashboard</span>

            </a>

            <a class="menu-item"
               asp-area="Member"
               asp-controller="Borrow"
               asp-action="MyBooks">

                <i class="bi bi-book"></i>
                <span>My Books</span>

            </a>

            <a class="menu-item"
               asp-area="Member"
               asp-controller="Borrow"
               asp-action="History">

                <i class="bi bi-clock-history"></i>
                <span>Borrow History</span>

            </a>

            <a class="menu-item"
               asp-area="Member"
               asp-controller="Wishlist"
               asp-action="Index">

                <i class="bi bi-heart-fill"></i>
                <span>Wishlist</span>

            </a>

            <a class="menu-item"
               asp-area="Member"
               asp-controller="Reservation"
               asp-action="Index">

                <i class="bi bi-calendar-event"></i>
                <span>Reservations</span>

            </a>

            <a class="menu-item"
               asp-area="Member"
               asp-controller="Profile"
               asp-action="Index">

                <i class="bi bi-person-circle"></i>
                <span>Profile</span>

            </a>

            <a class="menu-item"
               asp-area="Member"
               asp-controller="Profile"
               asp-action="ChangePassword">

                <i class="bi bi-shield-lock"></i>
                <span>Change Password</span>

            </a>

            <hr />

            <!-- LOGOUT -->

            <a asp-area=""
               asp-controller="Account"
               asp-action="Logout"
               class="logout-link">

                <i class="bi bi-box-arrow-right"></i>

                Logout

            </a>

        </aside>

        <!-- MAIN CONTENT -->

        <main class="main-content">

            <!-- NAVBAR -->

            <nav class="modern-navbar">

                <!-- SEARCH -->

                <div class="search-box">

                    <input type="text"
                           class="search-input"
                           placeholder="Search books, authors, categories..." />

                    <span class="search-icon">

                        <i class="bi bi-search"></i>

                    </span>

                </div>

                <!-- PROFILE -->
                @if (User.Identity != null &&
                                User.Identity.IsAuthenticated)
                {
                    <div class="dropdown profile-dropdown">

                        <a href="javascript:void(0)"
                           class="profile-trigger dropdown-toggle"
                           data-bs-toggle="dropdown">

                            @if (!string.IsNullOrEmpty(currentUser?.ProfileImagePath))
                            {
                                <img src="@profileImage"
                                     class="profile-avatar" />
                            }
                            else
                            {
                                <div class="profile-avatar default-avatar">

                                    @userName.Substring(0, 1).ToUpper()

                                </div>
                            }

                            <div class="profile-info">

                                <span class="profile-name">

                                    @userName

                                </span>

                                <span class="profile-role">

                                    Library Member

                                </span>

                            </div>

                            <i class="bi bi-chevron-down profile-arrow"></i>

                        </a>

                        <!-- DROPDOWN -->

                        <ul class="dropdown-menu dropdown-menu-end">

                            <li>

                                <a class="dropdown-item"
                                   asp-area="Member"
                                   asp-controller="Dashboard"
                                   asp-action="Index">

                                    <i class="bi bi-grid-fill me-2"></i>
                                    Dashboard

                                </a>

                            </li>

                            <li>

                                <a class="dropdown-item"
                                   asp-area="Member"
                                   asp-controller="Profile"
                                   asp-action="Index">

                                    <i class="bi bi-person-circle me-2"></i>
                                    My Profile

                                </a>

                            </li>

                            <li>

                                <a class="dropdown-item"
                                   asp-area="Member"
                                   asp-controller="Profile"
                                   asp-action="ChangePassword">

                                    <i class="bi bi-shield-lock me-2"></i>
                                    Change Password

                                </a>

                            </li>

                            <li>
                                <hr class="dropdown-divider">
                            </li>

                            <li>

                                <a class="dropdown-item"
                                   asp-area=""
                                   asp-controller="Account"
                                   asp-action="Logout">

                                    <i class="bi bi-box-arrow-right me-2"></i>
                                    Logout

                                </a>

                            </li>

                        </ul>

                    </div>
                }

            </nav>

            <!-- PAGE CONTENT -->
            @RenderBody()

        </main>

    </div>

    <!-- BOOTSTRAP -->

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- SIDEBAR SCRIPT -->

    <script>

        const toggleBtn =
            document.getElementById("mobileToggle");

        const sidebar =
            document.getElementById("sidebar");

        const overlay =
            document.getElementById("sidebarOverlay");

        toggleBtn.addEventListener("click", () => {

            sidebar.classList.toggle("show");
            overlay.classList.toggle("show");

        });

        overlay.addEventListener("click", () => {

            sidebar.classList.remove("show");
            overlay.classList.remove("show");

        });

    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>
