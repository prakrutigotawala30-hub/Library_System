@model LibraryManagementSystem.Models.Book

@{
    ViewData["Title"] = "Reserve Book";
}

<style>

    body {
        background: #050816;
        color: white;
    }

    .reserve-container {
        min-height: 90vh;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 40px;
    }

    .reserve-card {
        width: 100%;
        max-width: 700px;
        background: linear-gradient(145deg,#0f172a,#111827);
        border-radius: 28px;
        overflow: hidden;
        border: 1px solid rgba(255,255,255,0.05);
        box-shadow: 0 0 30px rgba(139,92,246,0.10);
    }

    .reserve-header {
        background: linear-gradient(135deg,#7c3aed,#9333ea);
        padding: 35px;
        text-align: center;
    }

        .reserve-header h2 {
            margin: 0;
            font-weight: 800;
        }

    .reserve-body {
        padding: 35px;
    }

    .book-cover {
        width: 180px;
        border-radius: 18px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.35);
    }

    .book-title {
        font-size: 32px;
        font-weight: 800;
    }

    .book-author {
        color: #9ca3af;
        margin-top: 8px;
        margin-bottom: 20px;
    }

    .book-description {
        color: #d1d5db;
        line-height: 1.8;
    }

    .reserve-btn {
        margin-top: 30px;
        width: 100%;
        height: 58px;
        border: none;
        border-radius: 16px;
        background: linear-gradient(135deg,#7c3aed,#9333ea);
        color: white;
        font-size: 18px;
        font-weight: 700;
    }

</style>

<div class="reserve-container">

    <div class="reserve-card">

        <div class="reserve-header">

            <h2>
                📚 Reserve This Book
            </h2>

        </div>

        <div class="reserve-body">

            <div class="row align-items-center">

                <div class="col-md-4 text-center">

                    <img src="@(string.IsNullOrEmpty(Model.CoverImageUrl)
                                                         ? "https://via.placeholder.com/300x450"
                                                                                  : Model.CoverImageUrl)"
                         class="book-cover" />

                </div>

                <div class="col-md-8">

                    <div class="book-title">
                        @Model.Title
                    </div>

                    <div class="book-author">
                        by @Model.Author.Name
                    </div>

                    <div class="book-description">
                        @Model.Description
                    </div>

                    <form asp-action="CreateReservation"
                          method="post">

                        <input type="hidden"
                               name="bookId"
                               value="@Model.Id" />

                        <button type="submit"
                                class="reserve-btn">

                            Confirm Reservation

                        </button>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>