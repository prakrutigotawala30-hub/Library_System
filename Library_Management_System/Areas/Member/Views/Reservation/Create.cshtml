@{
    Layout = "~/Areas/Member/Views/Shared/_MemberLayout.cshtml";
}

@model LibraryManagementSystem.ClassLibrary.Models.Book

@{
    ViewData["Title"] = "Reserve Book";
}

<style>

    body {
        background: #f4f7fb;
    }

    .reserve-section {
        padding: 60px 0;
        min-height: 100vh;
    }

    .reserve-card {
        background: white;
        border-radius: 32px;
        overflow: hidden;
        box-shadow: 0 20px 60px rgba(15,23,42,0.08);
    }

    .book-image {
        width: 100%;
        height: 100%;
        min-height: 620px;
        object-fit: cover;
    }

    .reserve-content {
        padding: 55px;
    }

    .reserve-badge {
        display: inline-block;
        background: #ede9fe;
        color: #6d28d9;
        padding: 10px 18px;
        border-radius: 50px;
        font-size: 14px;
        font-weight: 700;
        margin-bottom: 22px;
    }

    .book-title {
        font-size: 3rem;
        font-weight: 800;
        color: #0f172a;
        line-height: 1.2;
        margin-bottom: 12px;
    }

    .book-author {
        font-size: 1.1rem;
        color: #64748b;
        margin-bottom: 30px;
    }

    .book-description {
        color: #475569;
        line-height: 1.9;
        font-size: 1rem;
        margin-bottom: 35px;
    }

    .book-meta {
        display: grid;
        grid-template-columns: repeat(2,1fr);
        gap: 18px;
        margin-bottom: 35px;
    }

    .meta-box {
        background: #f8fafc;
        padding: 20px;
        border-radius: 18px;
    }

    .meta-title {
        color: #64748b;
        font-size: 14px;
        margin-bottom: 8px;
    }

    .meta-value {
        color: #0f172a;
        font-weight: 700;
        font-size: 18px;
    }

    .reserve-btn {
        width: 100%;
        height: 60px;
        border: none;
        border-radius: 18px;
        background: linear-gradient(135deg,#7c3aed,#9333ea);
        color: white;
        font-size: 18px;
        font-weight: 700;
        transition: 0.3s ease;
    }

        .reserve-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 30px rgba(124,58,237,0.25);
        }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
        color: #64748b;
        font-weight: 600;
        margin-bottom: 30px;
    }

        .back-link:hover {
            color: #0f172a;
        }

    @@media(max-width:991px) {

        .book-image {
            min-height: 400px;
        }

        .reserve-content {
            padding: 35px;
        }

        .book-title {
            font-size: 2.2rem;
        }

        .book-meta {
            grid-template-columns: 1fr;
        }
    }

</style>

<section class="reserve-section">

    <div class="container">

        <a asp-controller="Books"
           asp-action="Details"
           asp-route-id="@Model.Id"
           class="back-link">

            ← Back to Book Details

        </a>

        <div class="reserve-card">

            <div class="row g-0">

                <!-- IMAGE -->
                <div class="col-lg-5">

                    <img src="@(string.IsNullOrEmpty(Model.CoverImageUrl)
                                                         ? "/images/no-book.png"
                                                         : Model.CoverImageUrl)"
                         class="book-image"
                         alt="@Model.Title" />

                </div>

                <!-- CONTENT -->
                <div class="col-lg-7">

                    <div class="reserve-content">

                        <div class="reserve-badge">
                            Book Reservation
                        </div>

                        <h1 class="book-title">
                            @Model.Title
                        </h1>

                        <div class="book-author">
                            by @(Model.Author?.Name ?? "Unknown Author")
                        </div>

                        <div class="book-description">
                            @(string.IsNullOrEmpty(Model.Description)
                                                        ? "No description available for this book."
                                                        : Model.Description)
                        </div>

                        <!-- META -->
                        <div class="book-meta">

                            <div class="meta-box">

                                <div class="meta-title">
                                    Category
                                </div>

                                <div class="meta-value">
                                    @(Model.Category?.Name ?? "General")
                                </div>

                            </div>

                            <div class="meta-box">

                                <div class="meta-title">
                                    Available Copies
                                </div>

                                <div class="meta-value text-success">
                                    @Model.AvailableCopies
                                </div>

                            </div>

                            <div class="meta-box">

                                <div class="meta-title">
                                    Total Pages
                                </div>

                                <div class="meta-value">
                                    @Model.TotalPages
                                </div>

                            </div>

                            <div class="meta-box">

                                <div class="meta-title">
                                    ISBN
                                </div>

                                <div class="meta-value">
                                    @Model.ISBN
                                </div>

                            </div>

                        </div>

                        <!-- BUTTON -->
                        <form asp-action="CreateReservation"
                              method="post">

                            <input type="hidden"
                                   name="bookId"
                                   value="@Model.Id" />

                            <button type="submit"
                                    class="reserve-btn">

                                Confirm Reservation

                            </button>

                        </form>

                    </div>

                </div>

            </div>

        </div>

    </div>

</section>