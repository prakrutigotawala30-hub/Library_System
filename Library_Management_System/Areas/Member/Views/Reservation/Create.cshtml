@{
    Layout = "~/Areas/Member/Views/Shared/_MemberLayout.cshtml";
}

@model LibraryManagementSystem.ClassLibrary.Models.Book

@{
    ViewData["Title"] = "Reserve Book";
}

<style>

    body {
        background: #050816;
        color: white;
    }

    .reserve-wrapper {
        padding: 30px;
    }

    .page-title {
        font-size: 34px;
        font-weight: 800;
        margin-bottom: 30px;
    }

    .reserve-card {
        background: linear-gradient(145deg,#0f172a,#111827);
        border-radius: 24px;
        padding: 28px;
        border: 1px solid rgba(255,255,255,0.05);
        transition: 0.3s;
    }

        .reserve-card:hover {
            transform: translateY(-5px);
        }

    .book-cover {
        width: 100%;
        max-width: 260px;
        height: 360px;
        object-fit: cover;
        border-radius: 20px;
    }

    .reserve-badge {
        display: inline-block;
        background: rgba(124,58,237,0.2);
        color: #c4b5fd;
        padding: 8px 18px;
        border-radius: 30px;
        font-size: 13px;
        font-weight: 700;
        margin-bottom: 20px;
    }

    .book-title {
        font-size: 34px;
        font-weight: 800;
        margin-bottom: 10px;
    }

    .book-author {
        color: #9ca3af;
        font-size: 16px;
        margin-bottom: 25px;
    }

    .book-description {
        color: #d1d5db;
        line-height: 1.9;
        margin-bottom: 30px;
    }

    .book-info {
        display: flex;
        gap: 20px;
        flex-wrap: wrap;
        margin-bottom: 35px;
    }

    .info-box {
        background: rgba(255,255,255,0.04);
        padding: 16px 20px;
        border-radius: 16px;
        min-width: 180px;
    }

    .info-title {
        color: #9ca3af;
        font-size: 13px;
        margin-bottom: 8px;
    }

    .info-value {
        font-size: 18px;
        font-weight: 700;
    }

    .available {
        color: #10b981;
    }

    .reserve-btn {
        width: 100%;
        height: 60px;
        border: none;
        border-radius: 16px;
        background: linear-gradient(135deg,#7c3aed,#9333ea);
        color: white;
        font-size: 18px;
        font-weight: 700;
        transition: 0.3s;
    }

        .reserve-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 15px 30px rgba(124,58,237,0.3);
        }

    .back-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
        color: #9ca3af;
        font-weight: 600;
        margin-bottom: 25px;
    }

        .back-btn:hover {
            color: white;
        }

    @@media(max-width:991px) {

        .book-cover {
            margin-bottom: 25px;
            max-width: 100%;
            height: auto;
        }

        .book-title {
            font-size: 28px;
        }
    }
</style>

<div class="reserve-wrapper">

    @* Back link to the book detail page. CatalogController.Details is the
       right target in the user app — BooksController was deleted. *@
    <a asp-area=""
       asp-controller="Catalog"
       asp-action="Details"
       asp-route-id="@Model.Id"
       class="back-btn">

        ← Back To Book Details

    </a>

    <div class="page-title">
        📚 Reserve Book
    </div>

    <div class="reserve-card">

        <div class="row align-items-center g-5">

            <!-- IMAGE -->
            <div class="col-lg-4 text-center">

                <img src="@(string.IsNullOrEmpty(Model.CoverImageUrl)
                                         ? "/images/no-book.png"
                                         : Model.CoverImageUrl)"
                     class="book-cover"
                     alt="@Model.Title" />

            </div>

            <!-- CONTENT -->
            <div class="col-lg-8">

                <div class="reserve-badge">
                    Premium Reservation
                </div>

                <div class="book-title">
                    @Model.Title
                </div>

                <div class="book-author">
                    by @(Model.Author?.Name ?? "Unknown Author")
                </div>

                <div class="book-description">
                    @(string.IsNullOrEmpty(Model.Description)
                                        ? "No description available for this book."
                                        : Model.Description)
                </div>

                <!-- INFO -->
                <div class="book-info">

                    <div class="info-box">

                        <div class="info-title">
                            Category
                        </div>

                        <div class="info-value">
                            @(Model.Category?.Name ?? "General")
                        </div>

                    </div>

                    <div class="info-box">

                        <div class="info-title">
                            Available Copies
                        </div>

                        <div class="info-value available">
                            @Model.AvailableCopies
                        </div>

                    </div>

                    <div class="info-box">

                        <div class="info-title">
                            Total Pages
                        </div>

                        <div class="info-value">
                            @Model.TotalPages
                        </div>

                    </div>

                    <div class="info-box">

                        <div class="info-title">
                            ISBN
                        </div>

                        <div class="info-value">
                            @Model.ISBN
                        </div>

                    </div>

                </div>

                <!-- FORM -->
                <form asp-action="CreateReservation"
                      method="post">

                    @Html.AntiForgeryToken()

                    <input type="hidden"
                           name="bookId"
                           value="@Model.Id" />

                    <button type="submit"
                            class="reserve-btn">

                        Confirm Reservation

                    </button>

                </form>

            </div>

        </div>

    </div>

</div>
