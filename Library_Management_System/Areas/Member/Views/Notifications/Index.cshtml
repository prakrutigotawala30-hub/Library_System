@model IEnumerable<LibraryManagementSystem.ClassLibrary.Models.Notification>

@{
    ViewData["Title"] = "Notifications";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
}

<style>

    @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');

    .notification-page,
    .notification-page * {
        box-sizing: border-box;
        font-family: 'Inter', sans-serif;
    }

    .notification-page {
        min-height: 100vh;
        /* padding: 40px 20px 70px; */
        color: white;
    }

    .notification-container {
        width: 100%;
        max-width: 100%;
        margin: auto;
    }

    /* HERO */

    .notification-hero {
        position: relative;
        overflow: hidden;
        border-radius: 32px;
        padding: 60px;
        margin-bottom: 35px;
        background: linear-gradient(rgba(5,8,22,.82), rgba(15,23,42,.92)), url('/images/library-banner.png');
        background-size: cover;
        background-position: center;
        border: 1px solid rgba(255,255,255,.08);
        box-shadow: 0 30px 70px rgba(0,0,0,.35);
    }

        .notification-hero::before {
            content: "";
            position: absolute;
            width: 320px;
            height: 320px;
            border-radius: 50%;
            background: rgba(168,85,247,.18);
            filter: blur(100px);
            top: -120px;
            right: -120px;
        }

    .notification-title {
        position: relative;
        z-index: 2;
        font-size: 52px;
        font-weight: 900;
        margin-bottom: 12px;
        letter-spacing: -1px;
    }

        .notification-title span {
            background: linear-gradient(90deg,#a78bfa,#f472b6);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

    .notification-subtitle {
        position: relative;
        z-index: 2;
        color: #cbd5e1;
        font-size: 16px;
        max-width: 600px;
        line-height: 1.8;
    }

    /* LIST */

    .notification-list {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    /* CARD */

    .notification-card {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 20px;
        padding: 24px;
        border-radius: 24px;
        background: linear-gradient( 180deg, rgba(17,24,39,.95), rgba(15,23,42,.95) );
        border: 1px solid rgba(255,255,255,.07);
        box-shadow: 0 18px 45px rgba(0,0,0,.28);
        transition: .35s ease;
        backdrop-filter: blur(16px);
    }

        .notification-card:hover {
            transform: translateY(-5px);
            border-color: rgba(168,85,247,.35);
            box-shadow: 0 24px 55px rgba(124,58,237,.18);
        }

    .notification-left {
        display: flex;
        align-items: flex-start;
        gap: 18px;
        flex: 1;
    }

    .notification-icon {
        min-width: 40px;
        width: 40px;
        height: 40px;
        border-radius: 18px;
        background: linear-gradient(135deg,#7c3aed,#a855f7);
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 12px 30px rgba(124,58,237,.35);
    }

        .notification-icon i {
            font-size: 24px;
            color: white;
        }

    .notification-content {
        flex: 1;
    }

    .notification-message {
        font-size: 17px;
        font-weight: 600;
        color: white;
        line-height: 1.7;
        margin-bottom: 12px;
    }

    .notification-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
        padding: 10px 18px;
        border-radius: 14px;
        background: rgba(124,58,237,.12);
        color: #c4b5fd;
        font-size: 14px;
        font-weight: 700;
        border: 1px solid rgba(124,58,237,.25);
        transition: .3s ease;
    }

        .notification-link:hover {
            background: rgba(124,58,237,.22);
            color: white;
            transform: translateY(-2px);
        }

    .notification-time {
        color: #94a3b8;
        font-size: 13px;
        white-space: nowrap;
        font-weight: 600;
    }

    /* EMPTY */

    .notification-empty {
        padding: 70px 30px;
        border-radius: 30px;
        text-align: center;
        background: linear-gradient( 180deg, rgba(17,24,39,.95), rgba(15,23,42,.95) );
        border: 1px solid rgba(255,255,255,.08);
        box-shadow: 0 20px 50px rgba(0,0,0,.25);
    }

    .notification-empty-icon {
        width: 100px;
        height: 100px;
        margin: auto auto 24px;
        border-radius: 15px;
        background: linear-gradient(135deg,#7c3aed,#a855f7);
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 20px 45px rgba(124,58,237,.35);
    }

        .notification-empty-icon i {
            font-size: 42px;
            color: white;
        }

    .notification-empty h3 {
        font-size: 30px;
        font-weight: 800;
        margin-bottom: 10px;
    }

    .notification-empty p {
        color: #94a3b8;
        font-size: 16px;
    }

    /* RESPONSIVE */

    @@media(max-width:768px) {

        .notification-page {
            padding: 20px 14px 50px;
        }

        .notification-hero {
            padding: 40px 25px;
            border-radius: 24px;
        }

        .notification-title {
            font-size: 38px;
        }

        .notification-card {
            flex-direction: column;
        }

        .notification-time {
            margin-left: 76px;
        }
    }

    @@media(max-width:480px) {

        .notification-title {
            font-size: 30px;
        }

        .notification-message {
            font-size: 15px;
        }

        .notification-empty h3 {
            font-size: 24px;
        }
    }
</style>

<div class="notification-page">

    <div class="notification-container">

        <!-- HERO -->

        <section class="notification-hero">

            <h1 class="notification-title">
                Your <span>Notifications</span>
            </h1>

            <p class="notification-subtitle">
                Stay updated with reservations, returns, due reminders,
                and important activity from your library account.
            </p>

        </section>

        @if (!Model.Any())
        {
            <!-- EMPTY -->

            <div class="notification-empty">

                <div class="notification-empty-icon">
                    <i class="bi bi-bell"></i>
                </div>

                <h3>No Notifications Yet</h3>

                <p>
                    You're all caught up. New library activity will appear here.
                </p>

            </div>
        }
        else
        {
            <!-- LIST -->

            <div class="notification-list">

                @foreach (var n in Model)
                {
                    <div class="notification-card">

                        <div class="notification-left">

                            <div class="notification-icon">
                                <i class="bi bi-bell-fill"></i>
                            </div>

                            <div class="notification-content">

                                <div class="notification-message">
                                    @n.Message
                                </div>

                                @if (!string.IsNullOrEmpty(n.Link))
                                {
                                    <a href="@n.Link"
                                       class="notification-link">

                                        <i class="bi bi-arrow-right"></i>

                                        Open Notification

                                    </a>
                                }

                            </div>

                        </div>

                        <div class="notification-time">
                            @n.CreatedOn.ToString("dd MMM yyyy • hh:mm tt")
                        </div>

                    </div>
                }

            </div>
        }

    </div>

</div>

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
