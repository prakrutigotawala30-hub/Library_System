@model Library_Management_System.ViewModels.ProfileViewModel

@{
    ViewData["Title"] = "Upload Avatar";
    Layout = "~/Areas/Member/Views/Shared/_MemberLayout.cshtml";
}

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

<style>

    @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Inter',sans-serif;
        background: radial-gradient(circle at top left, rgba(124,58,237,.18), transparent 25%), radial-gradient(circle at bottom right, rgba(236,72,153,.14), transparent 25%), #050816;
        color: white;
        overflow-x: hidden;
    }

    /* REMOVE NAVBAR */

    .navbar,
    .top-navbar,
    .header,
    .member-navbar,
    nav {
        display: none !important;
    }

    .main-content,
    .page-content,
    .content-wrapper,
    .container-fluid {
        margin-top: 0 !important;
        padding-top: 0 !important;
    }

    .avatar-page {
        width: 100%;
        min-height: 100vh;
        padding: 40px 24px 80px;
    }

    /* HERO */

    .avatar-hero {
        position: relative;
        overflow: hidden;
        border-radius: 36px;
        padding: 70px 60px;
        margin-bottom: 32px;
        background: linear-gradient( rgba(7,11,26,.88), rgba(15,23,42,.95)), url('/images/library-banner.png');
        background-size: cover;
        background-position: center;
        border: 1px solid rgba(255,255,255,.06);
        box-shadow: 0 25px 70px rgba(0,0,0,.40);
    }

        .avatar-hero::before {
            content: "";
            position: absolute;
            width: 450px;
            height: 450px;
            border-radius: 50%;
            background: rgba(168,85,247,.12);
            top: -200px;
            right: -120px;
        }

        .avatar-hero::after {
            content: "";
            position: absolute;
            width: 300px;
            height: 300px;
            border-radius: 50%;
            background: rgba(236,72,153,.08);
            bottom: -120px;
            left: -80px;
        }

    .hero-content {
        position: relative;
        z-index: 2;
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 12px 22px;
        border-radius: 50px;
        background: rgba(255,255,255,.05);
        border: 1px solid rgba(255,255,255,.08);
        color: #d8b4fe;
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 1px;
        margin-bottom: 24px;
        backdrop-filter: blur(12px);
    }

    .hero-content h1 {
        font-size: 58px;
        font-weight: 900;
        line-height: 1.1;
        margin-bottom: 18px;
    }

        .hero-content h1 span {
            background: linear-gradient( 90deg, #c084fc, #f0abfc);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

    .hero-content p {
        color: #d1d5db;
        font-size: 16px;
        line-height: 1.9;
        max-width: 700px;
    }

    /* CARD */

    .avatar-card {
        background: linear-gradient( 145deg, #111827, #1f2937);
        border-radius: 32px;
        overflow: hidden;
        border: 1px solid rgba(255,255,255,.06);
        box-shadow: 0 20px 60px rgba(0,0,0,.35);
        padding: 45px;
    }

    /* ALERT */

    .success-alert {
        background: rgba(34,197,94,.12);
        border: 1px solid rgba(34,197,94,.25);
        color: #86efac;
        padding: 16px 20px;
        border-radius: 18px;
        margin-bottom: 25px;
        display: flex;
        align-items: center;
        gap: 12px;
        font-weight: 600;
    }

    .error-alert {
        background: rgba(239,68,68,.12);
        border: 1px solid rgba(239,68,68,.25);
        color: #fca5a5;
        padding: 16px 20px;
        border-radius: 18px;
        margin-bottom: 25px;
        display: flex;
        align-items: center;
        gap: 12px;
        font-weight: 600;
    }

    /* PREVIEW */

    .preview-section {
        text-align: center;
        margin-bottom: 40px;
    }

    .avatar-preview-wrap {
        position: relative;
        width: 170px;
        height: 170px;
        margin: auto;
    }

    .avatar-preview,
    .empty-avatar {
        width: 100%;
        height: 100%;
        border-radius: 50%;
    }

    .avatar-preview {
        object-fit: cover;
        border: 5px solid rgba(147,51,234,.35);
        box-shadow: 0 20px 45px rgba(0,0,0,.35);
    }

    .empty-avatar {
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient( 135deg, #7c3aed, #9333ea);
        font-size: 60px;
        font-weight: 900;
        border: 5px solid rgba(147,51,234,.35);
        box-shadow: 0 20px 45px rgba(0,0,0,.35);
    }

    .camera-badge {
        position: absolute;
        bottom: 6px;
        right: 6px;
        width: 54px;
        height: 54px;
        border-radius: 50%;
        background: linear-gradient( 135deg, #7c3aed, #d946ef);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 22px;
        border: 4px solid #111827;
    }

    .preview-section h3 {
        margin-top: 24px;
        font-size: 32px;
        font-weight: 800;
        margin-bottom: 10px;
    }

    .preview-section p {
        color: #9ca3af;
        font-size: 15px;
    }

    /* FORM */

    .upload-box {
        background: rgba(255,255,255,.03);
        border: 1px solid rgba(255,255,255,.06);
        border-radius: 28px;
        padding: 30px;
        margin-bottom: 30px;
    }

    .upload-label {
        display: block;
        margin-bottom: 14px;
        color: #ddd6fe;
        font-size: 15px;
        font-weight: 700;
    }

    .custom-file {
        width: 100%;
        padding: 18px;
        border-radius: 22px;
        background: #0f172a;
        border: 2px dashed rgba(139,92,246,.35);
        color: white;
        cursor: pointer;
        transition: .3s;
    }

        .custom-file:hover {
            border-color: #8b5cf6;
            background: rgba(255,255,255,.04);
        }

        .custom-file::file-selector-button {
            border: none;
            padding: 12px 20px;
            margin-right: 16px;
            border-radius: 14px;
            background: linear-gradient( 135deg, #7c3aed, #9333ea);
            color: white;
            font-weight: 700;
            cursor: pointer;
        }

    .upload-note {
        margin-top: 16px;
        color: #9ca3af;
        font-size: 14px;
        line-height: 1.8;
    }

    .text-danger {
        margin-top: 10px;
        display: block;
        color: #fca5a5 !important;
        font-size: 14px;
    }

    /* BUTTONS */

    .action-buttons {
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
    }

    .save-btn,
    .cancel-btn {
        height: 56px;
        padding: 0 28px;
        border-radius: 18px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        font-weight: 700;
        transition: .3s;
    }

    .save-btn {
        border: none;
        background: linear-gradient( 135deg, #7c3aed, #9333ea);
        color: white;
        box-shadow: 0 15px 30px rgba(147,51,234,.35);
    }

        .save-btn:hover {
            transform: translateY(-2px);
        }

    .cancel-btn {
        background: rgba(255,255,255,.06);
        border: 1px solid rgba(255,255,255,.08);
        color: #d1d5db;
        text-decoration: none;
    }

        .cancel-btn:hover {
            background: rgba(255,255,255,.12);
            color: white;
            transform: translateY(-2px);
        }

    /* RESPONSIVE */

    @@media(max-width:768px) {

        .avatar-page {
            padding: 20px 16px 60px;
        }

        .avatar-hero {
            padding: 50px 28px;
            border-radius: 28px;
        }

        .hero-content h1 {
            font-size: 40px;
        }

        .avatar-card {
            padding: 25px;
        }

        .upload-box {
            padding: 22px;
        }

        .action-buttons {
            flex-direction: column;
        }

        .avatar-preview-wrap {
            width: 140px;
            height: 140px;
        }
    }
</style>

<div class="avatar-page">

    <!-- HERO -->

    <section class="avatar-hero">

        <div class="hero-content">

            <div class="hero-badge">
                📷 PROFILE PHOTO SETTINGS
            </div>

            <h1>
                Upload Your
                <span>Avatar</span>
            </h1>

            <p>
                Personalize your library profile with a modern
                profile image visible across your member dashboard.
            </p>

        </div>

    </section>

    <!-- CARD -->

    <div class="avatar-card">

        @if (TempData["success"] != null)
        {
            <div class="success-alert">

                <i class="bi bi-check-circle-fill"></i>

                @TempData["success"]

            </div>
        }

        @if (TempData["error"] != null)
        {
            <div class="error-alert">

                <i class="bi bi-exclamation-circle-fill"></i>

                @TempData["error"]

            </div>
        }

        <!-- PREVIEW -->

        <div class="preview-section">

            <div class="avatar-preview-wrap">

                @if (!string.IsNullOrEmpty(Model.ProfileImagePath))
                {
                    <img src="@Model.ProfileImagePath"
                         class="avatar-preview" />
                }
                else
                {
                    <div class="empty-avatar">

                        @(string.IsNullOrEmpty(Model.Name)
                                            ? "U"
                                            : Model.Name.Substring(0, 1).ToUpper())

                    </div>
                }

                <div class="camera-badge">

                    <i class="bi bi-camera-fill"></i>

                </div>

            </div>

            <h3>
                Update Profile Picture
            </h3>

            <p>
                Choose a clean and high quality image
            </p>

        </div>

        <!-- FORM -->

        <form asp-area="Member"
              asp-controller="Profile"
              asp-action="Avatar"
              method="post"
              enctype="multipart/form-data">

            @Html.AntiForgeryToken()

            <div class="upload-box">

                <label asp-for="AvatarFile"
                       class="upload-label">

                    Select Profile Image

                </label>

                <input asp-for="AvatarFile"
                       type="file"
                       class="custom-file"
                       accept=".jpg,.jpeg,.png,.webp" />

                <span asp-validation-for="AvatarFile"
                      class="text-danger"></span>

                <div class="upload-note">

                    Supported formats:
                    JPG, JPEG, PNG, WEBP <br />

                    Recommended size:
                    500×500 pixels or higher

                </div>

            </div>

            <!-- BUTTONS -->

            <div class="action-buttons">

                <button type="submit"
                        class="save-btn">

                    <i class="bi bi-upload"></i>

                    Upload Photo

                </button>

                <a asp-area="Member"
                   asp-controller="Profile"
                   asp-action="Index"
                   class="cancel-btn">

                    <i class="bi bi-arrow-left"></i>

                    Back To Profile

                </a>

            </div>

        </form>

    </div>

</div>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

}
