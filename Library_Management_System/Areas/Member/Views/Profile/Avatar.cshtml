@model Library_Management_System.ViewModels.ProfileViewModel

@{
    ViewData["Title"] = "Upload Avatar";
    // Layout = "~/Areas/Member/Views/Shared/_MemberLayout.cshtml";
}

<style>

    body {
        background: #070b1a;
        font-family: 'Inter', sans-serif;
        color: white;
    }


    .avatar-page {
        min-height: 100vh;
        padding: 40px 0 80px;
    }

    /* HERO */

    .avatar-hero {
        position: relative;
        overflow: hidden;
        border-radius: 34px;
        padding: 70px 60px;
        margin-bottom: 35px;
        background: linear-gradient(rgba(7,11,26,.9), rgba(15,23,42,.95)), url('/images/library-banner.png');
        background-size: cover;
        background-position: center;
        border: 1px solid rgba(255,255,255,.08);
        box-shadow: 0 0 45px rgba(139,92,246,.15);
    }

        .avatar-hero::before {
            content: "";
            position: absolute;
            width: 420px;
            height: 420px;
            border-radius: 50%;
            background: rgba(168,85,247,.10);
            top: -180px;
            right: -120px;
        }

        .avatar-hero::after {
            content: "";
            position: absolute;
            width: 260px;
            height: 260px;
            border-radius: 50%;
            background: rgba(236,72,153,.08);
            bottom: -120px;
            left: -80px;
        }

    .hero-content {
        position: relative;
        z-index: 2;
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 12px 22px;
        border-radius: 50px;
        background: rgba(255,255,255,.05);
        border: 1px solid rgba(255,255,255,.08);
        color: #d8b4fe;
        font-size: 13px;
        letter-spacing: 1px;
        margin-bottom: 24px;
        backdrop-filter: blur(12px);
    }

    .hero-content h1 {
        font-size: 54px;
        font-weight: 900;
        line-height: 1.1;
        margin-bottom: 18px;
        color: white;
    }

        .hero-content h1 span {
            background: linear-gradient(90deg,#c084fc,#f0abfc);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

    .hero-content p {
        color: #d1d5db;
        font-size: 16px;
        line-height: 1.9;
        max-width: 700px;
    }

    /* CARD */

    .avatar-card {
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.08);
        border-radius: 30px;
        padding: 45px;
        backdrop-filter: blur(16px);
        box-shadow: 0 15px 45px rgba(0,0,0,.28);
    }

    /* PREVIEW */

    .preview-section {
        text-align: center;
        margin-bottom: 40px;
    }

    .avatar-preview-wrap {
        position: relative;
        width: 170px;
        height: 170px;
        margin: auto;
    }

    .avatar-preview {
        width: 100%;
        height: 100%;
        border-radius: 50%;
        object-fit: cover;
        border: 4px solid rgba(139,92,246,.45);
        box-shadow: 0 15px 40px rgba(139,92,246,.28);
    }

    .empty-avatar {
        width: 100%;
        height: 100%;
        border-radius: 50%;
        background: linear-gradient(135deg,#7c3aed,#9333ea);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 58px;
        font-weight: 800;
        border: 4px solid rgba(139,92,246,.45);
        box-shadow: 0 15px 40px rgba(139,92,246,.28);
    }

    .camera-badge {
        position: absolute;
        bottom: 8px;
        right: 8px;
        width: 52px;
        height: 52px;
        border-radius: 50%;
        background: linear-gradient(135deg,#9333ea,#d946ef);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 20px;
        border: 4px solid #111827;
        box-shadow: 0 10px 25px rgba(168,85,247,.35);
    }

    .preview-section h3 {
        margin-top: 24px;
        margin-bottom: 10px;
        color: white;
        font-size: 30px;
        font-weight: 800;
    }

    .preview-section p {
        color: #9ca3af;
        font-size: 15px;
        margin: 0;
    }

    /* UPLOAD */

    .upload-box {
        padding: 35px;
        border-radius: 28px;
        background: rgba(255,255,255,.03);
        border: 1px solid rgba(255,255,255,.06);
        margin-bottom: 30px;
    }

    .upload-label {
        display: block;
        margin-bottom: 16px;
        color: #ddd6fe;
        font-size: 15px;
        font-weight: 700;
    }

    .custom-file {
        width: 100%;
        padding: 18px;
        border-radius: 22px;
        background: rgba(255,255,255,.04);
        border: 2px dashed rgba(139,92,246,.35);
        color: white;
        cursor: pointer;
        transition: .3s;
    }

        .custom-file:hover {
            background: rgba(255,255,255,.06);
            border-color: #8b5cf6;
        }

        .custom-file::file-selector-button {
            border: none;
            padding: 12px 20px;
            margin-right: 18px;
            border-radius: 14px;
            background: linear-gradient(135deg,#7c3aed,#9333ea);
            color: white;
            font-weight: 700;
            cursor: pointer;
        }

    .upload-note {
        margin-top: 15px;
        color: #9ca3af;
        font-size: 14px;
        line-height: 1.7;
    }

    .text-danger {
        color: #fca5a5 !important;
        margin-top: 12px;
        display: block;
        font-size: 14px;
    }

    /* BUTTONS */

    .action-buttons {
        display: flex;
        gap: 18px;
        flex-wrap: wrap;
    }

    .save-btn {
        border: none;
        padding: 15px 30px;
        border-radius: 18px;
        background: linear-gradient(90deg,#7c3aed,#9333ea);
        color: white;
        font-size: 15px;
        font-weight: 700;
        transition: .3s;
        box-shadow: 0 10px 30px rgba(139,92,246,.25);
    }

        .save-btn:hover {
            transform: translateY(-2px);
        }

    .cancel-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 15px 28px;
        border-radius: 18px;
        background: rgba(255,255,255,.05);
        border: 1px solid rgba(255,255,255,.08);
        color: white;
        text-decoration: none;
        font-weight: 700;
        transition: .3s;
    }

        .cancel-btn:hover {
            color: white;
            transform: translateY(-2px);
            border-color: rgba(139,92,246,.35);
        }

    @@media(max-width:768px) {

        .avatar-hero {
            padding: 50px 28px;
            border-radius: 28px;
        }

        .hero-content h1 {
            font-size: 40px;
        }

        .avatar-card {
            padding: 25px;
        }

        .upload-box {
            padding: 22px;
        }

        .action-buttons {
            flex-direction: column;
        }

        .avatar-preview-wrap {
            width: 140px;
            height: 140px;
        }
    }

</style>

<div class="container avatar-page">

    <!-- HERO -->

    <section class="avatar-hero">

        <div class="hero-content">

            <div class="hero-badge">
                📷 PROFILE PHOTO SETTINGS
            </div>

            <h1>
                Upload Your
                <span>Avatar</span>
            </h1>

            <p>
                Personalize your library account with a custom
                profile picture visible across your member dashboard.
            </p>

        </div>

    </section>

    <!-- CARD -->

    <div class="avatar-card">

        @if (TempData["success"] != null)
        {
            <div class="alert alert-success rounded-4 mb-4">
                ✅ @TempData["success"]
            </div>
        }

        @if (TempData["error"] != null)
        {
            <div class="alert alert-danger rounded-4 mb-4">
                ❌ @TempData["error"]
            </div>
        }

        <!-- PREVIEW -->

        <div class="preview-section">

            <div class="avatar-preview-wrap">

                @if (!string.IsNullOrEmpty(Model.ProfileImagePath))
                {
                    <img src="@Model.ProfileImagePath"
                         class="avatar-preview" />
                }
                else
                {
                    <div class="empty-avatar">

                        @(string.IsNullOrEmpty(Model.Name)
                                            ? "U"
                                            : Model.Name.Substring(0, 1).ToUpper())

                    </div>
                }

                <div class="camera-badge">
                    📷
                </div>

            </div>

            <h3>
                Update Profile Picture
            </h3>

            <p>
                Choose a clean and clear photo for your account
            </p>

        </div>

        <!-- FORM -->

        <form asp-area="Member"
              asp-controller="Profile"
              asp-action="Avatar"
              method="post"
              enctype="multipart/form-data">

            @Html.AntiForgeryToken()

            <div class="upload-box">

                <label asp-for="AvatarFile"
                       class="upload-label">

                    Select Profile Image

                </label>

                <input asp-for="AvatarFile"
                       type="file"
                       class="custom-file"
                       accept=".jpg,.jpeg,.png,.webp" />

                <span asp-validation-for="AvatarFile"
                      class="text-danger"></span>

                <div class="upload-note">

                    Supported formats:
                    JPG, JPEG, PNG, WEBP <br />

                    Recommended size:
                    500×500 pixels or higher

                </div>

            </div>

            <!-- BUTTONS -->

            <div class="action-buttons">

                <button type="submit"
                        class="save-btn">

                    Upload Photo

                </button>

                <a asp-area="Member"
                   asp-controller="Profile"
                   asp-action="Index"
                   class="cancel-btn">

                    Back To Profile

                </a>

            </div>

        </form>

    </div>

</div>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

}
