@{
    ViewData["Title"] = "My Profile";
    Layout = "~/Areas/Member/Views/Shared/_MemberLayout.cshtml";
}

@model Library_Management_System.ViewModels.ProfileViewModel

<!DOCTYPE html>
<html lang="en">


<head>

    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1" />

    <title>My Profile</title>

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>

                @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');

                *{
                    margin:0;
                    padding:0;
                    box-sizing:border-box;
                }

                body{
                    font-family:'Inter',sans-serif;
                    background:
                        radial-gradient(circle at top left,
                        rgba(124,58,237,.18),
                        transparent 25%),

                        radial-gradient(circle at bottom right,
                        rgba(236,72,153,.14),
                        transparent 25%),

                        #050816;

                    color:white;
                    overflow-x:hidden;
                }

                a{
                    text-decoration:none;
                }

                /* REMOVE TOP NAVBAR */

        .navbar,
        .top-navbar,
        .header,
        .member-navbar,
        nav{
            display:none !important;
        }

        /* REMOVE TOP SPACE AFTER NAVBAR */

        .main-content,
        .page-content,
        .content-wrapper,
        .container-fluid{
            margin-top:0 !important;
            padding-top:0 !important;
        }

                /* =========================================================
                   PAGE
                ========================================================= */

                .profile-page{
                    width:100%;
                    min-height:100vh;
                    padding:40px 24px 80px;
                }

                /* =========================================================
                   HEADER
                ========================================================= */

                .profile-header{
                    position:relative;
                    overflow:hidden;

                    border-radius:36px;

                    margin-bottom:32px;

                    background:
                        linear-gradient(
                        145deg,
                        rgba(17,24,39,.95),
                        rgba(15,23,42,.98));

                    border:1px solid rgba(255,255,255,.06);

                    box-shadow:
                        0 25px 70px rgba(0,0,0,.40);
                }

                .profile-cover{
                    position:relative;

                    height:260px;

                    background:
                        radial-gradient(circle at top left,
                        rgba(168,85,247,.55),
                        transparent 30%),

                        radial-gradient(circle at bottom right,
                        rgba(59,130,246,.35),
                        transparent 30%),

                        linear-gradient(
                        135deg,
                        #111827,
                        #1e1b4b,
                        #312e81);
                }

                .profile-cover::before{
                    content:"";

                    position:absolute;

                    width:500px;
                    height:500px;

                    border-radius:50%;

                    background:
                        rgba(255,255,255,.05);

                    top:-220px;
                    right:-180px;

                    filter:blur(20px);
                }

                .profile-user{
                    position:relative;

                    display:flex;
                    align-items:flex-end;
                    justify-content:space-between;

                    gap:30px;
                    flex-wrap:wrap;

                    padding:0 40px 40px;

                    margin-top:-85px;

                    z-index:2;
                }

                /* =========================================================
                   IMAGE
                ========================================================= */

                .profile-image-wrapper{
                    position:relative;
                }

                .profile-image,
                .profile-avatar{
                    width:165px;
                    height:165px;

                    border-radius:50%;

                    border:7px solid #111827;

                    object-fit:cover;

                    box-shadow:
                        0 20px 45px rgba(0,0,0,.45);
                }

                .profile-avatar{
                    display:flex;
                    align-items:center;
                    justify-content:center;

                    background:
                        linear-gradient(
                        135deg,
                        #7c3aed,
                        #d946ef);

                    font-size:60px;
                    font-weight:900;
                }

                /* =========================================================
                   INFO
                ========================================================= */

                .profile-user-info{
                    flex:1;
                    min-width:250px;
                }

                .profile-user-info h1{
                    font-size:42px;
                    font-weight:900;

                    margin-bottom:8px;

                    letter-spacing:-1px;
                }

                .profile-user-info p{
                    color:#9ca3af;
                    font-size:16px;
                }

                /* =========================================================
                   BUTTONS
                ========================================================= */

                .profile-actions{
                    display:flex;
                    gap:16px;
                    flex-wrap:wrap;
                }

                .btn-profile-primary,
                .btn-profile-secondary{
                    height:56px;

                    padding:0 26px;

                    border-radius:18px;

                    display:inline-flex;
                    align-items:center;
                    justify-content:center;
                    gap:10px;

                    font-size:15px;
                    font-weight:700;

                    transition:.35s ease;
                }

                .btn-profile-primary{
                    background:
                        linear-gradient(
                        135deg,
                        #7c3aed,
                        #d946ef);

                    color:white;

                    box-shadow:
                        0 15px 35px rgba(124,58,237,.35);
                }

                .btn-profile-primary:hover{
                    transform:translateY(-4px);

                    color:white;

                    box-shadow:
                        0 20px 45px rgba(124,58,237,.45);
                }

                .btn-profile-secondary{
                    background:
                        rgba(255,255,255,.05);

                    border:
                        1px solid rgba(255,255,255,.08);

                    color:#d1d5db;
                }

                .btn-profile-secondary:hover{
                    background:
                        rgba(255,255,255,.08);

                    color:white;

                    transform:translateY(-4px);
                }

                /* =========================================================
                   GRID
                ========================================================= */

                .profile-grid{
                    display:grid;
                    grid-template-columns:1fr 1fr;
                    gap:28px;
                }

                /* =========================================================
                   CARD
                ========================================================= */

                .profile-card{
                    position:relative;

                    overflow:hidden;

                    border-radius:30px;

                    padding:30px;

                    background:
                        linear-gradient(
                        180deg,
                        rgba(17,24,39,.96),
                        rgba(10,15,28,.98));

                    border:
                        1px solid rgba(255,255,255,.06);

                    box-shadow:
                        0 18px 40px rgba(0,0,0,.28);

                    transition:.35s ease;
                }

                .profile-card:hover{
                    transform:translateY(-6px);

                    border-color:
                        rgba(168,85,247,.28);
                }

                .card-title{
                    display:flex;
                    align-items:center;
                    gap:12px;

                    margin-bottom:28px;

                    font-size:22px;
                    font-weight:800;
                }

                .card-title i{
                    color:#c084fc;
                }

                /* =========================================================
                   INFO LIST
                ========================================================= */

                .info-list{
                    display:flex;
                    flex-direction:column;
                    gap:18px;
                }

                .info-item{
                    padding:18px;

                    border-radius:20px;

                    background:
                        rgba(255,255,255,.03);

                    border:
                        1px solid rgba(255,255,255,.05);
                }

                .info-label{
                    color:#9ca3af;

                    font-size:13px;
                    font-weight:600;

                    margin-bottom:8px;

                    text-transform:uppercase;
                    letter-spacing:1px;
                }

                .info-value{
                    font-size:17px;
                    font-weight:700;
                }

                /* =========================================================
                   STATUS
                ========================================================= */

                .status-badge{
                    padding:9px 16px;

                    border-radius:999px;

                    font-size:13px;
                    font-weight:700;
                }

                .status-badge.success{
                    background:
                        rgba(34,197,94,.14);

                    color:#4ade80;
                }

                .status-badge.danger{
                    background:
                        rgba(239,68,68,.14);

                    color:#f87171;
                }

                /* =========================================================
                   QUICK ACTIONS
                ========================================================= */

                .quick-actions{
                    display:flex;
                    flex-direction:column;
                    gap:18px;
                }

                .quick-action-box{
                    display:flex;
                    align-items:center;
                    gap:18px;

                    padding:18px;

                    border-radius:22px;

                    background:
                        rgba(255,255,255,.03);

                    border:
                        1px solid rgba(255,255,255,.05);

                    transition:.35s ease;
                }

                .quick-action-box:hover{
                    transform:translateY(-4px);

                    border-color:
                        rgba(168,85,247,.30);

                    background:
                        rgba(124,58,237,.08);
                }

                .quick-action-box h5{
                    color:white;

                    font-size:17px;
                    font-weight:700;

                    margin-bottom:4px;
                }

                .quick-action-box p{
                    color:#9ca3af;
                    font-size:14px;
                }

                .quick-icon{
                    width:62px;
                    height:62px;

                    border-radius:18px;

                    display:flex;
                    align-items:center;
                    justify-content:center;

                    flex-shrink:0;

                    color:white;
                    font-size:24px;
                }

                .quick-icon.purple{
                    background:
                        linear-gradient(
                        135deg,
                        #7c3aed,
                        #9333ea);
                }

                .quick-icon.pink{
                    background:
                        linear-gradient(
                        135deg,
                        #ec4899,
                        #db2777);
                }

                .quick-icon.blue{
                    background:
                        linear-gradient(
                        135deg,
                        #2563eb,
                        #3b82f6);
                }

                /* =========================================================
                   RESPONSIVE
                ========================================================= */

                @@media(max-width:991px){

                    .profile-grid{
                        grid-template-columns:1fr;
                    }

                    .profile-user{
                        flex-direction:column;
                        align-items:center;
                        text-align:center;
                    }

                    .profile-actions{
                        justify-content:center;
                    }
                }

                @@media(max-width:768px){

                    .profile-page{
                        padding:20px 16px 60px;
                    }

                    .profile-cover{
                        height:220px;
                    }

                    .profile-user{
                        padding:0 22px 30px;
                    }

                    .profile-user-info h1{
                        font-size:34px;
                    }

                    .profile-card{
                        padding:24px;
                    }
                }

                @@media(max-width:576px){

                    .profile-cover{
                        height:180px;
                    }

                    .profile-image,
                    .profile-avatar{
                        width:120px;
                        height:120px;
                    }

                    .profile-avatar{
                        font-size:42px;
                    }

                    .profile-user-info h1{
                        font-size:28px;
                    }

                    .btn-profile-primary,
                    .btn-profile-secondary{
                        width:100%;
                    }

                    .profile-actions{
                        width:100%;
                    }

                    .quick-action-box{
                        flex-direction:column;
                        align-items:flex-start;
                    }
                }

    </style>

</head>

<body>

    <div class="profile-page">

        <div class="profile-header">

            <div class="profile-cover"></div>

            <div class="profile-user">

                <div class="profile-image-wrapper">

                    @if (!string.IsNullOrEmpty(Model.ProfileImagePath))
                    {
                        <img src="@Model.ProfileImagePath"
                             class="profile-image"
                             alt="Profile Image" />
                    }
                    else
                    {
                        <div class="profile-avatar">

                            @(Model.Name?.Substring(0, 1).ToUpper())

                        </div>
                    }

                </div>

                <div class="profile-user-info">

                    <h1>
                        @Model.Name
                    </h1>

                    <p>
                        Premium Library Member
                    </p>

                </div>

                <div class="profile-actions">

                    <a asp-area="Member"
                       asp-controller="Profile"
                       asp-action="Edit"
                       class="btn-profile-primary">

                        <i class="bi bi-pencil-square"></i>

                        Edit Profile

                    </a>

                    <a asp-area="Member"
                       asp-controller="Profile"
                       asp-action="ChangePassword"
                       class="btn-profile-secondary">

                        <i class="bi bi-shield-lock"></i>

                        Change Password

                    </a>

                </div>

            </div>

        </div>

        <div class="profile-grid">

            <div class="profile-card">

                <div class="card-title">

                    <i class="bi bi-person-circle"></i>

                    Personal Information

                </div>

                <div class="info-list">

                    <div class="info-item">

                        <div class="info-label">
                            Full Name
                        </div>

                        <div class="info-value">
                            @Model.Name
                        </div>

                    </div>

                    <div class="info-item">

                        <div class="info-label">
                            Phone Number
                        </div>

                        <div class="info-value">
                            @(string.IsNullOrEmpty(Model.Phone)
                                                        ? "Not Added"
                                                        : Model.Phone)
                        </div>

                    </div>

                    <div class="info-item">

                        <div class="info-label">
                            Notifications
                        </div>

                        <div class="info-value">

                            @if (Model.NotificationPrefs)
                            {
                                <span class="status-badge success">
                                    Enabled
                                </span>
                            }
                            else
                            {
                                <span class="status-badge danger">
                                    Disabled
                                </span>
                            }

                        </div>

                    </div>

                </div>

            </div>

            <div class="profile-card">

                <div class="card-title">

                    <i class="bi bi-lightning-charge"></i>

                    Quick Actions

                </div>

                <div class="quick-actions">

                    <a asp-area="Member"
                       asp-controller="Profile"
                       asp-action="Avatar"
                       class="quick-action-box">

                        <div class="quick-icon purple">
                            <i class="bi bi-image"></i>
                        </div>

                        <div>

                            <h5>
                                Update Avatar
                            </h5>

                            <p>
                                Upload new profile image
                            </p>

                        </div>

                    </a>

                    <a asp-area="Member"
                       asp-controller="Wishlist"
                       asp-action="Index"
                       class="quick-action-box">

                        <div class="quick-icon pink">
                            <i class="bi bi-heart"></i>
                        </div>

                        <div>

                            <h5>
                                Wishlist
                            </h5>

                            <p>
                                View your saved books
                            </p>

                        </div>

                    </a>

                    <a asp-area="Member"
                       asp-controller="BorrowHistory"
                       asp-action="Index"
                       class="quick-action-box">

                        <div class="quick-icon blue">
                            <i class="bi bi-clock-history"></i>
                        </div>

                        <div>

                            <h5>
                                Borrow History
                            </h5>

                            <p>
                                View borrowed books history
                            </p>

                        </div>

                    </a>

                </div>

            </div>

        </div>

    </div>

</body>

</html>
