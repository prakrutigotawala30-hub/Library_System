@model Library_Management_System.ViewModels.ChangePasswordViewModel

@{
    ViewData["Title"] = "Change Password";
    Layout = "~/Areas/Member/Views/Shared/_MemberLayout.cshtml";
}

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

<div class="password-page">

    <!-- HERO SECTION -->

    <div class="password-hero">

        <div class="hero-overlay"></div>

        <div class="hero-content">

            <div class="hero-left">

                <div class="hero-icon">

                    <i class="bi bi-shield-lock-fill"></i>

                </div>

                <div>

                    <div class="hero-badge">
                        🔒 ACCOUNT SECURITY
                    </div>

                    <h1>
                        Change Your Password
                    </h1>

                    <p>
                        Protect your account with a secure and strong password.
                    </p>

                </div>

            </div>

            <a asp-area="Member"
               asp-controller="Profile"
               asp-action="Index"
               class="hero-btn">

                <i class="bi bi-arrow-left"></i>

                Back To Profile

            </a>

        </div>

    </div>

    <!-- MAIN CARD -->

    <div class="password-card">

        <div class="card-header">

            <div class="card-icon">

                <i class="bi bi-key-fill"></i>

            </div>

            <div>

                <h2>
                    Update Password
                </h2>

                <p>
                    Enter your current password and set a new secure password.
                </p>

            </div>

        </div>

        <!-- SUCCESS -->
        @if (TempData["success"] != null)
        {
            <div class="success-alert">

                <i class="bi bi-check-circle-fill"></i>

                @TempData["success"]

            </div>
        }

        <!-- ERROR -->
        @if (TempData["error"] != null)
        {
            <div class="error-alert">

                <i class="bi bi-exclamation-circle-fill"></i>

                @TempData["error"]

            </div>
        }

        <!-- FORM -->

        <form asp-action="ChangePassword"
              method="post">

            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly"
                 class="validation-summary">
            </div>

            <!-- CURRENT PASSWORD -->

            <div class="form-group">

                <label asp-for="CurrentPassword">

                    <i class="bi bi-lock-fill"></i>

                    Current Password

                </label>

                <div class="input-wrapper">

                    <i class="bi bi-shield-lock input-icon"></i>

                    <input asp-for="CurrentPassword"
                           type="password"
                           class="custom-input"
                           placeholder="Enter current password" />

                </div>

                <span asp-validation-for="CurrentPassword"
                      class="text-danger">
                </span>

            </div>

            <!-- NEW PASSWORD -->

            <div class="form-group">

                <label asp-for="NewPassword">

                    <i class="bi bi-key-fill"></i>

                    New Password

                </label>

                <div class="input-wrapper">

                    <i class="bi bi-lock input-icon"></i>

                    <input asp-for="NewPassword"
                           type="password"
                           class="custom-input"
                           placeholder="Enter new password" />

                </div>

                <span asp-validation-for="NewPassword"
                      class="text-danger">
                </span>

            </div>

            <!-- CONFIRM PASSWORD -->

            <div class="form-group">

                <label asp-for="ConfirmPassword">

                    <i class="bi bi-check-circle-fill"></i>

                    Confirm Password

                </label>

                <div class="input-wrapper">

                    <i class="bi bi-check2-circle input-icon"></i>

                    <input asp-for="ConfirmPassword"
                           type="password"
                           class="custom-input"
                           placeholder="Confirm new password" />

                </div>

                <span asp-validation-for="ConfirmPassword"
                      class="text-danger">
                </span>

            </div>

            <!-- SECURITY BOX -->

            <div class="security-box">

                <div class="security-icon">

                    <i class="bi bi-shield-check"></i>

                </div>

                <div>

                    <h5>
                        Password Security Tips
                    </h5>

                    <p>
                        Use at least 8 characters including uppercase letters,
                        numbers and special symbols for better security.
                    </p>

                </div>

            </div>

            <!-- BUTTONS -->

            <div class="button-group">

                <button type="submit"
                        class="save-btn">

                    <i class="bi bi-check-circle-fill"></i>

                    Update Password

                </button>

                <a asp-area="Member"
                   asp-controller="Profile"
                   asp-action="Index"
                   class="cancel-btn">

                    <i class="bi bi-x-circle"></i>

                    Cancel

                </a>

            </div>

        </form>

    </div>

</div>

<style>

    @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Inter',sans-serif;
        background: radial-gradient(circle at top left, rgba(124,58,237,.18), transparent 25%), radial-gradient(circle at bottom right, rgba(236,72,153,.14), transparent 25%), #050816;
        color: white;
        overflow-x: hidden;
    }

    /* REMOVE NAVBAR */

    .navbar,
    .top-navbar,
    .header,
    .member-navbar,
    nav {
        display: none !important;
    }

    .main-content,
    .page-content,
    .content-wrapper,
    .container-fluid {
        margin-top: 0 !important;
        padding-top: 0 !important;
    }

    .password-page {
        width: 100%;
        min-height: 100vh;
        padding: 35px 24px 80px;
    }

    /* HERO */

    .password-hero {
        position: relative;
        overflow: hidden;
        border-radius: 36px;
        margin-bottom: 35px;
        background: linear-gradient(rgba(7,11,26,.86), rgba(15,23,42,.92)), url('/images/library-banner.png');
        background-size: cover;
        background-position: center;
        border: 1px solid rgba(255,255,255,.06);
        box-shadow: 0 25px 60px rgba(0,0,0,.35);
    }

    .hero-overlay {
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at top right, rgba(168,85,247,.20), transparent 30%);
    }

    .hero-content {
        position: relative;
        z-index: 2;
        padding: 45px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 30px;
        flex-wrap: wrap;
    }

    .hero-left {
        display: flex;
        align-items: center;
        gap: 25px;
        flex-wrap: wrap;
    }

    .hero-icon {
        width: 120px;
        height: 120px;
        border-radius: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg,#7c3aed,#9333ea);
        font-size: 50px;
        box-shadow: 0 15px 40px rgba(147,51,234,.35);
    }

    .hero-badge {
        display: inline-flex;
        padding: 10px 18px;
        border-radius: 50px;
        background: rgba(255,255,255,.08);
        color: #d8b4fe;
        font-size: 12px;
        font-weight: 700;
        margin-bottom: 15px;
    }

    .hero-content h1 {
        font-size: 48px;
        font-weight: 900;
        margin-bottom: 10px;
    }

    .hero-content p {
        color: #d1d5db;
        font-size: 15px;
    }

    .hero-btn {
        height: 56px;
        padding: 0 24px;
        border-radius: 18px;
        background: rgba(255,255,255,.08);
        color: white;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 10px;
        font-weight: 700;
        transition: .3s;
    }

        .hero-btn:hover {
            background: rgba(255,255,255,.15);
            color: white;
        }

    /* CARD */

    .password-card {
        max-width: 850px;
        margin: auto;
        background: linear-gradient(145deg,#111827,#1f2937);
        border-radius: 32px;
        padding: 40px;
        border: 1px solid rgba(255,255,255,.06);
        box-shadow: 0 20px 60px rgba(0,0,0,.35);
    }

    .card-header {
        display: flex;
        align-items: center;
        gap: 22px;
        margin-bottom: 35px;
    }

    .card-icon {
        width: 80px;
        height: 80px;
        border-radius: 24px;
        background: linear-gradient(135deg,#7c3aed,#9333ea);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 32px;
        box-shadow: 0 15px 35px rgba(147,51,234,.35);
    }

    .card-header h2 {
        font-size: 32px;
        font-weight: 800;
        margin-bottom: 8px;
    }

    .card-header p {
        color: #9ca3af;
    }

    /* ALERT */

    .success-alert,
    .error-alert {
        padding: 16px 18px;
        border-radius: 18px;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .success-alert {
        background: rgba(34,197,94,.12);
        border: 1px solid rgba(34,197,94,.2);
        color: #86efac;
    }

    .error-alert {
        background: rgba(239,68,68,.12);
        border: 1px solid rgba(239,68,68,.2);
        color: #fca5a5;
    }

    /* FORM */

    .form-group {
        margin-bottom: 25px;
    }

        .form-group label {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 12px;
            font-weight: 600;
        }

    .input-wrapper {
        position: relative;
    }

    .input-icon {
        position: absolute;
        left: 18px;
        top: 50%;
        transform: translateY(-50%);
        color: #9ca3af;
    }

    .custom-input {
        width: 100%;
        height: 58px;
        background: #0f172a;
        border: 1px solid rgba(255,255,255,.08);
        border-radius: 18px;
        padding-left: 52px;
        color: white;
    }

        .custom-input:focus {
            border-color: #9333ea;
            outline: none;
            box-shadow: 0 0 0 .2rem rgba(147,51,234,.2);
        }

    .text-danger {
        display: block;
        margin-top: 8px;
        font-size: 14px;
    }

    /* SECURITY */

    .security-box {
        margin-top: 10px;
        background: rgba(255,255,255,.03);
        border-radius: 22px;
        padding: 24px;
        display: flex;
        gap: 18px;
        align-items: flex-start;
    }

    .security-icon {
        width: 55px;
        height: 55px;
        border-radius: 18px;
        background: rgba(147,51,234,.15);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #c084fc;
        font-size: 24px;
    }

    .security-box h5 {
        margin-bottom: 6px;
        font-weight: 700;
    }

    .security-box p {
        color: #9ca3af;
        line-height: 1.7;
    }

    /* BUTTONS */

    .button-group {
        display: flex;
        gap: 16px;
        margin-top: 35px;
        flex-wrap: wrap;
    }

    .save-btn,
    .cancel-btn {
        flex: 1;
        height: 58px;
        border: none;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        font-weight: 700;
        text-decoration: none;
    }

    .save-btn {
        background: linear-gradient(135deg,#7c3aed,#9333ea);
        color: white;
    }

    .cancel-btn {
        background: rgba(255,255,255,.06);
        color: #d1d5db;
    }

        .cancel-btn:hover {
            background: rgba(255,255,255,.12);
            color: white;
        }

    /* RESPONSIVE */

    @@media(max-width:768px) {

        .hero-content {
            padding: 30px;
        }

            .hero-content h1 {
                font-size: 34px;
            }

        .password-card {
            padding: 28px;
        }

        .card-header {
            flex-direction: column;
            text-align: center;
        }

        .button-group {
            flex-direction: column;
        }

        .security-box {
            flex-direction: column;
        }
    }

</style>

@section Scripts {

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}
