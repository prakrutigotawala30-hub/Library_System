@model Library_Management_System.ViewModels.ChangePasswordViewModel

@{
    ViewData["Title"] = "Change Password";
    // Layout = "~/Areas/Member/Views/Shared/_MemberLayout.cshtml";
}

<div class="password-page">

    <!-- PAGE HEADER -->

    <div class="page-header">

        <div>

            <h1 class="page-title">
                Change Password
            </h1>

            <p class="page-subtitle">
                Keep your account secure with a strong password
            </p>

        </div>

    </div>

    <!-- CARD -->

    <div class="password-wrapper">

        <div class="password-card">

            <!-- ICON -->

            <div class="card-icon">
                <i class="bi bi-shield-lock-fill"></i>
            </div>

            <h2 class="card-title">
                Update Password
            </h2>

            <p class="card-subtitle">
                Enter your current password and choose a new secure password.
            </p>

            <!-- SUCCESS -->
            @if (TempData["success"] != null)
            {
                <div class="custom-alert success-alert">

                    <i class="bi bi-check-circle-fill"></i>

                    @TempData["success"]

                </div>
            }

            <!-- ERROR -->
            @if (TempData["error"] != null)
            {
                <div class="custom-alert error-alert">

                    <i class="bi bi-exclamation-circle-fill"></i>

                    @TempData["error"]

                </div>
            }

            <!-- FORM -->

            <form asp-action="ChangePassword"
                  method="post">

                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly"
                     class="validation-summary">
                </div>

                <!-- CURRENT PASSWORD -->

                <div class="form-group">

                    <label asp-for="CurrentPassword"
                           class="form-label">

                        Current Password

                    </label>

                    <div class="input-wrapper">

                        <i class="bi bi-lock-fill input-icon"></i>

                        <input asp-for="CurrentPassword"
                               type="password"
                               class="form-control custom-input"
                               placeholder="Enter current password" />

                    </div>

                    <span asp-validation-for="CurrentPassword"
                          class="text-danger">
                    </span>

                </div>

                <!-- NEW PASSWORD -->

                <div class="form-group">

                    <label asp-for="NewPassword"
                           class="form-label">

                        New Password

                    </label>

                    <div class="input-wrapper">

                        <i class="bi bi-key-fill input-icon"></i>

                        <input asp-for="NewPassword"
                               type="password"
                               class="form-control custom-input"
                               placeholder="Enter new password" />

                    </div>

                    <span asp-validation-for="NewPassword"
                          class="text-danger">
                    </span>

                </div>

                <!-- CONFIRM PASSWORD -->

                <div class="form-group">

                    <label asp-for="ConfirmPassword"
                           class="form-label">

                        Confirm Password

                    </label>

                    <div class="input-wrapper">

                        <i class="bi bi-check-circle-fill input-icon"></i>

                        <input asp-for="ConfirmPassword"
                               type="password"
                               class="form-control custom-input"
                               placeholder="Confirm new password" />

                    </div>

                    <span asp-validation-for="ConfirmPassword"
                          class="text-danger">
                    </span>

                </div>

                <!-- PASSWORD TIPS -->

                <div class="security-box">

                    <div class="security-icon">
                        <i class="bi bi-shield-check"></i>
                    </div>

                    <div>

                        <h5>
                            Password Tips
                        </h5>

                        <p>
                            Use at least 8 characters including uppercase,
                            lowercase, numbers and special symbols.
                        </p>

                    </div>

                </div>

                <!-- BUTTONS -->

                <div class="button-group">

                    <button type="submit"
                            class="save-btn">

                        <i class="bi bi-check-circle-fill"></i>

                        Update Password

                    </button>

                    <a asp-area="Member"
                       asp-controller="Profile"
                       asp-action="Index"
                       class="cancel-btn">

                        Cancel

                    </a>

                </div>

            </form>

        </div>

    </div>

</div>

<style>

    .password-page {
        width: 100%;
    }

    /* PAGE HEADER */

    .page-header {
        margin-bottom: 30px;
    }

    .page-title {
        font-size: 38px;
        font-weight: 800;
        color: white;
        margin-bottom: 8px;
    }

    .page-subtitle {
        color: #9ca3af;
        margin: 0;
        font-size: 15px;
    }

    /* WRAPPER */

    .password-wrapper {
        max-width: 700px;
        margin: auto;
    }

    /* CARD */

    .password-card {
        background: linear-gradient(145deg,#111827,#1f2937);
        border: 1px solid rgba(255,255,255,.06);
        border-radius: 30px;
        padding: 45px;
        box-shadow: 0 25px 60px rgba(0,0,0,.35);
    }

    /* ICON */

    .card-icon {
        width: 90px;
        height: 90px;
        margin: auto;
        margin-bottom: 22px;
        border-radius: 28px;
        background: linear-gradient(135deg,#7c3aed,#9333ea);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 38px;
        box-shadow: 0 15px 35px rgba(147,51,234,.35);
    }

    .card-title {
        text-align: center;
        color: white;
        font-size: 30px;
        font-weight: 800;
        margin-bottom: 10px;
    }

    .card-subtitle {
        text-align: center;
        color: #9ca3af;
        margin-bottom: 35px;
    }

    /* ALERTS */

    .custom-alert {
        padding: 16px 18px;
        border-radius: 16px;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        gap: 12px;
        font-weight: 500;
    }

    .success-alert {
        background: rgba(34,197,94,.12);
        color: #86efac;
        border: 1px solid rgba(34,197,94,.2);
    }

    .error-alert {
        background: rgba(239,68,68,.12);
        color: #fca5a5;
        border: 1px solid rgba(239,68,68,.2);
    }

    /* VALIDATION */

    .validation-summary {
        color: #fca5a5;
        margin-bottom: 20px;
    }

        .validation-summary ul {
            margin: 0;
            padding-left: 18px;
        }

    /* FORM */

    .form-group {
        margin-bottom: 24px;
    }

    .form-label {
        color: #f3f4f6;
        margin-bottom: 10px;
        font-weight: 600;
    }

    .input-wrapper {
        position: relative;
    }

    .input-icon {
        position: absolute;
        left: 18px;
        top: 50%;
        transform: translateY(-50%);
        color: #9ca3af;
        z-index: 10;
    }

    .custom-input {
        width: 100%;
        height: 58px;
        background: #0f172a;
        border: 1px solid rgba(255,255,255,.08);
        border-radius: 18px;
        padding-left: 52px;
        color: white;
        font-size: 15px;
    }

        .custom-input:focus {
            background: #0f172a;
            color: white;
            border-color: #9333ea;
            box-shadow: 0 0 0 .2rem rgba(147,51,234,.2);
        }

        .custom-input::placeholder {
            color: #6b7280;
        }

    .text-danger {
        font-size: 14px;
        margin-top: 6px;
        display: block;
    }

    /* SECURITY BOX */

    .security-box {
        margin-top: 10px;
        background: rgba(255,255,255,.04);
        border-radius: 20px;
        padding: 22px;
        display: flex;
        gap: 16px;
        align-items: flex-start;
    }

    .security-icon {
        width: 50px;
        height: 50px;
        border-radius: 14px;
        background: rgba(147,51,234,.18);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #c084fc;
        font-size: 22px;
    }

    .security-box h5 {
        color: white;
        margin-bottom: 6px;
        font-size: 17px;
        font-weight: 700;
    }

    .security-box p {
        color: #9ca3af;
        margin: 0;
        line-height: 1.7;
        font-size: 14px;
    }

    /* BUTTONS */

    .button-group {
        display: flex;
        gap: 16px;
        margin-top: 35px;
    }

    .save-btn {
        flex: 1;
        height: 58px;
        border: none;
        border-radius: 18px;
        background: linear-gradient(135deg,#7c3aed,#9333ea);
        color: white;
        font-weight: 700;
        transition: .3s;
    }

        .save-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 15px 30px rgba(147,51,234,.35);
        }

    .cancel-btn {
        flex: 1;
        height: 58px;
        border-radius: 18px;
        background: rgba(255,255,255,.06);
        color: #d1d5db;
        text-decoration: none;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        transition: .3s;
    }

        .cancel-btn:hover {
            background: rgba(255,255,255,.12);
            color: white;
        }

    /* RESPONSIVE */

    @@media(max-width:768px) {

        .password-card {
            padding: 28px;
        }

        .button-group {
            flex-direction: column;
        }

        .page-title {
            font-size: 28px;
        }

        .card-title {
            font-size: 24px;
        }
    }

</style>

@section Scripts {

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}
