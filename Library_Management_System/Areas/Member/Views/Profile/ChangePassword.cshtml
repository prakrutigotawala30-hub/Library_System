@model Library_Management_System.ViewModels.ChangePasswordViewModel

@{
    ViewData["Title"] = "Change Password";
}

<style>

    html,
    body {
        margin: 0;
        padding: 0;
        background: #050816;
        overflow-x: hidden;
    }

    .password-page {
        min-height: 100vh;
        padding: 35px;
        background: radial-gradient(circle at top right, rgba(147,51,234,.18), transparent 25%), radial-gradient(circle at bottom left, rgba(236,72,153,.12), transparent 30%), linear-gradient(to bottom,#050816,#0b1020);
    }

    .password-wrapper {
        max-width: 950px;
        margin: auto;
    }

    .password-card {
        background: rgba(8,12,24,.96);
        border-radius: 32px;
        overflow: hidden;
        box-shadow: 0 25px 60px rgba(0,0,0,.45);
    }

    /* HEADER */

    .password-header {
        padding: 38px 40px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 20px;
        background: linear-gradient( 135deg, rgba(147,51,234,.15), rgba(217,70,239,.06));
    }

        .password-header h2 {
            color: white;
            font-size: 34px;
            font-weight: 800;
            margin: 0 0 8px;
        }

        .password-header p {
            color: #9ca3af;
            margin: 0;
            font-size: 15px;
        }

    .back-btn {
        height: 55px;
        padding: 0 28px;
        border-radius: 18px;
        border: none;
        text-decoration: none;
        background: rgba(255,255,255,.05);
        color: white;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        transition: .3s;
    }

        .back-btn:hover {
            background: rgba(255,255,255,.1);
            color: white;
            transform: translateY(-3px);
        }

    /* BODY */

    .password-body {
        padding: 45px;
    }

    .password-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 28px;
    }

    .form-group {
        display: flex;
        flex-direction: column;
    }

        .form-group label {
            color: #d1d5db;
            margin-bottom: 10px;
            font-size: 15px;
            font-weight: 600;
        }

    .custom-input {
        height: 62px;
        border: none;
        border-radius: 20px;
        background: rgba(255,255,255,.05);
        color: white;
        padding: 0 22px;
        outline: none;
        font-size: 15px;
        transition: .3s;
    }

        .custom-input:focus {
            background: rgba(255,255,255,.08);
            box-shadow: 0 0 0 4px rgba(147,51,234,.18);
        }

        .custom-input::placeholder {
            color: #8b92a7;
        }

    .text-danger {
        margin-top: 8px;
        font-size: 14px;
    }

    .validation-summary-errors {
        margin-bottom: 25px;
        padding: 18px 20px;
        border-radius: 18px;
        background: rgba(239,68,68,.12);
        color: #fca5a5;
    }

        .validation-summary-errors ul {
            margin: 0;
            padding-left: 20px;
        }

    /* SECURITY BOX */

    .security-box {
        margin-top: 10px;
        padding: 24px;
        border-radius: 24px;
        background: rgba(255,255,255,.03);
    }

        .security-box h5 {
            color: white;
            margin-bottom: 10px;
            font-size: 18px;
            font-weight: 700;
        }

        .security-box p {
            color: #9ca3af;
            margin: 0;
            line-height: 1.7;
            font-size: 14px;
        }

    /* BUTTONS */

    .action-buttons {
        margin-top: 40px;
        display: flex;
        gap: 18px;
        flex-wrap: wrap;
    }

    .save-btn {
        height: 60px;
        padding: 0 40px;
        border: none;
        border-radius: 18px;
        background: linear-gradient(135deg,#9333ea,#d946ef);
        color: white;
        font-size: 15px;
        font-weight: 700;
        transition: .3s;
        box-shadow: 0 15px 30px rgba(168,85,247,.25);
    }

        .save-btn:hover {
            transform: translateY(-4px);
        }

    .cancel-btn {
        height: 60px;
        padding: 0 35px;
        border-radius: 18px;
        text-decoration: none;
        background: rgba(255,255,255,.05);
        color: white;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        transition: .3s;
    }

        .cancel-btn:hover {
            background: rgba(255,255,255,.1);
            color: white;
        }

    /* RESPONSIVE */

    @@media(max-width:768px) {

        .password-page {
            padding: 15px;
        }

        .password-header,
        .password-body {
            padding: 25px;
        }

        .password-header {
            flex-direction: column;
            align-items: flex-start;
        }

            .password-header h2 {
                font-size: 28px;
            }
    }

</style>

<div class="password-page">

    <div class="password-wrapper">

        <div class="password-card">

            <!-- HEADER -->

            <div class="password-header">

                <div>

                    <h2>
                        Change Password
                    </h2>

                    <p>
                        Update your password to keep your account secure
                    </p>

                </div>

                <a asp-area=""
                   asp-controller="Home"
                   asp-action="Index"
                   class="back-btn">

                    ← Back To Profile

                </a>

            </div>

            <!-- BODY -->

            <div class="password-body">

                <form method="post">

                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly"
                         class="text-danger">
                    </div>

                    <div class="password-grid">

                        <!-- CURRENT PASSWORD -->

                        <div class="form-group">

                            <label asp-for="CurrentPassword"></label>

                            <input asp-for="CurrentPassword"
                                   type="password"
                                   class="custom-input"
                                   placeholder="Enter current password" />

                            <span asp-validation-for="CurrentPassword"
                                  class="text-danger"></span>

                        </div>

                        <!-- NEW PASSWORD -->

                        <div class="form-group">

                            <label asp-for="NewPassword"></label>

                            <input asp-for="NewPassword"
                                   type="password"
                                   class="custom-input"
                                   placeholder="Enter new password" />

                            <span asp-validation-for="NewPassword"
                                  class="text-danger"></span>

                        </div>

                        <!-- CONFIRM PASSWORD -->

                        <div class="form-group">

                            <label asp-for="ConfirmPassword"></label>

                            <input asp-for="ConfirmPassword"
                                   type="password"
                                   class="custom-input"
                                   placeholder="Confirm new password" />

                            <span asp-validation-for="ConfirmPassword"
                                  class="text-danger"></span>

                        </div>

                    </div>

                    <!-- SECURITY NOTE -->

                    <div class="security-box">

                        <h5>
                            Password Security
                        </h5>

                        <p>
                            Use a strong password with uppercase letters,
                            lowercase letters, numbers and special characters
                            to improve account security.
                        </p>

                    </div>

                    <!-- BUTTONS -->

                    <div class="action-buttons">

                        <button type="submit"
                                class="save-btn">

                            Change Password

                        </button>

                        <a asp-area=""
                           asp-controller="Home"
                           asp-action="Index"
                           class="cancel-btn">

                            Cancel

                        </a>

                    </div>

                </form>

            </div>

        </div>

    </div>

</div>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

}