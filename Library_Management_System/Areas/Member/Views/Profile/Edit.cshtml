@model Library_Management_System.ViewModels.ProfileViewModel

@{
    // Layout = "~/Areas/Member/Views/Shared/_MemberLayout.cshtml";
    ViewData["Title"] = "Edit Profile";
}

<div class="profile-page">

    <!-- PAGE HEADER -->

    <div class="profile-header">

        <div>

            <h1>
                Edit Profile
            </h1>

            <p>
                Manage your personal information and account settings
            </p>

        </div>

        <a asp-area="Member"
           asp-controller="Profile"
           asp-action="Index"
           class="back-btn">

            <i class="bi bi-arrow-left"></i>

            Back To Profile

        </a>

    </div>

    <!-- SUCCESS MESSAGE -->
    @if (TempData["success"] != null)
    {
        <div class="success-alert">

            <i class="bi bi-check-circle-fill"></i>

            @TempData["success"]

        </div>
    }

    <!-- PROFILE CARD -->

    <div class="profile-card">

        <!-- LEFT SIDE -->

        <div class="profile-sidebar">

            <div class="avatar-wrapper">

                @if (!string.IsNullOrEmpty(Model.ProfileImagePath))
                {
                    <img src="@Model.ProfileImagePath"
                         class="profile-image" />
                }
                else
                {
                    <div class="profile-avatar">

                        @(string.IsNullOrEmpty(Model.Name)
                                            ? "U"
                                            : Model.Name.Substring(0, 1).ToUpper())

                    </div>
                }

            </div>

            <h3 class="member-name">
                @Model.Name
            </h3>

            <p class="member-role">
                Library Member
            </p>

            <a asp-area="Member"
               asp-controller="Profile"
               asp-action="Avatar"
               class="upload-btn">

                <i class="bi bi-camera"></i>

                Change Photo

            </a>

            <div class="member-stats">

                <div class="stat-box">

                    <i class="bi bi-shield-check"></i>

                    <span>
                        Secure Account
                    </span>

                </div>

                <div class="stat-box">

                    <i class="bi bi-bell"></i>

                    <span>
                        Notifications
                        @(Model.NotificationPrefs ? "Enabled" : "Disabled")
                    </span>

                </div>

            </div>

        </div>

        <!-- RIGHT SIDE -->

        <div class="profile-content">

            <form method="post">

                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly"
                     class="validation-box">
                </div>

                <div class="form-grid">

                    <!-- NAME -->

                    <div class="form-group">

                        <label asp-for="Name">

                            <i class="bi bi-person"></i>

                            Full Name

                        </label>

                        <input asp-for="Name"
                               class="custom-input"
                               placeholder="Enter your full name" />

                        <span asp-validation-for="Name"
                              class="text-danger">
                        </span>

                    </div>

                    <!-- PHONE -->

                    <div class="form-group">

                        <label asp-for="Phone">

                            <i class="bi bi-telephone"></i>

                            Phone Number

                        </label>

                        <input asp-for="Phone"
                               class="custom-input"
                               placeholder="Enter phone number" />

                        <span asp-validation-for="Phone"
                              class="text-danger">
                        </span>

                    </div>

                    <!-- NOTIFICATION -->

                    <div class="form-group full-width">

                        <div class="notification-box">

                            <div>

                                <h5>
                                    Email Notifications
                                </h5>

                                <p>
                                    Receive reminders and library updates
                                </p>

                            </div>

                            <label class="switch">

                                <input asp-for="NotificationPrefs" />

                                <span class="slider"></span>

                            </label>

                        </div>

                    </div>

                </div>

                <!-- ACTION BUTTONS -->

                <div class="button-group">

                    <button type="submit"
                            class="save-btn">

                        <i class="bi bi-check-circle"></i>

                        Save Changes

                    </button>

                    <a asp-area="Member"
                       asp-controller="Profile"
                       asp-action="ChangePassword"
                       class="password-btn">

                        <i class="bi bi-shield-lock"></i>

                        Change Password

                    </a>

                </div>

            </form>

        </div>

    </div>

</div>

<style>

    body {
        background: #050816;
        color: white;
        font-family: 'Inter', sans-serif;
    }

    .profile-page {
        width: 100%;
    }

    /* HEADER */

    .profile-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        flex-wrap: wrap;
        gap: 16px;
    }

        .profile-header h1 {
            font-size: 38px;
            font-weight: 800;
            color: white;
            margin-bottom: 8px;
        }

        .profile-header p {
            color: #9ca3af;
            margin: 0;
            font-size: 15px;
        }

    .back-btn {
        height: 52px;
        padding: 0 22px;
        border-radius: 16px;
        background: rgba(255,255,255,.06);
        color: white;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 10px;
        font-weight: 600;
        transition: .3s;
    }

        .back-btn:hover {
            background: rgba(255,255,255,.12);
            color: white;
        }

    /* ALERT */

    .success-alert {
        background: rgba(34,197,94,.12);
        border: 1px solid rgba(34,197,94,.25);
        color: #86efac;
        padding: 16px 20px;
        border-radius: 18px;
        margin-bottom: 25px;
        display: flex;
        align-items: center;
        gap: 12px;
        font-weight: 600;
    }

    .validation-box {
        background: rgba(239,68,68,.12);
        border: 1px solid rgba(239,68,68,.25);
        color: #fca5a5;
        border-radius: 18px;
        padding: 18px;
        margin-bottom: 25px;
    }

    /* CARD */

    .profile-card {
        background: linear-gradient(145deg,#111827,#1f2937);
        border-radius: 32px;
        overflow: hidden;
        display: grid;
        grid-template-columns: 320px 1fr;
        border: 1px solid rgba(255,255,255,.06);
        box-shadow: 0 20px 60px rgba(0,0,0,.35);
    }

    /* SIDEBAR */

    .profile-sidebar {
        padding: 40px 30px;
        border-right: 1px solid rgba(255,255,255,.06);
        text-align: center;
        background: rgba(255,255,255,.02);
    }

    .avatar-wrapper {
        margin-bottom: 20px;
    }

    .profile-image,
    .profile-avatar {
        width: 130px;
        height: 130px;
        border-radius: 50%;
        margin: auto;
    }

    .profile-image {
        object-fit: cover;
        border: 4px solid rgba(147,51,234,.35);
    }

    .profile-avatar {
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg,#7c3aed,#9333ea);
        font-size: 45px;
        font-weight: 800;
    }

    .member-name {
        font-size: 28px;
        font-weight: 800;
        margin-bottom: 6px;
    }

    .member-role {
        color: #9ca3af;
        margin-bottom: 24px;
    }

    .upload-btn {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 12px 20px;
        border-radius: 16px;
        background: rgba(147,51,234,.15);
        color: #d8b4fe;
        text-decoration: none;
        font-weight: 700;
        transition: .3s;
        margin-bottom: 30px;
    }

        .upload-btn:hover {
            color: white;
            background: rgba(147,51,234,.25);
        }

    .member-stats {
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .stat-box {
        background: rgba(255,255,255,.04);
        padding: 16px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        gap: 12px;
        color: #d1d5db;
    }

    /* CONTENT */

    .profile-content {
        padding: 40px;
    }

    .form-grid {
        display: grid;
        grid-template-columns: repeat(2,1fr);
        gap: 24px;
    }

    .form-group {
        display: flex;
        flex-direction: column;
    }

    .full-width {
        grid-column: span 2;
    }

    .form-group label {
        margin-bottom: 12px;
        color: #e5e7eb;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .custom-input {
        height: 58px;
        border-radius: 18px;
        border: 1px solid rgba(255,255,255,.08);
        background: #0f172a;
        color: white;
        padding: 0 18px;
        outline: none;
        transition: .3s;
    }

        .custom-input:focus {
            border-color: #9333ea;
            box-shadow: 0 0 0 .2rem rgba(147,51,234,.2);
        }

        .custom-input::placeholder {
            color: #6b7280;
        }

    /* NOTIFICATION */

    .notification-box {
        background: rgba(255,255,255,.03);
        border-radius: 22px;
        padding: 24px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

        .notification-box h5 {
            margin-bottom: 6px;
            font-weight: 700;
        }

        .notification-box p {
            margin: 0;
            color: #9ca3af;
        }

    /* SWITCH */

    .switch {
        position: relative;
        display: inline-block;
        width: 60px;
        height: 32px;
    }

        .switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

    .slider {
        position: absolute;
        cursor: pointer;
        inset: 0;
        background: #374151;
        border-radius: 50px;
        transition: .3s;
    }

        .slider:before {
            position: absolute;
            content: "";
            width: 24px;
            height: 24px;
            left: 4px;
            bottom: 4px;
            background: white;
            border-radius: 50%;
            transition: .3s;
        }

    input:checked + .slider {
        background: #9333ea;
    }

        input:checked + .slider:before {
            transform: translateX(28px);
        }

    /* BUTTONS */

    .button-group {
        display: flex;
        gap: 16px;
        margin-top: 30px;
        flex-wrap: wrap;
    }

    .save-btn,
    .password-btn {
        height: 56px;
        padding: 0 28px;
        border-radius: 18px;
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        font-weight: 700;
        transition: .3s;
        text-decoration: none;
    }

    .save-btn {
        background: linear-gradient(135deg,#7c3aed,#9333ea);
        color: white;
        box-shadow: 0 15px 30px rgba(147,51,234,.35);
    }

        .save-btn:hover {
            transform: translateY(-2px);
        }

    .password-btn {
        background: rgba(255,255,255,.06);
        color: #d1d5db;
    }

        .password-btn:hover {
            background: rgba(255,255,255,.12);
            color: white;
        }

    .text-danger {
        margin-top: 8px;
        font-size: 14px;
    }

    /* MOBILE */

    @@media(max-width:991px) {

        .profile-card {
            grid-template-columns: 1fr;
        }

        .profile-sidebar {
            border-right: none;
            border-bottom: 1px solid rgba(255,255,255,.06);
        }

        .form-grid {
            grid-template-columns: 1fr;
        }

        .full-width {
            grid-column: span 1;
        }
    }

    @@media(max-width:768px) {

        .profile-content,
        .profile-sidebar {
            padding: 25px;
        }

        .profile-header h1 {
            font-size: 30px;
        }

        .button-group {
            flex-direction: column;
        }

        .notification-box {
            flex-direction: column;
            align-items: flex-start;
            gap: 20px;
        }
    }

</style>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

}
