@model Library_Management_System.ViewModels.ProfileViewModel

@{
    ViewData["Title"] = "Edit Profile";
    Layout = "~/Areas/Member/Views/Shared/_MemberLayout.cshtml";
}


<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

<div class="profile-page">

    <!-- HERO SECTION -->

    <div class="profile-hero">

        <div class="hero-overlay"></div>

        <div class="hero-content">

            <div class="hero-left">

                <div class="hero-avatar-wrapper">

                    @if (!string.IsNullOrEmpty(Model.ProfileImagePath))
                    {
                        <img src="@Model.ProfileImagePath"
                             class="hero-avatar" />
                    }
                    else
                    {
                        <div class="hero-avatar-text">

                            @(string.IsNullOrEmpty(Model.Name)
                                                    ? "U"
                                                    : Model.Name.Substring(0, 1).ToUpper())

                        </div>
                    }

                </div>

                <div>

                    <div class="hero-badge">
                        ✨ EDIT ACCOUNT DETAILS
                    </div>

                    <h1>
                        Edit Your Profile
                    </h1>

                    <p>
                        Manage your personal details and customize your library account.
                    </p>

                </div>

            </div>

            <a asp-area="Member"
               asp-controller="Profile"
               asp-action="Index"
               class="hero-btn">

                <i class="bi bi-arrow-left"></i>

                Back To Profile

            </a>

        </div>

    </div>

    <!-- MAIN CARD -->

    <div class="profile-card">

        <!-- SIDEBAR -->

        <div class="profile-sidebar">

            <div class="avatar-wrapper">

                @if (!string.IsNullOrEmpty(Model.ProfileImagePath))
                {
                    <img src="@Model.ProfileImagePath"
                         class="profile-image" />
                }
                else
                {
                    <div class="profile-avatar">

                        @(string.IsNullOrEmpty(Model.Name)
                                            ? "U"
                                            : Model.Name.Substring(0, 1).ToUpper())

                    </div>
                }

            </div>

            <h3 class="member-name">
                @Model.Name
            </h3>

            <p class="member-role">
                Premium Library Member
            </p>

            <a asp-area="Member"
               asp-controller="Profile"
               asp-action="Avatar"
               class="upload-btn">

                <i class="bi bi-camera-fill"></i>

                Change Photo

            </a>

        </div>

        <!-- CONTENT -->

        <div class="profile-content">

            @if (TempData["success"] != null)
            {
                <div class="success-alert">

                    <i class="bi bi-check-circle-fill"></i>

                    @TempData["success"]

                </div>
            }

            <form method="post">

                @Html.AntiForgeryToken()

                <div class="form-grid">

                    <!-- NAME -->

                    <div class="form-group">

                        <label asp-for="Name">

                            <i class="bi bi-person-fill"></i>

                            Full Name

                        </label>

                        <input asp-for="Name"
                               class="custom-input"
                               placeholder="Enter your full name" />

                    </div>

                    <!-- PHONE -->

                    <div class="form-group">

                        <label asp-for="Phone">

                            <i class="bi bi-telephone-fill"></i>

                            Phone Number

                        </label>

                        <input asp-for="Phone"
                               class="custom-input"
                               placeholder="Enter phone number" />

                    </div>

                    <!-- NOTIFICATIONS -->

                    <div class="notification-box">

                        <div>

                            <h5>
                                Email Notifications
                            </h5>

                            <p>
                                Receive reminders and library updates.
                            </p>

                        </div>

                        <label class="switch">

                            <input asp-for="NotificationPrefs" />

                            <span class="slider"></span>

                        </label>

                    </div>

                </div>

                <!-- BUTTONS -->

                <div class="button-group">

                    <button type="submit"
                            class="save-btn">

                        <i class="bi bi-check-circle-fill"></i>

                        Save Changes

                    </button>

                    <a asp-area="Member"
                       asp-controller="Profile"
                       asp-action="ChangePassword"
                       class="password-btn">

                        <i class="bi bi-shield-lock-fill"></i>

                        Change Password

                    </a>

                </div>

            </form>

        </div>

    </div>

</div>

<style>

    @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Inter',sans-serif;
        background: radial-gradient(circle at top left, rgba(124,58,237,.18), transparent 25%), radial-gradient(circle at bottom right, rgba(236,72,153,.14), transparent 25%), #050816;
        color: white;
        overflow-x: hidden;
    }

    /* REMOVE NAVBAR */

    .navbar,
    .top-navbar,
    .header,
    .member-navbar,
    nav {
        display: none !important;
    }

    .main-content,
    .page-content,
    .content-wrapper,
    .container-fluid {
        margin-top: 0 !important;
        padding-top: 0 !important;
    }

    .profile-page {
        width: 100%;
        min-height: 100vh;
        padding: 35px 24px 80px;
    }

    /* HERO */

    .profile-hero {
        position: relative;
        overflow: hidden;
        border-radius: 36px;
        margin-bottom: 35px;
        background: linear-gradient(rgba(7,11,26,.86), rgba(15,23,42,.92)), url('/images/library-banner.png');
        background-size: cover;
        background-position: center;
        border: 1px solid rgba(255,255,255,.06);
        box-shadow: 0 25px 60px rgba(0,0,0,.35);
    }

    .hero-overlay {
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at top right, rgba(168,85,247,.20), transparent 30%);
    }

    .hero-content {
        position: relative;
        z-index: 2;
        padding: 45px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 30px;
        flex-wrap: wrap;
    }

    .hero-left {
        display: flex;
        align-items: center;
        gap: 25px;
        flex-wrap: wrap;
    }

    .hero-avatar,
    .hero-avatar-text {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        border: 5px solid rgba(255,255,255,.12);
    }

    .hero-avatar {
        object-fit: cover;
    }

    .hero-avatar-text {
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg,#7c3aed,#9333ea);
        font-size: 42px;
        font-weight: 800;
    }

    .hero-badge {
        display: inline-flex;
        padding: 10px 18px;
        border-radius: 50px;
        background: rgba(255,255,255,.08);
        color: #d8b4fe;
        font-size: 12px;
        font-weight: 700;
        margin-bottom: 15px;
    }

    .hero-content h1 {
        font-size: 48px;
        font-weight: 900;
        margin-bottom: 10px;
    }

    .hero-content p {
        color: #d1d5db;
        font-size: 15px;
    }

    .hero-btn {
        height: 56px;
        padding: 0 24px;
        border-radius: 18px;
        background: rgba(255,255,255,.08);
        color: white;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 10px;
        font-weight: 700;
        transition: .3s;
    }

        .hero-btn:hover {
            background: rgba(255,255,255,.15);
            color: white;
        }

    /* CARD */

    .profile-card {
        background: linear-gradient(145deg,#111827,#1f2937);
        border-radius: 32px;
        overflow: hidden;
        display: grid;
        grid-template-columns: 320px 1fr;
        border: 1px solid rgba(255,255,255,.06);
        box-shadow: 0 20px 60px rgba(0,0,0,.35);
    }

    /* SIDEBAR */

    .profile-sidebar {
        padding: 40px 30px;
        border-right: 1px solid rgba(255,255,255,.06);
        text-align: center;
        background: rgba(255,255,255,.02);
    }

    .profile-image,
    .profile-avatar {
        width: 130px;
        height: 130px;
        border-radius: 50%;
        margin: auto;
    }

    .profile-image {
        object-fit: cover;
        border: 4px solid rgba(147,51,234,.35);
    }

    .profile-avatar {
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg,#7c3aed,#9333ea);
        font-size: 45px;
        font-weight: 800;
    }

    .member-name {
        font-size: 28px;
        font-weight: 800;
        margin: 20px 0 6px;
    }

    .member-role {
        color: #9ca3af;
    }

    .upload-btn {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 12px 22px;
        border-radius: 16px;
        background: rgba(147,51,234,.15);
        color: #d8b4fe;
        text-decoration: none;
        margin-top: 24px;
        font-weight: 700;
    }

    /* CONTENT */

    .profile-content {
        padding: 40px;
    }

    .success-alert {
        background: rgba(34,197,94,.12);
        border: 1px solid rgba(34,197,94,.2);
        color: #86efac;
        padding: 16px 18px;
        border-radius: 18px;
        margin-bottom: 25px;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .form-grid {
        display: grid;
        grid-template-columns: repeat(2,1fr);
        gap: 24px;
    }

    .form-group {
        display: flex;
        flex-direction: column;
    }

        .form-group label {
            margin-bottom: 12px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 10px;
        }

    .custom-input {
        height: 58px;
        border-radius: 18px;
        border: 1px solid rgba(255,255,255,.08);
        background: #0f172a;
        color: white;
        padding: 0 18px;
    }

        .custom-input:focus {
            border-color: #9333ea;
            outline: none;
            box-shadow: 0 0 0 .2rem rgba(147,51,234,.2);
        }

    .notification-box {
        grid-column: span 2;
        background: rgba(255,255,255,.03);
        border-radius: 22px;
        padding: 24px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

        .notification-box h5 {
            margin-bottom: 5px;
            font-weight: 700;
        }

        .notification-box p {
            color: #9ca3af;
            margin: 0;
        }

    .switch {
        position: relative;
        width: 60px;
        height: 32px;
    }

        .switch input {
            opacity: 0;
        }

    .slider {
        position: absolute;
        inset: 0;
        background: #374151;
        border-radius: 50px;
        cursor: pointer;
    }

        .slider:before {
            content: "";
            position: absolute;
            width: 24px;
            height: 24px;
            left: 4px;
            bottom: 4px;
            background: white;
            border-radius: 50%;
            transition: .3s;
        }

    input:checked + .slider {
        background: #9333ea;
    }

        input:checked + .slider:before {
            transform: translateX(28px);
        }

    /* BUTTONS */

    .button-group {
        display: flex;
        gap: 16px;
        margin-top: 35px;
        flex-wrap: wrap;
    }

    .save-btn,
    .password-btn {
        height: 56px;
        padding: 0 28px;
        border: none;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        font-weight: 700;
        text-decoration: none;
    }

    .save-btn {
        background: linear-gradient(135deg,#7c3aed,#9333ea);
        color: white;
    }

    .password-btn {
        background: rgba(255,255,255,.06);
        color: #d1d5db;
    }

        .password-btn:hover {
            background: rgba(255,255,255,.12);
            color: white;
        }

    /* RESPONSIVE */

    @@media(max-width:991px) {

        .profile-card {
            grid-template-columns: 1fr;
        }

        .profile-sidebar {
            border-right: none;
            border-bottom: 1px solid rgba(255,255,255,.06);
        }

        .form-grid {
            grid-template-columns: 1fr;
        }

        .notification-box {
            grid-column: span 1;
        }
    }

    @@media(max-width:768px) {

        .hero-content {
            padding: 30px;
        }

            .hero-content h1 {
                font-size: 34px;
            }

        .profile-content,
        .profile-sidebar {
            padding: 25px;
        }

        .button-group {
            flex-direction: column;
        }

        .notification-box {
            flex-direction: column;
            align-items: flex-start;
            gap: 20px;
        }
    }

</style>
