@model Library_Management_System.ViewModels.MemberDashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Areas/Member/Views/Shared/_MemberLayout.cshtml";

    var memberName = ViewBag.MemberName;
    DateTime memberSince = ViewBag.MemberSince;
    DateTime membershipTill = ViewBag.MembershipTill;
    int daysLeft = ViewBag.DaysLeft;
}

<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

<style>

    @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        background: #070b17;
        color: white;
        font-family: 'Inter',sans-serif;
    }

    .dashboard-page {
        padding: 28px;
        max-width: 1600px;
        margin: auto;
    }

    .dashboard-header {
        display: flex;
        justify-content: space-between;
        gap: 24px;
        align-items: center;
        flex-wrap: wrap;
        margin-bottom: 30px;
    }

    .header-left h1 {
        font-size: 44px;
        font-weight: 900;
        margin-bottom: 12px;
    }

    .header-left p {
        color: #94a3b8;
        max-width: 650px;
        line-height: 1.8;
    }

    .member-card {
        width: 360px;
        background: linear-gradient(145deg,#111827,#0f172a);
        border: 1px solid rgba(255,255,255,.06);
        border-radius: 28px;
        padding: 28px;
        position: relative;
        overflow: hidden;
        box-shadow: 0 20px 50px rgba(0,0,0,.35);
    }

        .member-card::before {
            content: '';
            position: absolute;
            width: 180px;
            height: 180px;
            border-radius: 50%;
            background: rgba(124,58,237,.15);
            top: -70px;
            right: -70px;
        }

    .member-top {
        display: flex;
        gap: 16px;
        align-items: center;
        margin-bottom: 22px;
        position: relative;
        z-index: 2;
    }

    .member-icon {
        width: 70px;
        height: 70px;
        border-radius: 20px;
        background: linear-gradient(135deg,#7c3aed,#a855f7);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 26px;
        box-shadow: 0 15px 40px rgba(124,58,237,.4);
    }

    .member-title {
        font-size: 22px;
        font-weight: 800;
    }

    .member-sub {
        color: #c4b5fd;
        margin-top: 4px;
    }

    .member-progress {
        height: 12px;
        border-radius: 50px;
        overflow: hidden;
        background: rgba(255,255,255,.05);
        margin: 20px 0 12px;
    }

        .member-progress span {
            display: block;
            height: 100%;
            width: 78%;
            border-radius: 50px;
            background: linear-gradient(90deg,#7c3aed,#d946ef);
        }

    .member-date {
        color: #cbd5e1;
        font-size: 14px;
        line-height: 1.8;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: 22px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: linear-gradient(145deg,#111827,#0f172a);
        border: 1px solid rgba(255,255,255,.06);
        border-radius: 28px;
        padding: 28px;
        transition: .35s ease;
        position: relative;
        overflow: hidden;
    }

        .stat-card:hover {
            transform: translateY(-8px);
            border-color: rgba(168,85,247,.35);
        }

        .stat-card::before {
            content: '';
            position: absolute;
            width: 120px;
            height: 120px;
            border-radius: 50%;
            background: rgba(168,85,247,.08);
            right: -30px;
            top: -30px;
        }

    .stat-icon {
        width: 68px;
        height: 68px;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        margin-bottom: 22px;
        color: white;
    }

    .purple {
        background: linear-gradient(135deg,#7c3aed,#9333ea);
    }

    .green {
        background: linear-gradient(135deg,#059669,#10b981);
    }

    .red {
        background: linear-gradient(135deg,#dc2626,#ef4444);
    }

    .orange {
        background: linear-gradient(135deg,#ea580c,#fb923c);
    }

    .stat-title {
        color: #94a3b8;
        margin-bottom: 10px;
    }

    .stat-value {
        font-size: 42px;
        font-weight: 900;
    }

    .dashboard-card {
        background: linear-gradient(145deg,#111827,#0f172a);
        border: 1px solid rgba(255,255,255,.06);
        border-radius: 28px;
        padding: 28px;
        margin-bottom: 28px;
    }

    .card-title {
        font-size: 24px;
        font-weight: 800;
        margin-bottom: 24px;
    }

    .reading-progress {
        display: flex;
        align-items: center;
        gap: 24px;
    }

    .progress-circle {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        background: conic-gradient(#8b5cf6 72%, rgba(255,255,255,.08) 0);
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
    }

        .progress-circle::before {
            content: '';
            position: absolute;
            width: 88px;
            height: 88px;
            border-radius: 50%;
            background: #111827;
        }

        .progress-circle::after {
            content: '72%';
            position: absolute;
            font-size: 24px;
            font-weight: 800;
        }

    .text-muted-custom {
        color: #94a3b8;
        line-height: 1.8;
    }

    .main-grid {
        display: grid;
        grid-template-columns: 1.7fr 1fr;
        gap: 28px;
    }

    .table-wrap {
        overflow: auto;
    }

    .books-table {
        width: 100%;
        border-collapse: collapse;
    }

        .books-table th {
            color: #94a3b8;
            font-size: 13px;
            padding: 16px;
            border-bottom: 1px solid rgba(255,255,255,.06);
            text-align: left;
        }

        .books-table td {
            padding: 18px 16px;
            border-bottom: 1px solid rgba(255,255,255,.05);
        }

        .books-table tr:hover {
            background: rgba(255,255,255,.03);
        }

    .book-name {
        font-weight: 700;
    }

    .status {
        padding: 8px 15px;
        border-radius: 40px;
        font-size: 12px;
        font-weight: 700;
    }

    .active {
        background: rgba(16,185,129,.18);
        color: #34d399;
    }

    .overdue {
        background: rgba(239,68,68,.18);
        color: #f87171;
    }

    .quick-actions {
        display: grid;
        gap: 16px;
    }

    .quick-btn {
        display: flex;
        align-items: center;
        gap: 18px;
        text-decoration: none;
        color: white;
        padding: 18px;
        border-radius: 20px;
        background: rgba(255,255,255,.03);
        border: 1px solid rgba(255,255,255,.05);
        transition: .35s ease;
    }

        .quick-btn:hover {
            background: linear-gradient(135deg,#7c3aed,#9333ea);
            transform: translateY(-5px);
            color: white;
        }

        .quick-btn i {
            width: 54px;
            height: 54px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(255,255,255,.08);
            font-size: 20px;
        }

    .quick-title {
        font-weight: 700;
        margin-bottom: 5px;
    }

    .quick-sub {
        color: #cbd5e1;
        font-size: 13px;
    }

    .activity-item {
        display: flex;
        gap: 16px;
        padding: 18px;
        border-radius: 20px;
        background: rgba(255,255,255,.03);
        margin-bottom: 16px;
        transition: .35s ease;
    }

        .activity-item:hover {
            transform: translateY(-4px);
            background: rgba(255,255,255,.05);
        }

    .activity-icon {
        width: 54px;
        height: 54px;
        min-width: 54px;
        border-radius: 16px;
        background: linear-gradient(135deg,#7c3aed,#9333ea);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .activity-title {
        font-weight: 700;
        margin-bottom: 6px;
    }

    .activity-date {
        color: #94a3b8;
        font-size: 13px;
        margin-top: 6px;
    }

    .empty-box {
        text-align: center;
        padding: 50px 20px;
        color: #94a3b8;
    }

        .empty-box i {
            font-size: 60px;
            margin-bottom: 18px;
            color: #7c3aed;
        }

        .empty-box h5 {
            color: white;
            margin-bottom: 10px;
            font-size: 22px;
            font-weight: 700;
        }

    @@media(max-width:1200px) {

        .stats-grid {
            grid-template-columns: repeat(2,1fr);
        }

        .main-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media(max-width:768px) {

        .dashboard-page {
            padding: 16px;
        }

        .stats-grid {
            grid-template-columns: 1fr;
        }

        .member-card {
            width: 100%;
        }

        .header-left h1 {
            font-size: 34px;
        }
    }
</style>

<div class="dashboard-page">

    <!-- HEADER -->

    <div class="dashboard-header">

        <div class="header-left">

            <h1>
                Welcome Back, @memberName 👋
            </h1>

            <p>
                Manage your borrowed books, track due dates,
                view recent activities and explore your library membership.
            </p>

        </div>

        <div class="member-card">

            <div class="member-top">

                <div class="member-icon">
                    <i class="fa-solid fa-crown"></i>
                </div>

                <div>

                    <div class="member-title">
                        Premium Member
                    </div>

                    <div class="member-sub">
                        Active Membership
                    </div>

                </div>

            </div>

            <div class="member-progress">
                <span></span>
            </div>

            <div class="member-date">

                <div>
                    Member Since :
                    <b>@memberSince.ToString("dd MMM yyyy")</b>
                </div>

                <div>
                    Membership Till :
                    <b>@membershipTill.ToString("dd MMM yyyy")</b>
                </div>

                <div>
                    Remaining :
                    <b>@daysLeft Days</b>
                </div>

            </div>

        </div>

    </div>

    <!-- STATS -->

    <div class="stats-grid">

        <div class="stat-card">

            <div class="stat-icon purple">
                <i class="fa-solid fa-book"></i>
            </div>

            <div class="stat-title">
                Borrowed Books
            </div>

            <div class="stat-value">
                @Model.CurrentBorrows
            </div>

        </div>

        <div class="stat-card">

            <div class="stat-icon green">
                <i class="fa-solid fa-check"></i>
            </div>

            <div class="stat-title">
                Returned Books
            </div>

            <div class="stat-value">
                @Model.ReturnedBooks
            </div>

        </div>

        <div class="stat-card">

            <div class="stat-icon red">
                <i class="fa-solid fa-clock"></i>
            </div>

            <div class="stat-title">
                Overdue Books
            </div>

            <div class="stat-value">
                @Model.Overdue
            </div>

        </div>

        <div class="stat-card">

            <div class="stat-icon orange">
                <i class="fa-solid fa-heart"></i>
            </div>

            <div class="stat-title">
                Wishlist Books
            </div>

            <div class="stat-value">
                @Model.WishListCount
            </div>

        </div>

    </div>

    <!-- MAIN -->

    <div class="main-grid">

        <!-- LEFT -->

        <div>

            <!-- CURRENT BORROWED -->

            <div class="dashboard-card">

                <div class="d-flex justify-content-between align-items-center mb-4">

                    <div class="card-title mb-0">
                        Current Borrowed Books
                    </div>

                </div>

                @if (Model.MyBooks != null && Model.MyBooks.Any())
                {
                    <div class="table-wrap">

                        <table class="books-table">

                            <thead>

                                <tr>

                                    <th>Book</th>
                                    <th>Author</th>
                                    <th>Borrowed</th>
                                    <th>Due Date</th>
                                    <th>Status</th>

                                </tr>

                            </thead>

                            <tbody>

                                @foreach (var book in Model.MyBooks.Take(3))
                                {
                                    <tr>

                                        <td class="book-name">
                                            @book.BookTitle
                                        </td>

                                        <td>
                                            @book.Author
                                        </td>

                                        <td>
                                            @book.IssueDate.ToString("dd MMM yyyy")
                                        </td>

                                        <td>
                                            @book.DueDate.ToString("dd MMM yyyy")
                                        </td>

                                        <td>

                                            @if (book.DueDate < DateTime.Now)
                                            {
                                                <span class="status overdue">
                                                    Overdue
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="status active">
                                                    Active
                                                </span>
                                            }

                                        </td>

                                    </tr>
                                }

                            </tbody>

                        </table>

                    </div>
                }
                else
                {
                    <div class="empty-box">

                        <i class="fa-solid fa-book-open-reader"></i>

                        <h5>
                            No Borrowed Books
                        </h5>

                        <p>
                            You currently have no active borrowed books.
                        </p>

                    </div>
                }

            </div>

            <!-- UPCOMING DUE -->
            @if (Model.MyBooks != null && Model.MyBooks.Any())
            {
                <div class="dashboard-card">

                    <div class="card-title">
                        Upcoming Due Books
                    </div>

                    @foreach (var item in Model.MyBooks
                                    .Where(x => x.DueDate >= DateTime.Now)
                                    .OrderBy(x => x.DueDate)
                                    .Take(3))
                    {
                        var remainingDays = (item.DueDate - DateTime.Now).Days;

                        <div class="activity-item">

                            <div class="activity-icon">
                                <i class="fa-solid fa-calendar-days"></i>
                            </div>

                            <div class="w-100">

                                <div class="d-flex justify-content-between">

                                    <div class="activity-title">
                                        @item.BookTitle
                                    </div>

                                    <span class="status active">
                                        @remainingDays Days Left
                                    </span>

                                </div>

                                <div class="activity-date">
                                    Due on @item.DueDate.ToString("dd MMM yyyy")
                                </div>

                            </div>

                        </div>
                    }

                </div>
            }

            <!-- RECENTLY RETURNED -->
            @if (Model.RecentActivity != null && Model.RecentActivity.Any())
            {
                <div class="dashboard-card">

                    <div class="card-title">
                        Recently Returned Books
                    </div>

                    @foreach (var activity in Model.RecentActivity
                                    .Where(x => x.Activity.Contains("Returned"))
                                    .Take(3))
                    {
                        <div class="activity-item">

                            <div class="activity-icon">
                                <i class="fa-solid fa-check"></i>
                            </div>

                            <div>

                                <div class="activity-title">
                                    @activity.Activity
                                </div>

                                <div class="activity-date">
                                    @activity.ActivityDate.ToString("dd MMM yyyy hh:mm tt")
                                </div>

                            </div>

                        </div>
                    }

                </div>
            }

        </div>

        <!-- RIGHT -->

        <div>

            <!-- QUICK ACTIONS -->

            <div class="dashboard-card">

                <div class="card-title">
                    Quick Actions
                </div>

                <div class="quick-actions">

                    <a asp-controller="Catalog"
                       asp-action="Index"
                       asp-area=""
                       class="quick-btn">

                        <i class="fa-solid fa-book-open"></i>

                        <div>

                            <div class="quick-title">
                                Browse Books
                            </div>

                            <div class="quick-sub">
                                Explore all books
                            </div>

                        </div>

                    </a>

                    <a asp-controller="Wishlist"
                       asp-action="Index"
                       asp-area="Member"
                       class="quick-btn">

                        <i class="fa-solid fa-heart"></i>

                        <div>

                            <div class="quick-title">
                                Wishlist
                            </div>

                            <div class="quick-sub">
                                Saved favorite books
                            </div>

                        </div>

                    </a>

                    <a asp-controller="Reservation"
                       asp-action="Index"
                       asp-area="Member"
                       class="quick-btn">

                        <i class="fa-solid fa-bookmark"></i>

                        <div>

                            <div class="quick-title">
                                Reservations
                            </div>

                            <div class="quick-sub">
                                Manage reservations
                            </div>

                        </div>

                    </a>

                </div>

            </div>

            <!-- RECENT ACTIVITIES -->
            @if (Model.RecentActivity != null && Model.RecentActivity.Any())
            {
                <div class="dashboard-card">

                    <div class="card-title">
                        Recent Activities
                    </div>

                    @foreach (var activity in Model.RecentActivity.Take(5))
                    {
                        <div class="activity-item">

                            <div class="activity-icon">

                                <i class="fa-solid fa-bolt"></i>

                            </div>

                            <div>

                                <div class="activity-title">
                                    @activity.Activity
                                </div>

                                <div class="activity-date">
                                    @activity.ActivityDate.ToString("dd MMM yyyy hh:mm tt")
                                </div>

                            </div>

                        </div>
                    }

                </div>
            }

        </div>

    </div>

</div>
