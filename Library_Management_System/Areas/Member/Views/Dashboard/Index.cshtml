@model Library_Management_System.ViewModels.MemberDashboardViewModel

@{
    ViewData["Title"] = "My Dashboard";
    Layout = "~/Areas/Member/Views/Shared/_MemberLayout.cshtml";
}

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
      rel="stylesheet" />

<style>

    body {
        background: #050816;
        color: white;
        font-family: 'Segoe UI', sans-serif;
    }

    .dashboard-wrapper {
        padding: 25px;
    }

    /* TOPBAR */

    .topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 20px;
        margin-bottom: 25px;
        flex-wrap: wrap;
    }

    .search-box {
        position: relative;
        width: 420px;
        max-width: 100%;
    }

        .search-box input {
            width: 100%;
            height: 52px;
            border-radius: 14px;
            border: 1px solid rgba(255,255,255,.08);
            background: #0f172a;
            color: white;
            padding: 0 50px 0 18px;
            outline: none;
        }

        .search-box i {
            position: absolute;
            top: 18px;
            right: 18px;
            color: #9ca3af;
        }

    .profile-box {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .profile-avatar {
        width: 45px;
        height: 45px;
        border-radius: 50%;
        background: linear-gradient(135deg,#9333ea,#d946ef);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
    }

    /* HERO */

    .hero-section {
        background: linear-gradient(135deg,#4c1d95,#7e22ce,#9333ea);
        border-radius: 24px;
        padding: 40px;
        margin-bottom: 25px;
        overflow: hidden;
        position: relative;
    }

        .hero-section h1 {
            font-size: 48px;
            font-weight: 800;
            margin-bottom: 15px;
        }

        .hero-section p {
            color: #e5e7eb;
            font-size: 18px;
            margin-bottom: 25px;
        }

    .hero-btn {
        background: white;
        color: #7c3aed;
        padding: 14px 24px;
        border-radius: 14px;
        text-decoration: none;
        font-weight: 700;
    }

    .hero-image {
        width: 260px;
        max-width: 100%;
    }

    /* SUMMARY */
    .summary-card {
        background: linear-gradient(145deg,#0f172a,#111827);
        border-radius: 18px;
        padding: 22px;
        border: 1px solid rgba(255,255,255,.06);
        min-height: 150px;
        transition: .3s;
        display: flex;
        align-items: center;
        gap: 18px;
        box-shadow: 0 10px 30px rgba(0,0,0,.25);
    }

        .summary-card:hover {
            transform: translateY(-4px);
            border-color: rgba(147,51,234,.35);
        }

    .summary-icon {
        width: 70px;
        height: 70px;
        min-width: 70px;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 26px;
        color: white;
    }

    .summary-content {
        flex: 1;
    }

    .summary-title {
        color: #9ca3af;
        font-size: 14px;
        margin-bottom: 10px;
    }

    .summary-value {
        font-size: 34px;
        font-weight: 800;
        line-height: 1;
    }

    .purple {
        background: linear-gradient(135deg,#7c3aed,#9333ea);
    }

    .green {
        background: linear-gradient(135deg,#059669,#10b981);
    }

    .red {
        background: linear-gradient(135deg,#dc2626,#ef4444);
    }

    .orange {
        background: linear-gradient(135deg,#ea580c,#f97316);
    }

    /* SECTION CARD */

    .dashboard-card {
        background: linear-gradient(145deg,#0f172a,#111827);
        border-radius: 22px;
        padding: 24px;
        margin-top: 25px;
        border: 1px solid rgba(255,255,255,.05);
    }

        .dashboard-card h4 {
            margin-bottom: 20px;
            font-weight: 700;
        }

    /* TABLE */

    .table {
        color: white;
        margin-bottom: 0;
    }

        .table th {
            color: #9ca3af;
            border: none;
            background: rgba(255,255,255,.03);
            padding: 16px;
        }

        .table td {
            border: none;
            padding: 16px;
            vertical-align: middle;
        }

        .table tbody tr {
            background: rgba(255,255,255,.03);
        }

    /* BADGES */

    .status-badge {
        padding: 8px 14px;
        border-radius: 30px;
        font-size: 12px;
        font-weight: 600;
    }

    .active-badge {
        background: #16a34a;
    }

    .overdue-badge {
        background: #dc2626;
    }

    .returned-badge {
        background: #2563eb;
    }

    /* ACTIVITY */

    .activity-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 16px;
        border-radius: 16px;
        background: rgba(255,255,255,.03);
        margin-bottom: 14px;
    }

    .activity-date {
        color: #9ca3af;
        font-size: 13px;
    }

    /* QUICK ACTIONS */

    .quick-btn {
        display: flex;
        align-items: center;
        gap: 12px;
        text-decoration: none;
        color: white;
        padding: 16px;
        border-radius: 16px;
        background: rgba(255,255,255,.03);
        transition: .3s;
        margin-bottom: 15px;
    }

        .quick-btn:hover {
            background: linear-gradient(135deg,#7c3aed,#9333ea);
            color: white;
        }

    /* RESPONSIVE */

    @@media(max-width:991px) {

        .hero-section {
            text-align: center;
        }

        .hero-image {
            margin-top: 30px;
        }

        .topbar {
            flex-direction: column;
            align-items: stretch;
        }
    }

</style>

<div class="dashboard-wrapper">

    <!-- HERO -->

    <div class="hero-section">

                <h1>
                    My Dashboard
                </h1>

    </div>

    <!-- SUMMARY CARDS -->

    <div class="row g-4">


        <div class="col-lg-3 col-md-6">

            <div class="summary-card">

                <div class="summary-icon purple">
                    <i class="fa fa-book"></i>
                </div>

                <div class="summary-content">

                    <div class="summary-title">
                        Currently Borrowed
                    </div>

                    <div class="summary-value">
                        @Model.CurrentBorrows
                    </div>

                </div>

            </div>

        </div>


        <div class="col-lg-3 col-md-6">

            <div class="summary-card">

                <div class="summary-icon green">
                    <i class="fa fa-check"></i>
                </div>

                <div class="summary-content">

                    <div class="summary-title">
                        Returned Books
                    </div>

                    <div class="summary-value">
                        @Model.ReturnedBooks
                    </div>

                </div>

            </div>

        </div>


        <div class="col-lg-3 col-md-6">

            <div class="summary-card">

                <div class="summary-icon red">
                    <i class="fa fa-clock"></i>
                </div>

                <div class="summary-content">

                    <div class="summary-title">
                        Overdue Books
                    </div>

                    <div class="summary-value">
                        @Model.Overdue
                    </div>

                </div>

            </div>

        </div>


        <div class="col-lg-3 col-md-6">

            <div class="summary-card">

                <div class="summary-icon orange">
                    <i class="fa fa-indian-rupee-sign"></i>
                </div>

                <div class="summary-content">

                    <div class="summary-title">
                        Fine Due
                    </div>

                    <div class="summary-value">
                        ₹@Model.FineDue
                    </div>

                </div>

            </div>

        </div>

    </div>

    <div class="row">

        <!-- BOOKS -->

        <div class="col-lg-8">

            <div class="dashboard-card">

                <h4>
                    My Borrowed Books
                </h4>

                <div class="table-responsive">

                    <table class="table align-middle">

                        <thead>

                            <tr>

                                <th>Book</th>
                                <th>Author</th>
                                <th>Borrowed</th>
                                <th>Due Date</th>
                                <th>Status</th>

                            </tr>

                        </thead>

                        <tbody>

                            @foreach (var book in Model.MyBooks)
                            {
                                <tr>

                                    <td>@book.BookTitle</td>

                                    <td>@book.Author</td>

                                    <td>@book.IssueDate.ToShortDateString()</td>

                                    <td>@book.DueDate.ToShortDateString()</td>

                                    <td>

                                        @if (book.IsReturned)
                                        {
                                            <span class="status-badge returned-badge">
                                                Returned
                                            </span>
                                        }
                                        else if (book.DueDate < DateTime.Now)
                                        {
                                            <span class="status-badge overdue-badge">
                                                Overdue
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="status-badge active-badge">
                                                Active
                                            </span>
                                        }

                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>

                </div>

            </div>

        </div>

        <!-- RIGHT SIDE -->

        <div class="col-lg-4">

            <!-- QUICK ACTIONS -->

            <div class="dashboard-card">

                <h4>
                    Quick Actions
                </h4>

                <a asp-area=""
                   asp-controller="Books"
                   asp-action="Index"
                   class="quick-btn">

                    <i class="fa fa-book"></i>
                    Browse Books

                </a>

                <a asp-area="Member"
                   asp-controller="Wishlist"
                   asp-action="Index"
                   class="quick-btn">

                    <i class="fa fa-heart"></i>
                    My Wishlist

                </a>

                @* Controller name is singular ("Reservation") — using "Reservations"
                   here was producing a 404 on the My Reservations button. *@
                <a asp-area="Member"
                   asp-controller="Reservation"
                   asp-action="Index"
                   class="quick-btn">

                    <i class="fa fa-bookmark"></i>
                    My Reservations

                </a>

                <a asp-area="Member"
                   asp-controller="Profile"
                   asp-action="Index"
                   class="quick-btn">

                    <i class="fa fa-user"></i>
                    Profile Settings

                </a>

            </div>

            <!-- ACTIVITY -->

            <div class="dashboard-card">

                <h4>
                    Recent Activity
                </h4>

                @foreach (var activity in Model.RecentActivity)
                {
                    <div class="activity-item">

                        <div>
                            @activity.Activity
                        </div>

                        <div class="activity-date">
                            @activity.ActivityDate.ToShortDateString()
                        </div>

                    </div>
                }

            </div>

        </div>

    </div>

</div>