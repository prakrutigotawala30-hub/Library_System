@model Library_Management_System.ViewModels.MemberDashboardViewModel

@{
    ViewData["Title"] = "My Dashboard";
}

<h2 class="mb-4">📚 My Books Dashboard</h2>

<!-- SUMMARY CARDS -->
<div class="row mb-4">

    <div class="col-md-3">
        <div class="card p-3 shadow-sm">
            <h6>Current Borrows</h6>
            <h3>@Model.CurrentBorrows</h3>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card p-3 shadow-sm">
            <h6>Overdue</h6>
            <h3 class="text-danger">@Model.Overdue</h3>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card p-3 shadow-sm">
            <h6>Total Fine</h6>
            <h3 class="text-warning">₹@Model.FineDue</h3>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card p-3 shadow-sm">
            <h6>Wishlist</h6>
            <h3 class="text-primary">@Model.WishListCount</h3>
        </div>
    </div>

</div>

<!-- MY BOOKS TABLE -->
<div class="card p-3 shadow-sm mb-4">
    <h5>📖 My Books</h5>

    <table class="table table-striped mt-2">
        <thead>
            <tr>
                <th>Book</th>
                <th>Author</th>
                <th>Issue Date</th>
                <th>Due Date</th>
                <th>Status</th>
                <th>Fine</th>
            </tr>
        </thead>

        <tbody>
            @if (Model.MyBooks != null && Model.MyBooks.Any())
            {
                foreach (var book in Model.MyBooks)
                {
                    <tr>
                        <td>@book.BookTitle</td>
                        <td>@book.Author</td>
                        <td>@book.IssueDate.ToShortDateString()</td>
                        <td>@book.DueDate.ToShortDateString()</td>

                        <td>
                            @if (book.IsReturned)
                            {
                                <span class="badge bg-success">Returned</span>
                            }
                            else if (book.DueDate < DateTime.Now)
                            {
                                <span class="badge bg-danger">Overdue</span>
                            }
                            else
                            {
                                <span class="badge bg-primary">Active</span>
                            }
                        </td>

                        <td>₹@book.FineAmount</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center text-muted">
                        No books found
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- RECENT ACTIVITY -->
<div class="card p-3 shadow-sm">
    <h5>🕒 Recent Activity</h5>

    @if (Model.RecentActivity != null && Model.RecentActivity.Any())
    {
        <ul class="list-group">
            @foreach (var act in Model.RecentActivity)
            {
                <li class="list-group-item d-flex justify-content-between">
                    <span>@act.Activity</span>
                    <small class="text-muted">
                        @act.ActivityDate.ToShortDateString()
                    </small>
                </li>
            }
        </ul>
    }
    else
    {
        <p class="text-muted">No recent activity</p>
    }
</div>