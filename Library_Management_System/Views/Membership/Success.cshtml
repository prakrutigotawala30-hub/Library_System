@{
    ViewData["Title"] = "Payment Success";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
}

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

<style>
    

    body {
        background: radial-gradient(circle at top left, rgba(124,58,237,.18), transparent 30%), radial-gradient(circle at bottom right, rgba(217,70,239,.12), transparent 30%), #050816;
        font-family: 'Inter',sans-serif;
        color: white;
        overflow-x: hidden;
    }

    .success-page {
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 40px;
    }

    .success-card {
        width: 100%;
        max-width: 650px;
        background: linear-gradient(180deg, #0f172a, #081120);
        border-radius: 36px;
        padding: 55px;
        text-align: center;
        border: 1px solid rgba(255,255,255,.08);
        box-shadow: 0 20px 60px rgba(0,0,0,.45);
        position: relative;
        overflow: hidden;
    }

        .success-card::before {
            content: "";
            position: absolute;
            width: 350px;
            height: 350px;
            background: rgba(168,85,247,.15);
            border-radius: 50%;
            top: -180px;
            right: -180px;
            filter: blur(40px);
        }

    .success-icon {
        width: 110px;
        height: 110px;
        margin: auto auto 30px;
        border-radius: 50%;
        display: flex;
        justify-content: center;
        align-items: center;
        background: linear-gradient(135deg, #7c3aed, #d946ef);
        box-shadow: 0 15px 40px rgba(168,85,247,.35);
        position: relative;
        z-index: 2;
    }

        .success-icon i {
            font-size: 50px;
            color: white;
        }

    .success-title {
        font-size: 52px;
        font-weight: 900;
        margin-bottom: 18px;
        background: linear-gradient(135deg, #ffffff, #d8b4fe);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        position: relative;
        z-index: 2;
    }

    .success-text {
        color: #9ca3af;
        line-height: 1.9;
        font-size: 17px;
        margin-bottom: 35px;
        position: relative;
        z-index: 2;
    }

    .success-info {
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.08);
        border-radius: 24px;
        padding: 25px;
        margin-bottom: 35px;
        position: relative;
        z-index: 2;
    }

    .info-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 14px 0;
        border-bottom: 1px solid rgba(255,255,255,.06);
    }

        .info-row:last-child {
            border-bottom: none;
        }

    .info-label {
        color: #9ca3af;
    }

    .info-value {
        font-weight: 700;
        color: white;
    }

    .status-badge {
        padding: 8px 16px;
        border-radius: 999px;
        background: rgba(34,197,94,.15);
        color: #4ade80;
        font-size: 13px;
        font-weight: 700;
    }

    .success-actions {
        display: flex;
        gap: 18px;
        justify-content: center;
        flex-wrap: wrap;
        position: relative;
        z-index: 2;
    }

    .success-btn {
        text-decoration: none;
        padding: 16px 28px;
        border-radius: 18px;
        font-weight: 800;
        transition: .3s ease;
    }

    .primary-btn {
        background: linear-gradient(135deg, #7c3aed, #d946ef);
        color: white;
    }

        .primary-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 35px rgba(168,85,247,.35);
        }

    .secondary-btn {
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.08);
        color: white;
    }

        .secondary-btn:hover {
            background: rgba(255,255,255,.08);
            transform: translateY(-3px);
        }

    @@media(max-width:768px) {

        .success-card {
            padding: 40px 25px;
        }

        .success-title {
            font-size: 40px;
        }

        .success-actions {
            flex-direction: column;
        }

        .success-btn {
            width: 100%;
        }
    }

</style>

<div class="success-page">

    <div class="success-card">

        <!-- ICON -->

        <div class="success-icon">
            <i class="bi bi-check2"></i>
        </div>

        <!-- TITLE -->

        <div class="success-title">
            Payment Submitted
        </div>

        <!-- TEXT -->

        <div class="success-text">

            Your membership payment has been submitted
            successfully. Our team will verify your payment
            shortly and activate your membership.

        </div>

        <!-- INFO -->

        <div class="success-info">

            <div class="info-row">

                <div class="info-label">
                    Membership Status
                </div>

                <div class="status-badge">
                    Pending Verification
                </div>

            </div>

            <div class="info-row">

                <div class="info-label">
                    Payment Date
                </div>

                <div class="info-value">
                    @DateTime.Now.ToString("dd MMM yyyy")
                </div>

            </div>

            <div class="info-row">

                <div class="info-label">
                    Support
                </div>

                <div class="info-value">
                    Library Team
                </div>

            </div>

        </div>

        <!-- BUTTONS -->

        <div class="success-actions">

            <a asp-controller="Home"
               asp-action="Index"
               class="success-btn primary-btn">

                Go To Home

            </a>

            <a asp-controller="Membership"
               asp-action="Index"
               class="success-btn secondary-btn">

                View Membership

            </a>

        </div>

    </div>

</div>
