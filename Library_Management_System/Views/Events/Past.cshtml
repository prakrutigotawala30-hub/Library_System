@{
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
}

@model IEnumerable<LibraryManagementSystem.ClassLibrary.Models.Event>

@{
    ViewData["Title"] = "Past Events";
}

<style>

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        background: #070b1a;
        font-family: 'Inter', sans-serif;
    }

    .events-page {
        min-height: 100vh;
        padding: 30px;
        background: radial-gradient(circle at top right, rgba(168,85,247,.16), transparent 25%), radial-gradient(circle at bottom left, rgba(236,72,153,.12), transparent 30%), linear-gradient(135deg,#070b1a,#0f172a);
    }

    /* HERO */

    .events-hero {
        position: relative;
        overflow: hidden;
        border-radius: 38px;
        padding: 80px 70px;
        margin-bottom: 60px;
        background: linear-gradient(rgba(7,11,26,.88), rgba(15,23,42,.92)), url('/images/library-banner.jpg');
        background-size: cover;
        background-position: center;
        border: 1px solid rgba(255,255,255,.08);
        box-shadow: 0 0 40px rgba(139,92,246,.12);
    }

        .events-hero::before {
            content: "";
            position: absolute;
            width: 450px;
            height: 450px;
            border-radius: 50%;
            background: rgba(168,85,247,.08);
            top: -180px;
            right: -140px;
        }

    .hero-content {
        position: relative;
        z-index: 2;
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 12px 22px;
        border-radius: 50px;
        background: rgba(255,255,255,.05);
        border: 1px solid rgba(255,255,255,.08);
        color: #f9a8d4;
        font-size: 13px;
        letter-spacing: 1px;
        margin-bottom: 28px;
        backdrop-filter: blur(12px);
    }

    .hero-content h1 {
        color: white;
        font-size: 70px;
        line-height: 1.05;
        font-weight: 900;
        margin-bottom: 24px;
    }

        .hero-content h1 span {
            background: linear-gradient(90deg,#f472b6,#c084fc);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

    .hero-content p {
        color: #d1d5db;
        font-size: 17px;
        line-height: 1.9;
        max-width: 760px;
    }

    .hero-buttons {
        display: flex;
        gap: 18px;
        flex-wrap: wrap;
        margin-top: 34px;
    }

    .btn-main {
        padding: 15px 32px;
        border-radius: 18px;
        background: linear-gradient(90deg,#ec4899,#9333ea);
        color: white;
        text-decoration: none;
        font-weight: 700;
        transition: .35s;
        box-shadow: 0 12px 28px rgba(236,72,153,.25);
    }

        .btn-main:hover {
            transform: translateY(-3px);
            color: white;
        }

    .btn-glass {
        padding: 15px 32px;
        border-radius: 18px;
        border: 1px solid rgba(255,255,255,.08);
        background: rgba(255,255,255,.04);
        color: white;
        text-decoration: none;
        transition: .35s;
    }

        .btn-glass:hover {
            background: rgba(255,255,255,.08);
            color: white;
        }

    /* SECTION */

    .section-header {
        margin-bottom: 40px;
    }

        .section-header h2 {
            color: white;
            font-size: 48px;
            font-weight: 900;
            margin-bottom: 10px;
        }

        .section-header p {
            color: #9ca3af;
            font-size: 16px;
        }

    /* EVENTS */

    .events-listing {
        display: flex;
        flex-direction: column;
        gap: 34px;
    }

    /* CARD */

    .premium-event-card {
        position: relative;
        display: grid;
        grid-template-columns: 340px 1fr 200px;
        gap: 34px;
        padding: 28px;
        border-radius: 34px;
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.08);
        backdrop-filter: blur(16px);
        overflow: hidden;
        transition: .4s;
    }

        .premium-event-card:hover {
            transform: translateY(-8px);
            border-color: rgba(236,72,153,.22);
            box-shadow: 0 25px 60px rgba(236,72,153,.10), 0 10px 30px rgba(0,0,0,.25);
        }

        .premium-event-card::before {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(120deg,transparent,rgba(255,255,255,.03),transparent);
            opacity: 0;
            transition: .5s;
        }

        .premium-event-card:hover::before {
            opacity: 1;
        }

    /* IMAGE */

    .premium-event-image {
        position: relative;
        height: 100%;
        min-height: 320px;
        border-radius: 28px;
        overflow: hidden;
    }

        .premium-event-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: .7s;
        }

    .premium-event-card:hover img {
        transform: scale(1.08);
    }

    .premium-event-image::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(0,0,0,.6), transparent 55%);
    }

    .premium-badge {
        position: absolute;
        top: 18px;
        left: 18px;
        z-index: 2;
        padding: 10px 18px;
        border-radius: 50px;
        background: rgba(15,23,42,.85);
        border: 1px solid rgba(255,255,255,.08);
        color: white;
        font-size: 12px;
        font-weight: 700;
        backdrop-filter: blur(10px);
    }

    .image-overlay-info {
        position: absolute;
        bottom: 18px;
        left: 18px;
        z-index: 2;
        padding: 11px 18px;
        border-radius: 14px;
        background: rgba(0,0,0,.45);
        color: white;
        font-size: 13px;
        font-weight: 600;
        backdrop-filter: blur(10px);
    }

    /* CONTENT */

    .premium-event-content {
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .event-top-info {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 14px;
        flex-wrap: wrap;
        margin-bottom: 20px;
    }

    .event-category {
        padding: 9px 16px;
        border-radius: 50px;
        background: rgba(236,72,153,.12);
        color: #f9a8d4;
        font-size: 13px;
        font-weight: 700;
    }

    .event-date {
        color: #c4b5fd;
        font-size: 14px;
    }

    .premium-event-content h2 {
        color: white;
        font-size: 40px;
        line-height: 1.12;
        font-weight: 900;
        margin-bottom: 18px;
    }

    .premium-event-content p {
        color: #d1d5db;
        font-size: 15px;
        line-height: 1.9;
        margin-bottom: 28px;
    }

    /* DETAILS GRID */

    .details-grid {
        display: grid;
        grid-template-columns: repeat(2,1fr);
        gap: 18px;
    }

    .detail-box {
        padding: 18px;
        border-radius: 20px;
        background: rgba(255,255,255,.03);
        border: 1px solid rgba(255,255,255,.05);
        transition: .35s;
    }

        .detail-box:hover {
            transform: translateY(-4px);
            border-color: rgba(236,72,153,.25);
            background: rgba(255,255,255,.05);
        }

        .detail-box small {
            display: block;
            color: #f9a8d4;
            margin-bottom: 10px;
            font-size: 12px;
            letter-spacing: .5px;
        }

        .detail-box span {
            color: white;
            font-size: 14px;
            font-weight: 600;
            line-height: 1.6;
        }

    /* SIDE */

    .premium-event-side {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 22px;
    }

    .side-date-box {
        width: 130px;
        height: 130px;
        border-radius: 32px;
        background: linear-gradient(135deg,#ec4899,#9333ea);
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        color: white;
        box-shadow: 0 15px 35px rgba(236,72,153,.30);
    }

        .side-date-box strong {
            font-size: 48px;
            line-height: 1;
            font-weight: 900;
        }

        .side-date-box span {
            margin-top: 6px;
            font-size: 13px;
            letter-spacing: 1px;
        }

    .event-status {
        width: 100%;
        padding: 13px 18px;
        border-radius: 14px;
        background: rgba(236,72,153,.12);
        border: 1px solid rgba(236,72,153,.22);
        color: #f9a8d4;
        text-align: center;
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 1px;
    }

    .premium-btn {
        width: 100%;
        padding: 16px 20px;
        border-radius: 18px;
        text-align: center;
        text-decoration: none;
        font-weight: 700;
        color: white;
        background: rgba(255,255,255,.05);
        border: 1px solid rgba(255,255,255,.08);
        transition: .35s;
    }

        .premium-btn:hover {
            background: linear-gradient(90deg,#ec4899,#9333ea);
            border-color: transparent;
            color: white;
            transform: translateY(-3px);
        }

    /* EMPTY */

    .empty-box {
        padding: 90px 30px;
        border-radius: 34px;
        text-align: center;
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.08);
    }

        .empty-box h3 {
            color: white;
            font-size: 34px;
            margin-top: 20px;
            margin-bottom: 10px;
        }

        .empty-box p {
            color: #9ca3af;
        }

    /* RESPONSIVE */

    @@media(max-width:1200px) {

        .premium-event-card {
            grid-template-columns: 1fr;
        }

        .premium-event-side {
            flex-direction: row;
            justify-content: space-between;
        }

        .premium-event-image {
            min-height: 260px;
        }
    }

    @@media(max-width:768px) {

        .events-page {
            padding: 18px;
        }

        .events-hero {
            padding: 50px 28px;
            border-radius: 28px;
        }

        .hero-content h1 {
            font-size: 42px;
        }

        .section-header h2 {
            font-size: 34px;
        }

        .premium-event-content h2 {
            font-size: 30px;
        }

        .details-grid {
            grid-template-columns: 1fr;
        }

        .premium-event-side {
            flex-direction: column;
        }

        .hero-buttons {
            flex-direction: column;
        }

        .btn-main,
        .btn-glass {
            width: 100%;
            text-align: center;
        }
    }

</style>

<div class="events-page">

    <!-- HERO -->

    <section class="events-hero">

        <div class="hero-content">

            <div class="hero-badge">
                🕘 PREVIOUS LIBRARY EVENTS
            </div>

            <h1>
                Relive Our
                <span>Past Experiences</span>
            </h1>

            <p>
                Explore memorable workshops, inspiring author sessions,
                book launches, seminars, and community gatherings previously
                hosted by BookVerse Library.
            </p>

            <div class="hero-buttons">

                <a asp-action="Index" class="btn-main">
                    Upcoming Events
                </a>

                <a href="#pastEvents" class="btn-glass">
                    Browse History
                </a>

            </div>

        </div>

    </section>

    <!-- EVENTS -->

    <div class="container-fluid">

        <div class="section-header">

            <h2>Past Events</h2>

            <p>
                Browse completed library experiences and memorable sessions
            </p>

        </div>

        @if (Model.Any())
        {
            <div class="events-listing" id="pastEvents">

                @foreach (var item in Model)
                {
                    <div class="premium-event-card">

                        <!-- IMAGE -->

                        <div class="premium-event-image">

                            @if (!string.IsNullOrEmpty(item.ImagePath))
                            {
                                <img src="@item.ImagePath" />
                            }
                            else
                            {
                                <img src="/images/default-book.jpg" />
                            }

                            <div class="premium-badge">
                                COMPLETED
                            </div>

                            <div class="image-overlay-info">
                                ⭐ BookVerse Archive
                            </div>

                        </div>

                        <!-- CONTENT -->

                        <div class="premium-event-content">

                            <div class="event-top-info">

                                <div class="event-category">
                                    📚 Library Event
                                </div>

                                @* <div class="event-date">
                                    📅 @item.Date.ToString("dddd, dd MMM yyyy")
                                </div> *@

                            </div>

                            <h2>@item.Title</h2>

                            <p>
                                @(item.Description.Length > 240
                                                        ? item.Description.Substring(0, 240) + "..."
                                                        : item.Description)
                            </p>

                            <div class="details-grid">

                                <div class="detail-box">
                                    <small>Location</small>
                                    <span>📍 @item.Location</span>
                                </div>

                                <div class="detail-box">
                                    <small>Status</small>
                                    <span>✅ Successfully Conducted</span>
                                </div>

                                <div class="detail-box">
                                    <small>Experience</small>
                                    <span>🎤 Community Session</span>
                                </div>

                                <div class="detail-box">
                                    <small>Audience</small>
                                    <span>👥 Readers & Students</span>
                                </div>

                            </div>

                        </div>

                        <!-- SIDE -->

                        <div class="premium-event-side">

                            <div class="side-date-box">

                                <strong>@item.Date.Day</strong>

                                <span>@item.Date.ToString("MMM")</span>

                            </div>

                            <div class="event-status">
                                EVENT CLOSED
                            </div>

                            <a asp-action="Details"
                               asp-route-id="@item.Id"
                               class="premium-btn">

                                View Details

                            </a>

                        </div>

                    </div>
                }

            </div>
        }
        else
        {
            <div class="empty-box">

                <img src="https://cdn-icons-png.flaticon.com/512/7486/7486740.png"
                     width="120" />

                <h3>No Past Events Found</h3>

                <p>
                    Completed events will appear here once available.
                </p>

            </div>
        }

    </div>

</div>
