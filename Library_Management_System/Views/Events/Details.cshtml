@model LibraryManagementSystem.ClassLibrary.Models.Event

@{
    ViewData["Title"] = "Event Details";

    string speakerName = "James Clear";
    string speakerDesc = "Bestselling author and productivity expert known for inspiring readers through modern self-improvement.";
    string speakerImage = "/images/default-speaker.svg";

    if (Model.Title.Contains("Atomic Habits"))
    {
        speakerName = "James Clear";
        speakerDesc = "Author of Atomic Habits and expert in habits and productivity.";
        speakerImage = "/images/default-speaker.svg";
    }
    else if (Model.Title.Contains("Rich Dad"))
    {
        speakerName = "Robert Kiyosaki";
        speakerDesc = "Entrepreneur and financial educator.";
        speakerImage = "/images/default-speaker.svg";
    }
    else if (Model.Title.Contains("Alchemist"))
    {
        speakerName = "Paulo Coelho";
        speakerDesc = "Inspirational novelist and storyteller.";
        speakerImage = "/images/default-speaker.svg";
    }
    else if (Model.Title.Contains("Clean Code"))
    {
        speakerName = "Robert C. Martin";
        speakerDesc = "Software engineering expert and Clean Code author.";
        speakerImage = "/images/default-speaker.svg";
    }
    else if (Model.Title.Contains("Wings of Fire"))
    {
        speakerName = "Dr. A.P.J Abdul Kalam";
        speakerDesc = "Former President of India and inspirational leader.";
        speakerImage = "/images/default-speaker.svg";
    }
}

<style>

    body {
        margin: 0;
        font-family: 'Inter', sans-serif;
        background: radial-gradient(circle at top right, rgba(168,85,247,.16), transparent 30%), radial-gradient(circle at bottom left, rgba(236,72,153,.12), transparent 30%), linear-gradient(135deg,#070b1a,#0f172a);
        color: white;
    }

    .event-details-page {
        min-height: 100vh;
        padding: 30px;
    }

    .glass-card {
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.08);
        backdrop-filter: blur(16px);
        border-radius: 26px;
        box-shadow: 0 0 30px rgba(139,92,246,.10);
        padding: 25px;
    }

    /* TOP */
    .event-top {
        margin-bottom: 25px;
    }

    .event-cover {
        height: 340px;
        border-radius: 22px;
        overflow: hidden;
    }

        .event-cover img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: .5s;
        }

        .event-cover:hover img {
            transform: scale(1.05);
        }

    .event-info h1 {
        font-size: 46px;
        font-weight: 900;
        margin-bottom: 16px;
    }

    .event-meta {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-bottom: 18px;
    }

        .event-meta div {
            padding: 10px 14px;
            border-radius: 12px;
            background: rgba(255,255,255,.03);
            border: 1px solid rgba(255,255,255,.06);
            font-size: 14px;
        }

    .event-desc {
        color: #d1d5db;
        line-height: 1.8;
    }

    /* BUTTONS */
    .event-buttons {
        margin-top: 25px;
        display: flex;
        gap: 14px;
        flex-wrap: wrap;
    }

    .btn-main {
        background: linear-gradient(90deg,#7c3aed,#9333ea);
        color: white;
        padding: 14px 26px;
        border-radius: 14px;
        text-decoration: none;
        font-weight: 700;
        border: none;
        cursor: pointer;
        flex: 1;
        text-align: center;
        transition: .3s;
    }

        .btn-main:hover {
            transform: translateY(-3px);
            color: white;
            box-shadow: 0 12px 30px rgba(124,58,237,.35);
        }

    /* SPEAKER */
    .speaker-box {
        display: flex;
        gap: 20px;
        align-items: center;
    }

    .speaker-img {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        overflow: hidden;
        border: 3px solid rgba(255,255,255,.08);
    }

        .speaker-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .speaker-info h4 {
        font-size: 26px;
        margin-bottom: 10px;
    }

    .speaker-info p {
        color: #d1d5db;
        line-height: 1.7;
    }

    .summary-box p {
        color: #d1d5db;
        margin-bottom: 14px;
    }

    /* RESPONSIVE */
    @@media(max-width:768px) {

        .event-details-page {
            padding: 18px;
        }

        .event-info h1 {
            font-size: 32px;
        }

        .event-buttons {
            flex-direction: column;
        }

        .btn-main {
            width: 100%;
        }

        .speaker-box {
            flex-direction: column;
            text-align: center;
        }
    }

</style>

<div class="event-details-page container-fluid">

    <div class="row g-4">

        <!-- LEFT -->
        <div class="col-lg-9">

            <div class="glass-card event-top">

                <div class="row g-4">

                    <!-- IMAGE -->
                    <div class="col-lg-4">

                        <div class="event-cover">
                            <img src="@(string.IsNullOrEmpty(Model.ImagePath)
                                                                                                  ? "/images/no-event.svg"
                                                                                                  : Model.ImagePath)" />
                        </div>

                    </div>

                    <!-- INFO -->
                    <div class="col-lg-8">

                        <div class="event-info">

                            <h1>@Model.Title</h1>

                            <div class="event-meta">

                                <div>📅 @Model.Date.ToString("dd MMM yyyy")</div>
                                <div>⏰ 4:00 PM - 6:00 PM</div>
                                <div>📍 @Model.Location</div>

                            </div>

                            <div class="event-desc">
                                @Model.Description
                            </div>

                            <!-- BUTTON -->
                            <div class="event-buttons">

                                <a asp-area="Member"
                                   asp-controller="Reservation"
                                   asp-action="Create"
                                   asp-route-eventId="@Model.Id"
                                   class="btn-main">

                                    🎟 Reserve Seat

                                </a>

                            </div>

                        </div>

                    </div>

                </div>

            </div>

            <!-- SPEAKER -->
            <div class="glass-card mt-4">

                <h3>About Speaker</h3>

                <div class="speaker-box mt-3">

                    <div class="speaker-img">
                        <img src="@speakerImage" />
                    </div>

                    <div class="speaker-info">
                        <h4>@speakerName</h4>
                        <p>@speakerDesc</p>
                    </div>

                </div>

            </div>

        </div>

        <!-- RIGHT -->
        <div class="col-lg-3">

            <div class="glass-card summary-box">

                <h4 class="mb-4">Event Summary</h4>

                <p>📅 @Model.Date.ToString("dd MMM yyyy")</p>
                <p>📍 @Model.Location</p>
                <p>🎤 Author Session</p>
                <p>👥 Community Meetup</p>

            </div>

        </div>

    </div>

</div>
