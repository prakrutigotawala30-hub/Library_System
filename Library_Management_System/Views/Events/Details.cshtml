@model LibraryManagementSystem.ClassLibrary.Models.Event

@{
    Layout = "~/Areas/Member/Views/Shared/_MemberLayout.cshtml";
    ViewData["Title"] = "Event Details";

    string speakerName = "James Clear";
    string speakerDesc = "Bestselling author and productivity expert known for inspiring readers through modern self-improvement.";
    string speakerImage = "/images/default-speaker.svg";

    if (Model.Title.Contains("Atomic Habits"))
    {
        speakerName = "James Clear";
        speakerDesc = "Author of Atomic Habits and expert in habits and productivity.";
    }
    else if (Model.Title.Contains("Rich Dad"))
    {
        speakerName = "Robert Kiyosaki";
        speakerDesc = "Entrepreneur and financial educator.";
    }
    else if (Model.Title.Contains("Alchemist"))
    {
        speakerName = "Paulo Coelho";
        speakerDesc = "Inspirational novelist and storyteller.";
    }
    else if (Model.Title.Contains("Clean Code"))
    {
        speakerName = "Robert C. Martin";
        speakerDesc = "Software engineering expert and Clean Code author.";
    }
    else if (Model.Title.Contains("Wings of Fire"))
    {
        speakerName = "Dr. A.P.J Abdul Kalam";
        speakerDesc = "Former President of India and inspirational leader.";
    }
}

<style>

    @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Inter', sans-serif;
        background: radial-gradient(circle at top left, rgba(124,58,237,.12), transparent 25%), radial-gradient(circle at bottom right, rgba(217,70,239,.08), transparent 30%), #050816;
        color: white;
        overflow-x: hidden;
    }

    .event-page {
        width: 100%;
        min-height: 100vh;
        padding: 35px 24px 80px;
    }

    /* HERO */

    .event-hero {
        position: relative;
        overflow: hidden;
        border-radius: 34px;
        padding: 40px;
        margin-bottom: 34px;
        background: linear-gradient(rgba(5,8,22,.88), rgba(15,23,42,.95)), url('/images/library-banner.png');
        background-size: cover;
        background-position: center;
        border: 1px solid rgba(255,255,255,.06);
        box-shadow: 0 25px 70px rgba(0,0,0,.45);
    }

        .event-hero::before {
            content: "";
            position: absolute;
            width: 420px;
            height: 420px;
            border-radius: 50%;
            background: rgba(168,85,247,.15);
            top: -160px;
            right: -120px;
            filter: blur(80px);
        }

    .hero-inner {
        position: relative;
        z-index: 2;
    }

    /* IMAGE */

    .event-image-box {
        position: relative;
        height: 100%;
    }

    .event-image {
        width: 100%;
        height: 520px;
        object-fit: cover;
        border-radius: 30px;
        border: 1px solid rgba(255,255,255,.08);
        box-shadow: 0 20px 45px rgba(0,0,0,.45);
        transition: .4s;
        background: #111827;
    }

        .event-image:hover {
            transform: scale(1.02);
        }

    /* BADGE */

    .event-badge {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 12px 22px;
        border-radius: 999px;
        background: rgba(255,255,255,.06);
        border: 1px solid rgba(255,255,255,.08);
        color: #d8b4fe;
        font-size: 13px;
        font-weight: 700;
        margin-bottom: 24px;
    }

    /* TITLE */

    .event-title {
        font-size: 60px;
        font-weight: 900;
        line-height: 1.08;
        margin-bottom: 20px;
    }

        .event-title span {
            background: linear-gradient(90deg,#c084fc,#f0abfc);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

    .event-description {
        color: #d1d5db;
        line-height: 1.9;
        font-size: 15px;
        margin-bottom: 30px;
    }

    /* META */

    .event-meta-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(180px,1fr));
        gap: 16px;
        margin-bottom: 30px;
    }

    .meta-card {
        padding: 22px;
        border-radius: 24px;
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.05);
        transition: .3s;
    }

        .meta-card:hover {
            transform: translateY(-4px);
            border-color: rgba(168,85,247,.35);
        }

    .meta-label {
        color: #9ca3af;
        font-size: 12px;
        margin-bottom: 10px;
        font-weight: 700;
        letter-spacing: .5px;
    }

    .meta-value {
        font-size: 15px;
        font-weight: 700;
    }

    /* BUTTON */

    .reserve-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 16px 32px;
        border-radius: 22px;
        background: linear-gradient(135deg,#7c3aed,#d946ef);
        color: white;
        text-decoration: none;
        font-weight: 700;
        transition: .35s;
        box-shadow: 0 12px 35px rgba(168,85,247,.35);
    }

        .reserve-btn:hover {
            transform: translateY(-3px);
            color: white;
        }

    /* GLASS CARD */

    .glass-card {
        padding: 30px;
        border-radius: 34px;
        background: linear-gradient(180deg, rgba(10,15,30,.98), rgba(5,10,22,.98));
        border: 1px solid rgba(255,255,255,.06);
        box-shadow: 0 20px 60px rgba(0,0,0,.45);
    }

    /* SPEAKER */

    .speaker-box {
        display: flex;
        align-items: center;
        gap: 25px;
    }

    .speaker-image {
        width: 140px;
        height: 140px;
        border-radius: 50%;
        overflow: hidden;
        flex-shrink: 0;
        border: 4px solid rgba(168,85,247,.35);
        box-shadow: 0 15px 40px rgba(168,85,247,.20);
    }

        .speaker-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .speaker-name {
        font-size: 30px;
        font-weight: 800;
        margin-bottom: 12px;
    }

    .speaker-desc {
        color: #d1d5db;
        line-height: 1.9;
    }

    /* SUMMARY */

    .summary-card {
        position: sticky;
        top: 110px;
    }

    .summary-title {
        font-size: 30px;
        font-weight: 900;
        margin-bottom: 28px;
    }

    .summary-item {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 18px;
        border-radius: 22px;
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.05);
        margin-bottom: 18px;
        transition: .3s;
    }

        .summary-item:hover {
            transform: translateX(4px);
            border-color: rgba(168,85,247,.35);
        }

    .summary-icon {
        width: 56px;
        height: 56px;
        border-radius: 18px;
        background: linear-gradient(135deg,#7c3aed,#d946ef);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        box-shadow: 0 10px 25px rgba(168,85,247,.30);
    }

    .summary-text small {
        display: block;
        color: #9ca3af;
        margin-bottom: 5px;
    }

    .summary-text strong {
        font-size: 15px;
        color: white;
    }

    /* RESPONSIVE */

    @@media(max-width:1200px) {

        .event-title {
            font-size: 48px;
        }
    }

    @@media(max-width:992px) {

        .summary-card {
            position: static;
        }

        .event-image {
            height: 420px;
        }
    }

    @@media(max-width:768px) {

        .event-page {
            padding: 20px;
        }

        .event-hero {
            padding: 25px;
        }

        .event-title {
            font-size: 34px;
        }

        .speaker-box {
            flex-direction: column;
            text-align: center;
        }

        .event-image {
            height: 320px;
        }

        .reserve-btn {
            width: 100%;
        }
    }
</style>

<div class="event-page">

    <div class="row g-4">

        <!-- LEFT -->

        <div class="col-lg-8">

            <!-- HERO -->

            <div class="event-hero">

                <div class="hero-inner">

                    <div class="row g-4 align-items-center">

                        <!-- IMAGE -->

                        <div class="col-lg-5">

                            <div class="event-image-box">

                                <img src="@(string.IsNullOrEmpty(Model.ImagePath)
                                                                         ? "/images/no-event.svg"
                                                                         : Model.ImagePath)"
                                     class="event-image" />

                            </div>

                        </div>

                        <!-- CONTENT -->

                        <div class="col-lg-7">

                            <div class="event-badge">
                                ✨ PREMIUM AUTHOR EVENT
                            </div>

                            <div class="event-title">

                                Discover
                                <span>@Model.Title</span>

                            </div>

                            <div class="event-description">
                                @Model.Description
                            </div>

                            <div class="event-meta-grid">

                                <div class="meta-card">

                                    <div class="meta-label">
                                        EVENT DATE
                                    </div>

                                    <div class="meta-value">
                                        📅 @Model.Date.ToString("dd MMM yyyy")
                                    </div>

                                </div>

                                <div class="meta-card">

                                    <div class="meta-label">
                                        EVENT TIME
                                    </div>

                                    <div class="meta-value">
                                        ⏰ 4:00 PM - 6:00 PM
                                    </div>

                                </div>

                                @* <div class="meta-card">

                                    <div class="meta-label">
                                        LOCATION
                                    </div>

                                    <div class="meta-value">
                                        📍 @Model.Location
                                    </div>

                                </div> *@

                            </div>
                            <form asp-area="Member"
                                  asp-controller="EventReservation"
                                  asp-action="Create"
                                  method="get">

                                <input type="hidden" name="eventId" value="@Model.Id" />

                                <button type="submit" class="reserve-btn">
                                    🎟 Reserve Seat
                                </button>
                            </form>

                        </div>

                    </div>

                </div>

            </div>

            <!-- SPEAKER -->

            <div class="glass-card">

                <h2 class="mb-4 fw-bold">
                    About Speaker
                </h2>

                <div class="speaker-box">

                    <div class="speaker-image">

                        <img src="@speakerImage" />

                    </div>

                    <div>

                        <div class="speaker-name">
                            @speakerName
                        </div>

                        <div class="speaker-desc">
                            @speakerDesc
                        </div>

                    </div>

                </div>

            </div>

        </div>

        <!-- RIGHT -->

        <div class="col-lg-4">

            <div class="glass-card summary-card">

                <div class="summary-title">
                    Event Summary
                </div>

                <div class="summary-item">

                    <div class="summary-icon">
                        📅
                    </div>

                    <div class="summary-text">

                        <small>Date</small>

                        <strong>
                            @Model.Date.ToString("dd MMM yyyy")
                        </strong>

                    </div>

                </div>

                <div class="summary-item">

                    <div class="summary-icon">
                        📍
                    </div>

                    <div class="summary-text">

                        <small>Location</small>

                        <strong>
                            @Model.Location
                        </strong>

                    </div>

                </div>

                <div class="summary-item">

                    <div class="summary-icon">
                        🎤
                    </div>

                    <div class="summary-text">

                        <small>Category</small>

                        <strong>
                            Author Session
                        </strong>

                    </div>

                </div>

                <div class="summary-item">

                    <div class="summary-icon">
                        👥
                    </div>

                    <div class="summary-text">

                        <small>Audience</small>

                        <strong>
                            Book Community
                        </strong>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>
