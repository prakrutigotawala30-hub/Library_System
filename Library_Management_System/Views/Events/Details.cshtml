@model Library_Management_System.Models.Event

@{
    ViewData["Title"] = "Event Details";
}

<div class="container-fluid">

    <div class="details-card">

        <!-- IMAGE -->

        <div class="details-image">

            @if (!string.IsNullOrEmpty(Model.ImagePath))
            {
                <img src="@Model.ImagePath" alt="@Model.Title" />
            }
            else
            {
                <div class="details-placeholder">
                    📚
                </div>
            }

        </div>

        <!-- CONTENT -->

        <div class="details-content">

            <div class="event-badge">
                Upcoming Event
            </div>

            <h1 class="details-title">
                @Model.Title
            </h1>

            <div class="details-meta">

                <div class="meta-box">
                    <i class="bi bi-calendar-event"></i>
                    @Model.Date.ToString("dddd, dd MMM yyyy")
                </div>

                <div class="meta-box">
                    <i class="bi bi-geo-alt"></i>
                    @Model.Location
                </div>

            </div>

            <div class="details-description">

                @Model.Description

            </div>

            <a asp-action="Index"
               class="btn back-btn">
                Back to Events
            </a>

        </div>

    </div>

</div>

<style>

    .details-card{
        background:rgba(255,255,255,0.05);
        border:1px solid rgba(255,255,255,0.08);
        border-radius:28px;
        overflow:hidden;
        backdrop-filter:blur(12px);
    }

    .details-image{
        height:380px;
        overflow:hidden;
        background:linear-gradient(135deg,#7e22ce,#9333ea);
    }

    .details-image img{
        width:100%;
        height:100%;
        object-fit:cover;
    }

    .details-placeholder{
        width:100%;
        height:100%;
        display:flex;
        align-items:center;
        justify-content:center;
        color:white;
        font-size:100px;
    }

    .details-content{
        padding:40px;
    }

    .event-badge{
        display:inline-block;
        padding:8px 18px;
        border-radius:30px;
        background:rgba(147,51,234,0.20);
        color:#d8b4fe;
        font-size:13px;
        font-weight:600;
        margin-bottom:22px;
    }

    .details-title{
        color:white;
        font-size:48px;
        font-weight:800;
        margin-bottom:24px;
    }

    .details-meta{
        display:flex;
        gap:18px;
        flex-wrap:wrap;
        margin-bottom:28px;
    }

    .meta-box{
        padding:14px 20px;
        border-radius:16px;
        background:rgba(255,255,255,0.06);
        color:white;
    }

    .details-description{
        color:rgba(255,255,255,0.75);
        line-height:1.9;
        font-size:16px;
        margin-bottom:35px;
    }

    .back-btn{
        height:52px;
        padding:0 28px;
        border:none;
        border-radius:14px;

        background:
            linear-gradient(
                135deg,
                #7e22ce,
                #9333ea
            );

        color:white;
        font-weight:600;
    }

    .back-btn:hover{
        color:white;
        box-shadow:0 0 25px rgba(147,51,234,0.35);
    }

    @@media(max-width:768px){

        .details-image{
            height:240px;
        }

        .details-content{
            padding:24px;
        }

        .details-title{
            font-size:34px;
        }
    }

</style>