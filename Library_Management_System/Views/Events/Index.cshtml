@{
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
}
@model IEnumerable<LibraryManagementSystem.ClassLibrary.Models.Event>

@{
    ViewData["Title"] = "Events";
}

<style>

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        background: #070b1a;
        font-family: 'Inter', sans-serif;
    }

    .events-page {
        min-height: 100vh;
        padding: 28px;
        background: radial-gradient(circle at top right, rgba(168,85,247,.16), transparent 25%), radial-gradient(circle at bottom left, rgba(236,72,153,.12), transparent 28%), linear-gradient(135deg,#070b1a,#0f172a);
    }

    /* =========================================
           HERO SECTION
        ========================================= */

    .events-hero {
        position: relative;
        overflow: hidden;
        border-radius: 36px;
        padding: 75px 65px;
        margin-bottom: 55px;
        background: linear-gradient(rgba(7,11,26,.82), rgba(15,23,42,.90)), url('/images/library-banner.jpg');
        background-size: cover;
        background-position: center;
        border: 1px solid rgba(255,255,255,.08);
        box-shadow: 0 0 40px rgba(139,92,246,.12);
    }

        .events-hero::before {
            content: "";
            position: absolute;
            width: 420px;
            height: 420px;
            border-radius: 50%;
            background: rgba(168,85,247,.10);
            top: -180px;
            right: -120px;
        }

        .events-hero::after {
            content: "";
            position: absolute;
            width: 260px;
            height: 260px;
            border-radius: 50%;
            background: rgba(236,72,153,.08);
            bottom: -100px;
            left: -80px;
        }

    .hero-grid {
        position: relative;
        z-index: 2;
        display: grid;
        grid-template-columns: 1.5fr .8fr;
        gap: 40px;
        align-items: center;
    }

    /* HERO LEFT */

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 11px 22px;
        border-radius: 50px;
        background: rgba(255,255,255,.05);
        border: 1px solid rgba(255,255,255,.08);
        color: #c4b5fd;
        font-size: 13px;
        letter-spacing: 1px;
        margin-bottom: 26px;
        backdrop-filter: blur(12px);
    }

    .hero-left h1 {
        color: white;
        font-size: 68px;
        font-weight: 900;
        line-height: 1.05;
        margin-bottom: 24px;
    }

        .hero-left h1 span {
            background: linear-gradient(90deg,#c084fc,#f0abfc);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

    .hero-left p {
        color: #d1d5db;
        font-size: 17px;
        line-height: 1.9;
        max-width: 720px;
    }

    .hero-buttons {
        display: flex;
        gap: 18px;
        margin-top: 34px;
        flex-wrap: wrap;
    }

    .btn-main {
        padding: 15px 32px;
        border-radius: 16px;
        background: linear-gradient(90deg,#7c3aed,#9333ea);
        color: white;
        font-weight: 700;
        text-decoration: none;
        transition: .35s;
        border: none;
        box-shadow: 0 10px 25px rgba(139,92,246,.25);
    }

        .btn-main:hover {
            transform: translateY(-3px);
            color: white;
            box-shadow: 0 16px 35px rgba(139,92,246,.35);
        }

    .btn-glass {
        padding: 15px 32px;
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,.08);
        background: rgba(255,255,255,.04);
        color: white;
        text-decoration: none;
        transition: .35s;
        backdrop-filter: blur(10px);
    }

        .btn-glass:hover {
            background: rgba(255,255,255,.08);
            color: white;
            transform: translateY(-3px);
        }

    /* HERO CARD */

    .hero-side-card {
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.08);
        border-radius: 28px;
        padding: 34px;
        backdrop-filter: blur(16px);
        box-shadow: 0 0 25px rgba(139,92,246,.10);
    }

        .hero-side-card h4 {
            color: white;
            font-size: 24px;
            margin-bottom: 26px;
            font-weight: 700;
        }

    .stat-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        padding-bottom: 16px;
        border-bottom: 1px solid rgba(255,255,255,.06);
    }

        .stat-item:last-child {
            border-bottom: none;
            margin-bottom: 0;
            padding-bottom: 0;
        }

        .stat-item span {
            color: #c4b5fd;
            font-size: 14px;
        }

        .stat-item strong {
            color: white;
            font-size: 20px;
        }

    /* =========================================
           SECTION HEADER
        ========================================= */

    .section-header {
        margin-bottom: 38px;
    }

        .section-header h2 {
            color: white;
            font-size: 46px;
            font-weight: 800;
        }

        .section-header p {
            margin-top: 10px;
            color: #9ca3af;
            font-size: 16px;
        }

    /* =========================================
           EVENTS LIST
        ========================================= */

    .events-listing {
        display: flex;
        flex-direction: column;
        gap: 30px;
    }

    /* EVENT CARD */

    .premium-event-card {
        position: relative;
        display: grid;
        grid-template-columns: 320px 1fr 170px;
        gap: 30px;
        padding: 24px;
        border-radius: 30px;
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.08);
        backdrop-filter: blur(14px);
        transition: all .4s ease;
        overflow: hidden;
    }

        .premium-event-card::before {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(120deg, transparent, rgba(255,255,255,.03), transparent);
            opacity: 0;
            transition: .5s;
            pointer-events: none;
        }

        .premium-event-card:hover {
            transform: translateY(-8px);
            border-color: rgba(168,85,247,.25);
            box-shadow: 0 20px 50px rgba(139,92,246,.14), 0 10px 25px rgba(0,0,0,.25);
        }

            .premium-event-card:hover::before {
                opacity: 1;
            }

    /* IMAGE */

    .premium-event-image {
        position: relative;
        height: 260px;
        overflow: hidden;
        border-radius: 24px;
    }

        .premium-event-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: .7s;
        }

    .premium-event-card:hover img {
        transform: scale(1.08);
    }

    .premium-event-image::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(0,0,0,.55), transparent 55%);
    }

    .premium-badge {
        position: absolute;
        top: 16px;
        left: 16px;
        z-index: 2;
        padding: 9px 16px;
        border-radius: 50px;
        background: rgba(15,23,42,.85);
        border: 1px solid rgba(255,255,255,.08);
        color: white;
        font-size: 12px;
        font-weight: 600;
        backdrop-filter: blur(10px);
    }

    /* CONTENT */

    .premium-event-content {
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .event-top-info {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
        margin-bottom: 18px;
    }

    .event-category {
        padding: 8px 15px;
        border-radius: 50px;
        background: rgba(139,92,246,.12);
        color: #d8b4fe;
        font-size: 13px;
        font-weight: 600;
    }

    .event-date {
        color: #c4b5fd;
        font-size: 14px;
    }

    .premium-event-content h2 {
        color: white;
        font-size: 38px;
        font-weight: 800;
        line-height: 1.12;
        margin-bottom: 18px;
    }

    .premium-event-content p {
        color: #d1d5db;
        line-height: 1.9;
        font-size: 15px;
        margin-bottom: 24px;
        max-width: 92%;
    }

    /* META */

    .event-meta-list {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
    }

        .event-meta-list div {
            padding: 11px 16px;
            border-radius: 14px;
            background: rgba(255,255,255,.03);
            border: 1px solid rgba(255,255,255,.05);
            color: #ddd6fe;
            font-size: 14px;
        }

    /* SIDE */

    .premium-event-side {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 24px;
        position: relative;
        z-index: 5;
    }

    .side-date-box {
        width: 118px;
        height: 118px;
        border-radius: 30px;
        background: linear-gradient(135deg,#7c3aed,#9333ea);
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        color: white;
        box-shadow: 0 12px 30px rgba(139,92,246,.35);
    }

        .side-date-box strong {
            font-size: 44px;
            line-height: 1;
            font-weight: 900;
        }

        .side-date-box span {
            margin-top: 5px;
            font-size: 13px;
            letter-spacing: 1px;
        }

    .premium-btn {
        width: 100%;
        padding: 15px 20px;
        border-radius: 16px;
        text-align: center;
        text-decoration: none;
        font-weight: 700;
        background: rgba(255,255,255,.05);
        border: 1px solid rgba(255,255,255,.08);
        color: white;
        transition: .35s;
        position: relative;
        z-index: 10;
        cursor: pointer;
    }

        .premium-btn:hover {
            background: linear-gradient(90deg,#7c3aed,#9333ea);
            border-color: transparent;
            color: white;
            transform: translateY(-3px);
            box-shadow: 0 12px 25px rgba(139,92,246,.30);
        }

    /* =========================================
           RESPONSIVE
        ========================================= */

    @@media(max-width:1200px) {

        .premium-event-card {
            grid-template-columns: 1fr;
        }

        .premium-event-side {
            flex-direction: row;
            justify-content: space-between;
        }

        .premium-event-content p {
            max-width: 100%;
        }
    }

    @@media(max-width:991px) {

        .hero-grid {
            grid-template-columns: 1fr;
        }

        .hero-left h1 {
            font-size: 54px;
        }
    }

    @@media(max-width:768px) {

        .events-page {
            padding: 18px;
        }

        .events-hero {
            padding: 50px 26px;
            border-radius: 28px;
        }

        .hero-left h1 {
            font-size: 40px;
        }

        .hero-left p {
            font-size: 15px;
        }

        .section-header h2 {
            font-size: 34px;
        }

        .premium-event-image {
            height: 220px;
        }

        .premium-event-content h2 {
            font-size: 28px;
        }

        .premium-event-side {
            flex-direction: column;
        }

        .hero-buttons {
            flex-direction: column;
        }

        .btn-main,
        .btn-glass {
            width: 100%;
            text-align: center;
        }
    }

</style>

<div class="events-page">

    <!-- HERO -->

    <section class="events-hero">

        <div class="hero-grid">

            <!-- LEFT -->

            <div class="hero-left">

                <div class="hero-badge">
                    ✨ PREMIUM BOOKVERSE EVENTS
                </div>

                <h1>
                    Explore Inspiring
                    <span>Library Experiences</span>
                </h1>

                <p>
                    Discover premium workshops, author meetups,
                    book discussions, seminars and exclusive
                    community experiences crafted for readers.
                </p>

                <div class="hero-buttons">

                    <a href="#eventsList" class="btn-main">
                        Browse Events
                    </a>

                    <a asp-action="Past" class="btn-glass">
                        Past Events
                    </a>

                </div>

            </div>

            <!-- RIGHT -->

            <div class="hero-side-card">

                <h4>Quick Summary</h4>

                <div class="stat-item">
                    <span>Total Events</span>
                    <strong>@Model.Count()</strong>
                </div>

                <div class="stat-item">
                    <span>Current Month</span>
                    <strong>@DateTime.Now.ToString("MMM")</strong>
                </div>

                <div class="stat-item">
                    <span>Year</span>
                    <strong>@DateTime.Now.Year</strong>
                </div>

                <div class="stat-item">
                    <span>Active Sessions</span>
                    <strong>12</strong>
                </div>

            </div>

        </div>

    </section>

    <!-- EVENTS -->

    <div class="container-fluid">

        <div class="section-header">

            <h2>Upcoming Events</h2>

            <p>
                Discover and reserve your seat for upcoming sessions
            </p>

        </div>

        <div class="events-listing" id="eventsList">

            @foreach (var item in Model)
            {
                <div class="premium-event-card">

                    <!-- IMAGE -->

                    <div class="premium-event-image">

                        @if (!string.IsNullOrEmpty(item.ImagePath))
                        {
                            <img src="@item.ImagePath" />
                        }
                        else
                        {
                            <img src="/images/default-book.jpg" />
                        }

                        <div class="premium-badge">
                            Featured Event
                        </div>

                    </div>

                    <!-- CONTENT -->

                    <div class="premium-event-content">

                        <div class="event-top-info">

                            <div class="event-category">
                                📚 Library Event
                            </div>

                            <div class="event-date">
                                📅 @item.Date.ToString("dd MMM yyyy")
                            </div>

                        </div>

                        <h2>@item.Title</h2>

                        <p>
                            @(item.Description.Length > 180
                                                    ? item.Description.Substring(0, 180) + "..."
                                                    : item.Description)
                        </p>

                        <div class="event-meta-list">

                            <div>
                                📍 @item.Location
                            </div>

                            <div>
                                ⏰ 4:00 PM - 6:00 PM
                            </div>

                            <div>
                                👥 120 Seats
                            </div>

                        </div>

                    </div>

                    <!-- SIDE -->

                    <div class="premium-event-side">

                        <div class="side-date-box">

                            <strong>@item.Date.Day</strong>

                            <span>@item.Date.ToString("MMM")</span>

                        </div>

                        <a asp-controller="Events"
                           asp-action="Details"
                           asp-route-id="@item.Id"
                           class="premium-btn">

                            View Details

                        </a>

                    </div>

                </div>
            }

        </div>

    </div>

</div>