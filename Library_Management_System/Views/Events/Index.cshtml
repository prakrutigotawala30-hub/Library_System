@model IEnumerable<LibraryManagementSystem.ClassLibrary.Models.Event>

@{
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
    ViewData["Title"] = "Events";
}

<style>

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        background: #070b1a;
        font-family: 'Inter', sans-serif;
        overflow-x: hidden;
    }

    .events-page {
        min-height: 100vh;
        padding: 30px;
        background: radial-gradient(circle at top right, rgba(168,85,247,.18), transparent 25%), radial-gradient(circle at bottom left, rgba(236,72,153,.12), transparent 28%), linear-gradient(135deg,#070b1a,#0f172a);
    }

    /* ================= HERO ================= */

    .events-hero {
        position: relative;
        overflow: hidden;
        border-radius: 38px;
        padding: 80px 70px;
        margin-bottom: 55px;
        background: linear-gradient(rgba(7,11,26,.86), rgba(15,23,42,.92)), url('/images/library-banner.jpg');
        background-size: cover;
        background-position: center;
        border: 1px solid rgba(255,255,255,.08);
        box-shadow: 0 25px 60px rgba(0,0,0,.35);
    }

        .events-hero::before {
            content: "";
            position: absolute;
            width: 420px;
            height: 420px;
            border-radius: 50%;
            background: rgba(168,85,247,.10);
            top: -180px;
            right: -120px;
        }

        .events-hero::after {
            content: "";
            position: absolute;
            width: 280px;
            height: 280px;
            border-radius: 50%;
            background: rgba(236,72,153,.08);
            bottom: -100px;
            left: -80px;
        }

    .hero-grid {
        position: relative;
        z-index: 2;
        display: grid;
        grid-template-columns: 1.4fr .8fr;
        gap: 50px;
        align-items: center;
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 12px 22px;
        border-radius: 50px;
        background: rgba(255,255,255,.05);
        border: 1px solid rgba(255,255,255,.08);
        color: #c4b5fd;
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 1px;
        margin-bottom: 25px;
        backdrop-filter: blur(14px);
    }

    .hero-left h1 {
        color: white;
        font-size: 68px;
        line-height: 1.05;
        font-weight: 900;
        margin-bottom: 20px;
    }

        .hero-left h1 span {
            background: linear-gradient(90deg,#c084fc,#f0abfc);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

    .hero-left p {
        color: #d1d5db;
        line-height: 1.9;
        font-size: 17px;
        max-width: 700px;
    }

    .hero-actions {
        margin-top: 30px;
        display: flex;
        gap: 15px;
        flex-wrap: wrap;
    }

    .btn-main {
        padding: 15px 28px;
        border-radius: 16px;
        background: linear-gradient(90deg,#7c3aed,#9333ea);
        color: white;
        text-decoration: none;
        font-weight: 700;
        transition: .35s;
        box-shadow: 0 10px 25px rgba(139,92,246,.25);
    }

        .btn-main:hover {
            color: white;
            transform: translateY(-3px);
            box-shadow: 0 18px 35px rgba(139,92,246,.35);
        }

    .btn-glass {
        padding: 15px 28px;
        border-radius: 16px;
        text-decoration: none;
        font-weight: 700;
        color: white;
        background: rgba(255,255,255,.05);
        border: 1px solid rgba(255,255,255,.08);
        transition: .35s;
        backdrop-filter: blur(12px);
    }

        .btn-glass:hover {
            background: rgba(255,255,255,.08);
            color: white;
            transform: translateY(-3px);
        }

    /* ================= EVENTS GRID ================= */

    .events-listing {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px,1fr));
        gap: 30px;
    }

    /* ================= CARD ================= */

    .premium-event-card {
        overflow: hidden;
        border-radius: 30px;
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.08);
        transition: .35s;
        backdrop-filter: blur(16px);
        box-shadow: 0 10px 35px rgba(0,0,0,.25);
    }

        .premium-event-card:hover {
            transform: translateY(-10px);
            border-color: rgba(139,92,246,.35);
            box-shadow: 0 25px 55px rgba(139,92,246,.18);
        }

    /* ================= IMAGE ================= */

    .premium-event-image {
        position: relative;
        height: 240px;
        overflow: hidden;
        background: #111827;
    }

        .premium-event-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: .45s;
        }

    .premium-event-card:hover .premium-event-image img {
        transform: scale(1.05);
    }

    .premium-event-image::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(0,0,0,.55), transparent);
    }

    /* ================= CONTENT ================= */

    .premium-event-content {
        padding: 24px;
    }

    .event-date {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 14px;
        border-radius: 50px;
        background: rgba(139,92,246,.12);
        color: #d8b4fe;
        font-size: 12px;
        font-weight: 700;
        margin-bottom: 18px;
    }

    .event-title {
        color: white;
        font-size: 26px;
        line-height: 1.3;
        font-weight: 800;
        margin-bottom: 18px;
        min-height: 68px;
    }

    .event-details {
        display: grid;
        gap: 12px;
        margin-bottom: 24px;
    }

    .detail-box {
        padding: 16px;
        border-radius: 18px;
        background: rgba(255,255,255,.03);
        border: 1px solid rgba(255,255,255,.05);
    }

        .detail-box small {
            display: block;
            margin-bottom: 8px;
            color: #c4b5fd;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .detail-box span {
            color: white;
            font-size: 14px;
            font-weight: 600;
        }

    .premium-event-btn {
        width: 100%;
        display: inline-flex;
        justify-content: center;
        align-items: center;
        padding: 15px;
        border-radius: 18px;
        background: linear-gradient(90deg,#7c3aed,#9333ea);
        color: white;
        text-decoration: none;
        font-weight: 700;
        transition: .35s;
        box-shadow: 0 10px 25px rgba(139,92,246,.25);
    }

        .premium-event-btn:hover {
            color: white;
            transform: translateY(-3px);
            box-shadow: 0 18px 35px rgba(139,92,246,.35);
        }

    /* ================= EMPTY ================= */

    .empty-box {
        padding: 90px 30px;
        text-align: center;
        border-radius: 30px;
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.08);
    }

        .empty-box img {
            width: 120px;
            margin-bottom: 20px;
        }

        .empty-box h3 {
            color: white;
            font-size: 32px;
            margin-bottom: 10px;
        }

        .empty-box p {
            color: #9ca3af;
        }

    /* ================= RESPONSIVE ================= */

    @@media(max-width:992px) {

        .hero-grid {
            grid-template-columns: 1fr;
        }

        .hero-left h1 {
            font-size: 50px;
        }
    }

    @@media(max-width:768px) {

        .events-page {
            padding: 18px;
        }

        .events-hero {
            padding: 50px 30px;
            border-radius: 30px;
        }

        .hero-left h1 {
            font-size: 40px;
        }

        .events-listing {
            grid-template-columns: 1fr;
        }

        .premium-event-image {
            height: 220px;
        }
    }

</style>

<div class="events-page">

    <!-- HERO -->

    <section class="events-hero">

        <div class="hero-grid">

            <div class="hero-left">

                <div class="hero-badge">
                    ✨ PREMIUM LIBRARY EVENTS
                </div>

                <h1>
                    Discover Amazing
                    <span>Library Events</span>
                </h1>

                <p>
                    Join workshops, reading sessions, author meetups,
                    educational programs and premium community events
                    designed for passionate readers and learners.
                </p>

                <div class="hero-actions">

                    <a href="#eventsList" class="btn-main">
                        Browse Events
                    </a>

                    <a asp-action="Past" class="btn-glass">
                        View Past Events
                    </a>

                </div>

            </div>

        </div>

    </section>

    <!-- EVENTS -->

    <div class="events-listing" id="eventsList">

        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="premium-event-card">

                    <!-- IMAGE -->

                    <div class="premium-event-image">

                        <img src="@(string.IsNullOrEmpty(item.ImagePath)
                                                                                              ? "/images/default-book.jpg"
                                                                                              : item.ImagePath)" />

                    </div>

                    <!-- CONTENT -->

                    <div class="premium-event-content">

                        <div class="event-date">
                            📅 @item.Date.ToString("dd MMM yyyy")
                        </div>

                        <div class="event-title">
                            @item.Title
                        </div>

                        <div class="event-details">

                            <div class="detail-box">

                                <small>Location</small>

                                <span>
                                    📍 @item.Location
                                </span>

                            </div>

                            <div class="detail-box">

                                <small>Event Time</small>

                                <span>
                                    ⏰ @item.Date.ToString("hh:mm tt")
                                </span>

                            </div>

                        </div>

                        <a asp-controller="Events"
                           asp-action="Details"
                           asp-route-id="@item.Id"
                           class="premium-event-btn">

                            Explore Event →

                        </a>

                    </div>

                </div>
            }
        }
        else
        {
            <div class="empty-box">

                <img src="https://cdn-icons-png.flaticon.com/512/7486/7486740.png" />

                <h3>No Events Found</h3>

                <p>
                    There are currently no upcoming events available.
                </p>

            </div>
        }

    </div>

</div>
