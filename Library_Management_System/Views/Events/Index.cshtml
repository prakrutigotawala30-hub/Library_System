@{
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
}

@model IEnumerable<Library_Management_System.Models.Event>

@{
    ViewData["Title"] = "Events";
}

<style>

    .events-page {
        min-height: 100vh;
        padding: 40px;
        background: radial-gradient(circle at top right, rgba(168,85,247,.18), transparent 25%), radial-gradient(circle at bottom left, rgba(236,72,153,.15), transparent 30%), linear-gradient(to bottom,#040816,#0b1120);
    }

    /* =========================================
           HERO SECTION
        ========================================= */

    .events-hero {
        position: relative;
        overflow: hidden;
        border-radius: 38px;
        padding: 85px 75px;
        margin-bottom: 70px;
        background: linear-gradient( 135deg, rgba(76,29,149,.92), rgba(17,24,39,.94) ), url('/images/library-banner.jpg');
        background-size: cover;
        background-position: center;
    }

        .events-hero::before {
            content: "";
            position: absolute;
            width: 450px;
            height: 450px;
            border-radius: 50%;
            background: rgba(255,255,255,.04);
            top: -180px;
            right: -120px;
        }

    .hero-grid {
        position: relative;
        z-index: 2;
        display: grid;
        grid-template-columns: 1.5fr .8fr;
        gap: 45px;
    }

    /* LEFT */

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 11px 22px;
        border-radius: 50px;
        background: rgba(255,255,255,.08);
        border: 1px solid rgba(255,255,255,.12);
        backdrop-filter: blur(10px);
        color: #f5d0fe;
        margin-bottom: 28px;
        font-size: 13px;
        letter-spacing: 1px;
    }

    .hero-left h1 {
        color: white;
        font-size: 72px;
        font-weight: 900;
        line-height: 1.08;
    }

        .hero-left h1 span {
            color: #f0abfc;
        }

    .hero-left p {
        margin-top: 28px;
        color: #ddd6fe;
        line-height: 1.9;
        font-size: 17px;
        max-width: 720px;
    }

    .hero-buttons {
        display: flex;
        gap: 18px;
        margin-top: 38px;
        flex-wrap: wrap;
    }

    .btn-main {
        padding: 16px 34px;
        border-radius: 16px;
        text-decoration: none;
        font-weight: 700;
        background: linear-gradient( 135deg, #d946ef, #9333ea );
        color: white;
        transition: .4s;
    }

        .btn-main:hover {
            color: white;
            transform: translateY(-4px);
            box-shadow: 0 15px 35px rgba(192,38,211,.35);
        }

    .btn-glass {
        padding: 16px 34px;
        border-radius: 16px;
        text-decoration: none;
        border: 1px solid rgba(255,255,255,.12);
        background: rgba(255,255,255,.05);
        color: white;
    }

        .btn-glass:hover {
            background: rgba(255,255,255,.1);
            color: white;
        }

    /* RIGHT CARD */

    .hero-side-card {
        background: rgba(255,255,255,.06);
        border: 1px solid rgba(255,255,255,.08);
        border-radius: 30px;
        padding: 35px;
        backdrop-filter: blur(16px);
    }

        .hero-side-card h4 {
            color: white;
            margin-bottom: 28px;
            font-weight: 700;
        }

    .stat-item {
        display: flex;
        justify-content: space-between;
        margin-bottom: 24px;
        color: white;
    }

        .stat-item span {
            color: #c4b5fd;
        }

    /* =========================================
           SECTION
        ========================================= */

    .section-header {
        margin-bottom: 40px;
    }

        .section-header h2 {
            color: white;
            font-size: 44px;
            font-weight: 800;
        }

        .section-header p {
            color: #c4b5fd;
            margin-top: 10px;
        }

    /* =========================================
           PREMIUM LISTING
        ========================================= */

    .events-listing {
        display: flex;
        flex-direction: column;
        gap: 32px;
    }

    /* CARD */

    .premium-event-card {
        position: relative;
        display: grid;
        grid-template-columns: 340px 1fr 170px;
        gap: 35px;
        padding: 24px;
        border-radius: 34px;
        background: linear-gradient( 145deg, rgba(255,255,255,.07), rgba(255,255,255,.03) );
        border: 1px solid rgba(255,255,255,.08);
        backdrop-filter: blur(18px);
        overflow: hidden;
        transition: .45s;
    }

        .premium-event-card::before {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient( 120deg, transparent, rgba(255,255,255,.04), transparent );
            opacity: 0;
            transition: .5s;
            pointer-events: none;
        }

        .premium-event-card:hover {
            transform: translateY(-10px);
            border-color: rgba(216,180,254,.22);
            box-shadow: 0 20px 60px rgba(168,85,247,.16), 0 10px 25px rgba(0,0,0,.25);
        }

            .premium-event-card:hover::before {
                opacity: 1;
            }

    /* IMAGE */

    .premium-event-image {
        position: relative;
        height: 280px;
        overflow: hidden;
        border-radius: 26px;
    }

        .premium-event-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: .7s;
        }

    .premium-event-card:hover img {
        transform: scale(1.08);
    }

    .premium-event-image::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient( to top, rgba(0,0,0,.45), transparent 50% );
    }

    /* BADGE */

    .premium-badge {
        position: absolute;
        top: 18px;
        left: 18px;
        z-index: 2;
        padding: 10px 18px;
        border-radius: 50px;
        background: rgba(17,24,39,.78);
        border: 1px solid rgba(255,255,255,.08);
        backdrop-filter: blur(12px);
        color: white;
        font-size: 13px;
        font-weight: 600;
    }

    /* CONTENT */

    .premium-event-content {
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .event-top-info {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 12px;
        margin-bottom: 20px;
    }

    .event-category {
        padding: 8px 16px;
        border-radius: 50px;
        background: rgba(168,85,247,.12);
        color: #f0abfc;
        font-size: 13px;
        font-weight: 600;
    }

    .event-date {
        color: #c4b5fd;
        font-size: 14px;
    }

    .premium-event-content h2 {
        color: white;
        font-size: 42px;
        font-weight: 800;
        line-height: 1.15;
        margin-bottom: 18px;
    }

    .premium-event-content p {
        color: #d1d5db;
        line-height: 1.9;
        font-size: 15px;
        margin-bottom: 28px;
        max-width: 90%;
    }

    /* META */

    .event-meta-list {
        display: flex;
        flex-wrap: wrap;
        gap: 16px;
    }

        .event-meta-list div {
            padding: 12px 18px;
            border-radius: 14px;
            background: rgba(255,255,255,.04);
            border: 1px solid rgba(255,255,255,.05);
            color: #e9d5ff;
            font-size: 14px;
        }

    /* RIGHT SIDE */

    .premium-event-side {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 28px;
    }

    /* DATE BOX */

    .side-date-box {
        width: 120px;
        height: 120px;
        border-radius: 32px;
        background: linear-gradient( 145deg, #c026d3, #7e22ce );
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        color: white;
        box-shadow: 0 15px 35px rgba(168,85,247,.35);
    }

        .side-date-box strong {
            font-size: 46px;
            line-height: 1;
            font-weight: 900;
        }

        .side-date-box span {
            margin-top: 6px;
            font-size: 14px;
            letter-spacing: 1px;
        }

    /* BUTTON */

    .premium-btn {
        width: 100%;
        padding: 15px 22px;
        border-radius: 16px;
        text-align: center;
        text-decoration: none;
        font-weight: 700;
        background: linear-gradient( 135deg, rgba(255,255,255,.08), rgba(255,255,255,.04) );
        border: 1px solid rgba(255,255,255,.08);
        color: white;
        transition: .4s;
    }

        .premium-btn:hover {
            background: linear-gradient( 135deg, #c026d3, #7e22ce );
            border-color: transparent;
            color: white;
            transform: translateY(-3px);
            box-shadow: 0 12px 25px rgba(168,85,247,.35);
        }

    /* =========================================
           RESPONSIVE
        ========================================= */

    @@media(max-width:1200px) {

        .premium-event-card {
            grid-template-columns: 1fr;
        }

        .premium-event-side {
            flex-direction: row;
            justify-content: space-between;
        }

        .premium-event-content p {
            max-width: 100%;
        }
    }

    @@media(max-width:991px) {

        .hero-grid {
            grid-template-columns: 1fr;
        }

        .hero-left h1 {
            font-size: 54px;
        }
    }

    @@media(max-width:768px) {

        .events-page {
            padding: 20px;
        }

        .events-hero {
            padding: 55px 30px;
        }

        .hero-left h1 {
            font-size: 40px;
        }

        .section-header h2 {
            font-size: 34px;
        }

        .premium-event-image {
            height: 230px;
        }

        .premium-event-content h2 {
            font-size: 30px;
        }

        .premium-event-side {
            flex-direction: column;
        }
    }

</style>

<div class="events-page">

    <!-- HERO -->

    <section class="events-hero">

        <div class="hero-grid">

            <!-- LEFT -->

            <div class="hero-left">

                <div class="hero-badge">
                    ✨ PREMIUM BOOKVERSE EVENTS
                </div>

                <h1>
                    Explore Inspiring
                    <span>Library Experiences</span>
                </h1>

                <p>
                    Discover premium workshops, author meetups,
                    book discussions, seminars and exclusive
                    community experiences crafted for readers.
                </p>

                <div class="hero-buttons">

                    <a href="#eventsList" class="btn-main">
                        Browse Events
                    </a>

                    <a asp-action="Past" class="btn-glass">
                        Past Events
                    </a>

                </div>

            </div>

            <!-- RIGHT -->

            <div class="hero-side-card">

                <h4>Quick Summary</h4>

                <div class="stat-item">
                    <span>Total Events</span>
                    <strong>@Model.Count()</strong>
                </div>

                <div class="stat-item">
                    <span>Current Month</span>
                    <strong>@DateTime.Now.ToString("MMM")</strong>
                </div>

                <div class="stat-item">
                    <span>Year</span>
                    <strong>@DateTime.Now.Year</strong>
                </div>

                <div class="stat-item">
                    <span>Active Sessions</span>
                    <strong>12</strong>
                </div>

            </div>

        </div>

    </section>

    <!-- EVENTS -->

    <div class="container-fluid">

        <div class="section-header">

            <h2>Upcoming Events</h2>

            <p>
                Discover and reserve your seat for upcoming sessions
            </p>

        </div>

        <div class="events-listing" id="eventsList">

            @foreach (var item in Model)
            {
                <div class="premium-event-card">

                    <!-- IMAGE -->

                    <div class="premium-event-image">

                        @if (!string.IsNullOrEmpty(item.ImagePath))
                        {
                            <img src="@item.ImagePath" />
                        }
                        else
                        {
                            <img src="/images/default-book.jpg" />
                        }

                        <div class="premium-badge">
                            Featured Event
                        </div>

                    </div>

                    <!-- CONTENT -->

                    <div class="premium-event-content">

                        <div class="event-top-info">

                            <div class="event-category">
                                📚 Library Event
                            </div>

                            <div class="event-date">
                                📅 @item.Date.ToString("dd MMM yyyy")
                            </div>

                        </div>

                        <h2>@item.Title</h2>

                        <p>
                            @(item.Description.Length > 180
                                                    ? item.Description.Substring(0, 180) + "..."
                                                    : item.Description)
                        </p>

                        <div class="event-meta-list">

                            <div>
                                📍 @item.Location
                            </div>

                            <div>
                                ⏰ 4:00 PM - 6:00 PM
                            </div>

                            <div>
                                👥 120 Seats
                            </div>

                        </div>

                    </div>

                    <!-- SIDE -->

                    <div class="premium-event-side">

                        <div class="side-date-box">

                            <strong>@item.Date.Day</strong>

                            <span>@item.Date.ToString("MMM")</span>

                        </div>

                        <a asp-action="Details"
                           asp-route-id="@item.Id"
                           class="premium-btn">

                            View Details

                        </a>

                    </div>

                </div>
            }

        </div>

    </div>

</div>