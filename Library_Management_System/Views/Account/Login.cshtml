@model Library_Management_System.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Library Login</title>

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
          rel="stylesheet">

    <style>

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter',sans-serif;
        }

        body {
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 10px;
            overflow: hidden;
            background: linear-gradient( 135deg, #05010a 0%, #170022 30%, #32004d 65%, #5f006f 100% );
        }

        /* WRAPPER */

        .login-wrapper {
            width: 100%;
            max-width: 820px; /* SMALL */
        }

        /* CARD */

        .glass-card {
            width: 100%;
            min-height: 430px; /* SMALL */
            display: flex;
            overflow: hidden;
            border-radius: 22px;
            background: linear-gradient( 135deg, rgba(20,0,35,0.95), rgba(70,0,120,0.88), rgba(125,0,120,0.78) );
            border: 1px solid rgba(255,255,255,0.08);
            box-shadow: 0 15px 35px rgba(0,0,0,0.45), 0 0 24px rgba(192,38,211,0.16);
            backdrop-filter: blur(12px);
        }

        /* LEFT */

        .left-panel {
            width: 42%;
            padding: 32px 26px;
            color: white;
            background: linear-gradient( 180deg, rgba(35,0,60,0.95), rgba(95,0,140,0.85), rgba(125,0,115,0.82) );
            border-right: 1px solid rgba(255,255,255,0.06);
            display: flex;
            align-items: center;
        }

        .logo {
            font-size: 30px;
            margin-bottom: 14px;
        }

        .left-panel h2 {
            font-size: 36px;
            line-height: 1.1;
            font-weight: 800;
            margin-bottom: 14px;
        }

        .left-panel p {
            font-size: 13px;
            line-height: 1.7;
            color: #f3e8ff;
        }

        .feature-list {
            margin-top: 18px;
            padding-left: 18px;
        }

            .feature-list li {
                margin-bottom: 9px;
                font-size: 13px;
                color: #f5d0fe;
            }

        .quote {
            margin-top: 18px;
            font-size: 13px;
            font-style: italic;
            color: #fbcfe8;
        }

        /* RIGHT */

        .right-panel {
            width: 58%;
            padding: 32px 28px;
            color: white;
            background: linear-gradient( 135deg, rgba(55,0,85,0.70), rgba(120,0,120,0.48) );
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .title {
            text-align: center;
            font-size: 38px;
            font-weight: 800;
            margin-bottom: 24px;
        }

        .form-label {
            color: #f5d0fe;
            font-size: 14px;
            margin-bottom: 6px;
            font-weight: 500;
        }

        .form-control {
            height: 46px;
            border: none;
            border-radius: 12px;
            background: rgba(255,255,255,0.12);
            color: white;
            padding: 10px 14px;
            font-size: 14px;
            border: 1px solid rgba(255,255,255,0.08);
            margin-bottom: 4px;
        }

            .form-control::placeholder {
                color: rgba(255,255,255,0.55);
            }

            .form-control:focus {
                background: rgba(255,255,255,0.16);
                color: white;
                border: 1px solid #d946ef;
                box-shadow: 0 0 0 3px rgba(217,70,239,0.18);
            }

        .form-check {
            margin-top: 6px;
            margin-bottom: 18px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .form-check-input {
            width: 15px;
            height: 15px;
            background-color: rgba(255,255,255,0.12);
            border: 1px solid rgba(255,255,255,0.22);
        }

            .form-check-input:checked {
                background-color: #d946ef;
                border-color: #d946ef;
            }

        .form-check-label {
            font-size: 13px;
            color: #f8fafc;
        }

        /* BUTTON */

        .btn-login {
            width: 100%;
            height: 46px;
            border: none;
            border-radius: 12px;
            background: linear-gradient( 135deg, #ff00cc 0%, #c026d3 45%, #7e22ce 100% );
            color: white;
            font-size: 16px;
            font-weight: 700;
            transition: 0.3s;
        }

            .btn-login:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 18px rgba(192,38,211,0.35);
                color: white;
            }

        .bottom-links {
            margin-top: 18px;
            text-align: center;
        }

            .bottom-links a {
                color: #f9a8d4;
                text-decoration: none;
                font-size: 13px;
                transition: 0.3s;
            }

                .bottom-links a:hover {
                    color: white;
                }

        .register-text {
            margin-top: 8px;
            color: white;
            font-size: 13px;
        }

        .text-danger {
            font-size: 11px;
            color: #fecdd3 !important;
        }

        /* MOBILE */

        @@media(max-width:768px) {

            body {
                overflow: auto;
                padding: 12px;
            }

            .glass-card {
                flex-direction: column;
                min-height: auto;
            }

            .left-panel,
            .right-panel {
                width: 100%;
            }

            .left-panel {
                text-align: center;
                padding: 24px 20px;
            }

            .right-panel {
                padding: 24px 20px;
            }

            .left-panel h2 {
                font-size: 30px;
            }

            .title {
                font-size: 30px;
            }
        }

    </style>

</head>
<body>

    <div class="login-wrapper">

        <div class="glass-card">

            <!-- LEFT -->

            <div class="left-panel">

                <div>

                    <div class="logo">📚</div>

                    <h2>
                        Library<br>
                        System
                    </h2>

                    <p>
                        Smart digital platform for managing books,
                        members, issue-return operations and library
                        access securely.
                    </p>

                    <ul class="feature-list">
                        <li>Book Management</li>
                        <li>Issue & Return Tracking</li>
                        <li>Secure Authentication</li>
                        <li>Modern Dashboard</li>
                    </ul>

                    <p class="quote">
                        “Knowledge is the key to success.”
                    </p>

                </div>

            </div>

            <!-- RIGHT -->

            <div class="right-panel">

                <h2 class="title">Welcome Back</h2>

                <form asp-action="Login" method="post">

                    <div asp-validation-summary="ModelOnly"
                         class="text-danger mb-3">
                    </div>

                    @if (ViewBag.ShowResendConfirmation == true)
                    {
                        <div class="mb-3">
                            <button type="submit"
                                    formaction="@Url.Action("ResendConfirmation", "Account")"
                                    formmethod="post"
                                    name="email"
                                    value="@ViewBag.ResendEmail"
                                    class="btn btn-link p-0"
                                    style="font-size:14px;">
                                Resend confirmation email
                            </button>
                        </div>
                    }

                    <div class="mb-4">

                        <label asp-for="Email"
                               class="form-label">
                            Email
                        </label>

                        <input asp-for="Email"
                               class="form-control"
                               placeholder="Enter your email" />

                        <span asp-validation-for="Email"
                              class="text-danger">
                        </span>

                    </div>

                    <div class="mb-4">

                        <label asp-for="Password"
                               class="form-label">
                            Password
                        </label>

                        <input asp-for="Password"
                               type="password"
                               class="form-control"
                               placeholder="Enter your password" />

                        <span asp-validation-for="Password"
                              class="text-danger">
                        </span>

                    </div>

                    <div class="form-check">

                        <input asp-for="RememberMe"
                               class="form-check-input" />

                        <label asp-for="RememberMe"
                               class="form-check-label">
                            Remember Me
                        </label>

                    </div>

                    <button type="submit"
                            class="btn-login">
                        Login
                    </button>

                    <div class="bottom-links">

                        <div>
                            <a asp-action="ForgotPassword">
                                Forgot Password?
                            </a>
                        </div>

                        <div class="register-text">
                            Don’t have an account?

                            <a asp-action="Register">
                                Register
                            </a>
                        </div>

                    </div>

                </form>

            </div>

        </div>

    </div>

    <partial name="_ValidationScriptsPartial" />

</body>
</html>
```

