@model Library_Management_System.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<link rel="stylesheet" href="~/css/auth.css" />

<div class="login-wrapper">

    <div class="glass-card">

        <!-- LEFT PANEL -->
        <div class="left-panel">

            <div class="left-panel-content">

                <div class="logo">📚</div>

                <h2>Library System</h2>

                <p>
                    Smart digital platform for managing books,
                    members, issue-return operations and library access securely.
                </p>

                <ul class="feature-list">
                    <li>Book Management</li>
                    <li>Issue & Return Tracking</li>
                    <li>Secure Authentication</li>
                    <li>Modern Dashboard</li>
                </ul>

                <p class="quote">
                    “Knowledge is the key to success.”
                </p>

            </div>

        </div>

        <!-- RIGHT PANEL -->
        <div class="right-panel">

            <h2 class="title">Welcome Back</h2>

            <form asp-action="Login" method="post">

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small-text"></div>

                <div class="mb-3">
                    <label asp-for="Email"></label>
                    <input asp-for="Email" class="form-control" placeholder="Enter your email" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password"></label>
                    <input asp-for="Password" type="password" class="form-control" placeholder="Enter your password" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="form-check mb-3">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label"></label>
                </div>

                <button type="submit" class="btn btn-login w-100">
                    Login
                </button>

                <div class="text-center mt-3 small-text">
                    <a asp-action="ForgotPassword">Forgot Password?</a>
                </div>

                <div class="text-center mt-2 small-text">
                    Don’t have an account?
                    <a asp-action="Register">Register</a>
                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
<style>
    * {
        box-sizing: border-box;
    }

    body {
        margin: 0;
        min-height: 100vh;
        background: linear-gradient(135deg,#4b0082,#6a0dad,#9b30ff);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 18px;
        font-family: 'Segoe UI', sans-serif;
        overflow-x: hidden;
    }

    /* WRAPPER */
    .login-wrapper {
        width: 100%;
        max-width: 940px;
    }

    /* GLASS CARD */
    .glass-card {
        display: flex;
        width: 100%;
        min-height: 500px;
        border-radius: 24px;
        overflow: hidden;
        background: rgba(255,255,255,0.10);
        backdrop-filter: blur(16px);
        border: 1px solid rgba(255,255,255,0.12);
        box-shadow: 0 20px 45px rgba(0,0,0,0.28);
    }

    /* LEFT */
    .left-panel {
        width: 42%;
        padding: 42px 36px;
        background: linear-gradient(135deg, rgba(75,0,130,0.95), rgba(155,48,255,0.82));
        color: white;
        display: flex;
        flex-direction: column;
        justify-content: center;
        position: relative;
    }

        .left-panel::before {
            content: "";
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at top right, rgba(255,255,255,0.14), transparent 42%);
        }

    .left-panel-content {
        position: relative;
        z-index: 2;
    }

    .logo {
        font-size: 38px;
        margin-bottom: 10px;
    }

    .left-panel h2 {
        font-size: 30px;
        font-weight: 700;
        margin-bottom: 16px;
    }

    .left-panel p {
        font-size: 14px;
        line-height: 1.7;
        opacity: 0.92;
    }

    .feature-list {
        margin-top: 22px;
        padding-left: 18px;
    }

        .feature-list li {
            margin-bottom: 10px;
            font-size: 14px;
        }

    .quote {
        margin-top: 24px;
        font-style: italic;
        font-size: 13px;
        opacity: 0.9;
    }

    /* RIGHT */
    .right-panel {
        width: 58%;
        padding: 42px 38px;
        background: rgba(255,255,255,0.06);
        display: flex;
        flex-direction: column;
        justify-content: center;
        color: white;
    }

    .title {
        text-align: center;
        font-size: 28px;
        font-weight: 700;
        margin-bottom: 26px;
    }

    .subtitle {
        text-align: center;
        font-size: 13px;
        color: rgba(255,255,255,0.75);
        margin-bottom: 20px;
    }

    .form-control {
        height: 48px;
        border-radius: 12px;
        background: rgba(255,255,255,0.12);
        color: white;
        border: 1px solid rgba(255,255,255,0.12);
        padding: 12px 15px;
    }

        .form-control:focus {
            background: rgba(255,255,255,0.16);
            border-color: #d8b4fe;
            box-shadow: 0 0 0 4px rgba(216,180,254,0.22);
            color: white;
        }

        .form-control::placeholder {
            color: rgba(255,255,255,0.7);
        }

    .btn-login {
        height: 48px;
        border-radius: 12px;
        background: linear-gradient(135deg,#a855f7,#7e22ce);
        color: white;
        font-weight: 600;
        border: none;
    }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 22px rgba(168,85,247,0.35);
        }

    .small-text {
        font-size: 13px;
    }

    .text-danger {
        font-size: 12px;
    }

    /* MOBILE */
    @@media(max - width:768px) {

        .glass-card {
            flex-direction: column;
        }

        .left-panel,
        .right-panel {
            width: 100%;
        }

        .right-panel {
            padding: 34px 22px;
        }

        .left-panel {
            text-align: center;
            padding: 34px 24px;
        }
    }
</style>