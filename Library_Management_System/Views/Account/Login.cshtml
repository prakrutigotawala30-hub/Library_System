@model Library_Management_System.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Login";
}
<body>

<link rel="stylesheet" href="~/css/auth.css" />

<div class="login-wrapper">

    <div class="glass-card">

        <!-- LEFT PANEL -->
        <div class="left-panel">

            <div class="left-panel-content">

                <div class="logo">📚</div>

                <h2>Library System</h2>

                <p>
                    Smart digital platform for managing books,
                    members, issue-return operations and library access securely.
                </p>

                <ul class="feature-list">
                    <li>Book Management</li>
                    <li>Issue & Return Tracking</li>
                    <li>Secure Authentication</li>
                    <li>Modern Dashboard</li>
                </ul>

                <p class="quote">
                    “Knowledge is the key to success.”
                </p>

            </div>

        </div>

        <!-- RIGHT PANEL -->
        <div class="right-panel">

            <h2 class="title">Welcome Back</h2>

            <form asp-action="Login" method="post">

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small-text"></div>

                <div class="mb-3">
                    <label asp-for="Email"></label>
                    <input asp-for="Email" class="form-control" placeholder="Enter your email" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password"></label>
                    <input asp-for="Password" type="password" class="form-control" placeholder="Enter your password" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="form-check mb-3">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label"></label>
                </div>

                <button type="submit" class="btn btn-login w-100">
                    Login
                </button>

                <div class="text-center mt-3 small-text">
                    <a asp-action="ForgotPassword">Forgot Password?</a>
                </div>

                <div class="text-center mt-2 small-text">
                    Don’t have an account?
                    <a asp-action="Register">Register</a>
                </div>

            </form>

        </div>

    </div>

</div>
</body>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
<style>

    html, body {
        background: #000 !important;
        margin: 0 !important;
        padding: 0 !important;
        min-height: 100vh !important;
    }

    /* REMOVE LAYOUT BACKGROUND */
    main,
    .container,
    .container-fluid,
    .content-wrapper,
    .page,
    .wrapper {
        background: transparent !important;
    }

    * {
        box-sizing: border-box;
    }

    body {
        margin: 0;
        min-height: 100vh;
        background: #000000 !important;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
        font-family: 'Segoe UI', sans-serif;
        overflow-x: hidden;
    }

    /* WRAPPER */
    .login-wrapper {
        width: 100%;
        max-width: 980px;
    }

    /* MAIN CARD */
    .glass-card {
        display: flex;
        width: 100%;
        min-height: 540px;
        border-radius: 28px;
        overflow: hidden;
        /* background: linear-gradient( 135deg, #4c1d95, #6d28d9, #7c3aed ); */
        border: 1px solid rgba(255,255,255,0.08);
        backdrop-filter: blur(14px);
        box-shadow: 0 20px 50px rgba(0,0,0,0.55), 0 0 35px rgba(168,85,247,0.18);
    }

    /* LEFT PANEL */
    .left-panel {
        width: 42%;
        padding: 48px 38px;
        color: white;
        display: flex;
        flex-direction: column;
        justify-content: center;
        position: relative;
        background: rgba(0,0,0,0.28);
        backdrop-filter: blur(8px);
    }

        .left-panel::before {
            content: "";
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at top right, rgba(255,255,255,0.10), transparent 45%);
        }

    .left-panel-content {
        position: relative;
        z-index: 2;
    }

    .logo {
        font-size: 42px;
        margin-bottom: 14px;
    }

    .left-panel h2 {
        font-size: 34px;
        font-weight: 700;
        margin-bottom: 18px;
    }

    .left-panel p {
        font-size: 15px;
        line-height: 1.8;
        opacity: 0.92;
    }

    .feature-list {
        margin-top: 24px;
        padding-left: 20px;
    }

        .feature-list li {
            margin-bottom: 12px;
            font-size: 15px;
        }

    .quote {
        margin-top: 30px;
        font-style: italic;
        font-size: 14px;
        opacity: 0.9;
    }

    /* RIGHT PANEL */
    .right-panel {
        width: 58%;
        padding: 50px 42px;
        color: white;
        display: flex;
        flex-direction: column;
        justify-content: center;
        background: rgba(255,255,255,0.10);
        backdrop-filter: blur(10px);
    }

    .title {
        text-align: center;
        font-size: 34px;
        font-weight: 700;
        margin-bottom: 30px;
    }

    /* INPUTS */
    .form-control {
        height: 52px;
        border-radius: 14px;
        background: rgba(255,255,255,0.14);
        color: white;
        border: 1px solid rgba(255,255,255,0.12);
        padding: 12px 16px;
        transition: 0.3s;
    }

        .form-control:focus {
            background: rgba(255,255,255,0.18);
            border-color: #d8b4fe;
            box-shadow: 0 0 0 4px rgba(216,180,254,0.18);
            color: white;
        }

        .form-control::placeholder {
            color: rgba(255,255,255,0.65);
        }

    /* BUTTON */
    .btn-login {
        height: 52px;
        border-radius: 14px;
        background: linear-gradient( 135deg, #c084fc, #9333ea, #6b21a8 );
        color: white;
        font-weight: 700;
        border: none;
        transition: all 0.3s ease;
    }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 24px rgba(147,51,234,0.35);
            color: #f3f4f6;
        }

    /* LINKS */
    a {
        color: #ffffff !important;
        text-decoration: none;
        transition: 0.3s;
    }

        a:hover {
            color: #e9d5ff !important;
        }

    /* CHECKBOX */
    .form-check-input {
        background-color: rgba(255,255,255,0.15);
        border: 1px solid rgba(255,255,255,0.2);
    }

    .form-check-label {
        color: white;
    }

    /* TEXT */
    .small-text {
        font-size: 13px;
    }

    .text-danger {
        font-size: 12px;
        color: #fecaca !important;
    }

    /* MOBILE */
    @@media (max-width:768px) {

        .glass-card {
            flex-direction: column;
        }

        .left-panel,
        .right-panel {
            width: 100%;
        }

        .left-panel {
            padding: 34px 26px;
            text-align: center;
        }

        .right-panel {
            padding: 36px 24px;
        }

        .title {
            font-size: 28px;
        }
    }
</style>