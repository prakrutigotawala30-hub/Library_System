@{
    ViewData["Title"] = "Email Confirmed";
}

<style>

    * {
        box-sizing: border-box;
    }

    body {
        margin: 0;
        min-height: 100vh;
        background: linear-gradient(135deg,#4b0082,#6a0dad,#9b30ff);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 18px;
        font-family: 'Segoe UI', sans-serif;
        overflow: hidden;
    }

    .confirm-wrapper {
        width: 100%;
        max-width: 900px;
    }

    .glass-card {
        display: flex;
        width: 100%;
        min-height: 450px;
        border-radius: 24px;
        overflow: hidden;
        background: rgba(255,255,255,0.10);
        backdrop-filter: blur(16px);
        border: 1px solid rgba(255,255,255,0.12);
        box-shadow: 0 20px 45px rgba(0,0,0,0.28);
    }

    /* LEFT PANEL */

    .left-panel {
        width: 42%;
        padding: 42px 36px;
        background: linear-gradient(135deg, rgba(75,0,130,0.95), rgba(155,48,255,0.82));
        color: white;
        display: flex;
        flex-direction: column;
        justify-content: center;
        position: relative;
    }

        .left-panel::before {
            content: "";
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at top right, rgba(255,255,255,0.14), transparent 42%);
        }

    .left-content {
        position: relative;
        z-index: 2;
        text-align: center;
    }

    .logo {
        font-size: 42px;
        margin-bottom: 10px;
    }

    .left-panel h2 {
        font-size: 28px;
        font-weight: 700;
        margin-bottom: 14px;
    }

    .left-panel p {
        font-size: 14px;
        line-height: 1.7;
        opacity: 0.92;
    }

    /* RIGHT PANEL */

    .right-panel {
        width: 58%;
        padding: 42px 38px;
        background: rgba(255,255,255,0.06);
        display: flex;
        flex-direction: column;
        justify-content: center;
        color: white;
        text-align: center;
    }

    .success-title {
        font-size: 30px;
        font-weight: 700;
        margin-bottom: 18px;
    }

    .success-text {
        font-size: 15px;
        opacity: 0.9;
        margin-bottom: 28px;
    }

    .btn-login {
        display: inline-block;
        padding: 12px 22px;
        border-radius: 12px;
        background: linear-gradient(135deg,#a855f7,#7e22ce);
        color: white;
        font-weight: 600;
        text-decoration: none;
        transition: 0.3s;
    }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 22px rgba(168,85,247,0.35);
            color: white;
        }

    /* MOBILE */

    @@media(max-width:768px) {

        body {
            overflow-y: auto;
        }

        .glass-card {
            flex-direction: column;
        }

        .left-panel,
        .right-panel {
            width: 100%;
        }

        .right-panel {
            padding: 32px 22px;
        }
    }

</style>

<div class="confirm-wrapper">

    <div class="glass-card">

        <!-- LEFT SIDE -->
        <div class="left-panel">

            <div class="left-content">

                <div class="logo">🎉</div>

                <h2>Email Verified</h2>

                <p>
                    Your account has been successfully confirmed.
                    You can now access all library features securely.
                </p>

            </div>

        </div>

        <!-- RIGHT SIDE -->
        <div class="right-panel">

            <h2 class="success-title">Success!</h2>

            <p class="success-text">
                Your email has been verified successfully.
                You can now login to your account.
            </p>

            <a href="/Account/Login" class="btn-login">
                Go to Login
            </a>

        </div>

    </div>

</div>