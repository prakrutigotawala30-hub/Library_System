@model Library_Management_System.ViewModels.RegisterViewModel

@{

    ViewData["Title"] = "Register";

    Layout = null;

}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Library Register</title>

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
          rel="stylesheet">

    <style>

        /* RESET */

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        /* ✅ FIX: SCROLL ENABLED */

        body {
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 12px;
            overflow-y: auto;
            overflow-x: hidden;
            background: linear-gradient(135deg, #05010a 0%, #170022 30%, #32004d 65%, #5f006f 100%);
        }

        /* WRAPPER */

        .register-wrapper {
            width: 100%;
            max-width: 820px;
        }

        /* SAME AS LOGIN CARD STYLE */

        .glass-card {
            width: 100%;
            min-height: 430px;
            display: flex;
            overflow: hidden;
            border-radius: 22px;
            background: linear-gradient(135deg, rgba(20,0,35,0.95), rgba(70,0,120,0.88), rgba(125,0,120,0.78));
            border: 1px solid rgba(255,255,255,0.08);
            box-shadow: 0 15px 35px rgba(0,0,0,0.45), 0 0 24px rgba(192,38,211,0.16);
            backdrop-filter: blur(12px);
        }

        /* LEFT (same login style feel) */

        .left-panel {
            width: 42%;
            padding: 34px 28px;
            color: white;
            background: linear-gradient(180deg, rgba(25,0,45,0.98), rgba(70,0,120,0.85), rgba(120,0,150,0.75));
            border-right: 1px solid rgba(255,255,255,0.08);
            display: flex;
            align-items: center;
            justify-content: center;
        }



        /* RIGHT */

        .right-panel {
            width: 58%;
            padding: 32px 28px;
            color: white;
            background: linear-gradient(135deg, rgba(55,0,85,0.70), rgba(120,0,120,0.48));
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        /* TITLE SAME AS LOGIN */

        .title {
            text-align: center;
            font-size: 38px;
            font-weight: 800;
            margin-bottom: 20px;
        }

        /* INPUT */

        .form-control {
            height: 44px;
            border-radius: 12px;
            background: rgba(255,255,255,0.12);
            color: white;
            border: 1px solid rgba(255,255,255,0.08);
        }

            .form-control::placeholder {
                color: rgba(255,255,255,0.55);
            }

            .form-control:focus {
                background: rgba(255,255,255,0.16);
                border: 1px solid #d946ef;
                box-shadow: 0 0 0 3px rgba(217,70,239,0.18);
            }

        /* BUTTON SAME STYLE */

        .btn-register {
            width: 100%;
            height: 46px;
            border: none;
            border-radius: 12px;
            background: linear-gradient(135deg, #ff00cc, #c026d3, #7e22ce);
            color: white;
            font-weight: 700;
            transition: 0.3s;
            margin-top: 10px;
        }

            .btn-register:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 18px rgba(192,38,211,0.35);
            }

        /* LINKS */

        .bottom-links {
            margin-top: 18px;
            text-align: center;
        }

            .bottom-links a {
                color: #f9a8d4;
                text-decoration: none;
                font-size: 13px;
            }

        /* ERROR */

        .text-danger {
            font-size: 11px;
            color: #fecdd3 !important;
        }

        /* MOBILE FIX */

        @@media(max - width:768px) {

            body {
                overflow-y: auto;
            }

            .glass-card {
                flex-direction: column;
            }

            .left-panel,
            .right-panel {
                width: 100%;
            }

            .left-panel {
                text-align: center;
                padding: 24px 20px;
            }

            .right-panel {
                padding: 24px 20px;
            }

            .title {
                font-size: 30px;
            }
        }
    </style>

</head>

<body>

    <div class="register-wrapper">

        <div class="glass-card">

            <!-- LEFT -->
            <div class="left-panel">
                <div class="left-content">

                    <div class="logo" style="font-size:34px; margin-bottom:12px;">📚</div>

                    <h2 style="font-size:34px; font-weight:800; line-height:1.2;">

                        Library<br />

                        System
                    </h2>

                    <p style="margin-top:10px; font-size:13px; color:#f3e8ff; line-height:1.6;">

                        A modern platform to manage books, members, and transactions with secure access and fast performance.
                    </p>

                    <div style="margin-top:16px;">
                        <div style="font-size:13px; margin-bottom:8px; color:#f5d0fe;">✔ Smart Book Management</div>
                        <div style="font-size:13px; margin-bottom:8px; color:#f5d0fe;">✔ Issue & Return Tracking</div>
                        <div style="font-size:13px; margin-bottom:8px; color:#f5d0fe;">✔ Secure Authentication</div>
                        <div style="font-size:13px; margin-bottom:8px; color:#f5d0fe;">✔ Admin Dashboard</div>
                    </div>

                    <p style="margin-top:18px; font-size:12px; font-style:italic; color:#fbcfe8;">

                        “Knowledge grows when it is shared.”
                    </p>

                </div>
            </div>


            <!-- RIGHT -->
            <div class="right-panel">

                <h2 class="title">Create Account</h2>

                <form asp-action="Register" method="post">

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label">Full Name</label>
                        <input asp-for="FullName" class="form-control" placeholder="Enter full name" />
                        <span asp-validation-for="FullName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">Email</label>
                        <input asp-for="Email" class="form-control" placeholder="Enter email" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="PhoneNumber" class="form-label">Phone Number</label>
                        <input asp-for="PhoneNumber" class="form-control" placeholder="Enter phone" />
                        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                    </div>

                  @*   <div class="mb-3">
                        <label asp-for="Address" class="form-label">Address</label>
                        <input asp-for="Address" class="form-control" placeholder="Enter phone" />
                        <span asp-validation-for="Address" class="text-danger"></span>
                    </div> *@

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label">Password</label>
                        <input asp-for="Password" type="password" class="form-control" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ConfirmPassword" class="form-label">Confirm Password</label>
                        <input asp-for="ConfirmPassword" type="password" class="form-control" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn-register">Register</button>

                    <div class="bottom-links">
                        <a asp-action="Login">Already have account? Login</a>
                    </div>

                </form>

            </div>

        </div>

    </div>

    <partial name="_ValidationScriptsPartial" />

</body>
</html>
