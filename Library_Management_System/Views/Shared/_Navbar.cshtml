@using Microsoft.AspNetCore.Identity
@inject UserManager<LibraryManagementSystem.ClassLibrary.Models.ApplicationUser> UserManager

@{
    var currentUser = await UserManager.GetUserAsync(User);

    string profileImage = "/images/default-user.png";

    if (currentUser != null &&
        !string.IsNullOrEmpty(currentUser.ProfileImagePath))
    {
        profileImage = currentUser.ProfileImagePath;
    }
}

<style>

    body {
        overflow-x: hidden;
    }

    a {
        text-decoration: none;
    }

    /* =========================
           NAVBAR
        ==========================*/

    .modern-navbar {
        position: sticky;
        top: 0;
        z-index: 99999;
        background: rgba(5,8,22,.96);
        backdrop-filter: blur(18px);
        border-bottom: 1px solid rgba(255,255,255,.08);
        padding: 16px 0;
    }
    /* =========================
           SEARCH
        ==========================*/

    .search-box {
        position: relative;
        width: 430px;
    }

    .search-input {
        width: 100%;
        height: 58px;
        border-radius: 18px;
        border: 1px solid rgba(255,255,255,.08);
        background: rgba(255,255,255,.05);
        color: white;
        padding: 0 55px 0 22px;
        outline: none;
        transition: .3s;
        font-size: 15px;
        
    }

        .search-input:focus {
            border-color: #9333ea;
            background: rgba(255,255,255,.08);
        }

        .search-input::placeholder {
            color: #9ca3af;
        }

    .search-icon {
        position: absolute;
        top: 50%;
        right: 18px;
        transform: translateY(-50%);
        color: #9ca3af;
        font-size: 18px;
        pointer-events: none;
    }

    /* =========================
           PROFILE
        ==========================*/

    .dropdown {
        position: relative;
    }

    .profile-trigger {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 8px 16px;
        border-radius: 50px;
        background: rgba(255,255,255,.05);
        border: 1px solid rgba(255,255,255,.08);
        transition: .3s;
        color: white;
    }

        .profile-trigger:hover {
            background: rgba(255,255,255,.08);
            color: white;
        }

    .profile-avatar {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid rgba(255,255,255,.15);
    }

    .profile-user {
        color: white;
        font-size: 14px;
        font-weight: 700;
    }

    .default-avatar {
        background: white;
        color: black;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
    }

    /* =========================
           DROPDOWN
        ==========================*/

    .dropdown-menu {
        background: rgba(10,14,28,.98);
        border: 1px solid rgba(255,255,255,.08);
        border-radius: 20px;
        padding: 12px;
        min-width: 240px;
        margin-top: 18px;
    }

    .dropdown-item {
        color: white;
        padding: 13px 16px;
        border-radius: 14px;
        font-weight: 600;
        transition: .3s;
    }

        .dropdown-item:hover {
            background: rgba(255,255,255,.08);
            color: white;
        }

    .dropdown-divider {
        border-color: rgba(255,255,255,.08);
    }

    /* =========================
           TOGGLER
        ==========================*/

    .navbar-toggler {
        border: 1px solid rgba(255,255,255,.12);
        border-radius: 14px;
        padding: 10px 14px;
    }

        .navbar-toggler:focus {
            box-shadow: none;
        }

    /* =========================
           MOBILE
        ==========================*/

    @@media(max-width:991px) {

        .navbar-collapse {
            margin-top: 20px;
            padding: 20px;
            border-radius: 24px;
            background: rgba(10,14,28,.98);
            border: 1px solid rgba(255,255,255,.08);
        }

        .search-box {
            width: 100%;
        }

        .profile-trigger {
            width: 100%;
            justify-content: center;
        }

        .navbar-right {
            flex-direction: column;
            width: 100%;
        }
    }

</style>

<nav class="navbar navbar-expand-lg navbar-dark modern-navbar">

    <div class="container-fluid px-4">

      

        <!-- NAVBAR -->

        <div class="collapse navbar-collapse"
             id="mainNavbar">

            <!-- SEARCH LEFT -->

            <div class="search-box">

                <input type="text"
                       class="search-input"
                       placeholder="Search books, authors..." />

                <span class="search-icon">
                    🔍
                </span>

            </div>

            <!-- RIGHT SIDE -->

            <div class="ms-auto d-flex align-items-center gap-4 navbar-right">

                <!-- USER -->
                @if (User.Identity != null &&
                                User.Identity.IsAuthenticated)
                {
                    <div class="dropdown">

                        <a href="javascript:void(0)"
                           class="profile-trigger dropdown-toggle"
                           data-bs-toggle="dropdown">

                            @if (!string.IsNullOrEmpty(currentUser?.ProfileImagePath))
                            {
                                <img src="@currentUser.ProfileImagePath"
                                     class="profile-avatar" />
                            }
                            else
                            {
                                <div class="profile-avatar default-avatar">

                                    @(string.IsNullOrEmpty(currentUser?.FullName)
                                                                ? "U"
                                                                : currentUser.FullName.Substring(0, 1).ToUpper())

                                </div>
                            }

                            <span class="profile-user">

                                @currentUser?.FullName

                            </span>

                        </a>

                        <ul class="dropdown-menu dropdown-menu-end">

                            <li>

                                <a class="dropdown-item"
                                   asp-area="Member"
                                   asp-controller="Dashboard"
                                   asp-action="Index">

                                    📊 Dashboard

                                </a>

                            </li>

                            <li>

                                <a class="dropdown-item"
                                   asp-area="Member"
                                   asp-controller="Profile"
                                   asp-action="Edit">

                                    👤 My Profile

                                </a>

                            </li>

                            <li>

                                <a class="dropdown-item"
                                   asp-controller="Account"
                                   asp-action="Logout">

                                    🚪 Logout

                                </a>

                            </li>

                        </ul>

                    </div>
                }

            </div>

        </div>

    </div>

</nav>