@using Microsoft.AspNetCore.Identity
@inject UserManager<LibraryManagementSystem.Models.ApplicationUser> UserManager

@{
    var currentUser = await UserManager.GetUserAsync(User);

    string profileImage = "/images/default-user.png";

    if (currentUser != null &&
        !string.IsNullOrEmpty(currentUser.ProfileImagePath))
    {
        profileImage = currentUser.ProfileImagePath;
    }

    var currentController =
        ViewContext.RouteData.Values["controller"]?.ToString();

    var currentAction =
        ViewContext.RouteData.Values["action"]?.ToString();
}

<style>

    body {
        overflow-x: hidden;
    }

    a {
        text-decoration: none;
    }

    /* =========================
           NAVBAR
        ==========================*/

    .modern-navbar {
        position: sticky;
        top: 0;
        z-index: 99999;
        background: rgba(5,8,22,.94);
        backdrop-filter: blur(20px);
        border-bottom: 1px solid rgba(255,255,255,.08);
        padding: 14px 0;
    }

    /* =========================
           LOGO
        ==========================*/

    .brand-logo {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .brand-icon {
        width: 56px;
        height: 56px;
        border-radius: 18px;
        background: linear-gradient(135deg,#9333ea,#d946ef);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 28px;
        font-weight: 800;
        box-shadow: 0 10px 30px rgba(168,85,247,.35);
    }

    .brand-text h2 {
        margin: 0;
        color: white;
        font-size: 28px;
        font-weight: 800;
        letter-spacing: 1px;
    }

    .brand-text span {
        color: #d946ef;
    }

    .brand-text p {
        margin: 0;
        color: #9ca3af;
        font-size: 11px;
        letter-spacing: 2px;
    }

    /* =========================
           NAV LINKS
        ==========================*/

    .navbar-nav {
        gap: 10px;
    }

        .navbar-nav .nav-link {
            color: rgba(255,255,255,.82) !important;
            font-size: 15px;
            font-weight: 600;
            padding: 12px 18px !important;
            border-radius: 14px;
            transition: .35s;
        }

            .navbar-nav .nav-link:hover {
                background: rgba(255,255,255,.06);
                color: white !important;
            }

            .navbar-nav .nav-link.active {
                background: linear-gradient(135deg, rgba(147,51,234,.25), rgba(217,70,239,.18));
                color: white !important;
                border: 1px solid rgba(255,255,255,.08);
            }

    /* =========================
           SEARCH
        ==========================*/

    .search-box {
        position: relative;
        width: 340px;
        z-index: 1;
    }

    .search-input {
        width: 100%;
        height: 54px;
        border-radius: 18px;
        border: 1px solid rgba(255,255,255,.08);
        background: rgba(255,255,255,.05);
        color: white;
        padding: 0 52px 0 20px;
        outline: none;
        transition: .3s;
    }

        .search-input:focus {
            border-color: #9333ea;
            background: rgba(255,255,255,.08);
        }

        .search-input::placeholder {
            color: #9ca3af;
        }

    .search-icon {
        position: absolute;
        top: 50%;
        right: 18px;
        transform: translateY(-50%);
        color: #9ca3af;
        pointer-events: none;
    }

    /* =========================
           PROFILE
        ==========================*/

    .dropdown {
        position: relative;
        z-index: 5;
    }

    .profile-trigger {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 8px 14px;
        border-radius: 50px;
        background: rgba(255,255,255,.05);
        border: 1px solid rgba(255,255,255,.08);
        transition: .3s;
        color: white;
    }

        .profile-trigger:hover {
            background: rgba(255,255,255,.08);
            color: white;
        }

    .profile-avatar {
        width: 46px;
        height: 46px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid rgba(255,255,255,.15);
    }

    .profile-user {
        color: white;
        font-size: 14px;
        font-weight: 700;
    }

    /* =========================
           DROPDOWN
        ==========================*/

    .dropdown-menu {
        background: rgba(10,14,28,.98);
        border: 1px solid rgba(255,255,255,.08);
        border-radius: 20px;
        padding: 12px;
        min-width: 250px;
        margin-top: 18px;
    }

    .dropdown-item {
        color: white;
        padding: 13px 16px;
        border-radius: 14px;
        font-weight: 600;
        transition: .3s;
    }

        .dropdown-item:hover {
            background: rgba(255,255,255,.08);
            color: white;
        }

    .dropdown-divider {
        border-color: rgba(255,255,255,.08);
    }

    /* =========================
           AUTH BUTTONS
        ==========================*/

    .auth-btn {
        height: 52px;
        padding: 0 26px;
        border-radius: 16px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        transition: .3s;
    }

    .login-btn {
        background: rgba(255,255,255,.05);
        border: 1px solid rgba(255,255,255,.08);
        color: white;
    }

        .login-btn:hover {
            background: white;
            color: #7e22ce;
        }

    .register-btn {
        background: linear-gradient(135deg,#9333ea,#d946ef);
        color: white;
        box-shadow: 0 12px 28px rgba(168,85,247,.28);
    }

        .register-btn:hover {
            transform: translateY(-3px);
            color: white;
        }

    /* =========================
           TOGGLER
        ==========================*/

    .navbar-toggler {
        border: 1px solid rgba(255,255,255,.12);
        border-radius: 14px;
        padding: 10px 14px;
    }

        .navbar-toggler:focus {
            box-shadow: none;
        }

    /* =========================
           MOBILE
        ==========================*/

    @@media(max-width:991px) {

        .navbar-collapse {
            margin-top: 20px;
            padding: 22px;
            border-radius: 24px;
            background: rgba(10,14,28,.98);
            border: 1px solid rgba(255,255,255,.08);
        }

        .search-box {
            width: 100%;
            margin: 20px 0;
        }

        .auth-mobile {
            width: 100%;
        }

        .profile-trigger {
            width: 100%;
            justify-content: center;
        }
    }

</style>

<nav class="navbar navbar-expand-lg navbar-dark modern-navbar">

    <div class="container-fluid px-4">

        <!-- LOGO -->

        <a class="brand-logo"
           asp-area=""
           asp-controller="Home"
           asp-action="Index">

            <div class="brand-icon">
                ∞
            </div>

            <div class="brand-text">

                <h2>
                    BOOK<span>VERSE</span>
                </h2>

                <p>
                    LIBRARY MANAGEMENT SYSTEM
                </p>

            </div>

        </a>

        <!-- MOBILE BUTTON -->

        <button class="navbar-toggler"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#mainNavbar">

            <span class="navbar-toggler-icon"></span>

        </button>

        <!-- NAVBAR -->

        <div class="collapse navbar-collapse"
             id="mainNavbar">

            <!-- MENU -->

            <ul class="navbar-nav mx-auto">

                <li class="nav-item">

                    <a class="nav-link @(currentController == "Home" && currentAction == "Index" ? "active" : "")"
                       asp-controller="Home"
                       asp-action="Index">

                        Home

                    </a>

                </li>

                <li class="nav-item">

                    <a class="nav-link @(currentController == "Books" ? "active" : "")"
                       asp-controller="Books"
                       asp-action="Index">

                        Books

                    </a>

                </li>

                <li class="nav-item">

                    <a class="nav-link @(currentController == "Categories" ? "active" : "")"
                       asp-controller="Categories"
                       asp-action="Index">

                        Categories

                    </a>

                </li>

                <li class="nav-item">

                    <a class="nav-link @(currentController == "Events" ? "active" : "")"
                       asp-controller="Events"
                       asp-action="Index">

                        Events

                    </a>

                </li>

                <li class="nav-item">

                    <a class="nav-link @(currentAction == "About" ? "active" : "")"
                       asp-controller="Home"
                       asp-action="About">

                        About

                    </a>

                </li>

                <li class="nav-item">

                    <a class="nav-link @(currentController == "Contact" ? "active" : "")"
                       asp-controller="Contact"
                       asp-action="Index">

                        Contact

                    </a>

                </li>

            </ul>

            <!-- SEARCH -->

            <div class="search-box me-lg-4">

                <input type="text"
                       class="search-input"
                       placeholder="Search books, authors, categories..." />

                <span class="search-icon">
                    🔍
                </span>

            </div>

            <!-- USER -->
            @if (User.Identity != null &&
                        User.Identity.IsAuthenticated)
            {
                <div class="dropdown">

                    <a href="javascript:void(0)"
                       class="profile-trigger dropdown-toggle"
                       data-bs-toggle="dropdown"
                       role="button">

                        <img src="@profileImage"
                             class="profile-avatar" />

                        <span class="profile-user">

                            @currentUser?.FullName

                        </span>

                    </a>

                    <ul class="dropdown-menu dropdown-menu-end">

                        <li>

                            <a class="dropdown-item"
                               asp-area="Member"
                               asp-controller="Home"
                               asp-action="Dashboard">

                                📊 Dashboard

                            </a>

                        </li>

                        <li>

                            <a class="dropdown-item"
                               asp-area="Member"
                               asp-controller="Profile"
                               asp-action="Edit">

                                👤 My Profile

                            </a>

                        </li>

                        <li>

                            <a class="dropdown-item"
                               asp-area="Member"
                               asp-controller="Profile"
                               asp-action="Avatar">

                                📷 Change Avatar

                            </a>

                        </li>

                        <li>

                            <a class="dropdown-item"
                               asp-area="Member"
                               asp-controller="Profile"
                               asp-action="ChangePassword">

                                🔒 Change Password

                            </a>

                        </li>

                        <li>
                            <hr class="dropdown-divider">
                        </li>

                        <li>

                            <a class="dropdown-item"
                               asp-controller="Account"
                               asp-action="Logout">

                                🚪 Logout

                            </a>

                        </li>

                    </ul>

                </div>
            }
            else
            {
                <div class="d-flex gap-3 flex-lg-row flex-column auth-mobile">

                    <a class="auth-btn login-btn"
                       asp-controller="Account"
                       asp-action="Login">

                        Login

                    </a>

                    <a class="auth-btn register-btn"
                       asp-controller="Account"
                       asp-action="Register">

                        Get Started

                    </a>

                </div>
            }

        </div>

    </div>

</nav>