<!DOCTYPE html>
<html lang="en">
<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>@ViewData["Title"] - Library</title>
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/frontend.css" />


</head>

<body>

    <!-- SIDEBAR -->
    <partial name="_Sidebar" />

    <!-- PAGE CONTENT -->
    <div class="page-content">

        <!-- NAVBAR -->
        <partial name="_Navbar" />

        <!-- MAIN BODY -->
        <main>
            @RenderBody()
        </main>

        <!-- FOOTER -->
        <partial name="_Footer" />

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

    @* Filenames are Capital-C / Capital-W on disk. Case matters on Mac/Linux
       (case-sensitive filesystem) — a request for "catalog.js" 404s there
       even though it works on Windows. Match disk case for both OSes. *@
    <script src="~/js/Catalog.js"></script>

</body>
</html>
