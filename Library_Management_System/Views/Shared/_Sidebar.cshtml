<style>
    /* =========================
               LOGO
            ==========================*/

    .brand-logo {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom:20px;
    }

    .brand-icon {
        width: 40px;
        height: 40px;
        /* border-radius: 18px; */
        /* background: linear-gradient(135deg,#9333ea,#d946ef); */
        display: flex;
        align-items: center;
        justify-content: center;
        color: #d946ef;
        font-size: 50px;
        font-weight: 800;
        /* box-shadow: 0 10px 30px rgba(168,85,247,.35); */
    }

    .brand-text h2 {
        margin: 0;
        color: white;
        font-size: 25px;
        font-weight: 900;
        letter-spacing: 1px;
    }

    .brand-text span {
        color: #d946ef;
    }

    .brand-text p {
        margin: 0;
        color: #9ca3af;
        font-size: 7px;
        letter-spacing: 2px;
    }

    /* SIDEBAR LAYOUT */

    .sidebar {
        width: 245px;
        position: fixed;
        top: 0;
        left: 0;
        height: 100vh;
        background: linear-gradient(180deg,#0f172a,#111827);
        padding: 24px 18px;
        z-index: 9999;
        border-right: 1px solid rgba(255,255,255,.06);
        /* SCROLL */
        overflow-y: auto;
        /* HIDE SCROLLBAR */
        scrollbar-width: none; /* Firefox */
        -ms-overflow-style: none; /* IE + Edge */
    }

        /* Chrome + Safari */
        .sidebar::-webkit-scrollbar {
            display: none;
        }

    /* PAGE CONTENT */

    .page-content {
        margin-left: 280px;
        min-height: 100vh;
        width: calc(100% - 280px);
    }

    /* KEEP BODY SAME */

    body {
        background: #050816;
        color: white;
        overflow-x: hidden;
    }

    /* SIDEBAR MENU */

    .menu-item {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 14px 16px;
        margin-bottom: 8px;
        border-radius: 16px;
        text-decoration: none;
        color: #d1d5db;
        transition: .3s;
    }

        .menu-item:hover {
            background: rgba(124,58,237,.15);
            color: white;
        }

        .menu-item.active {
            background: linear-gradient(135deg,#7c3aed,#9333ea);
            color: white;
        }

    /* MOBILE */

    @@media(max - width:992px) {

        .sidebar {
            width: 85px;
        }

        .page-content {
            margin-left: 85px;
            width: calc(100% - 85px);
        }

        .logo-text,
        .menu-item span,
        .menu-heading,
        .badge-count {
            display: none;
        }

        .menu-item {
            justify-content: center;
        }
    }
</style>
