<style>
    @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');
    /* =========================================
           ROOT VARIABLES
        ========================================= */
    :root {
        --bg: #050816;
        --bg2: #0f172a;
        --card: #111827;
        --text: #ffffff;
        --text-light: #d1d5db;
        --text-muted: #94a3b8;
        --border: rgba(255,255,255,.06);
        --purple: #7c3aed;
        --purple2: #9333ea;
        --hover: rgba(124,58,237,.15);
        --shadow: 0 15px 40px rgba(0,0,0,.35);
        --sidebar-bg: linear-gradient(180deg,#0f172a,#111827);
        --navbar-bg: rgba(5,8,22,.92);
    }


    /* =========================================
           LIGHT MODE
        ========================================= */

    body.light-theme {
        --bg: #f3f5fb;
        --bg2: #ffffff;
        --card: #ffffff;
        --text: #111827;
        --text-light: #374151;
        --text-muted: #6b7280;
        --border: rgba(0,0,0,.08);
        --hover: rgba(124,58,237,.08);
        --shadow: 0 15px 35px rgba(0,0,0,.08);
        --sidebar-bg: linear-gradient(180deg,#ffffff,#f8fafc);
        --navbar-bg: rgba(255,255,255,.92);
    }

    /* =========================================
           GLOBAL
        ========================================= */

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: 'Inter',sans-serif;
    }

    html {
        scroll-behavior: smooth;
    }

    body {
        background: var(--bg);
        color: var(--text);
        overflow-x: hidden;
        transition: .35s;
    }

    a {
        text-decoration: none;
    }

    /* =========================================
           SIDEBAR
        ========================================= */

    .sidebar {
        width: 245px;
        position: fixed;
        top: 0;
        left: 0;
        height: 100vh;
        background: var(--sidebar-bg);
        padding: 24px 18px;
        z-index: 9999;
        border-right: 1px solid var(--border);
        overflow-y: auto;
        transition: .35s;
        scrollbar-width: none;
        -ms-overflow-style: none;
    }

        .sidebar::-webkit-scrollbar {
            display: none;
        }


        .sidebar hr {
            border-color: rgba(255,255,255,.08);
            margin: 22px 0;
        }

    ::-webkit-scrollbar-thumb {
        background: #7c3aed;
        border-radius: 20px;
    }

    ::-webkit-scrollbar {
        width: 8px;
        height: 8px;
    }
    /* =========================================
           PAGE CONTENT
        ========================================= */

    .page-content {
        margin-left: 245px;
        width: calc(100% - 245px);
        min-height: 100vh;
        transition: .35s;
    }

    /* =========================================
           LOGO
        ========================================= */

    .brand-logo {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 30px;
        padding: 10px 6px;
    }

    .brand-icon {
        width: 52px;
        height: 52px;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        /* background: linear-gradient(135deg,#7c3aed,#d946ef); */
        color: #d946ef;
        font-size: 48px;
        font-weight: 800;
        /* box-shadow: 0 15px 30px rgba(124,58,237,.35); */
    }

    .brand-text h2 {
        margin: 0;
        color: var(--text);
        font-size: 28px;
        font-weight: 900;
        letter-spacing: 1px;
    }

    .brand-text span {
        color: #d946ef;
    }

    .brand-text p {
        margin: 0;
        color: var(--text-muted);
        font-size: 8px;
        letter-spacing: 2px;
        margin-top: 2px;
    }

    /* =========================================
             MENU HEADING
          ========================================= */

    .menu-heading {
        color: var(--text-muted);
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 2px;
        margin: 28px 14px 14px;
    }

    /* =========================================
             MENU LIST
          ========================================= */

    .menu-list {
        margin-bottom: 10px;
    }

    /* =========================================
             MENU ITEM
          ========================================= */

    .menu-item {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 15px 18px;
        margin-bottom: 10px;
        border-radius: 18px;
        color: var(--text-light);
        transition: .3s;
        position: relative;
        overflow: hidden;
    }

        .menu-item i {
            font-size: 18px;
            min-width: 22px;
        }

        .menu-item span {
            font-size: 15px;
            font-weight: 600;
        }

        /* HOVER */

        .menu-item:hover {
            background: var(--hover);
            color: var(--text);
            transform: translateX(4px);
        }

        /* ACTIVE */

        .menu-item.active {
            background: linear-gradient(135deg,#7c3aed,#9333ea);
            color: white;
            box-shadow: 0 10px 30px rgba(124,58,237,.35);
        }

    /* =========================================
             HORIZONTAL LINE
          ========================================= */

    .sidebar hr {
        border-color: var(--border);
        margin: 22px 0;
    }

    /* =========================================
           LOGOUT
        ========================================= */

    .logout-box {
        margin-top: 40px;
    }

    .logout-link {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 15px 18px;
        border-radius: 18px;
        background: rgba(239,68,68,.08);
        border: 1px solid rgba(239,68,68,.12);
        color: #f87171;
        transition: .3s;
        font-weight: 600;
    }

        .logout-link:hover {
            background: #ef4444;
            color: white;
            transform: translateY(-2px);
        }

    /* =========================================
           NAVBAR
        ========================================= */

    .modern-navbar {
        position: sticky;
        top: 0;
        z-index: 999;
        background: var(--navbar-bg);
        backdrop-filter: blur(18px);
        border-bottom: 1px solid var(--border);
        padding: 18px 0;
        transition: .35s;
    }

    /* =========================================
           NAV BUTTONS
        ========================================= */

    .nav-icon-btn {
        width: 52px;
        height: 52px;
        border: none;
        border-radius: 16px;
        background: var(--card);
        color: var(--text);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: .3s;
        box-shadow: var(--shadow);
    }

        .nav-icon-btn:hover {
            background: linear-gradient(135deg,#7c3aed,#9333ea);
            color: white;
            transform: translateY(-3px);
        }

    /* =========================================
           THEME ICON
        ========================================= */

    .theme-light-icon {
        display: none;
    }

    body.light-theme .theme-dark-icon {
        display: none;
    }

    body.light-theme .theme-light-icon {
        display: block;
    }

    /* =========================================
           SCROLLBAR
        ========================================= */

    ::-webkit-scrollbar {
        width: 8px;
        height: 8px;
    }

    ::-webkit-scrollbar-thumb {
        background: #7c3aed;
        border-radius: 20px;
    }

    /* =========================================
           MOBILE
        ========================================= */

    @@media(max - width:992px) {

        .sidebar {
            width: 85px;
            padding: 20px 12px;
        }

        .page-content {
            margin-left: 85px;
            width: calc(100% - 85px);
        }

        .brand-text,
        .menu-heading,
        .menu-item span {
            display: none;
        }

        .brand-logo {
            justify-content: center;
        }

        .menu-item {
            justify-content: center;
            padding: 16px;
        }

        .logout-link {
            justify-content: center;
        }
    }

    @@media(max - width:768px) {

        .sidebar {
            position: fixed;
            left: -100%;
            transition: .4s;
        }

            .sidebar.active {
                left: 0;
            }

        .page-content {
            margin-left: 0;
            width: 100%;
        }
    }
</style>
<aside class="sidebar">

    <!-- LOGO -->

    <a class="brand-logo"
       asp-controller="Home"
       asp-action="Index">

        <div class="brand-icon">
            ∞
        </div>

        <div class="brand-text">

            <h2>
                BOOK<span>VERSE</span>
            </h2>

            <p>
                LIBRARY MANAGEMENT SYSTEM
            </p>

        </div>

    </a>

    @* <!-- MOBILE BUTTON -->

    <button class="navbar-toggler"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#mainNavbar">

        <span class="navbar-toggler-icon"></span>

    </button> *@


    <!-- HOME -->

    <a class="menu-item active" asp-controller="Home" asp-action="Index">

        <i class="bi bi-house-fill"></i>

        <span>Home</span>

    </a>

    <hr />

    <!-- MEMBERSHIP -->
    <div class="menu-heading">
        MEMBERSHIP
    </div>

    <div class="menu-list">

        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            @if (User.IsInRole("Member"))
            {
                <!-- MEMBER DASHBOARD -->

                <a class="menu-item"
                   asp-area="Member"
                   asp-controller="Dashboard"
                   asp-action="Index">

                    <i class="bi bi-speedometer2"></i>

                    <span>My Dashboard</span>

                </a>
            }
            else
            {
                <!-- BUY MEMBERSHIP -->

                <a class="menu-item"
                   asp-controller="Membership"
                   asp-action="Index">

                    <i class="bi bi-gem"></i>

                    <span>Get Membership</span>

                </a>
            }
        }

    </div>

    <!-- EXPLORE -->

    <div class="menu-heading">
        EXPLORE
    </div>


    <div class="menu-list">

        <a class="menu-item"
           asp-controller="Catalog"
           asp-action="Index">

            <i class="bi bi-book"></i>

            <span>Browse Books</span>

        </a>


        <a class="menu-item"
           asp-controller="Catalog"
           asp-action="ByCategory">

            <i class="bi bi-grid"></i>

            <span>Categories</span>

        </a>


        <a class="menu-item"
           asp-controller="Catalog"
           asp-action="ByAuthor">

            <i class="bi bi-person"></i>

            <span>Authors</span>

        </a>


        <a class="menu-item"
           asp-controller="Catalog"
           asp-action="NewArrivals">

            <i class="bi bi-stars"></i>

            <span>New Arrivals</span>

        </a>


        <a class="menu-item"
           asp-controller="Catalog"
           asp-action="MostPopularBooks">

            <i class="bi bi-fire"></i>

            <span>Popular Books</span>

        </a>


        <a class="menu-item"
           asp-controller="Events"
           asp-action="Index">

            <i class="bi bi-calendar2-event"></i>

            <span>Events</span>

        </a>

    </div>


    <!-- LOGOUT -->

    <div class="logout-box">

        <a asp-controller="Account"
           asp-action="Logout"
           class="logout-link">

            <i class="bi bi-box-arrow-left"></i>

            Logout

        </a>

    </div>

</aside>
