@model Library_Management_System.ViewModels.CatalogViewModel
@using System.Linq

@{
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
    ViewData["Title"] = "Browse Books";
    var wishlistIds = ViewBag.WishlistIds as List<int> ?? new List<int>();
}
<style>
    body {
        margin: 0;
        font-family: 'Inter', sans-serif;
        background: radial-gradient(circle at top right, rgba(168,85,247,.18), transparent 40%), radial-gradient(circle at bottom left, rgba(236,72,153,.12), transparent 40%), linear-gradient(135deg,#070b1a,#0f172a);
        color: white;
    }

    .catalog-page {
        padding: 30px;
        min-height: 100vh;
    }

    /* HERO */
    .catalog-hero {
        border-radius: 30px;
        padding: 65px;
        margin-bottom: 35px;
        background: linear-gradient(rgba(7,11,26,.85), rgba(15,23,42,.95)), url('/images/library-banner.jpg');
        background-size: cover;
        background-position: center;
        border: 1px solid rgba(255,255,255,.08);
        box-shadow: 0 20px 60px rgba(0,0,0,.4);
    }

    .hero-badge {
        display: inline-block;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(255,255,255,.06);
        border: 1px solid rgba(255,255,255,.08);
        color: #c4b5fd;
        font-size: 12px;
        margin-bottom: 12px;
    }

    .catalog-hero h1 {
        font-size: 48px;
        font-weight: 900;
        margin: 0;
    }

        .catalog-hero h1 span {
            background: linear-gradient(90deg,#a78bfa,#f472b6);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

    .catalog-hero p {
        color: #d1d5db;
        max-width: 650px;
        line-height: 1.7;
        margin-top: 10px;
    }

    /* FILTER */
    .filter-box {
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.08);
        border-radius: 18px;
        padding: 20px;
        margin-bottom: 35px;
        backdrop-filter: blur(14px);
    }

    .custom-input,
    .custom-select {
        height: 48px;
        border-radius: 12px;
        background: rgba(255,255,255,.05);
        border: 1px solid rgba(255,255,255,.08);
        color: white;
    }

    .search-btn {
        height: 48px;
        border-radius: 12px;
        border: none;
        background: linear-gradient(90deg,#7c3aed,#9333ea);
        color: white;
        font-weight: 700;
    }

    /* GRID */
    .books-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
        gap: 20px;
    }

    /* CARD */
    .book-card {
        border-radius: 22px;
        overflow: hidden;
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.08);
        transition: .3s;
    }

        .book-card:hover {
            transform: translateY(-8px);
            border-color: rgba(168,85,247,.3);
            box-shadow: 0 20px 40px rgba(0,0,0,.4);
        }

    /* IMAGE */
    .book-image {
        position: relative;
        height: 240px;
    }

        .book-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: .5s;
        }

    .book-card:hover img {
        transform: scale(1.08);
    }

    .image-shadow {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(0,0,0,.85), transparent);
    }

    .book-overlay {
        position: absolute;
        bottom: 12px;
        left: 12px;
        right: 12px;
    }

    .overlay-category {
        font-size: 12px;
        color: #f9a8d4;
    }

    .book-overlay h3 {
        font-size: 18px;
        margin: 5px 0 0;
        font-weight: 800;
    }

    .book-overlay span {
        font-size: 13px;
        color: #ddd6fe;
    }

    /* ❤️ FIXED HEART BUTTON */
    .wishlist-icon-btn {
        position: absolute;
        top: 12px;
        right: 12px;
        width: 44px;
        height: 44px;
        border-radius: 50%;
        border: 1px solid rgba(255,255,255,.12);
        background: rgba(0,0,0,.45);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        z-index: 10;
        transition: .25s;
        font-size: 18px;
    }

        .wishlist-icon-btn:hover {
            transform: scale(1.15);
            background: #fb7185;
            color: white;
        }

    /* CONTENT */
    .book-content {
        padding: 14px;
    }

    .book-main-title {
        font-size: 18px;
        font-weight: 800;
        margin-bottom: 6px;
    }

    .book-description {
        font-size: 13px;
        color: #d1d5db;
        margin-bottom: 10px;
    }

    /* META FIX */
    .top-meta {
        display: flex;
        justify-content: space-between;
        gap: 6px;
        margin-bottom: 10px;
    }

    .status-pill{
        font-size: 11px;
        padding: 6px 10px;
        border-radius: 999px;
        white-space: nowrap;
    }

    .available-pill {
        background: rgba(34,197,94,.15);
        color: #86efac;
    }

    .issued-pill {
        background: rgba(239,68,68,.15);
        color: #fca5a5;
    }

    .borrow-pill {
        font-size: 11px;
        padding: 6px 10px;
        border-radius: 999px;
        white-space: nowrap;
    }

    /* DETAILS GRID FIX */
    .details-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        margin-bottom: 12px;
    }

    .detail-card {
        background: rgba(255,255,255,.05);
        padding: 10px;
        border-radius: 12px;
        border: 1px solid rgba(255,255,255,.08);
    }

        .detail-card small {
            display: block;
            font-size: 11px;
            color: #c084fc;
            margin-bottom: 4px;
        }

        .detail-card span {
            font-size: 13px;
            font-weight: 600;
            color: white;
        }

    /* BUTTON */
    .view-btn {
        display: block;
        text-align: center;
        padding: 10px;
        border-radius: 12px;
        background: linear-gradient(90deg,#7c3aed,#9333ea);
        color: white;
        font-weight: 700;
        text-decoration: none;
    }

        .view-btn:hover {
            transform: translateY(-2px);
            color: white;
        }

    /* EMPTY */
    .empty-box {
        text-align: center;
        padding: 70px 20px;
        background: rgba(255,255,255,.04);
        border-radius: 20px;
    }
</style>
<div class="catalog-page">

    <!-- HERO -->
    <section class="catalog-hero">
        <div class="hero-content">
            <div class="hero-badge">✨ PREMIUM DIGITAL LIBRARY</div>

            <h1>
                Discover Your <span>Next Favorite Book</span>
            </h1>

            <p>
                Browse premium collections, explore authors, categories and find inspiring reads.
            </p>
        </div>
    </section>

    <!-- FILTER -->
    <div class="filter-box">
        <h3 class="filter-title">Browse Collection</h3>

        <form method="get" asp-action="Index" class="row g-3">

            <div class="col-lg-3">
                <input type="text"
                       name="SearchQuery"
                       value="@Model.SearchQuery"
                       class="form-control custom-input"
                       placeholder="Search books..." />
            </div>

            <div class="col-lg-2">
                <select name="CategoryId" class="form-select custom-select">
                    <option value="">All Categories</option>
                    @foreach (var c in Model.Categories)
                    {
                        <option value="@c.Id" selected="@(Model.CategoryId == c.Id)">
                            @c.Name
                        </option>
                    }
                </select>
            </div>

            <div class="col-lg-2">
                <select name="AuthorId" class="form-select custom-select">
                    <option value="">All Authors</option>
                    @foreach (var a in Model.Authors)
                    {
                        <option value="@a.Id" selected="@(Model.AuthorId == a.Id)">
                            @a.Name
                        </option>
                    }
                </select>
            </div>

            <div class="col-lg-2">
                <select name="Availability" class="form-select custom-select">
                    <option value="">All</option>
                    <option value="available" selected="@(Model.Availability == "available")">Available</option>
                    <option value="unavailable" selected="@(Model.Availability == "unavailable")">Unavailable</option>
                </select>
            </div>

            <div class="col-lg-2">
                <select name="SortBy" class="form-select custom-select">
                    <option value="">Sort By</option>
                    <option value="title" selected="@(Model.SortBy == "title")">Title</option>
                    <option value="newest" selected="@(Model.SortBy == "newest")">Newest</option>
                    <option value="popular" selected="@(Model.SortBy == "popular")">Popular</option>
                </select>
            </div>

            <div class="col-lg-1 d-grid">
                <button type="submit" class="search-btn">Search</button>
            </div>

        </form>
    </div>

    <!-- BOOKS -->
    @if (Model.PagedBooks != null && Model.PagedBooks.Count > 0)
    {
        <div class="books-grid">

            @foreach (var book in Model.PagedBooks)
            {
                <div class="book-card">

                    <!-- WISHLIST -->
                    <form asp-area="Member"
                          asp-controller="Wishlist"
                          asp-action="Toggle"
                          method="post"
                          class="wishlist-form js-wishlist-form">

                        @Html.AntiForgeryToken()
                        <input type="hidden" name="bookId" value="@book.Id" />

                        <button type="submit" class="wishlist-icon-btn">
                            <span class="heart-icon">
                                @(wishlistIds.Contains(book.Id) ? "❤️" : "🤍")
                            </span>
                        </button>
                    </form>

                    <!-- IMAGE -->
                    <div class="book-image">
                        <img src="@(string.IsNullOrEmpty(book.CoverImageUrl)
                                                         ? "/images/default-book.jpg"
                                                         : book.CoverImageUrl)" />

                        <div class="book-badge">✨ Featured</div>

                        <div class="image-shadow"></div>

                        <div class="book-overlay">
                            <div class="overlay-category">@book.Category?.Name</div>
                            <h3>@book.Title</h3>
                            <span>by @book.Author?.Name</span>
                        </div>
                    </div>

                    <!-- CONTENT -->
                    <div class="book-content">

                        <div class="top-meta">
                            @if (book.AvailableCopies > 0)
                            {
                                <div class="status-pill available-pill">✅ Available</div>
                            }
                            else
                            {
                                <div class="status-pill issued-pill">❌ Issued</div>
                            }

                            <div class="borrow-pill">🔥 @book.BorrowCount Borrows</div>
                        </div>

                        <h2 class="book-main-title">@book.Title</h2>

                        <p class="book-description">
                            @(string.IsNullOrEmpty(book.Description)
                                                ? "Explore this premium collection book."
                                                : (book.Description.Length > 120
                                                ? book.Description.Substring(0, 120) + "..."
                                                : book.Description))
                        </p>

                        <div class="details-grid">
                            <div class="detail-card"><small>ISBN</small><span>@book.ISBN</span></div>
                            <div class="detail-card"><small>Pages</small><span>@book.TotalPages</span></div>
                            <div class="detail-card"><small>Copies</small><span>@book.AvailableCopies</span></div>
                            <div class="detail-card"><small>Added</small><span>@book.CreatedAt.ToString("dd MMM yyyy")</span></div>
                        </div>

                        <div class="book-footer">
                            <div class="library-tag">🏛️ BookVerse</div>

                            <a asp-controller="Catalog"
                               asp-action="Details"
                               asp-route-id="@book.Id"
                               class="view-btn">
                                Explore Book →
                            </a>
                        </div>

                    </div>
                </div>
            }

        </div>
    }
    else
    {
        <div class="empty-box">
            <h3>No Books Found</h3>
            <p>Try changing filters</p>
        </div>
    }

</div>

<!-- AJAX WISHLIST TOGGLE -->
<form>
    <script>
        document.querySelectorAll(".js-wishlist-form").forEach(form => {

            form.addEventListener("submit", function (e) {
                e.preventDefault();

                const token = this.querySelector('input[name="__RequestVerificationToken"]').value;
                const bookId = this.querySelector('input[name="bookId"]').value;
                const heart = this.querySelector(".heart-icon");

                fetch('/Member/Wishlist/Toggle', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': token
                    },
                    body: new URLSearchParams({ bookId })
                })
                .then(r => r.json())
                .then(data => {
                    heart.innerHTML = data.added ? "❤️" : "🤍";
                });
            });

        });
    </script>
</form>
