@model Library_Management_System.ViewModels.CatalogViewModel
@using System.Linq

@{
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
    ViewData["Title"] = "Browse Books";
}

<style>

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        background: #070b1a;
        font-family: 'Inter', sans-serif;
    }

    .catalog-page {
        min-height: 100vh;
        padding: 28px;
        background: radial-gradient(circle at top right, rgba(168,85,247,.15), transparent 25%), radial-gradient(circle at bottom left, rgba(236,72,153,.10), transparent 28%), linear-gradient(135deg,#070b1a,#0f172a);
    }

    /* HERO */

    .catalog-hero {
        position: relative;
        overflow: hidden;
        border-radius: 36px;
        padding: 75px 65px;
        margin-bottom: 50px;
        background: linear-gradient(rgba(7,11,26,.85), rgba(15,23,42,.92)), url('/images/library-banner.jpg');
        background-size: cover;
        background-position: center;
        border: 1px solid rgba(255,255,255,.08);
        box-shadow: 0 0 40px rgba(139,92,246,.12);
    }

        .catalog-hero::before {
            content: "";
            position: absolute;
            width: 420px;
            height: 420px;
            border-radius: 50%;
            background: rgba(168,85,247,.10);
            top: -180px;
            right: -120px;
        }

        .catalog-hero::after {
            content: "";
            position: absolute;
            width: 260px;
            height: 260px;
            border-radius: 50%;
            background: rgba(236,72,153,.08);
            bottom: -100px;
            left: -80px;
        }

    .hero-content {
        position: relative;
        z-index: 2;
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 12px 22px;
        border-radius: 50px;
        background: rgba(255,255,255,.05);
        border: 1px solid rgba(255,255,255,.08);
        color: #c4b5fd;
        font-size: 13px;
        letter-spacing: 1px;
        margin-bottom: 24px;
        backdrop-filter: blur(12px);
    }

    .hero-content h1 {
        color: white;
        font-size: 68px;
        font-weight: 900;
        line-height: 1.05;
        margin-bottom: 22px;
    }

        .hero-content h1 span {
            background: linear-gradient(90deg,#c084fc,#f0abfc);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

    .hero-content p {
        color: #d1d5db;
        font-size: 17px;
        line-height: 1.9;
        max-width: 760px;
    }

    /* FILTER */

    .filter-box {
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.08);
        border-radius: 28px;
        padding: 28px;
        margin-bottom: 45px;
        backdrop-filter: blur(16px);
    }

    .filter-title {
        color: white;
        font-size: 24px;
        font-weight: 800;
        margin-bottom: 24px;
    }

    .custom-input,
    .custom-select {
        height: 55px;
        border-radius: 16px;
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.08);
        color: white;
        padding: 0 18px;
    }

        .custom-input:focus,
        .custom-select:focus {
            background: rgba(255,255,255,.06);
            border-color: #8b5cf6;
            box-shadow: 0 0 0 0.15rem rgba(139,92,246,.25);
            color: white;
        }

        .custom-input::placeholder {
            color: #9ca3af;
        }

        .custom-select option {
            background: #111827;
            color: white;
        }

    .search-btn {
        height: 55px;
        border: none;
        border-radius: 16px;
        background: linear-gradient(90deg,#7c3aed,#9333ea);
        color: white;
        font-weight: 700;
        transition: .35s;
        box-shadow: 0 10px 25px rgba(139,92,246,.25);
    }

        .search-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 35px rgba(139,92,246,.35);
        }

    /* BOOK GRID */

    .books-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill,minmax(280px,1fr));
        gap: 22px;
    }

    /* PREMIUM BOOK CARD */

    .book-card {
        position: relative;
        overflow: hidden;
        border-radius: 32px;
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.08);
        transition: .45s;
        backdrop-filter: blur(16px);
        box-shadow: 0 10px 35px rgba(0,0,0,.25);
    }

        .book-card:hover {
            transform: translateY(-12px);
            border-color: rgba(168,85,247,.30);
            box-shadow: 0 30px 60px rgba(139,92,246,.18), 0 15px 30px rgba(0,0,0,.30);
        }

    /* IMAGE */

    .book-image {
        position: relative;
        height: 240px;
        overflow: hidden;
    }

        .book-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: .7s;
        }

    .book-card:hover img {
        transform: scale(1.08);
    }

    .image-shadow {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(0,0,0,.92), rgba(0,0,0,.15), transparent);
    }

    .book-badge {
        position: absolute;
        top: 18px;
        left: 18px;
        z-index: 2;
        padding: 10px 18px;
        border-radius: 50px;
        background: rgba(15,23,42,.85);
        border: 1px solid rgba(255,255,255,.08);
        color: white;
        font-size: 12px;
        font-weight: 700;
        backdrop-filter: blur(10px);
    }

    .book-overlay {
        position: absolute;
        left: 24px;
        bottom: 24px;
        z-index: 2;
    }

    .overlay-category {
        display: inline-block;
        padding: 8px 14px;
        border-radius: 50px;
        background: rgba(236,72,153,.16);
        color: #f9a8d4;
        font-size: 12px;
        font-weight: 700;
        margin-bottom: 14px;
    }

    .book-overlay h3 {
        color: white;
        font-size: 20px;
        font-weight: 800;
        margin-bottom: 4px;
        line-height: 1.3;
    }

    .book-overlay span {
        color: #ddd6fe;
        font-size: 15px;
    }

    /* CONTENT */

    .book-content {
        padding: 20px;
    }

    .top-meta {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
        margin-bottom: 22px;
    }

    .status-pill,
    .borrow-pill {
        padding: 9px 15px;
        border-radius: 50px;
        font-size: 12px;
        font-weight: 700;
    }

    .available-pill {
        background: rgba(34,197,94,.14);
        color: #86efac;
    }

    .issued-pill {
        background: rgba(239,68,68,.14);
        color: #fca5a5;
    }

    .borrow-pill {
        background: rgba(139,92,246,.14);
        color: #d8b4fe;
    }

    .book-main-title {
        color: white;
        font-size: 22px;
        font-weight: 800;
        line-height: 1.3;
        margin-bottom: 12px;
    }

    .book-description {
        color: #d1d5db;
        line-height: 1.9;
        font-size: 15px;
        margin-bottom: 24px;
    }

    /* DETAILS GRID */

    .details-grid {
        display: grid;
        grid-template-columns: repeat(2,1fr);
        gap: 16px;
        margin-bottom: 28px;
    }

    .detail-card {
        padding: 12px;
        border-radius: 20px;
        background: rgba(255,255,255,.03);
        border: 1px solid rgba(255,255,255,.05);
        transition: .35s;
    }

        .detail-card:hover {
            transform: translateY(-4px);
            border-color: rgba(168,85,247,.25);
            background: rgba(255,255,255,.05);
        }

        .detail-card small {
            display: block;
            color: #c4b5fd;
            margin-bottom: 10px;
            font-size: 11px;
            letter-spacing: 1px;
            text-transform: uppercase;
            font-weight: 700;
        }

        .detail-card span {
            color: white;
            font-size: 14px;
            font-weight: 600;
            line-height: 1.6;
        }

    /* FOOTER */

    .book-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 18px;
        flex-wrap: wrap;
    }

    .library-tag {
        padding: 12px 18px;
        border-radius: 16px;
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.06);
        color: #ddd6fe;
        font-size: 13px;
        font-weight: 600;
    }

    .view-btn {
        padding: 11px 18px;
        border-radius: 18px;
        background: linear-gradient(90deg,#7c3aed,#9333ea);
        color: white;
        text-decoration: none;
        font-weight: 700;
        transition: .35s;
        box-shadow: 0 10px 25px rgba(139,92,246,.25);
    }

        .view-btn:hover {
            transform: translateY(-3px);
            color: white;
            box-shadow: 0 18px 40px rgba(139,92,246,.35);
        }

    /* MOBILE */

    @@media(max-width:768px) {

        .book-image {
            height: 300px;
        }

        .book-overlay h3 {
            font-size: 24px;
        }

        .book-main-title {
            font-size: 26px;
        }

        .details-grid {
            grid-template-columns: 1fr;
        }

        .book-footer {
            flex-direction: column;
            align-items: stretch;
        }

        .view-btn {
            width: 100%;
            text-align: center;
        }
    }
    /* CONTENT */

    .book-content {
        padding: 26px;
    }

    .book-meta {
        display: flex;
        justify-content: space-between;
        gap: 10px;
        margin-bottom: 18px;
        flex-wrap: wrap;
    }

    .meta-pill {
        padding: 8px 14px;
        border-radius: 50px;
        background: rgba(139,92,246,.12);
        color: #d8b4fe;
        font-size: 12px;
        font-weight: 700;
    }

    .status-available {
        background: rgba(34,197,94,.12);
        color: #86efac;
    }

    .status-issued {
        background: rgba(239,68,68,.12);
        color: #fca5a5;
    }

    .book-title {
        color: white;
        font-size: 28px;
        font-weight: 800;
        line-height: 1.2;
        margin-bottom: 20px;
    }

    .details-grid {
        display: grid;
        grid-template-columns: repeat(2,1fr);
        gap: 10px;
        margin-bottom: 18px;
    }

    .detail-box {
        padding: 15px;
        border-radius: 18px;
        background: rgba(255,255,255,.03);
        border: 1px solid rgba(255,255,255,.05);
        transition: .35s;
    }

        .detail-box:hover {
            transform: translateY(-3px);
            border-color: rgba(139,92,246,.25);
            background: rgba(255,255,255,.05);
        }

        .detail-box small {
            display: block;
            color: #c4b5fd;
            margin-bottom: 8px;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        .detail-box span {
            color: white;
            font-size: 14px;
            font-weight: 600;
            line-height: 1.5;
        }

    .view-btn {
        width: 100%;
        display: inline-flex;
        justify-content: center;
        align-items: center;
        padding: 15px 20px;
        border-radius: 18px;
        background: linear-gradient(90deg,#7c3aed,#9333ea);
        color: white;
        font-weight: 700;
        text-decoration: none;
        transition: .35s;
        box-shadow: 0 10px 25px rgba(139,92,246,.25);
    }

        .view-btn:hover {
            color: white;
            transform: translateY(-3px);
            box-shadow: 0 16px 35px rgba(139,92,246,.35);
        }

    /* EMPTY */

    .empty-box {
        padding: 80px 30px;
        text-align: center;
        border-radius: 30px;
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.08);
    }

        .empty-box h3 {
            color: white;
            margin-top: 20px;
            margin-bottom: 10px;
            font-size: 32px;
        }

        .empty-box p {
            color: #9ca3af;
        }

    /* PAGINATION */

    .pagination-box {
        margin-top: 45px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 15px;
    }

    .page-text {
        color: white;
        font-weight: 600;
    }

    .page-btn {
        padding: 12px 20px;
        border-radius: 14px;
        background: rgba(255,255,255,.05);
        border: 1px solid rgba(255,255,255,.08);
        color: white;
        text-decoration: none;
        transition: .35s;
    }

        .page-btn:hover {
            background: linear-gradient(90deg,#7c3aed,#9333ea);
            color: white;
            border-color: transparent;
        }

    /* RESPONSIVE */

    @@media(max-width:768px) {

        .catalog-page {
            padding: 18px;
        }

        .catalog-hero {
            padding: 50px 28px;
            border-radius: 28px;
        }

        .hero-content h1 {
            font-size: 42px;
        }

        .details-grid {
            grid-template-columns: 1fr;
        }

        .pagination-box {
            flex-direction: column;
        }
    }

</style>

<div class="catalog-page">

    <!-- HERO -->

    <section class="catalog-hero">

        <div class="hero-content">

            <div class="hero-badge">
                ✨ PREMIUM DIGITAL LIBRARY
            </div>

            <h1>
                Discover Your
                <span>Next Favorite Book</span>
            </h1>

            <p>
                Browse premium collections, explore authors,
                discover categories and find inspiring reads
                crafted for passionate readers.
            </p>

        </div>

    </section>

    <!-- FILTER -->

    <div class="filter-box">

        <h3 class="filter-title">
            Browse Collection
        </h3>

        <form method="get" asp-action="Index" class="row g-3">

            <!-- Search -->

            <div class="col-lg-3">
                <input type="text"
                       name="SearchQuery"
                       value="@Model.SearchQuery"
                       class="form-control custom-input"
                       placeholder="Search books..." />
            </div>

            <!-- Category -->

            <div class="col-lg-2">
                <select name="CategoryId" class="form-select custom-select">

                    <option value="">All Categories</option>

                    @foreach (var c in Model.Categories)
                    {
                        <option value="@c.Id"
                                selected="@(Model.CategoryId == c.Id)">
                            @c.Name
                        </option>
                    }

                </select>
            </div>

            <!-- Author -->

            <div class="col-lg-2">
                <select name="AuthorId" class="form-select custom-select">

                    <option value="">All Authors</option>

                    @foreach (var a in Model.Authors)
                    {
                        <option value="@a.Id"
                                selected="@(Model.AuthorId == a.Id)">
                            @a.Name
                        </option>
                    }

                </select>
            </div>

            <!-- Availability -->

            <div class="col-lg-2">
                <select name="Availability" class="form-select custom-select">

                    <option value="">All</option>

                    <option value="available"
                            selected="@(Model.Availability == "available")">
                        Available
                    </option>

                    <option value="unavailable"
                            selected="@(Model.Availability == "unavailable")">
                        Unavailable
                    </option>

                </select>
            </div>

            <!-- Sort -->

            <div class="col-lg-2">
                <select name="SortBy" class="form-select custom-select">

                    <option value="">Sort By</option>

                    <option value="title"
                            selected="@(Model.SortBy == "title")">
                        Title
                    </option>

                    <option value="newest"
                            selected="@(Model.SortBy == "newest")">
                        Newest
                    </option>

                    <option value="popular"
                            selected="@(Model.SortBy == "popular")">
                        Popular
                    </option>

                </select>
            </div>

            <!-- Button -->

            <div class="col-lg-1 d-grid">
                <button type="submit" class="search-btn">
                    Search
                </button>
            </div>

        </form>

    </div>

    <!-- BOOKS -->
    @if (Model.PagedBooks != null && Model.PagedBooks.Count > 0)
    {
        <div class="books-grid">

            @foreach (var book in Model.PagedBooks)
            {
                <div class="book-card">

                    <!-- TOP IMAGE -->

                    <div class="book-image">

                        <img src="@(string.IsNullOrEmpty(book.CoverImageUrl)
                                                 ? "/images/default-book.jpg"
                                                                              : book.CoverImageUrl)" />

                        <div class="book-badge">
                            ✨ Featured Library Edition
                        </div>

                        <div class="image-shadow"></div>

                        <div class="book-overlay">

                            <div class="overlay-category">
                                @book.Category?.Name
                            </div>

                            <h3>@book.Title</h3>

                            <span>
                                by @book.Author?.Name
                            </span>

                        </div>

                    </div>

                    <!-- CONTENT -->

                    <div class="book-content">

                        <!-- STATUS -->

                        <div class="top-meta">

                            @if (book.AvailableCopies > 0)
                            {
                                <div class="status-pill available-pill">
                                    ✅ Available
                                </div>
                            }
                            else
                            {
                                <div class="status-pill issued-pill">
                                    ❌ Issued
                                </div>
                            }

                            <div class="borrow-pill">
                                🔥 @book.BorrowCount Borrows
                            </div>

                        </div>

                        <!-- TITLE -->

                        <h2 class="book-main-title">
                            @book.Title
                        </h2>

                        <!-- DESCRIPTION -->

                        <p class="book-description">

                            @(string.IsNullOrEmpty(book.Description)
                                                ? "Explore this premium collection book available in BookVerse Library."
                                                : (book.Description.Length > 140
                                                ? book.Description.Substring(0, 80) + "..."
                                                : book.Description))

                        </p>

                        <!-- DETAILS -->

                        <div class="details-grid">

                            <div class="detail-card">
                                <small>ISBN</small>
                                <span>📘 @book.ISBN</span>
                            </div>

                            <div class="detail-card">
                                <small>Total Pages</small>
                                <span>📄 @book.TotalPages Pages</span>
                            </div>

                            <div class="detail-card">
                                <small>Available Copies</small>
                                <span>📚 @book.AvailableCopies Left</span>
                            </div>

                            <div class="detail-card">
                                <small>Added On</small>
                                <span>🗓️ @book.CreatedAt.ToString("dd MMM yyyy")</span>
                            </div>

                        </div>

                        <!-- FOOTER -->

                        <div class="book-footer">

                            <div class="library-tag">
                                🏛️ BookVerse Collection
                            </div>

                            <a asp-action="Details"
                               asp-route-id="@book.Id"
                               class="view-btn">

                                Explore Book →

                            </a>

                        </div>

                    </div>

                </div>
            }

        </div>
    }
    else
    {
        <div class="empty-box">

            <img src="https://cdn-icons-png.flaticon.com/512/7486/7486740.png"
                 width="120" />

            <h3>No Books Found</h3>

            <p>
                Try changing filters or search keywords.
            </p>

        </div>
    }

    <!-- PAGINATION -->

    <div class="pagination-box">

        <div class="page-text">
            Current Page : @Model.PageNumber
        </div>

        <div class="d-flex gap-2">

            <a asp-action="Index"
               asp-route-PageNumber="@(Model.PageNumber - 1)"
               class="page-btn @(Model.PageNumber <= 1 ? "disabled" : "")">

                ← Previous

            </a>

            <a asp-action="Index"
               asp-route-PageNumber="@(Model.PageNumber + 1)"
               class="page-btn">

                Next →

            </a>

        </div>

    </div>

</div>
