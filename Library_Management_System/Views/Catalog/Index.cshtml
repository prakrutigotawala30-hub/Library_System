@model Library_Management_System.ViewModels.CatalogViewModel
@using System.Linq

@{
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
    ViewData["Title"] = "Browse Books";
}

<style>

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        background: #070b1a;
        font-family: 'Inter', sans-serif;
    }

    .catalog-page {
        min-height: 100vh;
        padding: 28px;
        background: radial-gradient(circle at top right, rgba(168,85,247,.15), transparent 25%), radial-gradient(circle at bottom left, rgba(236,72,153,.10), transparent 28%), linear-gradient(135deg,#070b1a,#0f172a);
    }

    /* HERO */

    .catalog-hero {
        position: relative;
        overflow: hidden;
        border-radius: 36px;
        padding: 75px 65px;
        margin-bottom: 50px;
        background: linear-gradient(rgba(7,11,26,.85), rgba(15,23,42,.92)), url('/images/library-banner.jpg');
        background-size: cover;
        background-position: center;
        border: 1px solid rgba(255,255,255,.08);
        box-shadow: 0 0 40px rgba(139,92,246,.12);
    }

        .catalog-hero::before {
            content: "";
            position: absolute;
            width: 420px;
            height: 420px;
            border-radius: 50%;
            background: rgba(168,85,247,.10);
            top: -180px;
            right: -120px;
        }

        .catalog-hero::after {
            content: "";
            position: absolute;
            width: 260px;
            height: 260px;
            border-radius: 50%;
            background: rgba(236,72,153,.08);
            bottom: -100px;
            left: -80px;
        }

    .hero-content {
        position: relative;
        z-index: 2;
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 12px 22px;
        border-radius: 50px;
        background: rgba(255,255,255,.05);
        border: 1px solid rgba(255,255,255,.08);
        color: #c4b5fd;
        font-size: 13px;
        letter-spacing: 1px;
        margin-bottom: 24px;
        backdrop-filter: blur(12px);
    }

    .hero-content h1 {
        color: white;
        font-size: 68px;
        font-weight: 900;
        line-height: 1.05;
        margin-bottom: 22px;
    }

        .hero-content h1 span {
            background: linear-gradient(90deg,#c084fc,#f0abfc);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

    .hero-content p {
        color: #d1d5db;
        font-size: 17px;
        line-height: 1.9;
        max-width: 760px;
    }

    /* FILTER */

    .filter-box {
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.08);
        border-radius: 28px;
        padding: 28px;
        margin-bottom: 45px;
        backdrop-filter: blur(16px);
    }

    .filter-title {
        color: white;
        font-size: 24px;
        font-weight: 800;
        margin-bottom: 24px;
    }

    .custom-input,
    .custom-select {
        height: 55px;
        border-radius: 16px;
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.08);
        color: white;
        padding: 0 18px;
    }

        .custom-input:focus,
        .custom-select:focus {
            background: rgba(255,255,255,.06);
            border-color: #8b5cf6;
            box-shadow: 0 0 0 0.15rem rgba(139,92,246,.25);
            color: white;
        }

        .custom-input::placeholder {
            color: #9ca3af;
        }

        .custom-select option {
            background: #111827;
            color: white;
        }

    .search-btn {
        height: 55px;
        border: none;
        border-radius: 16px;
        background: linear-gradient(90deg,#7c3aed,#9333ea);
        color: white;
        font-weight: 700;
        transition: .35s;
        box-shadow: 0 10px 25px rgba(139,92,246,.25);
    }

        .search-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 35px rgba(139,92,246,.35);
        }

    /* BOOK GRID */

    .books-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill,minmax(280px,1fr));
        gap: 28px;
    }

    /* BOOK CARD */

    .book-card {
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.08);
        border-radius: 28px;
        overflow: hidden;
        transition: .35s;
        backdrop-filter: blur(16px);
        box-shadow: 0 10px 30px rgba(0,0,0,.25);
    }

        .book-card:hover {
            transform: translateY(-10px);
            border-color: rgba(139,92,246,.35);
            box-shadow: 0 25px 50px rgba(139,92,246,.18);
        }

    /* IMAGE */

    .book-image {
        width: 100%;
        height: 340px;
        overflow: hidden;
        background: #111827;
    }

        .book-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: .5s;
        }

    .book-card:hover .book-image img {
        transform: scale(1.05);
    }

    /* CONTENT */

    .book-content {
        padding: 22px;
    }

    /* TITLE */

    .book-title {
        color: white;
        font-size: 24px;
        font-weight: 800;
        line-height: 1.4;
        margin-bottom: 20px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        min-height: 68px;
    }

    /* STATUS */

    .status-wrapper {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
        margin-bottom: 22px;
    }

    .status-box {
        padding: 16px;
        border-radius: 18px;
        border: 1px solid rgba(255,255,255,.06);
        background: rgba(255,255,255,.03);
    }

        .status-box small {
            display: block;
            margin-bottom: 8px;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 700;
        }

        .status-box span {
            color: white;
            font-size: 15px;
            font-weight: 700;
        }

    .available-box small {
        color: #86efac;
    }

    .borrow-box small {
        color: #d8b4fe;
    }

    /* BUTTON */

    .explore-btn {
        display: flex;
        justify-content: center;
        align-items: center;
        width: 100%;
        height: 54px;
        border-radius: 18px;
        background: linear-gradient(90deg,#7c3aed,#9333ea);
        color: white;
        text-decoration: none;
        font-weight: 700;
        transition: .35s;
        box-shadow: 0 10px 25px rgba(139,92,246,.25);
    }

        .explore-btn:hover {
            color: white;
            transform: translateY(-3px);
            box-shadow: 0 18px 35px rgba(139,92,246,.35);
        }
    /* MOBILE */

    @@media(max-width:768px) {

        .book-image {
            height: 300px;
        }

        .book-overlay h3 {
            font-size: 24px;
        }

        .book-main-title {
            font-size: 26px;
        }

        .details-grid {
            grid-template-columns: 1fr;
        }

        .book-footer {
            flex-direction: column;
            align-items: stretch;
        }

        .view-btn {
            width: 100%;
            text-align: center;
        }
    }
    /* CONTENT */

    .book-content {
        padding: 26px;
    }

    .book-meta {
        display: flex;
        justify-content: space-between;
        gap: 10px;
        margin-bottom: 18px;
        flex-wrap: wrap;
    }

    .meta-pill {
        padding: 8px 14px;
        border-radius: 50px;
        background: rgba(139,92,246,.12);
        color: #d8b4fe;
        font-size: 12px;
        font-weight: 700;
    }

    .status-available {
        background: rgba(34,197,94,.12);
        color: #86efac;
    }

    .status-issued {
        background: rgba(239,68,68,.12);
        color: #fca5a5;
    }

    .book-title {
        color: white;
        font-size: 28px;
        font-weight: 800;
        line-height: 1.2;
        margin-bottom: 20px;
    }

    .details-grid {
        display: grid;
        grid-template-columns: repeat(2,1fr);
        gap: 10px;
        margin-bottom: 18px;
    }

    .detail-box {
        padding: 15px;
        border-radius: 18px;
        background: rgba(255,255,255,.03);
        border: 1px solid rgba(255,255,255,.05);
        transition: .35s;
    }

        .detail-box:hover {
            transform: translateY(-3px);
            border-color: rgba(139,92,246,.25);
            background: rgba(255,255,255,.05);
        }

        .detail-box small {
            display: block;
            color: #c4b5fd;
            margin-bottom: 8px;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        .detail-box span {
            color: white;
            font-size: 14px;
            font-weight: 600;
            line-height: 1.5;
        }

    .view-btn {
        width: 100%;
        display: inline-flex;
        justify-content: center;
        align-items: center;
        padding: 15px 20px;
        border-radius: 18px;
        background: linear-gradient(90deg,#7c3aed,#9333ea);
        color: white;
        font-weight: 700;
        text-decoration: none;
        transition: .35s;
        box-shadow: 0 10px 25px rgba(139,92,246,.25);
    }

        .view-btn:hover {
            color: white;
            transform: translateY(-3px);
            box-shadow: 0 16px 35px rgba(139,92,246,.35);
        }

    .book-card {
        position: relative;
    }

    .wishlist-container {
        position: absolute;
        top: 14px;
        right: 14px;
        z-index: 10;
    }

    .wishlist-btn {
        width: 45px;
        height: 45px;
        border: none;
        border-radius: 50%;
        background: rgba(255,255,255,0.95);
        backdrop-filter: blur(10px);
        box-shadow: 0 6px 18px rgba(0,0,0,0.15);
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .wishlist-btn i {
            font-size: 18px;
            color: #9e9e9e;
            transition: all 0.3s ease;
        }

        .wishlist-btn:hover {
            transform: scale(1.1);
        }

        .wishlist-btn.active {
            background: linear-gradient(135deg,#ff4b6e,#ff758c);
        }

            .wishlist-btn.active i {
                color: white;
            }

        .wishlist-btn.active {
            animation: pulse 0.4s ease;
        }

    @@keyframes pulse {

        0% {
            transform: scale(0.8);
        }

        50% {
            transform: scale(1.2);
        }

        100% {
            transform: scale(1);
        }
    }
    /* EMPTY */

    .empty-box {
        padding: 80px 30px;
        text-align: center;
        border-radius: 30px;
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.08);
    }

        .empty-box h3 {
            color: white;
            margin-top: 20px;
            margin-bottom: 10px;
            font-size: 32px;
        }

        .empty-box p {
            color: #9ca3af;
        }

    /* PAGINATION */

    .pagination-box {
        margin-top: 45px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 15px;
    }

    .page-text {
        color: white;
        font-weight: 600;
    }

    .page-btn {
        padding: 12px 20px;
        border-radius: 14px;
        background: rgba(255,255,255,.05);
        border: 1px solid rgba(255,255,255,.08);
        color: white;
        text-decoration: none;
        transition: .35s;
    }

        .page-btn:hover {
            background: linear-gradient(90deg,#7c3aed,#9333ea);
            color: white;
            border-color: transparent;
        }




    /* RESPONSIVE */

    @@media(max-width:768px) {

        .catalog-page {
            padding: 18px;
        }

        .catalog-hero {
            padding: 50px 28px;
            border-radius: 28px;
        }

        .hero-content h1 {
            font-size: 42px;
        }

        .details-grid {
            grid-template-columns: 1fr;
        }

        .pagination-box {
            flex-direction: column;
        }
    }
</style>

<div class="catalog-page">

    <!-- HERO -->

    <section class="catalog-hero">

        <div class="hero-content">

            <div class="hero-badge">
                ✨ PREMIUM DIGITAL LIBRARY
            </div>

            <h1>
                Discover Your
                <span>Next Favorite Book</span>
            </h1>

            <p>
                Browse premium collections, explore authors,
                discover categories and find inspiring reads
                crafted for passionate readers.
            </p>

        </div>

    </section>

    <!-- FILTER -->

    <div class="filter-box">

        <h3 class="filter-title">
            Browse Collection
        </h3>

        <form method="get" asp-action="Index" class="row g-3">

            <!-- Search -->

            <div class="col-lg-3">
                <input type="text"
                       name="SearchQuery"
                       value="@Model.SearchQuery"
                       class="form-control custom-input"
                       placeholder="Search books..." />
            </div>

            <!-- Category -->

            <div class="col-lg-2">
                <select name="CategoryId" class="form-select custom-select">

                    <option value="">All Categories</option>

                    @foreach (var c in Model.Categories)
                    {
                        <option value="@c.Id"
                                selected="@(Model.CategoryId == c.Id)">
                            @c.Name
                        </option>
                    }

                </select>
            </div>

            <!-- Author -->

            <div class="col-lg-2">
                <select name="AuthorId" class="form-select custom-select">

                    <option value="">All Authors</option>

                    @foreach (var a in Model.Authors)
                    {
                        <option value="@a.Id"
                                selected="@(Model.AuthorId == a.Id)">
                            @a.Name
                        </option>
                    }

                </select>
            </div>

            <!-- Availability -->

            <div class="col-lg-2">
                <select name="Availability" class="form-select custom-select">

                    <option value="">All</option>

                    <option value="available"
                            selected="@(Model.Availability == "available")">
                        Available
                    </option>

                    <option value="unavailable"
                            selected="@(Model.Availability == "unavailable")">
                        Unavailable
                    </option>

                </select>
            </div>

            <!-- Sort -->

            <div class="col-lg-2">
                <select name="SortBy" class="form-select custom-select">

                    <option value="">Sort By</option>

                    <option value="title"
                            selected="@(Model.SortBy == "title")">
                        Title
                    </option>

                    <option value="newest"
                            selected="@(Model.SortBy == "newest")">
                        Newest
                    </option>

                    <option value="popular"
                            selected="@(Model.SortBy == "popular")">
                        Popular
                    </option>

                </select>
            </div>

            <!-- Button -->

            <div class="col-lg-1 d-grid">
                <button type="submit" class="search-btn">
                    Search
                </button>
            </div>

        </form>

    </div>

    <!-- BOOKS -->
    @if (Model.PagedBooks != null && Model.PagedBooks.Count > 0)
    {
        <div class="books-grid">

            @foreach (var book in Model.PagedBooks)
            {
                <div class="book-card">
                    <!-- WISHLIST BUTTON -->

                    <div class="wishlist-container">

                        <button class="wishlist-btn"
                                data-bookid="@book.Id">

                            <i class="fa-regular fa-heart"></i>

                        </button>

                    </div>

                    <!-- BOOK IMAGE -->

                    <div class="book-image">

                        <img src="@(string.IsNullOrEmpty(book.CoverImageUrl)
                                                 ? "/images/default-book.jpg"
                                                 : book.CoverImageUrl)" />

                    </div>

                    <!-- CONTENT -->

                    <div class="book-content">

                        <!-- BOOK TITLE -->

                        <h2 class="book-title">
                            @book.Title
                        </h2>

                        <!-- STATUS BOXES -->

                        <div class="status-wrapper">

                            <div class="status-box available-box">

                                <small>Available</small>

                                <span>
                                    📚 @book.AvailableCopies Left
                                </span>

                            </div>

                            <div class="status-box borrow-box">

                                <small>Borrows</small>

                                <span>
                                    🔥 @book.BorrowCount Times
                                </span>

                            </div>

                        </div>

                        <!-- BUTTON -->

                        <a asp-action="Details"
                           asp-route-id="@book.Id"
                           class="explore-btn">

                            Explore Book →

                        </a>

                    </div>

                </div>

            }

        </div>
    }
    else
    {
        <div class="empty-box">

            <img src="https://cdn-icons-png.flaticon.com/512/7486/7486740.png"
                 width="120" />

            <h3>No Books Found</h3>

            <p>
                Try changing filters or search keywords.
            </p>

        </div>
    }

    <!-- PAGINATION -->

    <div class="pagination-box">

        <div class="page-text">
            Current Page : @Model.PageNumber
        </div>

        <div class="d-flex gap-2">

            <a asp-action="Index"
               asp-route-PageNumber="@(Model.PageNumber - 1)"
               class="page-btn @(Model.PageNumber <= 1 ? "disabled" : "")">

                ← Previous

            </a>

            <a asp-action="Index"
               asp-route-PageNumber="@(Model.PageNumber + 1)"
               class="page-btn">

                Next →

            </a>

        </div>

    </div>

</div>
