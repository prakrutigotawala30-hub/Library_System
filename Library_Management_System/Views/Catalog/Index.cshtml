@model Library_Management_System.ViewModels.CatalogViewModel
@using System.Linq

@{
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
    ViewData["Title"] = "Browse Books";
}

<link rel="stylesheet" href="~/css/book-card.css" />

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');

    :root {
        --shadow: 0 15px 45px rgba(0,0,0,.35);
        --transition: .35s ease;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    html {
        scroll-behavior: smooth;
    }

    body {
        font-family: 'Inter',sans-serif;
        background: radial-gradient(circle at top left,rgba(124,58,237,.12),transparent 25%), radial-gradient(circle at bottom right,rgba(217,70,239,.08),transparent 30%), #050816;
        color: white;
        overflow-x: hidden;
    }

    .catalog-page {
        width: 100%;
        min-height: 100vh;
        padding: 35px 24px 80px;
    }

    /* HERO */

    .catalog-hero {
        position: relative;
        overflow: hidden;
        border-radius: 34px;
        padding: 80px 60px;
        margin-bottom: 34px;
        background: linear-gradient(rgba(5,8,22,.84),rgba(15,23,42,.92)), url('/images/library-banner.png');
        background-size: cover;
        background-position: center;
        border: 1px solid rgba(255,255,255,.06);
        box-shadow: 0 25px 70px rgba(0,0,0,.45);
    }

        .catalog-hero::before {
            content: "";
            position: absolute;
            width: 420px;
            height: 420px;
            border-radius: 50%;
            background: rgba(168,85,247,.15);
            top: -160px;
            right: -120px;
            filter: blur(80px);
        }

    .hero-content {
        position: relative;
        z-index: 2;
        max-width: 720px;
    }

    .hero-badge {
        display: inline-flex;
        gap: 10px;
        padding: 12px 22px;
        border-radius: 999px;
        background: rgba(255,255,255,.06);
        border: 1px solid rgba(255,255,255,.08);
        color: #d8b4fe;
        font-size: 13px;
        font-weight: 700;
        margin-bottom: 24px;
    }

    .hero-content h1 {
        font-size: 68px;
        font-weight: 900;
        margin-bottom: 20px;
    }

        .hero-content h1 span {
            background: linear-gradient(90deg,#c084fc,#f0abfc);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

    .hero-content p {
        color: #d1d5db;
        line-height: 1.9;
    }
    /* FILTER */

    .filter-box {
        padding: 30px;
        margin-bottom: 35px;
        border-radius: 34px;
        background: linear-gradient(180deg, rgba(10,15,30,.98), rgba(5,10,22,.98));
        border: 1px solid rgba(255,255,255,.06);
        box-shadow: 0 20px 60px rgba(0,0,0,.45);
    }

    .filter-title {
        font-size: 42px;
        font-weight: 900;
        margin-bottom: 28px;
        letter-spacing: -.5px;
    }

    .filter-form {
        display: flex;
        gap: 18px;
        align-items: center;
        flex-wrap: wrap;
    }

    .filter-item {
        flex: 1;
        min-width: 180px;
    }

    .filter-search {
        flex: 1.5;
    }

    .custom-input,
    .custom-select {
        width: 100%;
        height: 60px;
        border-radius: 24px;
        border: 1px solid rgba(255,255,255,.06);
        background: rgba(255,255,255,.03);
        color: white;
        padding: 0 22px;
        font-size: 15px;
        font-weight: 500;
        transition: .3s;
    }

        .custom-input:focus,
        .custom-select:focus {
            border-color: #a855f7;
            box-shadow: 0 0 0 4px rgba(168,85,247,.15);
            background: rgba(255,255,255,.05);
            color: white;
        }

        .custom-input::placeholder {
            color: #9ca3af;
        }

        .custom-select option {
            background: #111827;
            color: white;
        }

    .filter-btn {
        width: 140px;
    }

    .search-btn {
        width: 100%;
        height: 60px;
        border: none;
        border-radius: 24px;
        background: linear-gradient(135deg,#7c3aed,#d946ef);
        color: white;
        font-size: 15px;
        font-weight: 500;
        transition: .3s;
        box-shadow: 0 10px 30px rgba(168,85,247,.35);
    }

        .search-btn:hover {
            transform: translateY(-2px);
        }

    @@media(max-width:1200px) {

        .filter-form {
            flex-direction: column;
        }

        .filter-item,
        .filter-search,
        .filter-btn {
            width: 100%;
        }
    }

    @@media(max-width:768px) {

        .filter-box {
            padding: 22px;
            border-radius: 24px;
        }

        .filter-title {
            font-size: 30px;
        }

        .custom-input,
        .custom-select,
        .search-btn {
            height: 58px;
            font-size: 16px;
            border-radius: 18px;
        }
    }
    /* WISHLIST */

    .wishlist-container {
        position: absolute;
        top: 14px;
        right: 14px;
        z-index: 5;
    }

    .wishlist-btn {
        width: 42px;
        height: 42px;
        border: none;
        border-radius: 50%;
        background: white;
        display: flex;
        justify-content: center;
        align-items: center;
    }

        .wishlist-btn.active {
            background: linear-gradient( 135deg, #ff4b6e, #ff758c);
        }

            .wishlist-btn.active i {
                color: white;
            }

    /* STATUS */

    .status-wrapper {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        margin-bottom: 18px;
    }

    .status-box {
        padding: 12px;
        border-radius: 16px;
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.05);
        text-align: center;
    }

        .status-box small {
            display: block;
            margin-bottom: 5px;
            font-size: 9px;
            font-weight: 700;
        }

        .status-box span {
            font-size: 13px;
        }

    .available-box small {
        color: #86efac;
    }

    .borrow-box small {
        color: #d8b4fe;
    }

    /* EMPTY */

    .empty-box {
        padding: 80px;
        text-align: center;
        border-radius: 30px;
        background: linear-gradient( 180deg, rgba(17,24,39,.96), rgba(10,15,28,.98));
    }

    /* PAGINATION */

    .pagination-box {
        margin-top: 45px;
        display: flex;
        justify-content: space-between;
    }

    .page-btn {
        padding: 13px 22px;
        border-radius: 14px;
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.08);
    }

    @@media(max-width:768px) {

        .hero-content h1 {
            font-size: 40px;
        }

        .catalog-page {
            padding: 20px;
        }

        .status-wrapper {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="catalog-page">

    <section class="catalog-hero">

        <div class="hero-content">

            <div class="hero-badge">
                ✨ PREMIUM DIGITAL LIBRARY
            </div>

            <h1>
                Discover Your
                <span>Next Favorite Book</span>
            </h1>

            <p>
                Browse premium collections, explore authors,
                discover categories and find inspiring reads.
            </p>

        </div>

    </section>

    <!-- FILTER -->
    <div class="filter-box">

        <h3 class="filter-title">
            Browse Collection
        </h3>

        <form method="get"
              asp-action="Index"
              class="filter-form">

            <!-- SEARCH -->
            <div class="filter-item filter-search">

                <input type="text"
                       name="SearchQuery"
                       value="@Model.SearchQuery"
                       class="form-control custom-input"
                       placeholder="Search books..." />

            </div>

            <!-- CATEGORY -->
            <div class="filter-item">

                <select name="CategoryId"
                        class="form-select custom-select">

                    <option value="">All Categories</option>

                    @foreach (var c in Model.Categories)
                    {
                        <option value="@c.Id"
                                selected="@(Model.CategoryId == c.Id)">
                            @c.Name
                        </option>
                    }

                </select>

            </div>

            <!-- AUTHOR -->
            <div class="filter-item">

                <select name="AuthorId"
                        class="form-select custom-select">

                    <option value="">All Authors</option>

                    @foreach (var a in Model.Authors)
                    {
                        <option value="@a.Id"
                                selected="@(Model.AuthorId == a.Id)">
                            @a.Name
                        </option>
                    }

                </select>

            </div>

            <!-- STATUS -->
            <div class="filter-item">

                <select class="form-select custom-select"
                        name="Availability">

                    <option value="">All</option>
                    <option value="available">Available</option>
                    <option value="borrowed">Borrowed</option>

                </select>

            </div>

            <!-- SORT -->
            <div class="filter-item">

                <select class="form-select custom-select"
                        name="SortBy">

                    <option value="">Sort By</option>
                    <option value="latest">Latest</option>
                    <option value="popular">Popular</option>
                    <option value="title">Title</option>

                </select>

            </div>

            <!-- BUTTON -->
            <div class="filter-btn">

                <button type="submit"
                        class="search-btn">

                    Search

                </button>

            </div>

        </form>

    </div>

@if (Model.PagedBooks != null && Model.PagedBooks.Any())
{
        <div class="catalog-books-grid">

            @foreach (var book in Model.PagedBooks)
            {
                <div class="catalog-book-card">

                    <div class="wishlist-container">

                        <button type="button"
                                class="wishlist-btn @(ViewBag.WishlistIds.Contains(book.Id) ? "active" : "")"
                                data-bookid="@book.Id">

                            <i class="@(ViewBag.WishlistIds.Contains(book.Id)
                                                            ? "fa-solid fa-heart"
                                                            : "fa-regular fa-heart")"></i>

                        </button>

                    </div>

                    <div class="catalog-book-image">

                        <img src="@(string.IsNullOrEmpty(book.CoverImageUrl)
                                                      ? "/images/default-book.jpg"
                                                      : book.CoverImageUrl)"
                             alt="@book.Title" />

                    </div>

                    <div class="catalog-book-content">

                        <h3 class="catalog-book-title">
                            @book.Title
                        </h3>

                        <div class="catalog-book-author">
                            ✍️ @(book.Author?.Name ?? "Unknown Author")
                        </div>

                        <div class="status-wrapper">

                            <div class="status-box available-box">
                                <small>Available</small>
                                <span>📚 @book.AvailableCopies Left</span>
                            </div>

                            <div class="status-box borrow-box">
                                <small>Borrows</small>
                                <span>🔥 @book.BorrowCount Times</span>
                            </div>

                        </div>

                        <div class="catalog-book-footer">

                            <a asp-action="Details"
                               asp-route-id="@book.Id"
                               class="catalog-details-btn">

                                Explore Book →

                            </a>

                        </div>

                    </div>

                </div>
            }

        </div>
}

    <script src="~/js/wishlist.js"></script>
