@model Library_Management_System.ViewModels.CatalogViewModel
@using System.Linq

@{
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
    ViewData["Title"] = "Browse Books";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');

    /* =========================================================
    ROOT
    ========================================================= */

    :root {
        --bg: #050816;
        --bg2: #0f172a;
        --card: #111827;
        --text: #ffffff;
        --muted: #94a3b8;
        --border: rgba(255,255,255,.07);
        --purple: #7c3aed;
        --purple2: #9333ea;
        --pink: #d946ef;
        --shadow: 0 15px 45px rgba(0,0,0,.35);
        --transition: .35s ease;
    }

    /* =========================================================
    RESET
    ========================================================= */

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    html {
        scroll-behavior: smooth;
    }

    body {
        font-family: 'Inter',sans-serif;
        background: radial-gradient(circle at top left, rgba(124,58,237,.12), transparent 25%), radial-gradient(circle at bottom right, rgba(217,70,239,.08), transparent 30%), #050816;
        color: white;
        overflow-x: hidden;
    }

    a {
        text-decoration: none;
        color: inherit;
    }

    img {
        width: 100%;
        display: block;
    }

    /* =========================================================
    SCROLLBAR
    ========================================================= */

    ::-webkit-scrollbar {
        width: 7px;
        height: 7px;
    }

    ::-webkit-scrollbar-track {
        background: #0f172a;
    }

    ::-webkit-scrollbar-thumb {
        background: linear-gradient(to bottom,#7c3aed,#d946ef);
        border-radius: 999px;
    }

    /* =========================================================
    PAGE
    ========================================================= */

    .catalog-page {
        width: 100%;
        min-height: 100vh;
        padding: 35px 24px 80px;
    }

    /* =========================================================
    HERO
    ========================================================= */

    .catalog-hero {
        position: relative;
        overflow: hidden;
        border-radius: 34px;
        padding: 80px 60px;
        margin-bottom: 34px;
        background: linear-gradient( rgba(5,8,22,.84), rgba(15,23,42,.92)), url('/images/library-banner.png');
        background-size: cover;
        background-position: center;
        border: 1px solid rgba(255,255,255,.06);
        box-shadow: 0 25px 70px rgba(0,0,0,.45);
    }

        .catalog-hero::before {
            content: "";
            position: absolute;
            width: 420px;
            height: 420px;
            border-radius: 50%;
            background: rgba(168,85,247,.15);
            top: -160px;
            right: -120px;
            filter: blur(80px);
        }

    .hero-content {
        position: relative;
        z-index: 2;
        max-width: 720px;
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 12px 22px;
        border-radius: 999px;
        background: rgba(255,255,255,.06);
        border: 1px solid rgba(255,255,255,.08);
        color: #d8b4fe;
        font-size: 13px;
        font-weight: 700;
        margin-bottom: 24px;
        backdrop-filter: blur(10px);
    }

    .hero-content h1 {
        font-size: 68px;
        font-weight: 900;
        line-height: 1.05;
        margin-bottom: 20px;
    }

        .hero-content h1 span {
            background: linear-gradient( 90deg, #c084fc, #f0abfc);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

    .hero-content p {
        color: #d1d5db;
        font-size: 17px;
        line-height: 1.9;
    }

    /* =========================================================
    FILTER BOX
    ========================================================= */

    .filter-box {
        padding: 26px;
        margin-bottom: 34px;
        border-radius: 28px;
        background: linear-gradient( 180deg, rgba(17,24,39,.96), rgba(10,15,28,.98));
        border: 1px solid rgba(255,255,255,.06);
        box-shadow: var(--shadow);
    }

    .filter-title {
        font-size: 24px;
        font-weight: 800;
        margin-bottom: 20px;
    }

    .custom-input,
    .custom-select {
        height: 54px;
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,.08);
        background: rgba(255,255,255,.04);
        color: white;
        padding: 0 16px;
        transition: var(--transition);
    }

        .custom-input::placeholder {
            color: #9ca3af;
        }

        .custom-input:focus,
        .custom-select:focus {
            background: rgba(255,255,255,.06);
            border-color: #8b5cf6;
            box-shadow: 0 0 0 4px rgba(139,92,246,.12);
            color: white;
        }

        .custom-select option {
            background: #111827;
        }

    .search-btn {
        width: 100%;
        height: 54px;
        border: none;
        border-radius: 16px;
        background: linear-gradient( 135deg, #7c3aed, #d946ef);
        color: white;
        font-size: 15px;
        font-weight: 700;
        transition: var(--transition);
        box-shadow: 0 12px 28px rgba(124,58,237,.25);
    }

        .search-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 18px 40px rgba(124,58,237,.35);
        }

    /* =========================================================
    GRID
    ========================================================= */

    .books-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill,minmax(240px,1fr));
        gap: 24px;
    }

    /* =========================================================
    PREMIUM CARD
    ========================================================= */

    .catalog-card {
        position: relative;
        overflow: hidden;
        border-radius: 26px;
        background: linear-gradient( 180deg, rgba(20,28,48,.98), rgba(8,12,24,.98));
        border: 1px solid rgba(255,255,255,.06);
        transition: all .35s ease;
        box-shadow: 0 12px 30px rgba(0,0,0,.30);
        display: flex;
        flex-direction: column;
        animation: fadeUp .5s ease;
    }

        .catalog-card:hover {
            transform: translateY(-8px);
            border-color: rgba(168,85,247,.35);
            box-shadow: 0 24px 55px rgba(124,58,237,.22);
        }

    /* =========================================================
    IMAGE
    ========================================================= */

    .catalog-image {
        position: relative;
        width: 100%;
        height: 300px;
        overflow: hidden;
        background: #0f172a;
    }

        .catalog-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: .45s ease;
        }

    .catalog-card:hover .catalog-image img {
        transform: scale(1.06);
    }

    .catalog-image::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient( to top, rgba(5,8,22,.85), transparent 50%);
    }

    /* =========================================================
    CATEGORY TAG
    ========================================================= */

    .catalog-category {
        position: absolute;
        left: 14px;
        bottom: 14px;
        z-index: 5;
        padding: 7px 14px;
        border-radius: 999px;
        background: rgba(255,255,255,.12);
        border: 1px solid rgba(255,255,255,.08);
        backdrop-filter: blur(10px);
        font-size: 11px;
        font-weight: 700;
    }

    /* =========================================================
    WISHLIST
    ========================================================= */

    .wishlist-container {
        position: absolute;
        top: 14px;
        right: 14px;
        z-index: 10;
    }

    .wishlist-btn {
        width: 42px;
        height: 42px;
        border: none;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        background: rgba(255,255,255,.95);
        transition: .3s ease;
        box-shadow: 0 8px 20px rgba(0,0,0,.20);
    }

        .wishlist-btn i {
            font-size: 16px;
            color: #94a3b8;
            transition: .3s ease;
        }

        .wishlist-btn:hover {
            transform: scale(1.08);
        }

        .wishlist-btn.active {
            background: linear-gradient( 135deg, #ff4b6e, #ff758c);
        }

            .wishlist-btn.active i {
                color: white;
            }

    /* =========================================================
    CONTENT
    ========================================================= */

    .catalog-content {
        padding: 18px;
        display: flex;
        flex-direction: column;
        flex: 1;
    }

    /* =========================================================
    TITLE
    ========================================================= */

    .catalog-title {
        font-size: 19px;
        font-weight: 800;
        line-height: 1.45;
        margin-bottom: 10px;
        min-height: 56px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    /* =========================================================
    AUTHOR
    ========================================================= */

    .catalog-author {
        color: #94a3b8;
        font-size: 13px;
        margin-bottom: 18px;
        overflow: hidden;
        white-space: nowrap;
        text-overflow: ellipsis;
    }

    /* =========================================================
    STATUS
    ========================================================= */

    .status-wrapper {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        margin-bottom: 18px;
    }

    .status-box {
        padding: 12px;
        border-radius: 16px;
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.05);
        text-align: center;
    }

        .status-box small {
            display: block;
            margin-bottom: 5px;
            font-size: 9px;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        .status-box span {
            font-size: 13px;
            font-weight: 700;
        }

    .available-box small {
        color: #86efac;
    }

    .borrow-box small {
        color: #d8b4fe;
    }

    /* =========================================================
    BUTTON
    ========================================================= */

    .catalog-btn,
    .explore-btn {
        width: 100%;
        height: 50px;
        border: none;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        margin-top: auto;
        background: linear-gradient( 135deg, #7c3aed, #d946ef);
        color: white;
        font-size: 14px;
        font-weight: 700;
        transition: all .35s ease;
        box-shadow: 0 12px 25px rgba(124,58,237,.22);
    }

        .catalog-btn:hover,
        .explore-btn:hover {
            transform: translateY(-3px);
            color: white;
            box-shadow: 0 18px 40px rgba(124,58,237,.35);
        }

    /* =========================================================
    EMPTY BOX
    ========================================================= */

    .empty-box {
        padding: 80px 24px;
        text-align: center;
        border-radius: 30px;
        background: linear-gradient( 180deg, rgba(17,24,39,.96), rgba(10,15,28,.98));
        border: 1px solid rgba(255,255,255,.06);
    }

        .empty-box img {
            width: 110px;
            margin: auto;
        }

        .empty-box h3 {
            font-size: 32px;
            font-weight: 800;
            margin-top: 22px;
            margin-bottom: 10px;
        }

        .empty-box p {
            color: #94a3b8;
        }

    /* =========================================================
    PAGINATION
    ========================================================= */

    .pagination-box {
        margin-top: 45px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
        flex-wrap: wrap;
    }

    .page-text {
        font-weight: 700;
    }

    .page-btn {
        padding: 13px 22px;
        border-radius: 14px;
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.08);
        transition: var(--transition);
    }

        .page-btn:hover {
            background: linear-gradient( 135deg, #7c3aed, #9333ea);
            border-color: transparent;
            color: white;
        }

    /* =========================================================
    ANIMATION
    ========================================================= */

    @@keyframes fadeUp {

        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* =========================================================
    RESPONSIVE
    ========================================================= */

    @@media(max-width:992px) {

        .catalog-hero {
            padding: 60px 34px;
        }

        .hero-content h1 {
            font-size: 52px;
        }
    }

    @@media(max-width:768px) {

        .catalog-page {
            padding: 20px 16px 60px;
        }

        .catalog-hero {
            padding: 45px 24px;
            border-radius: 28px;
        }

        .hero-content h1 {
            font-size: 38px;
        }

        .hero-content p {
            font-size: 15px;
        }

        .filter-box {
            padding: 20px;
        }

        .books-grid {
            grid-template-columns: repeat(2,1fr);
            gap: 16px;
        }

        .catalog-image {
            height: 240px;
        }

        .catalog-title {
            font-size: 17px;
        }

        .status-wrapper {
            grid-template-columns: 1fr;
        }
    }

    @@media(max-width:480px) {

        .hero-content h1 {
            font-size: 30px;
        }

        .books-grid {
            grid-template-columns: repeat(2,1fr);
        }

        .catalog-card {
            border-radius: 22px;
        }

        .catalog-image {
            height: 210px;
        }

        .catalog-content {
            padding: 14px;
        }

        .catalog-title {
            font-size: 15px;
            min-height: 46px;
        }

        .wishlist-btn {
            width: 38px;
            height: 38px;
        }

        .explore-btn {
            height: 44px;
            font-size: 13px;
        }
    }
</style>

<div class="catalog-page">

    <section class="catalog-hero">

        <div class="hero-content">

            <div class="hero-badge">
                ✨ PREMIUM DIGITAL LIBRARY
            </div>

            <h1>
                Discover Your
                <span>Next Favorite Book</span>
            </h1>

            <p>
                Browse premium collections, explore authors,
                discover categories and find inspiring reads.
            </p>

        </div>

    </section>

    <div class="filter-box">

        <h3 class="filter-title">
            Browse Collection
        </h3>

        <form method="get"
              asp-action="Index"
              class="row g-3">

            <div class="col-lg-3">

                <input type="text"
                       name="SearchQuery"
                       value="@Model.SearchQuery"
                       class="form-control custom-input"
                       placeholder="Search books..." />

            </div>

            <div class="col-lg-2">

                <select name="CategoryId"
                        class="form-select custom-select">

                    <option value="">
                        All Categories
                    </option>

                    @foreach (var c in Model.Categories)
                    {
                        <option value="@c.Id"
                                selected="@(Model.CategoryId == c.Id)">
                            @c.Name
                        </option>
                    }

                </select>

            </div>

            <div class="col-lg-2">

                <select name="AuthorId"
                        class="form-select custom-select">

                    <option value="">
                        All Authors
                    </option>

                    @foreach (var a in Model.Authors)
                    {
                        <option value="@a.Id"
                                selected="@(Model.AuthorId == a.Id)">
                            @a.Name
                        </option>
                    }

                </select>

            </div>

            <div class="col-lg-2">

                <select name="Availability"
                        class="form-select custom-select">

                    <option value="">All</option>

                    <option value="available"
                            selected="@(Model.Availability == "available")">
                        Available
                    </option>

                    <option value="unavailable"
                            selected="@(Model.Availability == "unavailable")">
                        Unavailable
                    </option>

                </select>

            </div>

            <div class="col-lg-2">

                <select name="SortBy"
                        class="form-select custom-select">

                    <option value="">Sort By</option>

                    <option value="title"
                            selected="@(Model.SortBy == "title")">
                        Title
                    </option>

                    <option value="newest"
                            selected="@(Model.SortBy == "newest")">
                        Newest
                    </option>

                    <option value="popular"
                            selected="@(Model.SortBy == "popular")">
                        Popular
                    </option>

                </select>

            </div>

            <div class="col-lg-1 d-grid">

                <button type="submit"
                        class="search-btn">

                    Search

                </button>

            </div>

        </form>

    </div>

    @if (Model.PagedBooks != null && Model.PagedBooks.Count > 0)
    {
        <div class="books-grid">

            @foreach (var book in Model.PagedBooks)
            {
                <div class="catalog-card">

                    <div class="wishlist-container">

                        <button type="button"
                                class="wishlist-btn @(ViewBag.WishlistIds.Contains(book.Id) ? "active" : "")"
                                data-bookid="@book.Id">

                            <i class="@(ViewBag.WishlistIds.Contains(book.Id)
                                                               ? "fa-solid fa-heart"
                                                               : "fa-regular fa-heart")"></i>

                        </button>

                    </div>

                    <div class="catalog-image">

                        <img src="@(string.IsNullOrEmpty(book.CoverImageUrl)
                                                         ? "/images/default-book.jpg"
                                                         : book.CoverImageUrl)" />

                    </div>

                    <div class="catalog-content">

                        <h2 class="catalog-title">
                            @book.Title
                        </h2>

                        <div class="status-wrapper">

                            <div class="status-box available-box">

                                <small>Available</small>

                                <span>
                                    📚 @book.AvailableCopies Left
                                </span>

                            </div>

                            <div class="status-box borrow-box">

                                <small>Borrows</small>

                                <span>
                                    🔥 @book.BorrowCount Times
                                </span>

                            </div>

                        </div>

                        <a asp-action="Details"
                           asp-route-id="@book.Id"
                           class="explore-btn">

                            Explore Book →

                        </a>

                    </div>

                </div>
            }

        </div>
    }
    else
    {
        <div class="empty-box">

            <img src="https://cdn-icons-png.flaticon.com/512/7486/7486740.png"
                 width="120" />

            <h3>No Books Found</h3>

            <p>
                Try changing filters or search keywords.
            </p>

        </div>
    }

    <div class="pagination-box">

        <div class="page-text">
            Current Page : @Model.PageNumber
        </div>

        <div class="d-flex gap-2">

            <a asp-action="Index"
               asp-route-PageNumber="@(Model.PageNumber - 1)"
               asp-route-SearchQuery="@Model.SearchQuery"
               asp-route-CategoryId="@Model.CategoryId"
               asp-route-AuthorId="@Model.AuthorId"
               asp-route-Availability="@Model.Availability"
               asp-route-SortBy="@Model.SortBy"
               class="page-btn @(Model.PageNumber <= 1 ? "disabled" : "")">

                ← Previous

            </a>

            <a asp-action="Index"
               asp-route-PageNumber="@(Model.PageNumber + 1)"
               asp-route-SearchQuery="@Model.SearchQuery"
               asp-route-CategoryId="@Model.CategoryId"
               asp-route-AuthorId="@Model.AuthorId"
               asp-route-Availability="@Model.Availability"
               asp-route-SortBy="@Model.SortBy"
               class="page-btn">

                Next →

            </a>

        </div>

    </div>

</div>

<script src="~/js/wishlist.js"></script>
