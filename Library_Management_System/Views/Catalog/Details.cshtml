@model Library_Management_System.ViewModels.BookDetailsViewModel

@{
    ViewData["Title"] = "Book Details";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
}

<style>

    @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');

    .details-page,
    .details-page * {
        box-sizing: border-box;
    }

    body {
        background: radial-gradient(circle at top left,rgba(124,58,237,.12),transparent 25%), radial-gradient(circle at bottom right,rgba(217,70,239,.08),transparent 30%), #050816;
    }

    .details-page {
        min-height: 100vh;
        padding: 40px 20px 70px;
        font-family: 'Inter', sans-serif;
        color: white;
    }

    .details-container {
        width: 100%;
        max-width: 1300px;
        margin: auto;
    }

    /* HERO */

    .details-hero {
        position: relative;
        overflow: hidden;
        border-radius: 32px;
        padding: 70px 60px;
        margin-bottom: 35px;
        background: linear-gradient(rgba(5,8,22,.82), rgba(15,23,42,.90)), url('/images/library-banner.png');
        background-size: cover;
        background-position: center;
        border: 1px solid rgba(255,255,255,.08);
        box-shadow: 0 30px 70px rgba(0,0,0,.35);
    }

        .details-hero::before {
            content: "";
            position: absolute;
            width: 320px;
            height: 320px;
            border-radius: 50%;
            background: rgba(168,85,247,.18);
            filter: blur(100px);
            top: -120px;
            right: -120px;
        }

    .details-title {
        position: relative;
        z-index: 2;
        font-size: 58px;
        font-weight: 900;
        line-height: 1.1;
        letter-spacing: -1px;
    }

        .details-title span {
            background: linear-gradient(90deg,#a78bfa,#f472b6);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

    /* BOOK CARD */

    .details-book-card {
        display: grid;
        grid-template-columns: 340px 1fr;
        gap: 35px;
        background: linear-gradient( 180deg, rgba(17,24,39,.95), rgba(15,23,42,.95));
        border: 1px solid rgba(255,255,255,.08);
        border-radius: 30px;
        padding: 30px;
        backdrop-filter: blur(16px);
        box-shadow: 0 25px 60px rgba(0,0,0,.35);
        margin-bottom: 40px;
    }

    /* IMAGE */

    .details-book-cover img {
        width: 100%;
        height: 500px;
        object-fit: cover;
        border-radius: 24px;
        box-shadow: 0 20px 40px rgba(0,0,0,.40);
        transition: .4s ease;
    }

        .details-book-cover img:hover {
            transform: scale(1.02);
        }

    /* INFO */

    .details-book-info {
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .details-book-name {
        font-size: 44px;
        font-weight: 900;
        line-height: 1.15;
        margin-bottom: 12px;
    }

    .details-book-author {
        color: #c4b5fd;
        font-size: 18px;
        font-weight: 600;
        margin-bottom: 24px;
    }

    .details-book-description {
        color: #d1d5db;
        line-height: 1.9;
        font-size: 16px;
        margin-bottom: 28px;
    }

    /* DETAILS GRID */

    .details-grid {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: 16px;
        margin-bottom: 30px;
    }

    .details-box {
        padding: 18px;
        border-radius: 18px;
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.07);
        transition: .3s ease;
    }

        .details-box:hover {
            transform: translateY(-4px);
            border-color: rgba(168,85,247,.35);
        }

        .details-box small {
            display: block;
            color: #a78bfa;
            font-size: 12px;
            font-weight: 700;
            margin-bottom: 8px;
            letter-spacing: .5px;
            text-transform: uppercase;
        }

        .details-box span {
            font-size: 16px;
            font-weight: 600;
            color: white;
        }

    /* BUTTONS */

    .details-actions {
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
        align-items: center;
    }

    .details-btn {
        height: 58px;
        border: none;
        border-radius: 18px;
        padding: 0 28px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        font-size: 15px;
        font-weight: 700;
        cursor: pointer;
        text-decoration: none;
        transition: .35s ease;
    }

    /* WISHLIST */

    .details-wishlist-btn {
        min-width: 180px;
        background: rgba(255,255,255,.06);
        border: 1px solid rgba(255,255,255,.08);
        color: white;
    }

        .details-wishlist-btn:hover {
            transform: translateY(-4px);
            background: rgba(255,255,255,.10);
        }

        .details-wishlist-btn.active {
            background: linear-gradient(135deg,#ef4444,#f43f5e);
            border: none;
        }

    /* RESERVE */

    .details-reserve-btn {
        min-width: 220px;
        background: linear-gradient(135deg,#7c3aed,#9333ea);
        color: white;
        box-shadow: 0 18px 35px rgba(124,58,237,.35);
    }

        .details-reserve-btn:hover {
            transform: translateY(-4px);
            box-shadow: 0 25px 45px rgba(124,58,237,.45);
            color: white;
        }

        .details-reserve-btn:disabled {
            opacity: .6;
            cursor: not-allowed;
        }

    /* QUANTITY */

    .quantity-wrapper {
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 170px;
        height: 58px;
        padding: 0 18px;
        border-radius: 18px;
        background: linear-gradient( 135deg, rgba(124,58,237,.95), rgba(168,85,247,.92));
        border: 1px solid rgba(255,255,255,.08);
        box-shadow: 0 18px 40px rgba(124,58,237,.35);
    }

    .qty-btn {
        width: 42px;
        height: 42px;
        border: none;
        border-radius: 12px;
        background: rgba(255,255,255,.08);
        color: white;
        font-size: 20px;
        font-weight: 700;
        cursor: pointer;
        transition: .25s ease;
    }

        .qty-btn:hover {
            background: rgba(255,255,255,.16);
            transform: scale(1.08);
        }

    .qty-number {
        min-width: 40px;
        text-align: center;
        color: white;
        font-size: 20px;
        font-weight: 700;
    }

    .pdf-section {
        margin-bottom: 50px;
    }

    .pdf-title {
        font-size: 34px;
        font-weight: 900;
        margin-bottom: 20px;
        color: white;
    }

    .pdf-actions {
        display: flex;
        gap: 15px;
        margin-bottom: 20px;
    }

    .pdf-section iframe {
        width: 100%;
        height: 900px;
        border: none;
        border-radius: 24px;
        background: white;
        box-shadow: 0 20px 50px rgba(0,0,0,.35);
    }

    /* REVIEW SECTION */

    .review-section {
        margin-top: 50px;
    }

    /* SUMMARY */

    .rating-summary {
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        gap: 30px;
        padding: 30px;
        margin-bottom: 35px;
        border-radius: 30px;
        background: linear-gradient( 180deg, rgba(17,24,39,.96), rgba(15,23,42,.96));
        border: 1px solid rgba(255,255,255,.08);
        box-shadow: 0 20px 50px rgba(0,0,0,.30);
    }

        .rating-summary::before {
            content: "";
            position: absolute;
            width: 260px;
            height: 260px;
            border-radius: 50%;
            background: rgba(168,85,247,.18);
            top: -120px;
            right: -120px;
            filter: blur(90px);
        }

    .big-rating {
        position: relative;
        z-index: 2;
        font-size: 82px;
        font-weight: 900;
        line-height: 1;
        background: linear-gradient(135deg,#c084fc,#f472b6);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .rating-info {
        position: relative;
        z-index: 2;
    }

    .rating-stars {
        display: flex;
        gap: 5px;
        margin-bottom: 10px;
    }

        .rating-stars span {
            color: #facc15;
            font-size: 26px;
        }

    .rating-text {
        color: #d1d5db;
        font-size: 15px;
        line-height: 1.7;
    }

    /* REVIEW CARD */

    .review-card {
        position: relative;
        overflow: hidden;
        padding: 28px;
        margin-bottom: 22px;
        border-radius: 28px;
        background: linear-gradient( 180deg, rgba(17,24,39,.96), rgba(10,15,28,.98));
        border: 1px solid rgba(255,255,255,.08);
        box-shadow: 0 18px 45px rgba(0,0,0,.25);
        transition: .35s ease;
    }

        .review-card:hover {
            transform: translateY(-5px);
            border-color: rgba(168,85,247,.28);
            box-shadow: 0 25px 55px rgba(124,58,237,.18);
        }

    .review-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        margin-bottom: 18px;
        flex-wrap: wrap;
    }

    .review-user {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .review-avatar {
        width: 52px;
        height: 52px;
        border-radius: 16px;
        background: linear-gradient(135deg,#7c3aed,#c026d3);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        font-weight: 800;
        color: white;
        box-shadow: 0 10px 25px rgba(124,58,237,.35);
    }

    .review-user-info h4 {
        margin: 0;
        font-size: 17px;
        font-weight: 700;
        color: white;
    }

    .review-user-info small {
        color: #9ca3af;
        font-size: 13px;
    }

    .review-stars {
        display: flex;
        gap: 4px;
    }

        .review-stars span {
            font-size: 22px;
            color: #facc15;
        }

    .review-comment {
        color: #d1d5db;
        font-size: 15px;
        line-height: 1.9;
    }

    /* REVIEW FORM */

    .review-form-card {
        position: relative;
        overflow: hidden;
        margin-top: 35px;
        padding: 35px;
        border-radius: 32px;
        background: linear-gradient( 180deg, rgba(17,24,39,.97), rgba(10,15,28,.98));
        border: 1px solid rgba(255,255,255,.08);
        box-shadow: 0 20px 60px rgba(0,0,0,.35);
    }

        .review-form-card::before {
            content: "";
            position: absolute;
            width: 320px;
            height: 320px;
            border-radius: 50%;
            background: rgba(168,85,247,.12);
            top: -120px;
            right: -120px;
            filter: blur(100px);
        }

    .review-form-title {
        position: relative;
        z-index: 2;
        font-size: 32px;
        font-weight: 900;
        margin-bottom: 10px;
        color: white;
    }

    .review-form-subtitle {
        position: relative;
        z-index: 2;
        color: #9ca3af;
        margin-bottom: 28px;
        line-height: 1.8;
    }

    .review-group {
        position: relative;
        z-index: 2;
        margin-bottom: 22px;
    }

    .review-label {
        display: block;
        margin-bottom: 10px;
        color: #d8b4fe;
        font-size: 13px;
        font-weight: 700;
        letter-spacing: .5px;
        text-transform: uppercase;
    }

    .review-select,
    .review-textarea {
        width: 100%;
        border: 1px solid rgba(255,255,255,.08);
        background: rgba(255,255,255,.04);
        color: white;
        border-radius: 22px;
        transition: .3s ease;
    }

    .review-select {
        height: 60px;
        padding: 0 20px;
        font-size: 15px;
    }

    .review-textarea {
        padding: 20px;
        min-height: 170px;
        resize: none;
        line-height: 1.8;
        font-size: 15px;
    }

        .review-select:focus,
        .review-textarea:focus {
            outline: none;
            border-color: #a855f7;
            background: rgba(255,255,255,.06);
            box-shadow: 0 0 0 4px rgba(168,85,247,.15);
        }

    .review-select option {
        background: #111827;
        color: white;
    }

    .review-textarea::placeholder {
        color: #9ca3af;
    }

    .review-submit-btn {
        position: relative;
        z-index: 2;
        min-width: 220px;
        height: 60px;
        border: none;
        border-radius: 20px;
        background: linear-gradient(135deg,#7c3aed,#d946ef);
        color: white;
        font-size: 15px;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        cursor: pointer;
        transition: .35s ease;
        box-shadow: 0 18px 35px rgba(124,58,237,.35);
    }

        .review-submit-btn:hover {
            transform: translateY(-4px);
            box-shadow: 0 25px 50px rgba(124,58,237,.45);
        }

    .empty-review-box {
        padding: 40px;
        text-align: center;
        border-radius: 26px;
        background: rgba(255,255,255,.03);
        border: 1px solid rgba(255,255,255,.08);
        color: #9ca3af;
    }

    /* RESPONSIVE */

    @@media(max-width:1100px) {

        .details-book-card {
            grid-template-columns: 1fr;
        }

        .details-book-cover {
            max-width: 420px;
            margin: auto;
        }

        .details-book-info {
            text-align: center;
        }

        .details-actions {
            justify-content: center;
        }
    }

    @@media(max-width:768px) {

        .details-page {
            padding: 20px 14px 50px;
        }

        .details-hero {
            padding: 45px 25px;
        }

        .details-title {
            font-size: 38px;
        }

        .details-book-card {
            padding: 20px;
        }

        .details-book-cover img {
            height: 380px;
        }

        .details-book-name {
            font-size: 32px;
        }

        .details-grid {
            grid-template-columns: 1fr;
        }

        .details-actions {
            flex-direction: column;
        }

        .details-btn,
        .quantity-wrapper {
            width: 100%;
        }

        .rating-summary {
            flex-direction: column;
            text-align: center;
        }

        .big-rating {
            font-size: 62px;
        }

        .review-form-card {
            padding: 24px;
        }

        .review-form-title {
            font-size: 26px;
        }

        .review-submit-btn {
            width: 100%;
        }
    }
</style>

<div class="details-page">

    <div class="details-container">

        <!-- HERO -->

        <section class="details-hero">

            <h1 class="details-title">
                Explore <span>Book Details</span>
            </h1>

        </section>

        <!-- BOOK CARD -->

        <div class="details-book-card">

            <!-- IMAGE -->

            <div class="details-book-cover">

                <img src="@(string.IsNullOrEmpty(Model.CoverImageUrl)
                                                             ? "/images/default-book.jpg"
                                                             : Model.CoverImageUrl)"
                     alt="@Model.Title" />

            </div>

            <!-- INFO -->

            <div class="details-book-info">

                <h1 class="details-book-name">
                    @Model.Title
                </h1>

                <div class="details-book-author">
                    by @Model.AuthorName
                </div>

                <p class="details-book-description">
                    @Model.Description
                </p>

                <!-- DETAILS -->

                <div class="details-grid">

                    <div class="details-box">

                        <small>Category</small>

                        <span>@Model.CategoryName</span>

                    </div>

                    <div class="details-box">

                        <small>Status</small>

                        <span>
                            @(Model.AvailableCopies > 0
                                                        ? "Available"
                                                        : "Out Of Stock")
                        </span>

                    </div>

                    <div class="details-box">

                        <small>Available Copies</small>

                        <span id="availableCopiesText">
                            @Model.AvailableCopies Books
                        </span>

                    </div>

                </div>

                <!-- ACTIONS -->

                <div class="details-actions">

                    <!-- WISHLIST -->

                    <button type="button"
                            class="details-btn details-wishlist-btn wishlist-btn @(Model.IsWishlisted ? "active" : "")"
                            data-bookid="@Model.Id">

                        <i class="wishlist-icon @(Model.IsWishlisted
                                                           ? "fa-solid fa-heart"
                                                           : "fa-regular fa-heart")"></i>

                        <span class="wishlist-text">
                            @(Model.IsWishlisted
                                                        ? "Wishlisted"
                                                        : "Add Wishlist")
                        </span>

                    </button>

                    <!-- QUANTITY -->

                    <div class="quantity-wrapper">

                        <button type="button"
                                class="qty-btn"
                                onclick="decreaseQty()">

                            -

                        </button>

                        <span id="qtyValue"
                              class="qty-number">

                            1

                        </span>

                        <button type="button"
                                class="qty-btn"
                                onclick="increaseQty()">

                            +

                        </button>

                    </div>

                    <!-- RESERVE -->
                    @if (Model.AvailableCopies > 0)
                    {
                        <a asp-area="Member"
                           asp-controller="Reservation"
                           asp-action="Create"
                           asp-route-bookId="@Model.Id"
                           class="details-btn details-reserve-btn">

                            <i class="bi bi-book"></i>

                            Reserve Book

                        </a>
                    }
                    else
                    {
                        <button class="details-btn details-reserve-btn"
                                disabled>

                            <i class="bi bi-lock"></i>

                            Not Available

                        </button>
                    }

                

                </div>

            </div>

        </div>

        @if (!string.IsNullOrEmpty(Model.PdfUrl))
        {
            <div class="pdf-section">

                <h2 class="pdf-title">
                    📖 Read Book Online
                </h2>

                <div class="pdf-actions">

                    <a href="@Model.PdfUrl"
                       target="_blank"
                       class="details-btn details-reserve-btn">

                        View PDF

                    </a>

                    <a href="@Model.PdfUrl"
                       download
                       class="details-btn details-wishlist-btn">

                        Download PDF

                    </a>

                </div>

                <iframe src="@Model.PdfUrl"
                        width="100%"
                        height="900">
                </iframe>

            </div>
        }

        <!-- REVIEW SECTION -->
        <div class="review-section">

            <!-- SUMMARY -->

            <div class="rating-summary">

                <div class="big-rating">
                    @Model.AverageRating.ToString("0.0")
                </div>

                <div class="rating-info">

                    <div class="rating-stars">

                        @for (int i = 1; i <= 5; i++)
                        {
                            if (i <= Math.Round(Model.AverageRating))
                            {
                                <span>★</span>
                            }
                            else
                            {
                                <span style="opacity:.25;">★</span>
                            }
                        }

                    </div>

                    <div class="rating-text">

                        Based on
                        <strong>@Model.TotalReviews</strong>
                        reader reviews.

                    </div>

                </div>

            </div>

            <!-- TITLE -->

            <h2 style="
                font-size:38px;
                font-weight:900;
                margin-bottom:28px;">

                Reader Reviews

            </h2>

            <!-- REVIEWS -->
            @if (Model.Reviews != null && Model.Reviews.Any())
            {
                @foreach (var review in Model.Reviews)
                {
                    <div class="review-card">

                        <div class="review-top">

                            <div class="review-user">

                                <div class="review-avatar">

                                    @review.Member.FullName.Substring(0, 1)

                                </div>

                                <div class="review-user-info">

                                    <h4>
                                        @review.Member.FullName
                                    </h4>

                                    <small>
                                        BookVerse Reader
                                    </small>

                                </div>

                            </div>

                            <div class="review-stars">

                                @for (int i = 1; i <= 5; i++)
                                {
                                    if (i <= review.Rating)
                                    {
                                        <span>★</span>
                                    }
                                    else
                                    {
                                        <span style="opacity:.20;">★</span>
                                    }
                                }

                            </div>

                        </div>

                        <div class="review-comment">

                            @review.Comment

                        </div>

                    </div>
                }
            }
            else
            {
                <div class="empty-review-box">

                    <h3 style="
                            color:white;
                            margin-bottom:10px;">

                        No Reviews Yet

                    </h3>

                    <p>
                        Be the first reader to review this book.
                    </p>

                </div>
            }

            <!-- REVIEW FORM -->
            @if (User.Identity.IsAuthenticated)
            {
                <form asp-action="AddReview"
                      method="post"
                      class="review-form-card">

                    <input type="hidden"
                           name="BookId"
                           value="@Model.Id" />

                    <h3 class="review-form-title">
                        Write Your Review
                    </h3>

                    <p class="review-form-subtitle">

                        Share your reading experience and help
                        other readers discover great books.

                    </p>

                    <!-- RATING -->

                    <div class="review-group">

                        <label class="review-label">

                            Select Rating

                        </label>

                        <select name="Rating"
                                class="review-select"
                                required>

                            <option value="">
                                Choose Rating
                            </option>

                            <option value="5">
                                ★★★★★ Excellent
                            </option>

                            <option value="4">
                                ★★★★ Very Good
                            </option>

                            <option value="3">
                                ★★★ Good
                            </option>

                            <option value="2">
                                ★★ Average
                            </option>

                            <option value="1">
                                ★ Poor
                            </option>

                        </select>

                    </div>

                    <!-- COMMENT -->

                    <div class="review-group">

                        <label class="review-label">

                            Your Review

                        </label>

                        <textarea name="Comment"
                              class="review-textarea"
                              placeholder="Write your thoughts about this book..."
                              required></textarea>

                    </div>

                    <!-- BUTTON -->

                    <button type="submit"
                            class="review-submit-btn">

                        ✨ Submit Review

                    </button>

                </form>
            }

        </div>

    </div>

</div>

<script src="~/js/wishlist.js"></script>
  <script>  

        let qty = 1;

        // Original stock from database
        let totalAvailableCopies = @Model.AvailableCopies;

        // Current remaining stock
        let remainingCopies = totalAvailableCopies - qty;

        // Initial load
        updateUI();

        function increaseQty() {

            // Quantity cannot exceed available copies
            if (qty < totalAvailableCopies) {

                qty++;

                updateUI();
            }
            else {

                alert("Only " + totalAvailableCopies + " copies available.");
            }
        }

        function decreaseQty() {

            if (qty > 1) {

                qty--;

                updateUI();
            }
        }

        function updateUI() {

            document.getElementById("qtyValue").innerText = qty;

            remainingCopies = totalAvailableCopies - qty;

            document.getElementById("availableCopiesText").innerText =
                remainingCopies + " Books";

        }


  </script>
