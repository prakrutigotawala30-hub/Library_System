@model Library_Management_System.ViewModels.BookDetailsViewModel

@{
    ViewData["Title"] = "Book Details";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');

    /* =========================
           ONLY DETAILS PAGE STYLE
        ========================== */

    .details-page,
    .details-page * {
        box-sizing: border-box;
    }

    .details-page {
        min-height: 100vh;
        padding: 40px 20px 70px;
        font-family: 'Inter', sans-serif;
        color: white;
    }

    .details-container {
        width: 100%;
        max-width: 1300px;
        margin: auto;
    }

    /* =========================
           HERO
        ========================== */

    .details-hero {
        position: relative;
        overflow: hidden;
        border-radius: 32px;
        padding: 70px 60px;
        margin-bottom: 35px;
        background: linear-gradient(rgba(5, 8, 22, .82), rgba(15, 23, 42, .90)), url('/images/library-banner.png');
        background-size: cover;
        background-position: center;
        border: 1px solid rgba(255,255,255,.08);
        box-shadow: 0 30px 70px rgba(0,0,0,.35);
    }

        .details-hero::before {
            content: "";
            position: absolute;
            width: 320px;
            height: 320px;
            border-radius: 50%;
            background: rgba(168,85,247,.18);
            filter: blur(100px);
            top: -120px;
            right: -120px;
        }

    .details-title {
        position: relative;
        z-index: 2;
        font-size: 58px;
        font-weight: 900;
        line-height: 1.1;
        letter-spacing: -1px;
    }

        .details-title span {
            background: linear-gradient(90deg,#a78bfa,#f472b6);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

    /* =========================
           BOOK CARD
        ========================== */

    .details-book-card {
        display: grid;
        grid-template-columns: 340px 1fr;
        gap: 35px;
        background: linear-gradient( 180deg, rgba(17,24,39,.95), rgba(15,23,42,.95) );
        border: 1px solid rgba(255,255,255,.08);
        border-radius: 30px;
        padding: 30px;
        backdrop-filter: blur(16px);
        box-shadow: 0 25px 60px rgba(0,0,0,.35);
    }

    /* =========================
           IMAGE
        ========================== */

    .details-book-cover {
        width: 100%;
    }

        .details-book-cover img {
            width: 100%;
            height: 500px;
            object-fit: cover;
            border-radius: 24px;
            box-shadow: 0 20px 40px rgba(0,0,0,.40);
            transition: .4s ease;
        }

            .details-book-cover img:hover {
                transform: scale(1.02);
            }

    /* =========================
           INFO
        ========================== */

    .details-book-info {
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .details-book-name {
        font-size: 44px;
        font-weight: 900;
        line-height: 1.15;
        margin-bottom: 12px;
    }

    .details-book-author {
        color: #c4b5fd;
        font-size: 18px;
        font-weight: 600;
        margin-bottom: 24px;
    }

    .details-book-description {
        color: #d1d5db;
        line-height: 1.9;
        font-size: 16px;
        margin-bottom: 28px;
    }

    /* =========================
           DETAILS GRID
        ========================== */

    .details-grid {
        display: grid;
        grid-template-columns: repeat(2,1fr);
        gap: 16px;
        margin-bottom: 30px;
    }

    .details-box {
        padding: 18px;
        border-radius: 18px;
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.07);
        transition: .3s ease;
    }

        .details-box:hover {
            transform: translateY(-4px);
            border-color: rgba(168,85,247,.35);
        }

        .details-box small {
            display: block;
            color: #a78bfa;
            font-size: 12px;
            font-weight: 700;
            margin-bottom: 8px;
            letter-spacing: .5px;
            text-transform: uppercase;
        }

        .details-box span {
            font-size: 16px;
            font-weight: 600;
            color: white;
        }

    /* =========================
           BUTTONS
        ========================== */

    .details-actions {
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
    }

    .details-btn {
        height: 58px;
        border: none;
        border-radius: 18px;
        padding: 0 28px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        font-size: 15px;
        font-weight: 700;
        cursor: pointer;
        text-decoration: none;
        transition: .35s ease;
    }

    /* WISHLIST */

    .details-wishlist-btn {
        min-width: 180px;
        background: rgba(255,255,255,.06);
        border: 1px solid rgba(255,255,255,.08);
        color: white;
    }

        .details-wishlist-btn i {
            font-size: 18px;
        }

        .details-wishlist-btn:hover {
            transform: translateY(-4px);
            background: rgba(255,255,255,.10);
        }

        .details-wishlist-btn.active {
            background: linear-gradient(135deg,#ef4444,#f43f5e);
            border: none;
        }

    /* RESERVE */

    .details-reserve-btn {
        min-width: 220px;
        background: linear-gradient(135deg,#7c3aed,#9333ea);
        color: white;
        box-shadow: 0 18px 35px rgba(124,58,237,.35);
    }

        .details-reserve-btn:hover {
            transform: translateY(-4px);
            box-shadow: 0 25px 45px rgba(124,58,237,.45);
        }

        .details-reserve-btn:disabled {
            opacity: .6;
            cursor: not-allowed;
        }

    /* =========================
           RESPONSIVE
        ========================== */

    @@media(max-width:1100px) {

        .details-book-card {
            grid-template-columns: 1fr;
        }

        .details-book-cover {
            max-width: 420px;
            margin: auto;
        }

        .details-book-info {
            text-align: center;
        }

        .details-actions {
            justify-content: center;
        }
    }

    @@media(max-width:768px) {

        .details-page {
            padding: 20px 14px 50px;
        }

        .details-hero {
            padding: 45px 25px;
            border-radius: 24px;
        }

        .details-title {
            font-size: 38px;
        }

        .details-book-card {
            padding: 20px;
            border-radius: 24px;
            gap: 25px;
        }

        .details-book-cover img {
            height: 380px;
        }

        .details-book-name {
            font-size: 32px;
        }

        .details-book-author {
            font-size: 16px;
        }

        .details-grid {
            grid-template-columns: 1fr;
        }

        .details-actions {
            flex-direction: column;
        }

        .details-btn {
            width: 100%;
        }
    }

    @@media(max-width:480px) {

        .details-title {
            font-size: 30px;
        }

        .details-book-name {
            font-size: 26px;
        }

        .details-book-cover img {
            height: 320px;
        }

        .details-book-description {
            font-size: 15px;
            line-height: 1.8;
        }
    }
</style>

<div class="details-page">

    <div class="details-container">

        <!-- HERO -->
        <section class="details-hero">

            <h1 class="details-title">
                Explore <span>Book Details</span>
            </h1>

        </section>

        <!-- BOOK CARD -->
        <div class="details-book-card">

            <!-- LEFT IMAGE -->
            <div class="details-book-cover">

                <img src="@(string.IsNullOrEmpty(Model.CoverImageUrl)
                                         ? "/images/default-book.jpg"
                                         : Model.CoverImageUrl)"
                     alt="@Model.Title" />

            </div>

            <!-- RIGHT INFO -->
            <div class="details-book-info">

                <h1 class="details-book-name">
                    @Model.Title
                </h1>

                <div class="details-book-author">
                    by @Model.AuthorName
                </div>

                <p class="details-book-description">
                    @Model.Description
                </p>

                <!-- DETAILS -->
                <div class="details-grid">

                    <div class="details-box">
                        <small>Category</small>
                        <span>@Model.CategoryName</span>
                    </div>

                    <div class="details-box">
                        <small>Status</small>

                        <span>
                            @(Model.IsAvailable ? "Available" : "Issued")
                        </span>
                    </div>

                </div>

                <!-- BUTTONS -->
                <div class="details-actions">

                    <button type="button"
                            class="details-btn details-wishlist-btn @(Model.IsWishlisted ? "active" : "")"
                            data-bookid="@Model.Id">

                        <i class="@(Model.IsWishlisted
                                                       ? "fa-solid fa-heart"
                                                       : "fa-regular fa-heart")"></i>

                        @(Model.IsWishlisted
                                                ? "Wishlisted"
                                                : "Add Wishlist")

                    </button>

                    @if (Model.IsAvailable)
                    {
                        <a asp-area="Member"
                           asp-controller="Reservation"
                           asp-action="Create"
                           asp-route-bookId="@Model.Id"
                           class="details-btn details-reserve-btn">

                            <i class="bi bi-book"></i>

                            Reserve Book

                        </a>
                    }
                    else
                    {
                        <button class="details-btn details-reserve-btn" disabled>

                            <i class="bi bi-lock"></i>

                            Not Available

                        </button>
                    }

                </div>

            </div>

        </div>

    </div>

</div>

<script src="~/js/wishlist.js"></script>
