@{
    ViewData["Title"] = "Book Details";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
}

<style>

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        background: #050816;
        font-family: 'Inter', sans-serif;
        color: white;
    }

    .details-page {
        min-height: 100vh;
        padding: 40px 28px;
        background: radial-gradient(circle at top right, rgba(139,92,246,.18), transparent 22%), radial-gradient(circle at bottom left, rgba(236,72,153,.12), transparent 28%), linear-gradient(135deg,#050816,#0f172a);
    }

    /* HERO */

    .details-hero {
        position: relative;
        overflow: hidden;
        border-radius: 36px;
        padding: 70px;
        margin-bottom: 40px;
        background: linear-gradient(rgba(5,8,22,.86), rgba(15,23,42,.92)), url('/images/library-banner.jpg');
        background-size: cover;
        background-position: center;
        border: 1px solid rgba(255,255,255,.08);
        box-shadow: 0 0 40px rgba(139,92,246,.12);
    }

        .details-hero::before {
            content: "";
            position: absolute;
            width: 420px;
            height: 420px;
            border-radius: 50%;
            background: rgba(168,85,247,.10);
            top: -180px;
            right: -120px;
        }

    .hero-content {
        position: relative;
        z-index: 2;
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 11px 22px;
        border-radius: 50px;
        background: rgba(255,255,255,.05);
        border: 1px solid rgba(255,255,255,.08);
        color: #c4b5fd;
        font-size: 13px;
        letter-spacing: 1px;
        margin-bottom: 24px;
        backdrop-filter: blur(10px);
    }

    .hero-title {
        font-size: 58px;
        font-weight: 900;
        line-height: 1.1;
        margin-bottom: 18px;
    }

        .hero-title span {
            background: linear-gradient(90deg,#c084fc,#f0abfc);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

    .hero-text {
        max-width: 750px;
        color: #d1d5db;
        line-height: 1.9;
        font-size: 16px;
    }

    /* MAIN CARD */

    .book-card {
        position: relative;
        display: grid;
        grid-template-columns: 330px 1fr;
        gap: 35px;
        padding: 30px;
        border-radius: 32px;
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.08);
        backdrop-filter: blur(16px);
        overflow: hidden;
        transition: .4s ease;
    }

        .book-card:hover {
            transform: translateY(-6px);
            border-color: rgba(168,85,247,.25);
            box-shadow: 0 20px 50px rgba(139,92,246,.16), 0 10px 30px rgba(0,0,0,.35);
        }

        .book-card::before {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient( 120deg, transparent, rgba(255,255,255,.03), transparent );
            opacity: 0;
            transition: .5s;
            pointer-events: none;
        }

        .book-card:hover::before {
            opacity: 1;
        }

    /* COVER */

    .book-cover {
        position: relative;
        border-radius: 28px;
        overflow: hidden;
        height: 500px;
        box-shadow: 0 20px 40px rgba(0,0,0,.35);
    }

        .book-cover img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: .7s;
        }

    .book-card:hover .book-cover img {
        transform: scale(1.06);
    }

    .book-badge {
        position: absolute;
        top: 18px;
        left: 18px;
        z-index: 5;
        padding: 10px 16px;
        border-radius: 50px;
        background: rgba(15,23,42,.86);
        border: 1px solid rgba(255,255,255,.08);
        color: white;
        font-size: 12px;
        font-weight: 700;
        letter-spacing: .8px;
        backdrop-filter: blur(10px);
    }

    /* INFO */

    .book-info {
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .book-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 16px;
        margin-bottom: 18px;
    }

    .book-category {
        padding: 10px 16px;
        border-radius: 50px;
        background: rgba(139,92,246,.12);
        color: #d8b4fe;
        font-size: 13px;
        font-weight: 700;
        border: 1px solid rgba(139,92,246,.15);
    }

    .availability-badge {
        padding: 10px 16px;
        border-radius: 50px;
        font-size: 13px;
        font-weight: 700;
        border: 1px solid transparent;
    }

    .available {
        background: rgba(34,197,94,.12);
        color: #86efac;
        border-color: rgba(34,197,94,.22);
    }

    .unavailable {
        background: rgba(239,68,68,.12);
        color: #fca5a5;
        border-color: rgba(239,68,68,.20);
    }

    .book-title {
        font-size: 52px;
        font-weight: 900;
        line-height: 1.08;
        margin-bottom: 18px;
        color: white;
    }

    .book-author {
        color: #c4b5fd;
        font-size: 18px;
        margin-bottom: 30px;
    }

        .book-author strong {
            color: white;
        }

    .book-description {
        color: #d1d5db;
        line-height: 2;
        font-size: 15px;
        margin-bottom: 32px;
    }

    /* DETAILS GRID */

    .details-grid {
        display: grid;
        grid-template-columns: repeat(2,1fr);
        gap: 18px;
        margin-bottom: 35px;
    }

    .detail-box {
        padding: 18px;
        border-radius: 20px;
        background: rgba(255,255,255,.03);
        border: 1px solid rgba(255,255,255,.06);
        transition: .35s;
    }

        .detail-box:hover {
            transform: translateY(-3px);
            border-color: rgba(139,92,246,.22);
            background: rgba(255,255,255,.05);
        }

        .detail-box small {
            display: block;
            margin-bottom: 10px;
            color: #c084fc;
            font-size: 12px;
            letter-spacing: .6px;
            text-transform: uppercase;
        }

        .detail-box span {
            color: white;
            font-size: 15px;
            font-weight: 600;
            line-height: 1.7;
        }

    /* ACTIONS */

    .actions {
        display: flex;
        gap: 18px;
        flex-wrap: wrap;
    }

        .actions form {
            flex: 1;
        }

    .premium-btn {
        width: 100%;
        padding: 16px 20px;
        border-radius: 18px;
        border: none;
        font-size: 15px;
        font-weight: 700;
        cursor: pointer;
        transition: .35s;
    }

    .wishlist-btn {
        background: rgba(255,255,255,.05);
        border: 1px solid rgba(255,255,255,.08);
        color: white;
    }

        .wishlist-btn:hover {
            background: linear-gradient(90deg,#7c3aed,#9333ea);
            transform: translateY(-3px);
            box-shadow: 0 14px 30px rgba(139,92,246,.30);
        }

    .reserve-btn {
        background: linear-gradient(90deg,#7c3aed,#9333ea);
        color: white;
        box-shadow: 0 12px 25px rgba(139,92,246,.28);
    }

        .reserve-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 18px 35px rgba(139,92,246,.35);
        }

        .reserve-btn:disabled {
            background: #374151;
            cursor: not-allowed;
            box-shadow: none;
            opacity: .7;
        }

    /* RESPONSIVE */

    @@media(max-width:1100px) {

        .book-card {
            grid-template-columns: 1fr;
        }

        .book-cover {
            height: 420px;
        }
    }

    @@media(max-width:768px) {

        .details-page {
            padding: 18px;
        }

        .details-hero {
            padding: 45px 28px;
            border-radius: 28px;
        }

        .hero-title {
            font-size: 42px;
        }

        .book-title {
            font-size: 36px;
        }

        .details-grid {
            grid-template-columns: 1fr;
        }

        .actions {
            flex-direction: column;
        }

        .book-cover {
            height: 360px;
        }
    }

</style>

<div class="details-page">

    <!-- HERO -->

    <section class="details-hero">

        <div class="hero-content">

            <div class="hero-badge">
                📚 PREMIUM BOOK COLLECTION
            </div>

            <h1 class="hero-title">
                Explore This
                <span>Book Experience</span>
            </h1>

            <p class="hero-text">
                Discover detailed information, availability,
                author insights and reserve your favorite
                books from the BookVerse digital library.
            </p>

        </div>

    </section>

    <!-- BOOK DETAILS -->

    <div class="book-card">

        <!-- COVER -->

        <div class="book-cover">

            <img src="@Model.CoverImageUrl"
                 alt="@Model.Title" />

            <div class="book-badge">
                ⭐ Featured Book
            </div>

        </div>

        <!-- INFO -->

        <div class="book-info">

            <div class="book-top">

                <div class="book-category">
                    📖 @Model.CategoryName
                </div>

                @if (Model.IsAvailable)
                {
                    <div class="availability-badge available">
                        ✅ Available Now
                    </div>
                }
                else
                {
                    <div class="availability-badge unavailable">
                        ❌ Currently Issued
                    </div>
                }

            </div>

            <h1 class="book-title">
                @Model.Title
            </h1>

            <p class="book-author">
                by <strong>@Model.AuthorName</strong>
            </p>

            <p class="book-description">
                @Model.Description
            </p>

            <!-- DETAILS -->

            <div class="details-grid">

                <div class="detail-box">
                    <small>Author</small>
                    <span>✍️ @Model.AuthorName</span>
                </div>

                <div class="detail-box">
                    <small>Category</small>
                    <span>📚 @Model.CategoryName</span>
                </div>

                <div class="detail-box">
                    <small>Status</small>
                    <span>
                        @(Model.IsAvailable
                                                ? "✅ Ready For Reservation"
                                                : "❌ Currently Borrowed")
                    </span>
                </div>

                <div class="detail-box">
                    <small>Library</small>
                    <span>🏛️ BookVerse Collection</span>
                </div>

            </div>

            <!-- ACTIONS -->

            <div class="actions">

                <form asp-controller="Wishlist"
                      asp-action="Add"
                      method="post">

                    <input type="hidden"
                           name="BookId"
                           value="@Model.Id" />

                    <button type="submit"
                            class="premium-btn wishlist-btn">

                        ❤️ Add to Wishlist

                    </button>

                </form>

                <form asp-controller="Reservation"
                      asp-action="Reserve"
                      method="post">

                    <input type="hidden"
                           name="BookId"
                           value="@Model.Id" />

                    <button type="submit"
                            class="premium-btn reserve-btn"
                            @(Model.IsAvailable ? "" : "disabled")>

                        📘 Reserve Book

                    </button>

                </form>

            </div>

        </div>

    </div>

</div>