@{
    ViewData["Title"] = "Book Details";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
}

<style>
    body {
        margin: 0;
        font-family: 'Inter', sans-serif;
        color: white;
        background: radial-gradient(circle at top right, rgba(139,92,246,.18), transparent 30%), radial-gradient(circle at bottom left, rgba(236,72,153,.12), transparent 30%), linear-gradient(135deg,#050816,#0f172a);
    }

    .details-page {
        min-height: 100vh;
        padding: 40px 20px;
    }

    /* CONTAINER */
    .container-box {
        max-width: 1200px;
        margin: auto;
    }

    /* HERO */
    .details-hero {
        border-radius: 30px;
        padding: 60px;
        margin-bottom: 35px;
        background: linear-gradient(rgba(5,8,22,.88), rgba(15,23,42,.92)), url('/images/library-banner.jpg');
        background-size: cover;
        background-position: center;
        border: 1px solid rgba(255,255,255,.08);
        box-shadow: 0 20px 60px rgba(0,0,0,.4);
    }

    .hero-badge {
        display: inline-block;
        padding: 8px 16px;
        border-radius: 50px;
        background: rgba(255,255,255,.06);
        color: #c4b5fd;
        font-size: 12px;
        margin-bottom: 15px;
    }

    .hero-title {
        font-size: 42px;
        font-weight: 900;
        margin-bottom: 10px;
    }

        .hero-title span {
            background: linear-gradient(90deg,#a78bfa,#f472b6);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

    .hero-text {
        color: #d1d5db;
        max-width: 700px;
        line-height: 1.7;
    }

    /* MAIN CARD */
    .book-card {
        display: grid;
        grid-template-columns: 300px 1fr;
        gap: 25px;
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.08);
        border-radius: 25px;
        padding: 25px;
        backdrop-filter: blur(12px);
        transition: .3s;
    }

        .book-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 20px 50px rgba(139,92,246,.18);
        }

    /* COVER */
    .book-cover {
        border-radius: 18px;
        overflow: hidden;
        height: 380px;
    }

        .book-cover img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: .5s;
        }

    .book-card:hover .book-cover img {
        transform: scale(1.05);
    }

    /* INFO */
    .book-info {
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .book-title {
        font-size: 32px;
        font-weight: 900;
        margin-bottom: 10px;
    }

    .book-author {
        color: #c4b5fd;
        margin-bottom: 15px;
    }

    .book-description {
        color: #d1d5db;
        line-height: 1.7;
        margin-bottom: 20px;
    }

    /* DETAILS GRID */
    .details-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        margin-bottom: 20px;
    }

    .detail-box {
        padding: 14px;
        border-radius: 14px;
        background: rgba(255,255,255,.03);
        border: 1px solid rgba(255,255,255,.06);
    }

        .detail-box small {
            color: #a78bfa;
            font-size: 11px;
            display: block;
            margin-bottom: 5px;
        }

        .detail-box span {
            font-size: 14px;
            font-weight: 600;
        }

    /* BUTTONS */
    .actions {
        display: flex;
        gap: 15px;
        flex-wrap: wrap;
    }

    .btn {
        flex: 1;
        padding: 14px;
        border-radius: 14px;
        border: none;
        font-weight: 700;
        cursor: pointer;
        transition: .3s;
        text-align: center;
        text-decoration: none;
    }

    .wishlist-btn {
        background: rgba(255,255,255,.06);
        color: white;
    }

        .wishlist-btn:hover {
            background: linear-gradient(90deg,#7c3aed,#9333ea);
            transform: translateY(-3px);
        }

    .reserve-btn {
        background: linear-gradient(90deg,#7c3aed,#9333ea);
        color: white;
    }

        .reserve-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(139,92,246,.3);
        }

    /* RESPONSIVE */
    @@media (max-width: 900px) {
        .book-card {
            grid-template-columns: 1fr;
        }

        .book-card {
            grid-template-columns: 1fr;
        }

        .book-cover {
            height: 300px;
        }

        .hero-title {
            font-size: 28px;
        }
    }
</style>

<div class="details-page">

    <div class="container-box">

        <!-- HERO -->
        <section class="details-hero">
            <div class="hero-badge">📚 Premium Library</div>
            <h1 class="hero-title">
                Explore <span>Book Details</span>
            </h1>
            <p class="hero-text">
                Discover full information, author insights and availability status.
            </p>
        </section>

        <!-- BOOK -->
        <div class="book-card">

            <div class="book-cover">
                <img src="@Model.CoverImageUrl" />
            </div>

            <div class="book-info">

                <h1 class="book-title">@Model.Title</h1>
                <div class="book-author">by <strong>@Model.AuthorName</strong></div>

                <p class="book-description">@Model.Description</p>

                <div class="details-grid">
                    <div class="detail-box">
                        <small>Category</small>
                        <span>@Model.CategoryName</span>
                    </div>

                    <div class="detail-box">
                        <small>Status</small>
                        <span>
                            @(Model.IsAvailable ? "Available" : "Issued")
                        </span>
                    </div>

                    <div class="detail-box">
                        <small>Library</small>
                        <span>BookVerse</span>
                    </div>

                    <div class="detail-box">
                        <small>Author</small>
                        <span>@Model.AuthorName</span>
                    </div>
                </div>

                <div class="actions">

                    <form asp-area="Member"
                          asp-controller="Wishlist"
                          asp-action="Add"
                          method="post">
                        <input type="hidden" name="BookId" value="@Model.Id" />
                        <button class="btn wishlist-btn" type="submit">
                            ❤️ Wishlist
                        </button>
                    </form>

                    @if (Model.IsAvailable)
                    {
                        <a asp-area="Member"
                           asp-controller="Reservation"
                           asp-action="Create"
                           asp-route-bookId="@Model.Id"
                           class="btn reserve-btn">
                            📘 Reserve
                        </a>
                    }
                    else
                    {
                        <button class="btn reserve-btn" disabled>
                            Not Available
                        </button>
                    }

                </div>

            </div>
        </div>

    </div>
</div>
