@model Library_Management_System.ViewModels.BookDetailsViewModel

@{
    ViewData["Title"] = "Book Details";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
}

<style>
    body {
        margin: 0;
        font-family: 'Inter', sans-serif;
        color: white;
        background: radial-gradient(circle at top right, rgba(139,92,246,.18), transparent 30%), radial-gradient(circle at bottom left, rgba(236,72,153,.12), transparent 30%), linear-gradient(135deg,#050816,#0f172a);
    }

    .details-page {
        min-height: 100vh;
        padding: 40px 20px;
    }

    .container-box {
        max-width: 1200px;
        margin: auto;
    }

    .details-hero {
        border-radius: 30px;
        padding: 60px;
        margin-bottom: 35px;
        background: linear-gradient(rgba(5,8,22,.88), rgba(15,23,42,.92)), url('/images/library-banner.jpg');
        background-size: cover;
        background-position: center;
    }

    .hero-title {
        font-size: 42px;
        font-weight: 900;
    }

        .hero-title span {
            background: linear-gradient(90deg,#a78bfa,#f472b6);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

    .book-card {
        display: grid;
        grid-template-columns: 300px 1fr;
        gap: 25px;
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.08);
        border-radius: 25px;
        padding: 25px;
    }

    .book-cover img {
        width: 100%;
        height: 380px;
        object-fit: cover;
        border-radius: 18px;
    }

    .book-title {
        font-size: 32px;
        font-weight: 900;
    }

    .book-author {
        color: #c4b5fd;
        margin-bottom: 10px;
    }

    .book-description {
        color: #d1d5db;
        line-height: 1.7;
        margin-bottom: 20px;
    }

    .details-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        margin-bottom: 20px;
    }

    .detail-box {
        padding: 14px;
        border-radius: 14px;
        background: rgba(255,255,255,.03);
        border: 1px solid rgba(255,255,255,.06);
    }

        .detail-box small {
            color: #a78bfa;
            font-size: 11px;
            display: block;
            margin-bottom: 5px;
        }

    .actions {
        display: flex;
        gap: 15px;
        flex-wrap: wrap;
    }

    .btn {
        padding: 14px;
        border-radius: 14px;
        border: none;
        font-weight: 700;
        cursor: pointer;
        text-decoration: none;
        text-align: center;
        transition: 0.3s;
    }

    .wishlist-btn {
        background: rgba(255,255,255,.06);
        color: white;
        flex: 1;
    }

        .wishlist-btn.active {
            background: linear-gradient(135deg,#ef4444,#f43f5e);
        }

            .wishlist-btn.active i {
                color: white;
            }

    .reserve-btn {
        background: linear-gradient(90deg,#7c3aed,#9333ea);
        color: white;
        flex: 1;
    }

        .reserve-btn:hover {
            transform: translateY(-3px);
        }
</style>

<div class="details-page">

    <div class="container-box">

        <!-- HERO -->
        <section class="details-hero">
            <h1 class="hero-title">
                Explore <span>Book Details</span>
            </h1>
        </section>

        <!-- BOOK -->
        <div class="book-card">

            <!-- IMAGE -->
            <div class="book-cover">
                <img src="@(string.IsNullOrEmpty(Model.CoverImageUrl)
                                                 ? "/images/default-book.jpg"
                                                 : Model.CoverImageUrl)" />
            </div>

            <!-- INFO -->
            <div>

                <h1 class="book-title">@Model.Title</h1>
                <div class="book-author">by @Model.AuthorName</div>

                <p class="book-description">@Model.Description</p>

                <div class="details-grid">
                    <div class="detail-box">
                        <small>Category</small>
                        <span>@Model.CategoryName</span>
                    </div>

                    <div class="detail-box">
                        <small>Status</small>
                        <span>@(Model.IsAvailable ? "Available" : "Issued")</span>
                    </div>
                </div>

                <!-- ACTIONS -->
                <div class="actions">

                    <button type="button"
                            class="wishlist-btn @(Model.IsWishlisted ? "active" : "")"
                            data-bookid="@Model.Id">

                        <i class="@(Model.IsWishlisted
                                   ? "fa-solid fa-heart"
                                   : "fa-regular fa-heart")"></i>

                    </button>

                    @if (Model.IsAvailable)
                    {
                        <a asp-area="Member"
                           asp-controller="Reservation"
                           asp-action="Create"
                           asp-route-bookId="@Model.Id"
                           class="btn reserve-btn">
                            📘 Reserve
                        </a>
                    }
                    else
                    {
                        <button class="btn reserve-btn" disabled>
                            Not Available
                        </button>
                    }

                </div>

            </div>
        </div>

    </div>
</div>

<!-- ✅ WISHLIST SCRIPT (FULL FIXED) -->
<script src="~/js/wishlist.js"></script>

