@model List<Library_Management_System.ViewModels.MostPopularBookViewModel>

@{
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
    ViewData["Title"] = "Most Popular Books";
}

<style>

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        background: #070b1a;
        font-family: 'Inter', sans-serif;
    }

    .popular-page {
        min-height: 100vh;
        padding: 28px;
        background: radial-gradient(circle at top right, rgba(168,85,247,.15), transparent 25%), radial-gradient(circle at bottom left, rgba(236,72,153,.10), transparent 28%), linear-gradient(135deg,#070b1a,#0f172a);
    }

    /* HERO */

    .popular-hero {
        position: relative;
        overflow: hidden;
        border-radius: 36px;
        padding: 75px 65px;
        margin-bottom: 45px;
        background: linear-gradient(rgba(7,11,26,.88), rgba(15,23,42,.92)), url('/images/library-banner.jpg');
        background-size: cover;
        background-position: center;
        border: 1px solid rgba(255,255,255,.08);
        box-shadow: 0 0 40px rgba(139,92,246,.15);
    }

        .popular-hero::before {
            content: "";
            position: absolute;
            width: 420px;
            height: 420px;
            border-radius: 50%;
            background: rgba(168,85,247,.10);
            top: -180px;
            right: -120px;
        }

        .popular-hero::after {
            content: "";
            position: absolute;
            width: 260px;
            height: 260px;
            border-radius: 50%;
            background: rgba(236,72,153,.08);
            bottom: -100px;
            left: -80px;
        }

    .hero-content {
        position: relative;
        z-index: 2;
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 12px 22px;
        border-radius: 50px;
        background: rgba(255,255,255,.05);
        border: 1px solid rgba(255,255,255,.08);
        color: #c4b5fd;
        font-size: 13px;
        letter-spacing: 1px;
        margin-bottom: 24px;
        backdrop-filter: blur(12px);
    }

    .hero-content h1 {
        color: white;
        font-size: 62px;
        font-weight: 900;
        line-height: 1.1;
        margin-bottom: 20px;
    }

        .hero-content h1 span {
            background: linear-gradient(90deg,#c084fc,#f0abfc);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

    .hero-content p {
        color: #d1d5db;
        font-size: 17px;
        line-height: 1.9;
        max-width: 720px;
    }

    /* GRID */

    .books-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill,minmax(280px,1fr));
        gap: 24px;
    }

    /* CARD */

    .book-card {
        position: relative;
        overflow: hidden;
        border-radius: 30px;
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.08);
        transition: .45s;
        backdrop-filter: blur(14px);
        box-shadow: 0 10px 35px rgba(0,0,0,.25);
    }

        .book-card:hover {
            transform: translateY(-10px);
            border-color: rgba(168,85,247,.30);
            box-shadow: 0 30px 60px rgba(139,92,246,.18), 0 15px 30px rgba(0,0,0,.30);
        }

    /* IMAGE */

    .book-image {
        position: relative;
        height: 250px;
        overflow: hidden;
    }

        .book-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: .7s;
        }

    .book-card:hover img {
        transform: scale(1.08);
    }

    .image-shadow {
        position: absolute;
        inset: 0;
        background: linear-gradient( to top, rgba(0,0,0,.92), rgba(0,0,0,.15), transparent );
    }

    .top-badge {
        position: absolute;
        top: 16px;
        left: 16px;
        z-index: 2;
        padding: 10px 16px;
        border-radius: 50px;
        background: rgba(15,23,42,.85);
        border: 1px solid rgba(255,255,255,.08);
        color: white;
        font-size: 12px;
        font-weight: 700;
        backdrop-filter: blur(10px);
    }

    .book-overlay {
        position: absolute;
        left: 20px;
        bottom: 20px;
        z-index: 2;
    }

    .category-pill {
        display: inline-block;
        padding: 7px 14px;
        border-radius: 50px;
        background: rgba(236,72,153,.16);
        color: #f9a8d4;
        font-size: 11px;
        font-weight: 700;
        margin-bottom: 12px;
    }

    .book-overlay h3 {
        color: white;
        font-size: 22px;
        font-weight: 800;
        margin-bottom: 5px;
        line-height: 1.3;
    }

    .book-overlay span {
        color: #ddd6fe;
        font-size: 14px;
    }

    /* CONTENT */

    .book-content {
        padding: 22px;
    }

    .borrow-box {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 16px;
        border-radius: 50px;
        background: rgba(139,92,246,.14);
        color: #d8b4fe;
        font-size: 13px;
        font-weight: 700;
        margin-bottom: 18px;
    }

    .book-title {
        color: white;
        font-size: 22px;
        font-weight: 800;
        line-height: 1.3;
        margin-bottom: 16px;
    }

    /* DETAILS */

    .details-grid {
        display: grid;
        grid-template-columns: repeat(2,1fr);
        gap: 12px;
        margin-bottom: 20px;
    }

    .detail-card {
        padding: 14px;
        border-radius: 18px;
        background: rgba(255,255,255,.03);
        border: 1px solid rgba(255,255,255,.05);
        transition: .35s;
    }

        .detail-card:hover {
            transform: translateY(-3px);
            border-color: rgba(168,85,247,.25);
            background: rgba(255,255,255,.05);
        }

        .detail-card small {
            display: block;
            color: #c4b5fd;
            margin-bottom: 8px;
            font-size: 10px;
            letter-spacing: 1px;
            text-transform: uppercase;
            font-weight: 700;
        }

        .detail-card span {
            color: white;
            font-size: 13px;
            font-weight: 600;
            line-height: 1.5;
        }

    /* BUTTON */

    .view-btn {
        width: 100%;
        display: inline-flex;
        justify-content: center;
        align-items: center;
        padding: 14px 20px;
        border-radius: 18px;
        background: linear-gradient(90deg,#7c3aed,#9333ea);
        color: white;
        text-decoration: none;
        font-weight: 700;
        transition: .35s;
        box-shadow: 0 10px 25px rgba(139,92,246,.25);
    }

        .view-btn:hover {
            color: white;
            transform: translateY(-3px);
            box-shadow: 0 16px 35px rgba(139,92,246,.35);
        }

    /* EMPTY */

    .empty-box {
        padding: 80px 30px;
        text-align: center;
        border-radius: 30px;
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.08);
    }

        .empty-box h3 {
            color: white;
            margin-top: 20px;
            margin-bottom: 10px;
            font-size: 32px;
        }

        .empty-box p {
            color: #9ca3af;
        }

    /* MOBILE */

    @@media(max-width:768px) {

        .popular-page {
            padding: 18px;
        }

        .popular-hero {
            padding: 50px 28px;
            border-radius: 28px;
        }

        .hero-content h1 {
            font-size: 42px;
        }

        .details-grid {
            grid-template-columns: 1fr;
        }
    }

</style>

<div class="popular-page">

    <!-- HERO -->

    <section class="popular-hero">

        <div class="hero-content">

            <div class="hero-badge">
                🔥 TRENDING LIBRARY COLLECTION
            </div>

            <h1>
                Most Popular
                <span>Books</span>
            </h1>

            <p>
                Explore the most borrowed and trending books loved
                by readers across the library community.
            </p>

        </div>

    </section>

    <!-- BOOKS -->
    @if (Model != null && Model.Any())
    {
        <div class="books-grid">

            @foreach (var book in Model)
            {
                <div class="book-card">

                    <!-- IMAGE -->

                    <div class="book-image">

                        <img src="@(string.IsNullOrEmpty(book.CoverImageUrl)
                                                                                              ? "/images/default-book.jpg"
                                                                                              : book.CoverImageUrl)" />

                        <div class="top-badge">
                            🔥 Top Borrowed
                        </div>

                        <div class="image-shadow"></div>

                        <div class="book-overlay">

                            <div class="category-pill">
                                @book.CategoryName
                            </div>

                            <h3>
                                @book.Title
                            </h3>

                            <span>
                                by @book.AuthorName
                            </span>

                        </div>

                    </div>

                    <!-- CONTENT -->

                    <div class="book-content">

                        <div class="borrow-box">
                            🔥 @book.TotalBorrows Borrows
                        </div>

                        <h2 class="book-title">
                            @book.Title
                        </h2>

                        <!-- DETAILS -->

                        <div class="details-grid">

                            <div class="detail-card">
                                <small>Author</small>
                                <span>
                                    ✍️ @book.AuthorName
                                </span>
                            </div>

                            <div class="detail-card">
                                <small>Category</small>
                                <span>
                                    📚 @book.CategoryName
                                </span>
                            </div>

                            <div class="detail-card">
                                <small>ISBN</small>
                                <span>
                                    📘 @book.ISBN
                                </span>
                            </div>

                            <div class="detail-card">
                                <small>Popularity</small>
                                <span>
                                    🚀 Trending
                                </span>
                            </div>

                        </div>

                        <!-- BUTTON -->

                        <a asp-controller="Catalog"
                           asp-action="Details"
                           asp-route-id="@book.BookId"
                           class="view-btn">

                            Explore Book →

                        </a>

                    </div>

                </div>
            }

        </div>
    }
    else
    {
        <div class="empty-box">

            <img src="https://cdn-icons-png.flaticon.com/512/7486/7486740.png"
                 width="120" />

            <h3>No Popular Books Found</h3>

            <p>
                There are currently no trending books available.
            </p>

        </div>
    }

</div>
