@model List<Library_Management_System.ViewModels.MostPopularBookViewModel>

@{
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
    ViewData["Title"] = "Most Popular Books";
}


<link rel="stylesheet"
      href="~/css/popular-book-card.css" />

<style>

    body {
        background: #070b1a;
        color: white;
        font-family: 'Inter',sans-serif;
    }

    .popular-page {
        padding: 25px 0 80px;
    }

    /* HERO */

    .popular-hero {
        position: relative;
        overflow: hidden;
        border-radius: 36px;
        padding: 80px 65px;
        margin-bottom: 60px;
        background: linear-gradient( rgba(7,11,26,.88), rgba(15,23,42,.92)), url('/images/library-banner.png');
        background-size: cover;
        background-position: center;
        border: 1px solid rgba(255,255,255,.08);
        box-shadow: 0 0 40px rgba(139,92,246,.15);
    }

        .popular-hero::before {
            content: "";
            position: absolute;
            width: 420px;
            height: 420px;
            border-radius: 50%;
            background: rgba(168,85,247,.10);
            top: -180px;
            right: -120px;
        }

        .popular-hero::after {
            content: "";
            position: absolute;
            width: 260px;
            height: 260px;
            border-radius: 50%;
            background: rgba(236,72,153,.08);
            bottom: -100px;
            left: -80px;
        }

    .hero-content {
        position: relative;
        z-index: 2;
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 12px 22px;
        border-radius: 50px;
        background: rgba(255,255,255,.05);
        border: 1px solid rgba(255,255,255,.08);
        color: #c4b5fd;
        font-size: 13px;
        margin-bottom: 24px;
    }

    .hero-content h1 {
        font-size: 62px;
        font-weight: 900;
        color: white;
        margin-bottom: 20px;
    }

        .hero-content h1 span {
            background: linear-gradient( 90deg, #c084fc, #f0abfc);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

    .hero-content p {
        color: #d1d5db;
        line-height: 1.9;
        max-width: 700px;
    }

    @@media(max-width:768px) {

        .popular-hero {
            padding: 55px 30px;
            border-radius: 28px;
        }

        .hero-content h1 {
            font-size: 42px;
        }
    }
</style>


<div class="container popular-page">

    <!-- HERO -->

    <section class="popular-hero">

        <div class="hero-content">

            <div class="hero-badge">

                🔥 TRENDING LIBRARY COLLECTION

            </div>

            <h1>

                Most Popular
                <span>Books</span>

            </h1>

            <p>

                Explore the most borrowed and
                trending books loved by readers
                across the library community.

            </p>

        </div>

    </section>


    @if (Model != null && Model.Any())
    {

        <div class="popular-books-grid">

            @foreach (var book in Model)
            {

                <div class="popular-book-card">

                    <!-- IMAGE -->

                    <div class="popular-book-image">

                        <img src="@(string.IsNullOrEmpty(book.CoverImageUrl)
                                                          ? "/images/default-book.jpg"
                                                          : book.CoverImageUrl)"
                             alt="@book.Title" />


                        <div class="popular-top-badge">

                            🔥 Top Borrowed

                        </div>


                        <div class="popular-overlay">

                            <div class="popular-category">

                                📚 @book.CategoryName

                            </div>

                            <h3>

                                @book.Title

                            </h3>

                            <span>

                                ✍️ @book.AuthorName

                            </span>

                        </div>

                    </div>


                    <!-- CONTENT -->

                    <div class="popular-book-content">


                        <div class="popular-borrow-box">

                            🔥 @book.TotalBorrows
                            Borrows

                        </div>


                        <!-- DETAILS -->

                        <div class="popular-detail-grid">

                            <div class="popular-detail-card">

                                <small>
                                    AUTHOR
                                </small>

                                <span>

                                    ✍️ @book.AuthorName

                                </span>

                            </div>


                            <div class="popular-detail-card">

                                <small>
                                    CATEGORY
                                </small>

                                <span>

                                    📚 @book.CategoryName

                                </span>

                            </div>


                            <div class="popular-detail-card">

                                <small>
                                    ISBN
                                </small>

                                <span>

                                    📘 @book.ISBN

                                </span>

                            </div>


                            <div class="popular-detail-card">

                                <small>
                                    POPULARITY
                                </small>

                                <span>

                                    🚀 Trending

                                </span>

                            </div>

                        </div>


                        <a asp-controller="Catalog"
                           asp-action="Details"
                           asp-route-id="@book.BookId"
                           class="popular-view-btn">

                            Explore Book →

                        </a>

                    </div>

                </div>

            }

        </div>

    }

    else
    {

        <div class="popular-empty-box">

            <img src="/images/empty-books.png"
                 width="120" />

            <h3>

                No Popular Books Found

            </h3>

            <p>

                There are currently no
                trending books available.

            </p>

        </div>

    }

</div>
