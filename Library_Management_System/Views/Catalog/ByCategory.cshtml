@{
    ViewData["Title"] = "Books By Category";
    Layout = "_Layout";
}

<div class="category-page">

    <!-- HEADER -->
    <div class="page-header">
        <h1>@ViewBag.CategoryName Books</h1>
        <p>Explore books available in this category.</p>
    </div>

    <!-- BOOK GRID -->
    <div class="book-grid">

        @if (Model != null && Model.Any())
        {
            @foreach (var book in Model)
            {
                <div class="book-card">

                    <!-- COVER -->
                    <div class="book-image">
                        <img src="@book.CoverImageUrl"
                             alt="@book.Title" />
                    </div>

                    <!-- CONTENT -->
                    <div class="book-content">

                        <h3>@book.Title</h3>

                        <p class="author">
                            @(book.Author != null ? book.Author.Name : "Unknown Author")
                        </p>

                        <p class="desc">
                            @(book.Description != null && book.Description.Length > 100
                                ? book.Description.Substring(0, 100) + "..."
                                : book.Description)
                        </p>

                        <!-- STATUS -->
                        <div class="status">
                            @if (book.IsAvailable)
                            {
                                <span class="available">
                                    Available
                                </span>
                            }
                            else
                            {
                                <span class="unavailable">
                                    Reserved
                                </span>
                            }
                        </div>

                        <!-- BUTTON -->
                        <a asp-controller="Catalog"
                           asp-action="Details"
                           asp-route-id="@book.Id"
                           class="details-btn">
                            View Details
                        </a>

                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty-state">
                <h3>No books found in this category.</h3>
            </div>
        }

    </div>
</div>

<style>
    body {
        background: #070b1a;
        color: white;
        font-family: Inter, sans-serif;
    }

    .category-page {
        padding: 40px;
    }

    .page-header {
        margin-bottom: 35px;
    }

    .page-header h1 {
        font-size: 38px;
        margin-bottom: 10px;
    }

    .page-header p {
        opacity: 0.7;
    }

    .book-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill,minmax(250px,1fr));
        gap: 25px;
    }

    .book-card {
        background: #11182d;
        border-radius: 16px;
        overflow: hidden;
        transition: 0.3s ease;
        box-shadow: 0 8px 25px rgba(0,0,0,0.3);
    }

    .book-card:hover {
        transform: translateY(-5px);
    }

    .book-image img {
        width: 100%;
        height: 320px;
        object-fit: cover;
    }

    .book-content {
        padding: 20px;
    }

    .book-content h3 {
        margin-bottom: 8px;
        font-size: 22px;
    }

    .author {
        color: #9aa4c7;
        margin-bottom: 12px;
    }

    .desc {
        font-size: 14px;
        line-height: 1.6;
        opacity: 0.8;
        min-height: 70px;
    }

    .status {
        margin: 15px 0;
    }

    .available {
        background: #1f9d55;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 13px;
    }

    .unavailable {
        background: #e3342f;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 13px;
    }

    .details-btn {
        display: inline-block;
        margin-top: 10px;
        background: #6c5ce7;
        color: white;
        padding: 10px 18px;
        border-radius: 8px;
        text-decoration: none;
        transition: 0.3s;
    }

    .details-btn:hover {
        background: #5848d6;
    }

    .empty-state {
        padding: 50px;
        text-align: center;
        background: #11182d;
        border-radius: 12px;
    }
</style>