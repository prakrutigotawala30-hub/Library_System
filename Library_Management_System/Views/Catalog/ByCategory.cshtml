@model Library_Management_System.ViewModels.CatalogViewModel

@{
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
    ViewData["Title"] = "Book Categories";
}
<style>

    body {
        background: #070b1a;
        color: white;
        font-family: 'Inter', sans-serif;
    }

    .categories-page {
        padding: 25px 0 80px;
    }

    /* HERO SECTION */

    .categories-hero {
        position: relative;
        overflow: hidden;
        border-radius: 36px;
        padding: 80px 65px;
        margin-bottom: 60px;
        background: linear-gradient(rgba(7,11,26,.88), rgba(15,23,42,.92)), url('/images/library-banner.jpg');
        background-size: cover;
        background-position: center;
        border: 1px solid rgba(255,255,255,.08);
        box-shadow: 0 0 40px rgba(139,92,246,.15);
    }

        .categories-hero::before {
            content: "";
            position: absolute;
            width: 420px;
            height: 420px;
            border-radius: 50%;
            background: rgba(168,85,247,.10);
            top: -180px;
            right: -120px;
        }

        .categories-hero::after {
            content: "";
            position: absolute;
            width: 260px;
            height: 260px;
            border-radius: 50%;
            background: rgba(236,72,153,.08);
            bottom: -100px;
            left: -80px;
        }

    .hero-content {
        position: relative;
        z-index: 2;
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 12px 22px;
        border-radius: 50px;
        background: rgba(255,255,255,.05);
        border: 1px solid rgba(255,255,255,.08);
        color: #c4b5fd;
        font-size: 13px;
        letter-spacing: 1px;
        margin-bottom: 24px;
        backdrop-filter: blur(12px);
    }

    .hero-content h1 {
        color: white;
        font-size: 62px;
        font-weight: 900;
        line-height: 1.1;
        margin-bottom: 20px;
    }

        .hero-content h1 span {
            background: linear-gradient(90deg,#c084fc,#f0abfc);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

    .hero-content p {
        color: #d1d5db;
        font-size: 17px;
        line-height: 1.9;
        max-width: 720px;
    }

    /* CATEGORY GROUP */

    .category-section {
        margin-bottom: 60px;
    }

    .category-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 25px;
        padding-bottom: 12px;
        border-bottom: 1px solid rgba(255,255,255,.08);
    }

        .category-header h2 {
            font-size: 28px;
            font-weight: 800;
            color: white;
        }

    .book-count {
        padding: 8px 16px;
        border-radius: 50px;
        background: rgba(139,92,246,.15);
        color: #c4b5fd;
        font-size: 13px;
        font-weight: 700;
    }

    /* BOOK GRID */

    .books-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill,minmax(240px,1fr));
        gap: 24px;
    }

    /* BOOK CARD */

    .book-card {
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.08);
        border-radius: 24px;
        overflow: hidden;
        transition: .35s;
        backdrop-filter: blur(12px);
    }

        .book-card:hover {
            transform: translateY(-8px);
            border-color: rgba(139,92,246,.35);
            box-shadow: 0 20px 40px rgba(139,92,246,.18);
        }

    .book-image {
        height: 300px;
        overflow: hidden;
    }

        .book-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: .5s;
        }

    .book-card:hover img {
        transform: scale(1.08);
    }

    .book-content {
        padding: 20px;
    }

    .book-title {
        font-size: 20px;
        font-weight: 700;
        margin-bottom: 10px;
        color: white;
    }

    .book-author {
        color: #cbd5e1;
        font-size: 14px;
        margin-bottom: 15px;
    }

    .book-description {
        color: #94a3b8;
        font-size: 13px;
        line-height: 1.7;
        min-height: 65px;
    }

    .book-footer {
        margin-top: 20px;
    }

    .details-btn {
        width: 100%;
        display: inline-flex;
        justify-content: center;
        align-items: center;
        padding: 12px;
        border-radius: 14px;
        background: linear-gradient(90deg,#7c3aed,#9333ea);
        color: white;
        text-decoration: none;
        font-weight: 700;
        transition: .3s;
    }

        .details-btn:hover {
            color: white;
            transform: translateY(-2px);
        }

    @@media(max-width:768px) {

        .categories-hero {
            padding: 55px 30px;
            border-radius: 28px;
        }

        .hero-content h1 {
            font-size: 42px;
        }

        .category-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 12px;
        }
    }

</style>

<div class="container categories-page">

    <section class="categories-hero">

        <div class="hero-content">

            <div class="hero-badge">
                📚 EXPLORE LIBRARY COLLECTION
            </div>

            <h1>
                Browse
                <span>Book Categories</span>
            </h1>

            <p>
                Discover books organized by categories including
                fiction, science, history, technology, biographies,
                and many more curated collections.
            </p>

        </div>

    </section>

    @if (Model.PagedBooks != null && Model.PagedBooks.Any())
    {
        var groupedBooks = Model.PagedBooks
        .GroupBy(x => x.Category?.Name);

        @foreach (var categoryGroup in groupedBooks)
        {
            <div class="category-section">

                <!-- CATEGORY HEADER -->

                <div class="category-header">

                    <h2>
                        📚 @categoryGroup.Key
                    </h2>

                    <div class="book-count">
                        @categoryGroup.Count() Books
                    </div>

                </div>

                <!-- BOOKS -->

                <div class="books-grid">

                    @foreach (var book in categoryGroup)
                    {
                        <div class="book-card">

                            <div class="book-image">

                                <img src="@(string.IsNullOrEmpty(book.CoverImageUrl)
                                                                                 ? "/images/default-book.jpg"
                                                                                 : book.CoverImageUrl)"
                                     alt="@book.Title" />

                            </div>

                            <div class="book-content">

                                <h3 class="book-title">
                                    @book.Title
                                </h3>

                                <div class="book-author">
                                    ✍️ @(book.Author?.Name ?? "Unknown Author")
                                </div>

                                <div class="book-description">

                                    @(string.IsNullOrEmpty(book.Description)
                                                            ? "No description available."
                                                            : (book.Description.Length > 90
                                                            ? book.Description.Substring(0, 90) + "..."
                                                            : book.Description))

                                </div>

                                <div class="book-footer">

                                    <a asp-controller="Catalog"
                                       asp-action="Details"
                                       asp-route-id="@book.Id"
                                       class="details-btn">

                                        View Details →

                                    </a>

                                </div>

                            </div>

                        </div>
                    }

                </div>

            </div>
        }
    }
    else
    {
        <div class="text-center mt-5">
            <h3>No Books Found</h3>
        </div>
    }

</div>
