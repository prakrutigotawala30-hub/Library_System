@model Library_Management_System.ViewModels.CatalogViewModel

@{
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
    ViewData["Title"] = "New Arrivals";
}

<link rel="stylesheet" href="~/css/book-arrival-card.css" />


<style>

    body {
        background: #070b1a;
        color: white;
        font-family: 'Inter',sans-serif;
    }

    .arrivals-page {
        padding: 25px 0 80px;
    }

    /* HERO */

    .arrivals-hero {
        position: relative;
        overflow: hidden;
        border-radius: 36px;
        padding: 80px 65px;
        margin-bottom: 60px;
        background: linear-gradient( rgba(7,11,26,.88), rgba(15,23,42,.92)), url('/images/library-banner.png');
        background-size: cover;
        background-position: center;
        border: 1px solid rgba(255,255,255,.08);
    }

        .arrivals-hero:before {
            content: "";
            position: absolute;
            width: 420px;
            height: 420px;
            border-radius: 50%;
            background: rgba(168,85,247,.10);
            top: -180px;
            right: -120px;
        }

        .arrivals-hero:after {
            content: "";
            position: absolute;
            width: 260px;
            height: 260px;
            border-radius: 50%;
            background: rgba(236,72,153,.08);
            bottom: -100px;
            left: -80px;
        }

    .hero-content {
        position: relative;
        z-index: 2;
    }

    .hero-badge {
        display: inline-flex;
        padding: 12px 22px;
        border-radius: 50px;
        background: rgba(255,255,255,.05);
        border: 1px solid rgba(255,255,255,.08);
        color: #c4b5fd;
        margin-bottom: 25px;
    }

    .hero-content h1 {
        font-size: 60px;
        font-weight: 900;
        margin-bottom: 18px;
    }

    .hero-content span {
        background: linear-gradient( 90deg,#c084fc,#f0abfc);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .hero-content p {
        color: #cbd5e1;
        line-height: 1.8;
    }

    /* GRID */

    .arrival-book-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill,minmax(260px,1fr));
        gap: 28px;
    }

    /* EMPTY */

    .empty-box {
        padding: 80px 30px;
        text-align: center;
        border-radius: 30px;
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.08);
    }

        .empty-box h3 {
            font-size: 32px;
            margin-bottom: 12px;
        }

        .empty-box p {
            color: #94a3b8;
        }

    @@media(max-width:768px) {

        .arrivals-hero {
            padding: 55px 30px;
            border-radius: 28px;
        }

        .hero-content h1 {
            font-size: 42px;
        }

        .arrival-book-grid {
            grid-template-columns: repeat(2,1fr);
            gap: 16px;
        }
    }
</style>


<div class="container arrivals-page">

    <section class="arrivals-hero">

        <div class="hero-content">

            <div class="hero-badge">
                🆕 LATEST LIBRARY COLLECTION
            </div>

            <h1>
                New
                <span>Arrivals</span>
            </h1>

            <p>
                Explore recently added books from the last
                30 days including trending novels,
                educational resources and technology books.
            </p>

        </div>

    </section>


    @if (Model.PagedBooks != null && Model.PagedBooks.Any())
    {
        <div class="arrival-book-grid">

            @foreach (var book in Model.PagedBooks)
            {
                <div class="arrival-book-card">

                    <div class="arrival-book-image">

                        <img src="@(string.IsNullOrEmpty(book.CoverImageUrl)
                             ? "/images/default-book.jpg"
                             : book.CoverImageUrl)" />

                        <div class="arrival-new-badge">
                            🆕 New Arrival
                        </div>

                    </div>


                    <div class="arrival-book-content">

                        <div class="arrival-category-pill">

                            📚
                            @(book.Category?.Name
                                                ?? "Unknown")

                        </div>


                        <h2 class="arrival-book-title">
                            @book.Title
                        </h2>

                        <div class="arrival-book-author">

                            ✍️
                            @(book.Author?.Name
                                                ?? "Unknown Author")

                        </div>


                        <div class="arrival-book-description">

                            @(string.IsNullOrEmpty(book.Description)
                                                ? "No description available."
                                                : (book.Description.Length > 100
                                                ? book.Description.Substring(0, 100) + "..."
                                                : book.Description))

                        </div>


                        <div class="arrival-book-date">

                            📅 Added:
                            @book.CreatedAt.ToString("dd MMM yyyy")

                        </div>


                        <div class="arrival-book-footer">

                            <a asp-controller="Catalog"
                               asp-action="Details"
                               asp-route-id="@book.Id"
                               class="arrival-details-btn">

                                View Details →

                            </a>

                        </div>

                    </div>

                </div>
            }

        </div>
    }
    else
    {

        <div class="empty-box">

            <h3>No New Arrivals</h3>

            <p>
                No books were added in the last 30 days
            </p>

        </div>

    }

</div>
