@{
    ViewData["Title"] = "Hours";
}

<section class="py-5 bg-white min-vh-100">
    <div class="container">

        <div class="text-center mb-5">
            <h1 class="fw-bold">Library Hours</h1>
            <p class="text-muted">Opening and closing schedule</p>
        </div>

        <div class="table-responsive shadow rounded-4 overflow-hidden">
            <table class="table table-bordered align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Day</th>
                        <th>Opening</th>
                        <th>Closing</th>
                    </tr>
                </thead>

                <tbody>
                    <tr>
                        <td>Monday - Friday</td>
                        <td>8:00 AM</td>
                        <td>8:00 PM</td>
                    </tr>

                    <tr>
                        <td>Saturday</td>
                        <td>9:00 AM</td>
                        <td>5:00 PM</td>
                    </tr>

                    <tr>
                        <td>Sunday</td>
                        <td colspan="2">Closed</td>
                    </tr>
                </tbody>
            </table>
        </div>

    </div>
</section>

