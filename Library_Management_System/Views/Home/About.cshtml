@{
    ViewData["Title"] = "About";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>

    body {
        background: #050816;
        font-family: 'Inter', sans-serif;
    }

    .about-section {
        min-height: 100vh;
        padding: 90px 0;
        display: flex;
        align-items: center;
        background: radial-gradient(circle at top right, rgba(124,58,237,0.18), transparent 30%), linear-gradient(135deg,#050816,#0b1120,#111827);
    }

    .about-header {
        text-align: center;
        margin-bottom: 70px;
    }

        .about-header h1 {
            color: #ffffff;
            font-size: 52px;
            font-weight: 800;
            margin-bottom: 18px;
            letter-spacing: -1px;
        }

        .about-header p {
            color: #9ca3af;
            font-size: 18px;
            max-width: 700px;
            margin: auto;
        }

    /* CARDS */

    .about-card {
        background: rgba(255,255,255,0.04);
        padding: 40px 35px;
        border-radius: 28px;
        backdrop-filter: blur(14px);
        border: 1px solid rgba(255,255,255,0.08);
        height: 100%;
        transition: 0.35s ease;
        box-shadow: 0 10px 30px rgba(0,0,0,0.35), 0 0 20px rgba(124,58,237,0.10);
    }

        .about-card:hover {
            transform: translateY(-6px);
            border-color: rgba(139,92,246,0.35);
            box-shadow: 0 18px 40px rgba(0,0,0,0.45), 0 0 30px rgba(139,92,246,0.18);
        }

        .about-card h3 {
            color: white;
            font-size: 28px;
            font-weight: 700;
            margin-bottom: 18px;
        }

        .about-card p {
            color: #d1d5db;
            line-height: 1.9;
            font-size: 16px;
            margin: 0;
        }

    /* OPTIONAL ICON CIRCLE */

    .icon-box {
        width: 70px;
        height: 70px;
        border-radius: 20px;
        background: linear-gradient(135deg,#7c3aed,#9333ea);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 25px;
        font-size: 30px;
        color: white;
        box-shadow: 0 0 20px rgba(124,58,237,0.4);
    }

    /* MOBILE */

    @@media(max-width:768px) {

        .about-section {
            padding: 60px 0;
        }

        .about-header h1 {
            font-size: 40px;
        }

        .about-header p {
            font-size: 16px;
        }

        .about-card {
            padding: 30px 25px;
        }

            .about-card h3 {
                font-size: 24px;
            }
    }

</style>

<section class="about-section">

    <div class="container">

        <!-- HEADER -->

        <div class="about-header">

            <h1>About BookVerse Library</h1>

            <p>
                A modern digital library platform designed to simplify
                book management, borrowing, reservations, and learning
                experiences for students and faculty.
            </p>

        </div>

        <!-- CARDS -->

        <div class="row g-4">

            <!-- CARD 1 -->

            <div class="col-lg-4">

                <div class="about-card">

                    <div class="icon-box">
                        📚
                    </div>

                    <h3>Our Mission</h3>

                    <p>
                        To provide innovative learning resources,
                        smart digital services, and seamless access
                        to academic knowledge for every learner.
                    </p>

                </div>

            </div>

            <!-- CARD 2 -->

            <div class="col-lg-4">

                <div class="about-card">

                    <div class="icon-box">
                        🏛
                    </div>

                    <h3>Library History</h3>

                    <p>
                        BookVerse was established to modernize
                        traditional library systems with digital
                        borrowing, smart catalog management,
                        and interactive member services.
                    </p>

                </div>

            </div>

            <!-- CARD 3 -->

            <div class="col-lg-4">

                <div class="about-card">

                    <div class="icon-box">
                        💻
                    </div>

                    <h3>Developed By</h3>

                    <p>
                        Designed and developed by Janvi & Prakruti
                        using ASP.NET Core MVC with a modern
                        responsive UI and advanced library features.
                    </p>

                </div>

            </div>

        </div>

    </div>

</section>