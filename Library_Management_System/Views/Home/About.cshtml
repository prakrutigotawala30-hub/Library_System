@{
    ViewData["Title"] = "About";
}

<section class="py-5 bg-dark text-white min-vh-100 d-flex align-items-center">
    <div class="container">

        <div class="text-center mb-5">
            <h1 class="display-4 fw-bold">About Our Library</h1>
            <p class="lead text-light">
                Modern digital library experience for students and faculty.
            </p>
        </div>

        <div class="row g-4">

            <div class="col-lg-4">
                <div class="about-card h-100">
                    <h3 class="fw-bold mb-3">Our Mission</h3>
                    <p>
                        To provide innovative learning resources and premium academic support.
                    </p>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="about-card h-100">
                    <h3 class="fw-bold mb-3">Library History</h3>
                    <p>
                        Established with thousands of books, journals, and digital resources.
                    </p>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="about-card h-100">
                    <h3 class="fw-bold mb-3">Developed By</h3>
                    <p>
                        Built by Janvi & Prakruti.
                    </p>
                </div>
            </div>

        </div>

    </div>
</section>

<style>
    .about-card {
        background: rgba(255,255,255,0.08);
        padding: 35px;
        border-radius: 24px;
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255,255,255,0.1);
    }
</style>