@model Library_Management_System.ViewModels.HomePageViewModel

@{
    ViewData["Title"] = "Home";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
}

<link rel="stylesheet" href="~/css/frontend.css" />

<style>
    a.book-card-link,
    a.event-card-link,
    a.arrival-card-link,
    a.category-item-link,
    a.membership-card-link {
        text-decoration: none;
        color: inherit;
        display: block;
    }


    .book-card,
    .event-card,
    .arrival-card,
    .category-item,
    .membership-card {
        cursor: pointer;
        transition: 0.3s ease;
    }

        .book-card:hover,
        .event-card:hover,
        .arrival-card:hover,
        .category-item:hover,
        .membership-card:hover {
            transform: translateY(-5px);
        }

</style>

<div class="dashboard-wrapper">

    <!-- HERO -->
    <section class="hero-section">

        <div class="hero-card">

            <div class="hero-left">

                <div class="welcome-badge">
                    <i class="bi bi-stars"></i>
                    Welcome Back,
                    @ViewBag.UserName 👋
                </div>

                <h1>
                    Knowledge is <span>Power</span>
                </h1>

                <p>
                    Explore the world’s best books and unlock
                    endless imagination through reading.
                </p>

                <div class="hero-buttons">

                    <!-- EXPLORE -->
                    <a asp-controller="Catalog"
                       asp-action="Index"
                       class="hero-btn">

                        Explore Books
                        <i class="bi bi-arrow-right"></i>

                    </a>

                    <!-- MEMBERSHIP -->
                    <a asp-controller="Membership"
                       asp-action="Index"
                       class="hero-btn membership-hero-btn">

                        Get Membership
                        <i class="bi bi-stars"></i>

                    </a>

                </div>

            </div>

            <div class="hero-right">
                <img src="~/images/hero/hero.png" alt="Hero" />
            </div>

        </div>

    </section>

    <!-- GRID -->
    <div class="dashboard-grid">

        <!-- LEFT -->
        <div class="dashboard-main">

            <!-- CONTINUE READING -->
            <div class="modern-card">

                <div class="section-header">
                    <h3>Continue Reading</h3>

                    <a asp-controller="Catalog"
                       asp-action="Index">
                        View All
                    </a>
                </div>

                <div class="books-row">

                    @foreach (var book in Model.ContinueReadingBooks)
                    {
                        <a asp-controller="Catalog"
                           asp-action="Details"
                           asp-route-id="@book.Id"
                           class="book-card-link">

                            <div class="book-card">

                                <img src="@(string.IsNullOrEmpty(book.CoverImageUrl)
                                                                                                  ? "/images/default-book.jpg"
                                                                                                  : book.CoverImageUrl)"
                                     alt="@book.Title" />

                                <div class="book-content">

                                    <h4>@book.Title</h4>

                                    <p>@(book.Author?.Name ?? "Unknown")</p>

                                    <!-- ❌ Removed progress bar completely -->

                                </div>

                            </div>

                        </a>
                    }

                </div>

            </div>

            <!-- EVENTS -->
            <div class="modern-card mt-4">

                <div class="section-header">
                    <h3>Upcoming Events</h3>

                    <a asp-controller="Events"
                       asp-action="Index">
                        View All
                    </a>
                </div>

                <div class="event-grid">

                    @foreach (var ev in Model.UpcomingEvents)
                    {
                        <a asp-controller="Events"
                           asp-action="Details"
                           asp-route-id="@ev.Id"
                           class="event-card-link">

                            <div class="event-card">

                                <div class="event-date">
                                    <h2>@ev.Date.Day</h2>
                                    <span>@ev.Date.ToString("MMM").ToUpper()</span>
                                </div>

                                <div class="event-info">
                                    <h4>@ev.Title</h4>
                                    <p>@ev.Location</p>
                                    <small>@ev.Date.ToString("hh:mm tt")</small>
                                </div>

                            </div>

                        </a>
                    }

                </div>

            </div>

            <!-- FULL WIDTH NEW ARRIVALS -->
            <div class="modern-card full-width-arrivals">

                <div class="section-header">

                    <h3>New Arrivals</h3>

                    <a asp-controller="Catalog"
                       asp-action="NewArrivals">
                        View All
                    </a>

                </div>

                <div class="arrival-row">

                    @foreach (var book in Model.NewArrivals)
                    {
                        <a asp-controller="Catalog"
                           asp-action="Details"
                           asp-route-id="@book.Id"
                           class="arrival-card-link">

                            <div class="arrival-card">

                                <img src="@(string.IsNullOrEmpty(book.CoverImageUrl)
                                                             ? "/images/default-book.jpg"
                                                             : book.CoverImageUrl)"
                                     alt="@book.Title" />

                            </div>

                        </a>
                    }

                </div>

            </div>

        </div>

        <!-- RIGHT -->
        <div class="dashboard-sidebar">

            <!-- MEMBERSHIP -->
            <div class="membership-box">

                <div class="sidebar-title">
                    <h3>Membership Plans</h3>
                </div>

                <a asp-controller="Membership"
                   asp-action="Index"
                   class="membership-card-link">

                    <div class="membership-card">
                        <div class="membership-icon student">
                            <i class="bi bi-mortarboard-fill"></i>
                        </div>

                        <div class="membership-content">
                            <h4>Student</h4>
                            <p>Perfect for learners</p>
                            <div class="membership-price">₹1000 / year</div>
                        </div>
                    </div>

                </a>

                <a asp-controller="Membership"
                   asp-action="Index"
                   class="membership-card-link">

                    <div class="membership-card active-membership">

                        <div class="popular-badge">Popular</div>

                        <div class="membership-icon regular">
                            <i class="bi bi-book-fill"></i>
                        </div>

                        <div class="membership-content">
                            <h4>Regular</h4>
                            <p>Best for readers</p>
                            <div class="membership-price">₹1500 / year</div>
                        </div>

                    </div>

                </a>

                <a asp-controller="Membership"
                   asp-action="Index"
                   class="membership-card-link">

                    <div class="membership-card">
                        <div class="membership-icon premium">
                            <i class="bi bi-gem"></i>
                        </div>

                        <div class="membership-content">
                            <h4>Premium</h4>
                            <p>Ultimate access</p>
                            <div class="membership-price">₹3000 / year</div>
                        </div>
                    </div>

                </a>

                <a asp-controller="Membership"
                   asp-action="Index"
                   class="membership-btn">

                    View Membership Plans
                    <i class="bi bi-arrow-right"></i>

                </a>

            </div>

            <!-- CATEGORIES -->
            <div class="modern-card mt-4">

                <div class="section-header">
                    <h3>Popular Categories</h3>

                    <a asp-controller="Catalog"
                       asp-action="ByCategory">
                        View All
                    </a>
                </div>

                @foreach (var category in Model.PopularCategories.Take(4))
                {
                    <div class="category-item">

                        <div class="category-icon">
                            <span style="font-size:24px;">
                                @category.IconClass
                            </span>
                        </div>

                        <div class="category-content">
                            <h4>@category.CategoryName</h4>
                            <span>@category.BookCount+ Books</span>
                        </div>

                    </div>
                }

            </div>

        </div>

    </div>

</div>
