@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<style>

    .hero-section {
        background: linear-gradient(135deg,#7e22ce,#9333ea);
        border-radius: 30px;
        padding: 50px;
        position: relative;
        overflow: hidden;
        margin-bottom: 30px;
    }

        .hero-section h1 {
            font-size: 52px;
            font-weight: 800;
            margin-bottom: 16px;
        }

            .hero-section h1 span {
                color: #facc15;
            }

        .hero-section p {
            color: rgba(255,255,255,.82);
            max-width: 600px;
            line-height: 1.7;
            margin-bottom: 25px;
        }

    .hero-btn {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: white;
        color: #7e22ce;
        padding: 14px 24px;
        border-radius: 16px;
        font-weight: 700;
        transition: .3s;
    }

        .hero-btn:hover {
            transform: translateY(-3px);
            color: #7e22ce;
        }

    .dashboard-grid {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 25px;
    }

    .content-card,
    .summary-card {
        background: rgba(255,255,255,.05);
        border: 1px solid rgba(255,255,255,.06);
        border-radius: 26px;
        padding: 24px;
        margin-bottom: 25px;
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 22px;
    }

        .section-header h4 {
            margin: 0;
            font-size: 20px;
            font-weight: 700;
        }

        .section-header a {
            color: #a855f7;
            font-size: 14px;
        }

    .books-row {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(180px,1fr));
        gap: 20px;
    }

    .book-card {
        background: rgba(255,255,255,.04);
        border-radius: 20px;
        overflow: hidden;
        transition: .3s;
    }

        .book-card:hover {
            transform: translateY(-8px);
        }

        .book-card img {
            width: 100%;
            height: 250px;
            object-fit: cover;
        }

    .book-info {
        padding: 16px;
    }

        .book-info h5 {
            font-size: 17px;
            margin-bottom: 5px;
        }

        .book-info p {
            color: rgba(255,255,255,.6);
            font-size: 14px;
            margin-bottom: 0;
        }

    .summary-item {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 22px;
    }

    .summary-icon {
        width: 55px;
        height: 55px;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        color: white;
    }

    .purple {
        background: linear-gradient(135deg,#9333ea,#7e22ce);
    }

    .green {
        background: linear-gradient(135deg,#10b981,#059669);
    }

    .orange {
        background: linear-gradient(135deg,#f59e0b,#ea580c);
    }

    .red {
        background: linear-gradient(135deg,#ef4444,#dc2626);
    }

    .dashboard-btn {
        width: 100%;
        margin-top: 10px;
        background: linear-gradient(135deg,#7e22ce,#9333ea);
        border: none;
        border-radius: 16px;
        color: white;
        padding: 14px;
        font-weight: 600;
    }

    .event-item,
    .activity-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 16px 0;
        border-bottom: 1px solid rgba(255,255,255,.05);
    }

    .event-date {
        width: 70px;
        height: 70px;
        border-radius: 18px;
        background: linear-gradient(135deg,#7e22ce,#9333ea);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        margin-right: 18px;
    }

        .event-date h3 {
            margin: 0;
            font-size: 24px;
            font-weight: 800;
        }

    .activity-left {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .activity-icon {
        width: 46px;
        height: 46px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
    }

    @@media(max-width:992px) {

        .dashboard-grid {
            grid-template-columns: 1fr;
        }
    }

</style>

<!-- HERO -->

<div class="hero-section">

    <h1>
        Knowledge is <span>Power</span>
    </h1>

    <p>
        Explore thousands of books, discover new authors,
        and manage your reading journey with BOOKVERSE.
    </p>

    <a asp-controller="Books"
       asp-action="Index"
       class="hero-btn">

        Explore Books
        <i class="fa fa-arrow-right"></i>

    </a>

</div>

<!-- GRID -->

<div class="dashboard-grid">

    <!-- LEFT -->

    <div>

        <!-- CONTINUE READING -->

        <div class="content-card">

            <div class="section-header">

                <h4>Continue Reading</h4>

                <a href="#">View All</a>

            </div>

            <div class="books-row">

                <div class="book-card">

                    <img src="https://m.media-amazon.com/images/I/71aFt4+OTOL.jpg" />

                    <div class="book-info">

                        <h5>The Alchemist</h5>

                        <p>Paulo Coelho</p>

                    </div>

                </div>

                <div class="book-card">

                    <img src="https://m.media-amazon.com/images/I/71QKQ9mwV7L.jpg" />

                    <div class="book-info">

                        <h5>Deep Work</h5>

                        <p>Cal Newport</p>

                    </div>

                </div>

                <div class="book-card">

                    <img src="https://m.media-amazon.com/images/I/81wgcld4wxL.jpg" />

                    <div class="book-info">

                        <h5>Atomic Habits</h5>

                        <p>James Clear</p>

                    </div>

                </div>

            </div>

        </div>

        <!-- EVENTS -->

        <div class="content-card">

            <div class="section-header">

                <h4>Upcoming Events</h4>

                <a href="#">View All</a>

            </div>

            <div class="event-item">

                <div class="activity-left">

                    <div class="event-date">

                        <h3>12</h3>

                        <small>JUL</small>

                    </div>

                    <div>

                        <h5>Book Reading Session</h5>

                        <p class="text-light opacity-75">
                            Weekly reading club event.
                        </p>

                    </div>

                </div>

            </div>

            <div class="event-item">

                <div class="activity-left">

                    <div class="event-date">

                        <h3>25</h3>

                        <small>JUL</small>

                    </div>

                    <div>

                        <h5>Author Meet</h5>

                        <p class="text-light opacity-75">
                            Meet bestselling authors.
                        </p>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <!-- RIGHT -->

    <div>

        <!-- SUMMARY -->

        <div class="summary-card">

            <h4 class="mb-4">
                Quick Summary
            </h4>

            <div class="summary-item">

                <div class="summary-icon purple">
                    <i class="fa fa-book-open"></i>
                </div>

                <div>

                    <h5>12</h5>

                    <p>Books Borrowed</p>

                </div>

            </div>

            <div class="summary-item">

                <div class="summary-icon green">
                    <i class="fa fa-bookmark"></i>
                </div>

                <div>

                    <h5>3</h5>

                    <p>Reserved</p>

                </div>

            </div>

            <div class="summary-item">

                <div class="summary-icon orange">
                    <i class="fa fa-clock"></i>
                </div>

                <div>

                    <h5>2</h5>

                    <p>Overdue</p>

                </div>

            </div>

            <div class="summary-item">

                <div class="summary-icon red">
                    ₹
                </div>

                <div>

                    <h5>₹0.00</h5>

                    <p>Total Fine</p>

                </div>

            </div>

            <button class="dashboard-btn">

                View Dashboard →

            </button>

        </div>

        <!-- ACTIVITY -->

        <div class="content-card">

            <div class="section-header">

                <h4>Recent Activity</h4>

            </div>

            <div class="activity-item">

                <div class="activity-left">

                    <div class="activity-icon purple">

                        <i class="fa fa-book"></i>

                    </div>

                    <div>
                        Borrowed "Clean Code"
                    </div>

                </div>

                <small>2h ago</small>

            </div>

            <div class="activity-item">

                <div class="activity-left">

                    <div class="activity-icon green">

                        <i class="fa fa-heart"></i>

                    </div>

                    <div>
                        Added "Atomic Habits"
                    </div>

                </div>

                <small>1d ago</small>

            </div>

        </div>

    </div>

</div>