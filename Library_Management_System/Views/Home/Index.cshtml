

@{
    ViewData["Title"] = "Home";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
}

<link rel="stylesheet" href="~/css/frontend.css" />

<div class="dashboard-wrapper">

    <!-- HERO SECTION -->
    <div class="hero-grid">

        <div class="hero-card">
            <div class="hero-content">

                @using System.Security.Claims
                <div class="welcome-text">
                    Welcome Back, @User.Identity?.Name 👋
                </div>

                <h1>
                    Knowledge is <span>Power</span>
                </h1>

                <p>
                    Explore the world's best books and
                    expand your imagination.
                </p>

                <a asp-controller="Catalog"
                   asp-action="Index"
                   class="hero-btn">
                    Explore Books →
                </a>

            </div>

            <div class="hero-image">
                <img src="~/images/hero/hero.png" alt="Hero" />
            </div>
        </div>

        <!-- QUICK SUMMARY -->
        <div class="summary-card">

            <h3>Quick Summary</h3>

            <div class="summary-item blue">
                <div class="icon">📘</div>
                <div>
                    <h4>12</h4>
                    <span>Books Borrowed</span>
                </div>
            </div>

            <div class="summary-item green">
                <div class="icon">📗</div>
                <div>
                    <h4>3</h4>
                    <span>Books Reserved</span>
                </div>
            </div>

            <div class="summary-item orange">
                <div class="icon">⏰</div>
                <div>
                    <h4>2</h4>
                    <span>Overdue Books</span>
                </div>
            </div>

            <div class="summary-item red">
                <div class="icon">₹</div>
                <div>
                    <h4>₹0.00</h4>
                    <span>Total Fine</span>
                </div>
            </div>

            <a href="#" class="dashboard-btn">
                View My Dashboard →
            </a>

        </div>

    </div>

    <!-- CONTENT GRID -->
    <div class="content-grid">

        <!-- CONTINUE READING -->
        <div class="card-section">

            <div class="section-header">
                <h3>Continue Reading</h3>
                <a href="#">View All</a>
            </div>

            <div class="books-row">

                <div class="book-card">
                    <img src="~/images/covers/TheAlchemist.jpeg" />
                    <h4>The Alchemist</h4>
                    <p>Paulo Coelho</p>
                    <div class="progress-bar">
                        <span style="width:45%"></span>
                    </div>
                    <small>45%</small>
                </div>

                <div class="book-card">
                    <img src="~/images/covers/deepwork.jpeg" />
                    <h4>Deep Work</h4>
                    <p>Cal Newport</p>
                    <div class="progress-bar">
                        <span style="width:60%"></span>
                    </div>
                    <small>60%</small>
                </div>

                <div class="book-card">
                    <img src="~/images/covers/AtomicHabits.jpeg" />
                    <h4>Atomic Habits</h4>
                    <p>James Clear</p>
                    <div class="progress-bar">
                        <span style="width:30%"></span>
                    </div>
                    <small>30%</small>
                </div>

                <div class="book-card">
                    <img src="~/images/covers/RichDad.jpeg" />
                    <h4>Rich Dad Poor Dad</h4>
                    <p>Robert Kiyosaki</p>
                    <div class="progress-bar">
                        <span style="width:25%"></span>
                    </div>
                    <small>25%</small>
                </div>

            </div>
        </div>

        <!-- EVENTS -->
        <div class="card-section">

            <div class="section-header">
                <h3>Upcoming Events</h3>
                <a href="#">View All</a>
            </div>

            <div class="event-list">

                <div class="event-card">
                    <div class="event-date">
                        <h2>24</h2>
                        <span>MAY</span>
                    </div>

                    <div>
                        <h4>Author Meet: Chetan Bhagat</h4>
                        <p>Seminar Hall, Main Building</p>
                        <small>11:00 AM - 01:00 PM</small>
                    </div>
                </div>

                <div class="event-card">
                    <div class="event-date">
                        <h2>30</h2>
                        <span>MAY</span>
                    </div>

                    <div>
                        <h4>Book Fair 2025</h4>
                        <p>Central Library Campus</p>
                        <small>10:00 AM - 06:00 PM</small>
                    </div>
                </div>

                <div class="event-card">
                    <div class="event-date">
                        <h2>05</h2>
                        <span>JUN</span>
                    </div>

                    <div>
                        <h4>Reading Competition</h4>
                        <p>Seminar Hall, Main Building</p>
                        <small>02:00 PM - 04:00 PM</small>
                    </div>
                </div>

            </div>

        </div>

        <!-- CATEGORIES -->
        <div class="card-section">

            <div class="section-header">
                <h3>Popular Categories</h3>
                <a href="#">View All</a>
            </div>

            <div class="category-list">

                <div class="category-item">
                    <span>📚 Fiction</span>
                    <small>1200+ Books</small>
                </div>

                <div class="category-item">
                    <span>🧪 Science</span>
                    <small>980+ Books</small>
                </div>

                <div class="category-item">
                    <span>💻 Technology</span>
                    <small>850+ Books</small>
                </div>

                <div class="category-item">
                    <span>💼 Business</span>
                    <small>760+ Books</small>
                </div>

                <div class="category-item">
                    <span>🏛 History</span>
                    <small>640+ Books</small>
                </div>

            </div>

        </div>

    </div>

    <!-- NEW ARRIVALS -->
    <div class="card-section mt-4">

        <div class="section-header">
            <h3>New Arrivals</h3>
            <a href="#">View All</a>
        </div>

        <div class="arrival-row">

            <img src="~/images/covers/sapiens.jpeg" />
            <img src="~/images/covers/thinkingfast.jpeg" />
            <img src="~/images/covers/subtleart.jpeg" />
            <img src="~/images/covers/AtomicHabits.jpeg" />
            <img src="~/images/covers/5amclub.jpeg" />
            <img src="~/images/covers/howtowin.jpeg" />
            <img src="~/images/covers/psychology.jpeg" />
            <img src="~/images/covers/startup.jpeg" />
            <img src="~/images/covers/RichDad.jpeg" />
            <img src="~/images/covers/AtomicHabits.jpeg" />
            <img src="~/images/covers/deepwork.jpeg" />
            <img src="~/images/covers/TheAlchemist.jpeg" />
        </div>

    </div>

</div>
<style>

</style>