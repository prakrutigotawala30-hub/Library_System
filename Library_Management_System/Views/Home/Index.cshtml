@{
    ViewData["Title"] = "Home";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
}

<link rel="stylesheet" href="~/css/frontend.css" />

<div class="dashboard-wrapper">

    <!-- HERO SECTION -->
    <div class="hero-grid">

        <div class="hero-card">
            <div class="hero-content">

                @using System.Security.Claims
                <div class="welcome-text">
                    Welcome Back, @User.Identity?.Name 👋
                </div>

                <h1>
                    Knowledge is <span>Power</span>
                </h1>

                <p>
                    Explore the world's best books and
                    expand your imagination.
                </p>

                <a asp-controller="Catalog"
                   asp-action="Index"
                   class="hero-btn">
                    Explore Books →
                </a>

            </div>

            <div class="hero-image">
                <img src="~/images/hero/hero.png" alt="Hero" />
            </div>
        </div>

        <!-- QUICK SUMMARY -->
        <div class="summary-card">

            <h3>Quick Summary</h3>

            <div class="summary-item blue">
                <div class="icon">📘</div>
                <div>
                    <h4>12</h4>
                    <span>Books Borrowed</span>
                </div>
            </div>

            <div class="summary-item green">
                <div class="icon">📗</div>
                <div>
                    <h4>3</h4>
                    <span>Books Reserved</span>
                </div>
            </div>

            <div class="summary-item orange">
                <div class="icon">⏰</div>
                <div>
                    <h4>2</h4>
                    <span>Overdue Books</span>
                </div>
            </div>

            <div class="summary-item red">
                <div class="icon">₹</div>
                <div>
                    <h4>₹0.00</h4>
                    <span>Total Fine</span>
                </div>
            </div>

            <a href="/Member" class="dashboard-btn">
                View My Dashboard →
            </a>

        </div>

    </div>

    <!-- CONTENT GRID -->

    <div class="hero-grid mt-4">

        <!-- LEFT SIDE -->
        <div class="card-section">

            <!-- CONTINUE READING -->
            <div class="section-header">
                <h3>Continue Reading</h3>

                @* Was: asp-controller="Books" asp-action="ContinueReading".
                   BooksController doesn't exist in user app and there's no
                   ContinueReading action anywhere — point to the catalog
                   instead so the View All link doesn't 404. *@
                <a asp-controller="Catalog"
                   asp-action="Index">
                    View All
                </a>
            </div>
            <div class="books-row">

                <div class="book-card">
                    <img src="~/images/covers/TheAlchemist.jpeg" />
                    <h4>The Alchemist</h4>
                    <p>Paulo Coelho</p>

                    <div class="progress-bar">
                        <span style="width:45%"></span>
                    </div>

                    <small>45%</small>
                </div>

                <div class="book-card">
                    <img src="~/images/covers/deepwork.jpeg" />
                    <h4>Deep Work</h4>
                    <p>Cal Newport</p>

                    <div class="progress-bar">
                        <span style="width:60%"></span>
                    </div>

                    <small>60%</small>
                </div>

                <div class="book-card">
                    <img src="~/images/covers/AtomicHabits.jpeg" />
                    <h4>Atomic Habits</h4>
                    <p>James Clear</p>

                    <div class="progress-bar">
                        <span style="width:30%"></span>
                    </div>

                    <small>30%</small>
                </div>

                <div class="book-card">
                    <img src="~/images/covers/startup.jpeg" />
                    <h4>Start Up</h4>
                    <p>James Clear</p>

                    <div class="progress-bar">
                        <span style="width:20%"></span>
                    </div>

                    <small>20%</small>
                </div>

                <div class="book-card">
                    <img src="~/images/covers/AtomicHabits.jpeg" />
                    <h4>Atomic Habits</h4>
                    <p>James Clear</p>

                    <div class="progress-bar">
                        <span style="width:30%"></span>
                    </div>

                    <small>30%</small>
                </div>

            </div>

        </div>

        <!-- RIGHT SIDE -->
        <div class="summary-card">

            <h3>Popular Categories</h3>

            <div class="summary-item blue">
                <div class="icon">📚</div>

                <div>
                    <h4>Fiction</h4>
                    <span>1200+ Books</span>
                </div>
            </div>

            <div class="summary-item green">
                <div class="icon">💻</div>

                <div>
                    <h4>Technology</h4>
                    <span>850+ Books</span>
                </div>
            </div>

            <div class="summary-item orange">
                <div class="icon">🧪</div>

                <div>
                    <h4>Science</h4>
                    <span>980+ Books</span>
                </div>
            </div>

            <div class="summary-item red">
                <div class="icon">💼</div>

                <div>
                    <h4>Business</h4>
                    <span>760+ Books</span>
                </div>
            </div>
        </div>

    </div>

    <!-- EVENTS -->
    <div class="card-section mt-4">


        <div class="section-header">
            <h3>Upcoming Events</h3>

            <a asp-controller="Events"
               asp-action="Index">
                View All
            </a>
        </div>
        <div class="event-column">

            <div class="event-card">

                <div class="event-date">
                    <h2>24</h2>
                    <span>MAY</span>
                </div>

                <div>
                    <h4>Author Meet</h4>
                    <p>Chetan Bhagat</p>
                    <small>11:00 AM</small>
                </div>

            </div>

            <div class="event-card">

                <div class="event-date">
                    <h2>30</h2>
                    <span>MAY</span>
                </div>

                <div>
                    <h4>Book Fair</h4>
                    <p>Main Campus</p>
                    <small>10:00 AM</small>
                </div>

            </div>

            <div class="event-card">
                <div class="event-date">
                    <h2>05</h2>
                    <span>JUN</span>
                </div>

                <div>
                    <h4>Reading Competition</h4>
                    <p>Seminar Hall, Main Building</p>
                    <small>02:00 PM - 04:00 PM</small>
                </div>
            </div>

            <div class="event-card">
                <div class="event-date">
                    <h2>12</h2>
                    <span>JUN</span>
                </div>

                <div>
                    <h4> Coding & AI Workshop</h4>
                    <p>Tech Lab </p>
                    <small>• 09:00 AM - 12:00 PM</small>
                </div>
            </div>

            <div class="event-card">
                <div class="event-date">
                    <h2>18</h2>
                    <span>JUN</span>
                </div>

                <div>
                    <h4>Startup Networking Meetup</h4>
                    <p> Innovation Hub </p>
                    <small>02:00 PM - 04:00 PM</small>
                </div>
            </div>

        </div>

    </div>

    <!-- NEW ARRIVALS -->
    <div class="card-section mt-4">

        <!-- NEW ARRIVALS -->
        <div class="section-header">
            <h3>New Arrivals</h3>

            @* CatalogController.NewArrivals exists; BooksController in user app does not. *@
            <a asp-controller="Catalog"
               asp-action="NewArrivals">
                View All
            </a>
        </div>

        <div class="arrival-row">

            <img src="~/images/covers/sapiens.jpeg" />
            <img src="~/images/covers/thinkingfast.jpeg" />
            <img src="~/images/covers/subtleart.jpeg" />
            <img src="~/images/covers/AtomicHabits.jpeg" />
            <img src="~/images/covers/5amclub.jpeg" />
            <img src="~/images/covers/howtowin.jpeg" />
            <img src="~/images/covers/psychology.jpeg" />
            <img src="~/images/covers/startup.jpeg" />
            <img src="~/images/covers/RichDad.jpeg" />
            <img src="~/images/covers/AtomicHabits.jpeg" />
            <img src="~/images/covers/deepwork.jpeg" />
            <img src="~/images/covers/TheAlchemist.jpeg" />
        </div>

    </div>

</div>
<style>

</style>