@model Library_Management_System.ViewModels.HomePageViewModel

@{
    ViewData["Title"] = "Home";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
}

<link rel="stylesheet" href="~/css/frontend.css" />

<div class="dashboard-wrapper">

    <!-- HERO -->
    <!-- HERO SECTION -->

    <section class="hero-section">

        <div class="hero-card">

            <!-- LEFT CONTENT -->

            <div class="hero-left">

                <div class="welcome-badge">

                    <i class="bi bi-stars"></i>

                    Welcome Back,
                    @User.Identity?.Name 👋

                </div>

                <h1>

                    Knowledge is

                    <span>Power</span>

                </h1>

                <p>
                    Explore the world’s best books,
                    discover new authors, and unlock
                    endless imagination through reading.
                </p>

                <div class="hero-buttons">

                    <a asp-controller="Catalog" asp-action="Index" class="hero-btn">

                        Explore Books

                        <i class="bi bi-arrow-right"></i>

                    </a>

                    @if (User.Identity != null &&
                                        User.Identity.IsAuthenticated &&
                                        !User.IsInRole("Member"))
                    {
                        <a asp-controller="Membership" asp-action="Index" class="membership-btn">

                            <i class="bi bi-gem"></i>

                            Get Membership

                        </a>
                    }

                </div>

            </div>

            <!-- RIGHT IMAGE -->

            <div class="hero-right">

                <img src="~/images/hero/hero.png" alt="Library Hero" />

            </div>

            <!-- GLOW -->

            <div class="hero-glow glow-1"></div>
            <div class="hero-glow glow-2"></div>

        </div>

    </section>

    <!-- CONTENT -->
    <div class="hero-grid mt-4">

        <!-- LEFT -->
        <div class="card-section">

            <!-- CONTINUE READING -->
            <div class="section-header">

                <h3>📖 Pick Up Where You Left Off</h3>

                <a asp-controller="Catalog" asp-action="Index">

                    View All →

                </a>

            </div>

            <div class="books-row">

                @foreach (var book in Model.ContinueReadingBooks)
                {
                    <div class="book-card">

                        <img src="@(string.IsNullOrEmpty(book.CoverImageUrl)
                                                                                                  ? "/images/default-book.jpg"
                                                                                                  : book.CoverImageUrl)" alt="@book.Title" />

                        <h4 title="@book.Title">
                            @book.Title
                        </h4>

                        <p>
                            @(book.Author?.Name ?? "Unknown Author")
                        </p>

                        <div class="book-status">

                            <span class="status-dot"></span>

                            Last opened recently

                        </div>

                    </div>
                }

            </div>

        </div>

        <!-- RIGHT -->
        <div class="summary-card">

            <div class="section-header">

                <h3>🔥 Popular Categories</h3>

                <a asp-controller="Catalog" asp-action="ByCategory">

                    View All →

                </a>

            </div>

            @foreach (var category in Model.PopularCategories.Take(4))
            {
                <div class="summary-item">

                    <div class="icon">
                        @category.IconClass
                    </div>

                    <div class="summary-content">

                        <h4>@category.CategoryName</h4>

                        <span>
                            @category.BookCount+ Books
                        </span>

                    </div>

                </div>
            }
        </div>

    </div>

    <!-- EVENTS -->
    <div class="card-section mt-4">

        <div class="section-header">

            <h3>📅 Upcoming Events</h3>

            <a asp-controller="Events" asp-action="Index">

                View All →

            </a>

        </div>

        <div class="event-column">

            <div class="event-card">

                <div class="event-date">
                    <h2>24</h2>
                    <span>MAY</span>
                </div>

                <div>
                    <h4>Author Meet</h4>
                    <p>Chetan Bhagat</p>
                    <small>11:00 AM</small>
                </div>

            </div>

            <div class="event-card">

                <div class="event-date">
                    <h2>30</h2>
                    <span>MAY</span>
                </div>

                <div>
                    <h4>Book Fair</h4>
                    <p>Main Campus</p>
                    <small>10:00 AM</small>
                </div>

            </div>

            <div class="event-card">

                <div class="event-date">
                    <h2>05</h2>
                    <span>JUN</span>
                </div>

                <div>
                    <h4>Reading Competition</h4>
                    <p>Seminar Hall</p>
                    <small>02:00 PM - 04:00 PM</small>
                </div>

            </div>

            <div class="event-card">

                <div class="event-date">
                    <h2>12</h2>
                    <span>JUN</span>
                </div>

                <div>
                    <h4>Coding & AI Workshop</h4>
                    <p>Tech Lab</p>
                    <small>09:00 AM - 12:00 PM</small>
                </div>

            </div>

        </div>

    </div>

    <!-- NEW ARRIVALS -->
    <div class="card-section mt-4">

        <div class="section-header">

            <h3>✨ New Arrivals</h3>

            <a asp-controller="Catalog" asp-action="NewArrivals">

                View All →

            </a>

        </div>

        <div class="arrival-row">

            @foreach (var book in Model.NewArrivals)
            {
                <img src="@(string.IsNullOrEmpty(book.CoverImageUrl)
                                                                          ? "/images/default-book.jpg"
                                                                          : book.CoverImageUrl)" alt="@book.Title" />
            }

        </div>

    </div>

</div>
