@{
    ViewData["Title"] = "Home Page";
}

<style>

    body {
        background: linear-gradient(135deg,#05010a 0%,#170022 30%,#32004d 65%,#5f006f 100%);
        min-height: 100vh;
        font-family: 'Inter',sans-serif;
    }

    .home-container {
        padding: 30px 10px;
    }

    /* HERO SECTION */

    .hero {
        position: relative;
        overflow: hidden;
        background: linear-gradient( 135deg, rgba(20,0,35,0.95), rgba(70,0,120,0.88), rgba(125,0,120,0.78) );
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 28px;
        padding: 70px 50px;
        color: white;
        backdrop-filter: blur(12px);
        box-shadow: 0 15px 35px rgba(0,0,0,0.45), 0 0 24px rgba(192,38,211,0.16);
    }

        .hero::before {
            content: "";
            position: absolute;
            width: 280px;
            height: 280px;
            background: rgba(255,255,255,0.06);
            border-radius: 50%;
            top: -120px;
            right: -80px;
        }

        .hero::after {
            content: "";
            position: absolute;
            width: 220px;
            height: 220px;
            background: rgba(255,255,255,0.04);
            border-radius: 50%;
            bottom: -100px;
            left: -60px;
        }

        .hero h1 {
            font-size: 52px;
            font-weight: 800;
            margin-bottom: 16px;
            position: relative;
            z-index: 2;
        }

        .hero p {
            font-size: 16px;
            line-height: 1.8;
            max-width: 700px;
            color: #f3e8ff;
            position: relative;
            z-index: 2;
        }

    .hero-btn {
        margin-top: 28px;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: linear-gradient( 135deg, #ff00cc 0%, #c026d3 45%, #7e22ce 100% );
        color: white;
        padding: 14px 28px;
        border-radius: 14px;
        font-weight: 700;
        text-decoration: none;
        transition: 0.3s;
        position: relative;
        z-index: 2;
    }

        .hero-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 22px rgba(192,38,211,0.35);
            color: white;
        }

    /* DASHBOARD CARDS */

    .dashboard-cards {
        margin-top: 35px;
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(240px,1fr));
        gap: 22px;
    }

    .card-box {
        background: rgba(255,255,255,0.08);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 22px;
        padding: 28px 24px;
        backdrop-filter: blur(12px);
        transition: 0.3s;
        color: white;
        box-shadow: 0 10px 25px rgba(0,0,0,0.25);
    }

        .card-box:hover {
            transform: translateY(-6px);
            box-shadow: 0 18px 32px rgba(0,0,0,0.35), 0 0 18px rgba(192,38,211,0.20);
        }

    .icon {
        font-size: 36px;
        margin-bottom: 16px;
    }

    .card-box h3 {
        font-size: 22px;
        font-weight: 700;
        margin-bottom: 10px;
        color: white;
    }

    .card-box p {
        font-size: 14px;
        line-height: 1.7;
        color: #e9d5ff;
        margin: 0;
    }

    /* QUICK LINKS */

    .quick-links {
        margin-top: 35px;
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
    }

        .quick-links a {
            background: rgba(255,255,255,0.10);
            border: 1px solid rgba(255,255,255,0.08);
            color: #f3e8ff;
            padding: 12px 20px;
            border-radius: 14px;
            text-decoration: none;
            font-weight: 600;
            transition: 0.3s;
            backdrop-filter: blur(8px);
        }

            .quick-links a:hover {
                background: linear-gradient( 135deg, #ff00cc 0%, #c026d3 45%, #7e22ce 100% );
                color: white;
                transform: translateY(-2px);
            }

    /* MOBILE */

    @@media(max-width:768px) {

        .hero {
            padding: 45px 25px;
            border-radius: 22px;
        }

            .hero h1 {
                font-size: 36px;
            }

            .hero p {
                font-size: 14px;
            }

        .dashboard-cards {
            gap: 18px;
        }

        .card-box {
            padding: 22px 20px;
        }

        .quick-links {
            gap: 10px;
        }

            .quick-links a {
                width: 100%;
                text-align: center;
            }
    }

</style>

<div class="container-fluid home-container">

    <!-- HERO -->

    <div class="hero">

        <h1>📚 Library Management System</h1>

        <p>
            Welcome to your smart digital library dashboard.
            Manage books, members, borrowing records,
            reports and library operations efficiently
            with a modern secure system.
        </p>

        <a class="hero-btn"
           asp-controller="Books"
           asp-action="Index">

            Explore Books →

        </a>

    </div>

    <!-- DASHBOARD CARDS -->

    <div class="dashboard-cards">

        <div class="card-box">

            <div class="icon">📖</div>

            <h3>Books</h3>

            <p>
                Manage library books, stock,
                categories and availability.
            </p>

        </div>

        <div class="card-box">

            <div class="icon">👥</div>

            <h3>Members</h3>

            <p>
                Track all registered users
                and membership activity.
            </p>

        </div>

        <div class="card-box">

            <div class="icon">🔄</div>

            <h3>Borrow System</h3>

            <p>
                Handle issue-return process,
                due dates and fines.
            </p>

        </div>

        <div class="card-box">

            <div class="icon">📊</div>

            <h3>Reports</h3>

            <p>
                View library analytics,
                borrowing trends and reports.
            </p>

        </div>

    </div>

    <!-- QUICK LINKS -->

    <div class="quick-links">

        <a asp-area="Member" asp-controller="Dashboard" asp-action="Index">
            📊 My Dashboard
        </a>

        <a asp-controller="Books" asp-action="Index">
            📚 Books
        </a>

        <a asp-controller="Borrow" asp-action="Index">
            🔄 Borrow
        </a>

        <a asp-controller="Members" asp-action="Index">
            👥 Members
        </a>

        <a asp-controller="Categories" asp-action="Index">
            🗂 Categories
        </a>

        <a asp-controller="Contact" asp-action="Index">
            📩 Contact
        </a>

    </div>

</div>