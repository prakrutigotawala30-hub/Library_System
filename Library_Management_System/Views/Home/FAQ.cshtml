@{
    ViewData["Title"] = "FAQ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>

    body {
        background: #050816;
        font-family: 'Inter', sans-serif;
    }

    .faq-section {
        padding: 90px 0;
        min-height: 100vh;
        background: radial-gradient(circle at top right, rgba(124,58,237,0.18), transparent 30%), linear-gradient(135deg,#050816,#0b1120,#111827);
    }

    .faq-header {
        text-align: center;
        margin-bottom: 65px;
    }

        .faq-header h1 {
            color: #ffffff;
            font-size: 52px;
            font-weight: 800;
            margin-bottom: 18px;
            letter-spacing: -1px;
        }

        .faq-header p {
            color: #9ca3af;
            font-size: 18px;
            max-width: 650px;
            margin: auto;
        }

    /* ACCORDION */

    .custom-accordion .accordion-item {
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 22px !important;
        overflow: hidden;
        margin-bottom: 22px;
        backdrop-filter: blur(12px);
        box-shadow: 0 10px 30px rgba(0,0,0,0.35), 0 0 20px rgba(124,58,237,0.12);
        transition: 0.3s ease;
    }

        .custom-accordion .accordion-item:hover {
            transform: translateY(-2px);
            border-color: rgba(139,92,246,0.35);
        }

    .custom-accordion .accordion-button {
        background: transparent;
        color: white;
        font-size: 18px;
        font-weight: 600;
        padding: 24px;
        box-shadow: none !important;
    }

        .custom-accordion .accordion-button:not(.collapsed) {
            background: linear-gradient(90deg,#7c3aed,#9333ea,#a855f7);
            color: white;
        }

        .custom-accordion .accordion-button:focus {
            box-shadow: none;
        }

        .custom-accordion .accordion-button::after {
            filter: brightness(0) invert(1);
        }

    .custom-accordion .accordion-body {
        color: #d1d5db;
        font-size: 16px;
        line-height: 1.9;
        padding: 26px;
        background: rgba(255,255,255,0.02);
    }

    /* MOBILE */

    @@media(max-width:768px) {

        .faq-section {
            padding: 60px 0;
        }

        .faq-header h1 {
            font-size: 38px;
        }

        .faq-header p {
            font-size: 16px;
        }

        .custom-accordion .accordion-button {
            font-size: 16px;
            padding: 20px;
        }

        .custom-accordion .accordion-body {
            font-size: 15px;
            padding: 20px;
        }
    }

</style>

<section class="faq-section">

    <div class="container">

        <!-- HEADER -->

        <div class="faq-header">

            <h1>
                Frequently Asked Questions
            </h1>

            <p>
                Everything you need to know about BookVerse Library System
            </p>

        </div>

        <!-- ACCORDION -->

        <div class="accordion custom-accordion"
             id="faqAccordion">

            <!-- FAQ 1 -->

            <div class="accordion-item">

                <h2 class="accordion-header">

                    <button class="accordion-button"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#faq1">

                        How can I borrow books?

                    </button>

                </h2>

                <div id="faq1"
                     class="accordion-collapse collapse show"
                     data-bs-parent="#faqAccordion">

                    <div class="accordion-body">

                        Login with your account, browse books,
                        and click the borrow button for available books.

                    </div>

                </div>

            </div>

            <!-- FAQ 2 -->

            <div class="accordion-item">

                <h2 class="accordion-header">

                    <button class="accordion-button collapsed"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#faq2">

                        What is the late return fine?

                    </button>

                </h2>

                <div id="faq2"
                     class="accordion-collapse collapse"
                     data-bs-parent="#faqAccordion">

                    <div class="accordion-body">

                        ₹5 fine is charged per day after the due date
                        until the book is returned.

                    </div>

                </div>

            </div>

            <!-- FAQ 3 -->

            <div class="accordion-item">

                <h2 class="accordion-header">

                    <button class="accordion-button collapsed"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#faq3">

                        What if the book is lost?

                    </button>

                </h2>

                <div id="faq3"
                     class="accordion-collapse collapse"
                     data-bs-parent="#faqAccordion">

                    <div class="accordion-body">

                        The member must replace the lost book
                        or pay the replacement amount decided by the library.

                    </div>

                </div>

            </div>

            <!-- FAQ 4 -->

            <div class="accordion-item">

                <h2 class="accordion-header">

                    <button class="accordion-button collapsed"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#faq4">

                        Can I reserve unavailable books?

                    </button>

                </h2>

                <div id="faq4"
                     class="accordion-collapse collapse"
                     data-bs-parent="#faqAccordion">

                    <div class="accordion-body">

                        Yes, you can reserve books that are currently borrowed.
                        You will receive a notification once available.

                    </div>

                </div>

            </div>

            <!-- FAQ 5 -->

            <div class="accordion-item">

                <h2 class="accordion-header">

                    <button class="accordion-button collapsed"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#faq5">

                        How many books can I borrow?

                    </button>

                </h2>

                <div id="faq5"
                     class="accordion-collapse collapse"
                     data-bs-parent="#faqAccordion">

                    <div class="accordion-body">

                        Members can borrow up to 5 books at a time
                        depending on library rules.

                    </div>

                </div>

            </div>

        </div>

    </div>

</section>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>