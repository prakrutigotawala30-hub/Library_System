@{
    ViewData["Title"] = "FAQ";
}

<section class="py-5 bg-light min-vh-100">
    <div class="container">

        <div class="text-center mb-5">
            <h1 class="fw-bold">Frequently Asked Questions</h1>
            <p class="text-muted">Everything you need to know</p>
        </div>

        <div class="accordion custom-accordion" id="faqAccordion">

            <div class="accordion-item mb-3 border-0 shadow-sm rounded-4 overflow-hidden">
                <h2 class="accordion-header">
                    <button class="accordion-button fw-semibold" type="button" data-bs-toggle="collapse" data-bs-target="#faq1">
                        How can I borrow books?
                    </button>
                </h2>

                <div id="faq1" class="accordion-collapse collapse show">
                    <div class="accordion-body">
                        Login with your account and request available books online.
                    </div>
                </div>
            </div>

            <div class="accordion-item mb-3 border-0 shadow-sm rounded-4 overflow-hidden">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed fw-semibold" type="button" data-bs-toggle="collapse" data-bs-target="#faq2">
                        What is the late return fine?
                    </button>
                </h2>

                <div id="faq2" class="accordion-collapse collapse">
                    <div class="accordion-body">
                        ₹5 fine per day after due date.
                    </div>
                </div>
            </div>

            <div class="accordion-item border-0 shadow-sm rounded-4 overflow-hidden">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed fw-semibold" type="button" data-bs-toggle="collapse" data-bs-target="#faq3">
                        What if the book is lost?
                    </button>
                </h2>

                <div id="faq3" class="accordion-collapse collapse">
                    <div class="accordion-body">
                        The member must replace the book or pay the replacement amount.
                    </div>
                </div>
            </div>

        </div>

    </div>
</section>
