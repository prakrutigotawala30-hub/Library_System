@{
    ViewData["Title"] = "Rules";
}

<section class="py-5 bg-light min-vh-100">
    <div class="container">

        <div class="text-center mb-5">
            <h1 class="fw-bold">Library Rules</h1>
            <p class="text-muted">Follow the library guidelines</p>
        </div>

        <div class="row g-4">

            <div class="col-md-6">
                <div class="rule-card h-100">
                    <h4>Borrowing Limit</h4>
                    <p>Students can borrow maximum 3 books.</p>
                </div>
            </div>

            <div class="col-md-6">
                <div class="rule-card h-100">
                    <h4>Late Fine</h4>
                    <p>₹5 per day after due date.</p>
                </div>
            </div>

            <div class="col-md-6">
                <div class="rule-card h-100">
                    <h4>Silence</h4>
                    <p>Maintain silence inside library.</p>
                </div>
            </div>

            <div class="col-md-6">
                <div class="rule-card h-100">
                    <h4>Book Care</h4>
                    <p>Handle books carefully and responsibly.</p>
                </div>
            </div>

        </div>

    </div>
</section>

<style>
    .rule-card {
        background: white;
        padding: 35px;
        border-radius: 24px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
    }
</style>