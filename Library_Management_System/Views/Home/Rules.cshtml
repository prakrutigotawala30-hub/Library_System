@{
    ViewData["Title"] = "Rules";
}

<style>

    body {
        background: #070b1a;
    }

    .rules-section {
        min-height: 100vh;
        padding: 80px 0;
        background: linear-gradient(135deg,#070b1a,#0f172a);
    }

    .rules-header {
        text-align: center;
        margin-bottom: 60px;
    }

        .rules-header h1 {
            color: white;
            font-size: 48px;
            font-weight: 800;
            margin-bottom: 15px;
        }

        .rules-header p {
            color: #9ca3af;
            font-size: 18px;
        }

    .rule-card {
        background: rgba(255,255,255,0.04);
        padding: 35px;
        border-radius: 24px;
        border: 1px solid rgba(255,255,255,0.08);
        backdrop-filter: blur(12px);
        box-shadow: 0 0 30px rgba(139,92,246,0.12);
        transition: all 0.3s ease;
        height: 100%;
    }

        .rule-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 0 35px rgba(168,85,247,0.25);
            border-color: rgba(168,85,247,0.4);
        }

        .rule-card h4 {
            color: #c084fc;
            font-weight: 700;
            margin-bottom: 15px;
        }

        .rule-card p {
            color: #d1d5db;
            line-height: 1.8;
            margin-bottom: 0;
        }

</style>

<section class="rules-section">

    <div class="container">

        <!-- HEADER -->

        <div class="rules-header">

            <h1>Library Rules</h1>

            <p>
                Please follow these guidelines for a better library experience
            </p>

        </div>

        <!-- RULES -->

        <div class="row g-4">

            <div class="col-md-6">

                <div class="rule-card">

                    <h4>📚 Borrowing Limit</h4>

                    <p>
                        Students can borrow a maximum of 3 books at a time.
                    </p>

                </div>

            </div>

            <div class="col-md-6">

                <div class="rule-card">

                    <h4>⏰ Late Fine</h4>

                    <p>
                        ₹5 fine will be charged per day after the due date.
                    </p>

                </div>

            </div>

            <div class="col-md-6">

                <div class="rule-card">

                    <h4>🤫 Maintain Silence</h4>

                    <p>
                        Keep silence inside the library to maintain a peaceful environment.
                    </p>

                </div>

            </div>

            <div class="col-md-6">

                <div class="rule-card">

                    <h4>📖 Book Care</h4>

                    <p>
                        Handle books carefully and avoid damaging library resources.
                    </p>

                </div>

            </div>

        </div>

    </div>

</section>