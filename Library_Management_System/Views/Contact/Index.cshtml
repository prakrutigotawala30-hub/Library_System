@{
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
}
@model Library_Management_System.ViewModels.ContactFormViewModel

@{
    ViewData["Title"] = "Contact Us";
}

<style>

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: 'Inter', sans-serif;
    }

    body {
        min-height: 100vh;
        background: #070b1a;
        color: white;
    }

    .contact-container {
        padding: 50px 15px;
        background: linear-gradient(135deg,#070b1a,#0f172a);
    }

    /* HERO */

    .contact-hero {
        background: linear-gradient(135deg,rgba(124,58,237,0.18),rgba(168,85,247,0.10));
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 30px;
        padding: 60px 45px;
        margin-bottom: 30px;
        backdrop-filter: blur(14px);
        box-shadow: 0 0 35px rgba(139,92,246,0.18);
        position: relative;
        overflow: hidden;
    }

        .contact-hero::before {
            content: "";
            position: absolute;
            width: 260px;
            height: 260px;
            background: rgba(168,85,247,0.10);
            border-radius: 50%;
            top: -120px;
            right: -80px;
        }

        .contact-hero h1 {
            font-size: 50px;
            font-weight: 800;
            margin-bottom: 14px;
            position: relative;
            z-index: 2;
        }

        .contact-hero p {
            font-size: 16px;
            color: #d1d5db;
            line-height: 1.9;
            max-width: 720px;
            position: relative;
            z-index: 2;
        }

    /* MAIN GRID */

    .contact-grid {
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        gap: 24px;
    }

    /* GLASS CARD */

    .glass-card {
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 26px;
        padding: 35px;
        backdrop-filter: blur(14px);
        box-shadow: 0 0 30px rgba(139,92,246,0.10);
        transition: 0.3s ease;
    }

        .glass-card:hover {
            border-color: rgba(168,85,247,0.30);
            box-shadow: 0 0 35px rgba(168,85,247,0.18);
        }

    .section-title {
        font-size: 30px;
        font-weight: 700;
        margin-bottom: 24px;
        color: white;
    }

    /* FORM */

    label {
        color: #c084fc;
        font-size: 14px;
        margin-bottom: 8px;
        font-weight: 600;
    }

    .form-control {
        height: 50px;
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,0.08);
        background: rgba(255,255,255,0.05);
        color: white;
        padding: 12px 16px;
        font-size: 14px;
        margin-bottom: 4px;
        transition: 0.3s;
    }

        .form-control:focus {
            background: rgba(255,255,255,0.08);
            color: white;
            border-color: #a855f7;
            box-shadow: 0 0 0 4px rgba(168,85,247,0.18);
        }

        .form-control::placeholder {
            color: rgba(255,255,255,0.45);
        }

    textarea.form-control {
        min-height: 140px;
        resize: none;
        padding-top: 14px;
    }

    .text-danger {
        font-size: 12px;
        color: #fda4af !important;
    }

    /* BUTTON */

    .btn-send {
        width: 100%;
        height: 52px;
        border: none;
        border-radius: 16px;
        background: linear-gradient(90deg,#7c3aed,#9333ea);
        color: white;
        font-size: 16px;
        font-weight: 700;
        transition: all 0.3s ease;
        margin-top: 10px;
    }

        .btn-send:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 24px rgba(139,92,246,0.35);
            color: white;
        }

    /* INFO */

    .info-box {
        margin-bottom: 26px;
    }

        .info-box h5 {
            font-size: 18px;
            margin-bottom: 8px;
            color: #c084fc;
            font-weight: 700;
        }

        .info-box p {
            font-size: 14px;
            color: #d1d5db;
            line-height: 1.9;
            margin: 0;
        }

    /* MAP */

    .map-box {
        overflow: hidden;
        border-radius: 22px;
        margin-top: 25px;
        border: 1px solid rgba(255,255,255,0.08);
        box-shadow: 0 0 25px rgba(139,92,246,0.12);
    }

        .map-box iframe {
            width: 100%;
            height: 280px;
            border: 0;
            filter: grayscale(20%) contrast(1.05);
        }

    /* MOBILE */

    @@media(max-width:992px) {

        .contact-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media(max-width:768px) {

        .contact-container {
            padding: 35px 12px;
        }

        .contact-hero {
            padding: 40px 25px;
        }

            .contact-hero h1 {
                font-size: 38px;
            }

            .contact-hero p {
                font-size: 15px;
            }

        .glass-card {
            padding: 24px 20px;
        }

        .section-title {
            font-size: 25px;
        }
    }

</style>

<div class="container-fluid contact-container">

    <!-- HERO -->

    <div class="contact-hero">

        <h1>📩 Contact Us</h1>

        <p>
            Have questions about books, borrowing,
            membership or library services?
            Contact our Library Management Team anytime.
        </p>

    </div>

    <!-- MAIN CONTENT -->

    <div class="contact-grid">

        <!-- CONTACT FORM -->

        <div class="glass-card">

            <h2 class="section-title">
                Send Message
            </h2>

            <form asp-action="Send" method="post">

                <div asp-validation-summary="ModelOnly"
                     class="text-danger mb-3">
                </div>

                <div class="mb-3">

                    <label asp-for="Name"></label>

                    <input asp-for="Name"
                           class="form-control"
                           placeholder="Enter your name" />

                    <span asp-validation-for="Name"
                          class="text-danger">
                    </span>

                </div>

                <div class="mb-3">

                    <label asp-for="Email"></label>

                    <input asp-for="Email"
                           class="form-control"
                           placeholder="Enter your email" />

                    <span asp-validation-for="Email"
                          class="text-danger">
                    </span>

                </div>

                <div class="mb-3">

                    <label asp-for="Subject"></label>

                    <input asp-for="Subject"
                           class="form-control"
                           placeholder="Enter subject" />

                    <span asp-validation-for="Subject"
                          class="text-danger">
                    </span>

                </div>

                <div class="mb-3">

                    <label asp-for="Message"></label>

                    <textarea asp-for="Message"
                              class="form-control"
                              placeholder="Write your message">
                    </textarea>

                    <span asp-validation-for="Message"
                          class="text-danger">
                    </span>

                </div>

                <button type="submit"
                        class="btn-send">

                    Send Message

                </button>

            </form>

        </div>

        <!-- CONTACT INFO -->

        <div class="glass-card">

            <h2 class="section-title">
                Library Information
            </h2>

            <div class="info-box">

                <h5>📍 Address</h5>

                <p>
                    Library Management System<br />
                    Surat, Gujarat, India
                </p>

            </div>

            <div class="info-box">

                <h5>📧 Email</h5>

                <p>
                    library@gmail.com
                </p>

            </div>

            <div class="info-box">

                <h5>📞 Phone</h5>

                <p>
                    +91 9876543210
                </p>

            </div>

            <div class="info-box">

                <h5>🕒 Working Hours</h5>

                <p>
                    Monday - Saturday<br />
                    9:00 AM - 7:00 PM
                </p>

            </div>

            <!-- MAP -->

            <div class="map-box">

                <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3719.514432837173!2d72.8311!3d21.1702!2m3!1f0!2f0!3f0!"
                        allowfullscreen=""
                        loading="lazy">
                </iframe>

            </div>

        </div>

    </div>

</div>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

}