@{
    ViewData["Title"] = "Message Received";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
}

<style>

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: 'Inter', sans-serif;
    }

    body {
        min-height: 100vh;
        overflow-x: hidden;
        background: radial-gradient(circle at top right, rgba(139,92,246,0.20), transparent 22%), radial-gradient(circle at bottom left, rgba(168,85,247,0.16), transparent 24%), linear-gradient(135deg,#050816 0%,#0b1120 45%,#111827 100%);
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 24px;
        color: white;
    }

    /* MAIN WRAPPER */

    .thank-wrapper {
        width: 100%;
        max-width: 1100px;
        position: relative;
    }

    /* MAIN CARD */

    .glass-card {
        width: 100%;
        min-height: 560px;
        display: flex;
        overflow: hidden;
        border-radius: 34px;
        position: relative;
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.08);
        backdrop-filter: blur(18px);
        box-shadow: 0 20px 60px rgba(0,0,0,0.45), 0 0 45px rgba(139,92,246,0.12);
    }

        .glass-card::before {
            content: "";
            position: absolute;
            width: 320px;
            height: 320px;
            background: rgba(168,85,247,0.10);
            border-radius: 50%;
            top: -140px;
            right: -100px;
            filter: blur(10px);
        }

        .glass-card::after {
            content: "";
            position: absolute;
            width: 250px;
            height: 250px;
            background: rgba(124,58,237,0.08);
            border-radius: 50%;
            bottom: -120px;
            left: -80px;
            filter: blur(10px);
        }

    /* LEFT PANEL */

    .left-panel {
        width: 42%;
        padding: 55px 42px;
        position: relative;
        background: linear-gradient( 180deg, rgba(124,58,237,0.24), rgba(91,33,182,0.12) );
        border-right: 1px solid rgba(255,255,255,0.08);
        display: flex;
        align-items: center;
        overflow: hidden;
    }

        .left-panel::before {
            content: "";
            position: absolute;
            width: 240px;
            height: 240px;
            background: rgba(255,255,255,0.04);
            border-radius: 50%;
            top: -80px;
            right: -60px;
        }

    .left-content {
        width: 100%;
        position: relative;
        z-index: 2;
    }

    /* LOGO */

    .logo {
        width: 92px;
        height: 92px;
        border-radius: 28px;
        display: flex;
        justify-content: center;
        align-items: center;
        background: linear-gradient(135deg,#7c3aed,#9333ea);
        font-size: 42px;
        margin-bottom: 28px;
        box-shadow: 0 12px 28px rgba(139,92,246,0.35), inset 0 1px 1px rgba(255,255,255,0.15);
    }

    /* LEFT TEXT */

    .left-panel h2 {
        font-size: 46px;
        line-height: 1.1;
        font-weight: 800;
        margin-bottom: 20px;
        letter-spacing: -1px;
        color: white;
    }

    .left-panel p {
        font-size: 15px;
        line-height: 1.9;
        color: #d1d5db;
    }

    /* FEATURE LIST */

    .feature-list {
        margin-top: 28px;
        padding-left: 20px;
    }

        .feature-list li {
            margin-bottom: 12px;
            color: #ddd6fe;
            font-size: 14px;
        }

    /* QUOTE */

    .quote {
        margin-top: 28px;
        font-size: 14px;
        font-style: italic;
        color: #e9d5ff;
        opacity: 0.95;
    }

    /* RIGHT PANEL */

    .right-panel {
        width: 58%;
        padding: 60px 45px;
        position: relative;
        z-index: 2;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
    }

    /* SUCCESS ICON WRAPPER */

    .success-circle {
        width: 135px;
        height: 135px;
        border-radius: 50%;
        display: flex;
        justify-content: center;
        align-items: center;
        margin-bottom: 30px;
        background: linear-gradient( 135deg, rgba(124,58,237,0.22), rgba(147,51,234,0.16) );
        border: 1px solid rgba(255,255,255,0.08);
        box-shadow: 0 0 35px rgba(139,92,246,0.25), inset 0 1px 2px rgba(255,255,255,0.08);
    }

    .success-icon {
        font-size: 68px;
        filter: drop-shadow(0 0 15px rgba(139,92,246,0.45));
    }

    /* TITLE */

    .title {
        font-size: 54px;
        font-weight: 800;
        letter-spacing: -1px;
        margin-bottom: 18px;
        color: white;
    }

    /* MESSAGE */

    .message {
        max-width: 470px;
        font-size: 16px;
        line-height: 1.9;
        color: #d1d5db;
        margin-bottom: 34px;
    }

    /* BUTTON */

    .btn-home {
        height: 56px;
        padding: 0 36px;
        border-radius: 18px;
        border: none;
        outline: none;
        text-decoration: none;
        display: inline-flex;
        justify-content: center;
        align-items: center;
        gap: 10px;
        font-size: 15px;
        font-weight: 700;
        color: white;
        background: linear-gradient(90deg,#7c3aed,#9333ea);
        transition: all 0.35s ease;
        box-shadow: 0 12px 26px rgba(139,92,246,0.28);
    }

        .btn-home:hover {
            transform: translateY(-4px);
            color: white;
            box-shadow: 0 18px 34px rgba(139,92,246,0.38);
        }

    /* STATUS BADGE */

    .status-badge {
        margin-top: 20px;
        padding: 11px 20px;
        border-radius: 999px;
        background: rgba(34,197,94,0.10);
        border: 1px solid rgba(34,197,94,0.16);
        color: #86efac;
        font-size: 13px;
        font-weight: 600;
    }

    /* RESPONSIVE */

    @@media(max-width:992px) {

        body {
            align-items: flex-start;
        }

        .glass-card {
            flex-direction: column;
            min-height: auto;
        }

        .left-panel,
        .right-panel {
            width: 100%;
        }

        .left-panel {
            border-right: none;
            border-bottom: 1px solid rgba(255,255,255,0.08);
        }
    }

    @@media(max-width:768px) {

        body {
            padding: 14px;
        }

        .glass-card {
            border-radius: 28px;
        }

        .left-panel {
            padding: 38px 24px;
            text-align: center;
        }

        .right-panel {
            padding: 42px 24px;
        }

        .logo {
            margin: 0 auto 24px;
        }

        .left-panel h2 {
            font-size: 36px;
        }

        .title {
            font-size: 40px;
        }

        .message {
            font-size: 15px;
        }

        .feature-list {
            list-style: none;
            padding-left: 0;
        }

        .btn-home {
            width: 100%;
        }
    }

    @@media(max-width:480px) {

        .left-panel h2 {
            font-size: 32px;
        }

        .title {
            font-size: 34px;
        }

        .success-circle {
            width: 110px;
            height: 110px;
        }

        .success-icon {
            font-size: 56px;
        }
    }

</style>

<div class="thank-wrapper">

    <div class="glass-card">

        <!-- LEFT PANEL -->

        <div class="left-panel">

            <div class="left-content">

                <div class="logo">
                    📩
                </div>

                <h2>
                    Message<br />
                    Received
                </h2>

                <p>
                    Thank you for contacting our
                    BookVerse Library Management System.
                    Your message has been delivered
                    successfully to our support team.
                </p>

                <ul class="feature-list">

                    <li>Quick Response Support</li>

                    <li>Secure Communication</li>

                    <li>Professional Assistance</li>

                    <li>Student Friendly Service</li>

                </ul>

                <p class="quote">
                    “Knowledge grows when we connect.”
                </p>

            </div>

        </div>

        <!-- RIGHT PANEL -->

        <div class="right-panel">

            <div class="success-circle">

                <div class="success-icon">
                    ✅
                </div>

            </div>

            <h2 class="title">
                Thank You!
            </h2>

            <p class="message">

                Your message has been successfully submitted.
                Our library administration team will contact you
                shortly through your registered email address.

            </p>

            <a asp-controller="Home"
               asp-action="Index"
               class="btn-home">

                ⬅ Back To Home

            </a>

            <div class="status-badge">
                Message Sent Successfully
            </div>

        </div>

    </div>

</div>