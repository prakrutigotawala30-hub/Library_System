{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch LibraryManagementSystem (https)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/LibraryManagementSystem/bin/Debug/net8.0/LibraryManagementSystem.dll",
      "args": [],
      "cwd": "${workspaceFolder}/LibraryManagementSystem",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "https://localhost:7113;http://localhost:5221"
      },
      "sourceFileMap": {
        "/Views": "${workspaceFolder}/LibraryManagementSystem/Views"
      }
    },
    {
      "name": "Launch LibraryManagementSystem (http only)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/LibraryManagementSystem/bin/Debug/net8.0/LibraryManagementSystem.dll",
      "args": [],
      "cwd": "${workspaceFolder}/LibraryManagementSystem",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5221"
      },
      "sourceFileMap": {
        "/Views": "${workspaceFolder}/LibraryManagementSystem/Views"
      }
    },
    {
      "name": "Attach to .NET process",
      "type": "coreclr",
      "request": "attach"
    }
  ]
}
