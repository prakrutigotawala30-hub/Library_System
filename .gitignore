# Build output
bin/
obj/

# Per-developer Visual Studio state
*.user
.vs/
*.csproj.lscache
*.lscache

# Keep the shared multi-launch profile config (not per-developer)
!*.slnLaunch.user

# VS Code workspaces (use VS .sln instead; if a team member wants VS Code
# workspaces, put a single .code-workspace at the solution root, not buried)
*.code-workspace

# SQLite dev DBs — never commit
*.db
*.db-shm
*.db-wal

# OS noise
.DS_Store
Thumbs.db

# Typo guard — the real one is `.gitignore`
.gitignore.txt
